  "sqlGenerado": "SELECT TOP (10) d.IDARTICULO, d.DESCRIPCION_ARTICULO, d.COSTO, c.IDCOMPROBANTE, c.FECHA FROM vw_compras_detalle_dashboard d JOIN vw_compras_cabecera_dashboard c ON d.TC = c.TC AND d.IDCOMPROBANTE = c.IDCOMPROBANTE WHERE (@CurFechaDesde IS NULL OR d.FECHA \u003E= @CurFechaDesde) AND (@CurFechaHasta IS NULL OR d.FECHA \u003C DATEADD(day, 1, @CurFechaHasta)) ORDER BY d.COSTO DESC"
