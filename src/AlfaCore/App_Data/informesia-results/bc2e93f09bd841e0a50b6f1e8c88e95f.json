  "sqlGenerado": "SELECT TOP (10) d.IDARTICULO, d.DESCRIPCION_ARTICULO, d.COSTO, d.CANTIDAD, d.TotalDashboard, c.FECHA, c.CUENTA, c.RAZON_SOCIAL, c.SUCURSAL, c.USUARIO, c.TC, c.IDCOMPROBANTE FROM vw_compras_detalle_dashboard d JOIN vw_compras_cabecera_dashboard c ON d.TC = c.TC AND d.IDCOMPROBANTE = c.IDCOMPROBANTE AND d.CUENTA = c.CUENTA WHERE (@CurFechaDesde IS NULL OR d.FECHA \u003E= @CurFechaDesde) AND (@CurFechaHasta IS NULL OR d.FECHA \u003C DATEADD(day, 1, @CurFechaHasta)) ORDER BY d.COSTO DESC"
