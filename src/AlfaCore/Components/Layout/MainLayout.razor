                    </NavLink>
                    <NavLink class="menu__link" href="/ventas/articulos">
                        <span class="menu__icon"><i class="bi bi-box-fill"></i></span>
                        <span>Artículos</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/ventas/comprobantes">
                        <span class="menu__icon"><i class="bi bi-receipt"></i></span>
                        <span>Comprobantes</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/ventas/comparativo">
                        <span class="menu__icon"><i class="bi bi-bar-chart-line-fill"></i></span>
                        <span>Comparativo</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "stock")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Stock</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/stock" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-box-seam"></i></span>
                        <span>Resumen</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "caja-bancos")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Caja y Bancos</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/caja-bancos" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-bank"></i></span>
                        <span>Resumen</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "contabilidad")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Contabilidad</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/contabilidad" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-journal-bookmark-fill"></i></span>
                        <span>Resumen</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/contabilidad/posicion-iva" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-receipt"></i></span>
                        <span>Posición de IVA</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "compras")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Compras</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/compras" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-house-fill"></i></span>
                        <span>Inicio</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/proveedores">
                        <span class="menu__icon"><i class="bi bi-people-fill"></i></span>
                        <span>Proveedores</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/comprobantes">
                        <span class="menu__icon"><i class="bi bi-receipt"></i></span>
                        <span>Comprobantes</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/rubros">
                        <span class="menu__icon"><i class="bi bi-tag-fill"></i></span>
                        <span>Rubros</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/familias">
                        <span class="menu__icon"><i class="bi bi-collection-fill"></i></span>
                        <span>Familias</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/articulos">
                        <span class="menu__icon"><i class="bi bi-box-fill"></i></span>
                        <span>Artículos</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/actividad">
                        <span class="menu__icon"><i class="bi bi-bar-chart-steps"></i></span>
                        <span>Actividad</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/compras/informesia">
                        <span class="menu__icon"><i class="bi bi-stars"></i></span>
                        <span>InformesIA</span>
                    </NavLink>
                </nav>
            }
            else
            {
                <p class="menu__section">Tableros</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-grid-3x3-gap-fill"></i></span>
                        <span>Aplicaciones</span>
                    </NavLink>
                </nav>
            }

            <div class="menu__footer">
                <NavLink class="menu__link menu__link--help" href="@(_currentModule == "consultas" ? "/ayuda?topic=consultas" : "/ayuda")">
                    <span class="menu__icon"><i class="bi bi-question-circle-fill"></i></span>
                    <span>Ayuda</span>
                </NavLink>
            </div>
        </div>
    </aside>

    <main class="shell__main">
        <header class="shell__header">
            <div>
                <p class="shell__eyebrow">Alfa Gestión</p>
                <p class="shell__module">@GetModuleTitle()</p>
            </div>
            <div class="shell__actions">
                <button type="button" class="btn btn--ghost no-print" @onclick="ToggleThemeAsync" title="@(_isDark ? "Cambiar a modo claro" : "Cambiar a modo oscuro")">
                    <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
                </button>
                @if (_currentModule == "compras")
                {
                    <button type="button" class="btn btn--ghost shell__print no-print" @onclick="ExportCurrentPageToPdfAsync" title="Exportar pantalla actual a PDF">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Exportar PDF</span>
                    </button>
                }
                <button class="session-chip no-print" @onclick="() => _drawerOpen = true" title="Gestionar sesiones de base de datos">
                    <span class="session-chip__dot"></span>
                    <span class="session-chip__text">@(_activeSession?.Servidor ?? "—") · @(_activeSession?.BaseDatos ?? "—")</span>
                    <i class="bi bi-chevron-down"></i>
                </button>
                @if (AppUserSession.IsAuthenticated && AppUserSession.CurrentUser is not null)
                {
                    <button type="button" class="session-chip no-print" @onclick="LogoutAppUser" title="Cerrar sesión del sistema">
                        <span class="session-chip__dot"></span>
                        <span class="session-chip__text">@AppUserSession.CurrentUser.UserName</span>
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                }
                <div class="shell__status">
                    <span class="shell__dot"></span>
                    <span>Actualizado en tiempo real</span>
                    <span class="shell__date">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                    <a class="help-btn no-print" href="@(_currentModule == "consultas" ? "/ayuda?topic=consultas" : "/ayuda")" title="Manual de usuario">
                        <i class="bi bi-question-circle"></i>
                    </a>
                </div>
            </div>
        </header>

        <section class="shell__content">
            <div class="print-banner print-only">
                <div>
                    <p class="print-banner__eyebrow">Dashboard de Compras</p>
                    <h2 class="print-banner__title">@CurrentPageTitle</h2>
                </div>
                <p class="print-banner__meta">Exportado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            @Body
        </section>
    </main>
</div>

<SessionDrawer Open="_drawerOpen" OnClose="() => _drawerOpen = false" />
<AppLoginOverlay Open="@(!AppUserSession.IsAuthenticated)"
                 SqlSessionLabel="@GetSqlSessionLabel()"
                 UserName="@_loginUserName"
                 Password="@_loginPassword"
                 ErrorMessage="@_loginError"
                 IsBusy="@_loginBusy"
                 ShowPassword="@_loginShowPassword"
                 UserNameChanged="@(value => _loginUserName = value)"
                 PasswordChanged="@(value => _loginPassword = value)"
                 ShowPasswordChanged="@(value => _loginShowPassword = value)"
                 OnSubmit="LoginAsync"
                 OnOpenSqlSessions="OpenSqlSessionDrawerAsync" />

@code {
    private bool _sidebarCollapsed;
    private bool _sidebarInitialized;
    private bool _isDark = false;
    private bool _drawerOpen;
    private AlfaCore.Models.SessionDto? _activeSession;
    private string _loginUserName = string.Empty;
    private string _loginPassword = string.Empty;
    private string _loginError = string.Empty;
    private bool _loginBusy;
    private bool _loginShowPassword;
    private string CurrentPageTitle => GetCurrentPageTitle();

    private string _currentModule = string.Empty;

    protected override void OnInitialized()
    {
        _activeSession = SessionSvc.GetActiveSession();
        SessionSvc.SessionChanged += OnSessionChanged;
        AppUserSession.StateChanged += OnAppUserStateChanged;
    }

    private void OnSessionChanged()
    {
        _activeSession = SessionSvc.GetActiveSession();
        var wasAuthenticated = AppUserSession.IsAuthenticated;
        AppUserSession.HandleSqlSessionChanged();
        if (wasAuthenticated && !AppUserSession.IsAuthenticated)
        {
            _ = InvokeAsync(async () =>
            {
                try { await JS.InvokeVoidAsync("localStorage.removeItem", "alfacore_user_token"); }
                catch { }
            });
        }
        _loginPassword = string.Empty;
        _loginShowPassword = false;
        _loginError = string.Empty;
        InvokeAsync(StateHasChanged);
    }

    private void OnAppUserStateChanged()
    {
        if (!AppUserSession.IsAuthenticated)
        {
            _loginPassword = string.Empty;
            _loginShowPassword = false;
        }

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionSvc.SessionChanged -= OnSessionChanged;
        AppUserSession.StateChanged -= OnAppUserStateChanged;
    }

    protected override void OnParametersSet()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('#')[0].Trim('/');
        _currentModule = path.Split('/').FirstOrDefault()?.ToLowerInvariant() ?? string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            var sidebar = await JS.InvokeAsync<string?>("localStorage.getItem", "dashboard.sidebar.collapsed");
            _sidebarCollapsed = string.Equals(sidebar, "true", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            _sidebarCollapsed = false;
        }

        try
        {
            var theme = await JS.InvokeAsync<string>("dashboardTheme.get");
            _isDark = !string.Equals(theme, "light", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            _isDark = true;
        }

        if (!AppUserSession.IsAuthenticated)
        {
            try
            {
                var token = await JS.InvokeAsync<string?>("localStorage.getItem", "alfacore_user_token");
                if (!string.IsNullOrEmpty(token))
                    AppUserSession.TryRestoreFromToken(token);
            }
            catch { }
        }

        _sidebarInitialized = true;
        StateHasChanged();
    }

    private async Task ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;

        if (!_sidebarInitialized)
            return;

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "dashboard.sidebar.collapsed", _sidebarCollapsed ? "true" : "false");
        }
        catch
        {
            // Si localStorage no está disponible, dejamos el estado solo en memoria.
        }
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = !_isDark;
        try
        {
            await JS.InvokeVoidAsync("dashboardTheme.set", _isDark ? "dark" : "light");
        }
        catch { }
    }

    private async Task ExportCurrentPageToPdfAsync()
    {
        await JS.InvokeVoidAsync("dashboardExport.printCurrentPage", CurrentPageTitle);
    }

    private async Task LoginAsync()
    {
        _loginBusy = true;
        _loginError = string.Empty;

        try
        {
            var session = await AppUserSession.LoginAsync(_loginUserName, _loginPassword);
            _loginUserName = session.UserName;
            _loginPassword = string.Empty;
            _loginShowPassword = false;
            if (AppUserSession.CurrentToken is not null)
            {
                try { await JS.InvokeVoidAsync("localStorage.setItem", "alfacore_user_token", AppUserSession.CurrentToken); }
                catch { }
            }
        }
        catch (InvalidOperationException ex)
        {
            _loginError = ex.Message;
        }
        finally
        {
            _loginBusy = false;
            StateHasChanged();
        }
    }

    private async Task LogoutAppUser()
    {
        AppUserSession.Logout();
        _loginError = string.Empty;
        try { await JS.InvokeVoidAsync("localStorage.removeItem", "alfacore_user_token"); }
        catch { }
    }

    private Task OpenSqlSessionDrawerAsync()
    {
        _drawerOpen = true;
        return Task.CompletedTask;
    }

    private string GetSqlSessionLabel()
        => _activeSession is null
            ? "Sin base activa"
            : $"{_activeSession.Nombre} · {_activeSession.Servidor} · {_activeSession.BaseDatos}";

    private string GetCurrentPageTitle()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var path = relative.Split('?', '#', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.Trim('/').ToLowerInvariant() ?? string.Empty;

        return path switch
        {
            "" => "Aplicaciones",
            "ventas" => "Ventas",
            "ventas/clientes" => "Clientes",
            "ventas/rubros" => "Rubros",
            "ventas/familias" => "Familias",
            "ventas/articulos" => "Artículos",
            "ventas/comprobantes" => "Comprobantes",
            "ventas/comparativo" => "Comparativo",
            "stock" => "Stock",
            "caja-bancos" => "Caja y Bancos",
            "contabilidad" => "Contabilidad",
            "contabilidad/posicion-iva" => "Posición de IVA",
            "costos" => "Actualización de Costos",
            "costos/nueva" => "Nueva Importación",
            "costos/perfiles" => "Perfiles de Costos",
            "costos/historial" => "Historial de Costos",
            "auditoria" => "Auditoría",
            "auditoria/errores" => "Errores",
            "conversaciones" => "Conversaciones",
            "conversaciones/plantillas" => "Plantillas de WhatsApp",
            "conversaciones/configuracion" => "Configuración de WhatsApp",
            "interfaces" => "Recepción documental",
            "interfaces/configuracion" => "Configuración de Interfaces",
            "interfaces/nuevo" => "Nuevo documento",
            "actualizaciones" => "Actualizaciones",
            "usuarios" => "Usuarios",
            "contactos" => "Contactos",
            "compras" => "Inicio",
            "compras/proveedores" => "Proveedores",
            "compras/comprobantes" => "Comprobantes",
            "compras/rubros" => "Rubros",
            "compras/familias" => "Familias",
            "compras/articulos" => "Artículos",
            "compras/actividad" => "Actividad",
            "compras/informesia" => "Informes IA",
            "consultas" => "Consultas",
            "ayuda" => "Ayuda",
            _ when path.StartsWith("interfaces/") => "Documento recibido",
            _ when path.StartsWith("compras/informesia/resultado/") => "Informe IA",
            _ when path.StartsWith("costos/lotes/") => "Lote de Costos",
            _ when path.StartsWith("auditoria/error/") => "Detalle de Error",
            "consultas/nueva" => "Nueva consulta",
            _ when path.StartsWith("consultas/") && path.EndsWith("/editar") => "Editar consulta",
            _ when path.StartsWith("consultas/") => "Consulta",
            _ => "Dashboard"
        };
    }

    private string GetModuleTitle() => _currentModule switch
    {
        "" => "Inicio",
        "consultas" => "Diseñador de Consultas",
        "ventas" => "Dashboard de Ventas",
        "stock" => "Dashboard de Stock",
        "caja-bancos" => "Caja y Bancos",
        "contabilidad" => "Dashboard Contable",
        "costos" => "Actualización de Costos",
        "auditoria" => "Auditoría",
        "conversaciones" => "Conversaciones",
        "interfaces" => "Interfaces",
        "actualizaciones" => "Actualizaciones",
        "usuarios" => "Usuarios",
        "contactos" => "Contactos",
        _ => "Dashboard de Compras"
    };
}
