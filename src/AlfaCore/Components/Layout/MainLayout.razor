@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AlfaCore.Services.ISessionService SessionSvc
@inject AlfaCore.Services.IAppUserSessionService AppUserSession
@implements IDisposable

<div class="shell @(_sidebarCollapsed ? "shell--collapsed" : string.Empty)">
    <aside class="shell__sidebar">
        <div class="brand">
            <img class="brand__logo" src="logo.png" alt="Alfa Gestión" />
            <div class="brand__content">
                <p class="brand__eyebrow">Business Intelligence</p>
                <a class="brand__title" href="/">Alfa Gestión</a>
            </div>
            <button type="button"
                    class="sidebar-toggle"
                    @onclick="ToggleSidebar"
                    title="@(_sidebarCollapsed ? "Mostrar menú" : "Ocultar menú")"
                    aria-label="@(_sidebarCollapsed ? "Mostrar menú lateral" : "Ocultar menú lateral")">
                <i class="bi @(_sidebarCollapsed ? "bi-layout-sidebar-inset" : "bi-layout-sidebar")"></i>
            </button>
        </div>

        <div class="menu">
            @if (_currentModule == "consultas")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Consultas</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/consultas" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-table"></i></span>
                        <span>Mis consultas</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/consultas/nueva" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-plus-circle"></i></span>
                        <span>Nueva consulta</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "costos")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Actualización de Costos</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/costos" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-currency-dollar"></i></span>
                        <span>Inicio</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/costos/nueva" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-upload"></i></span>
                        <span>Nueva importación</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/costos/perfiles">
                        <span class="menu__icon"><i class="bi bi-sliders"></i></span>
                        <span>Perfiles</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/costos/historial">
                        <span class="menu__icon"><i class="bi bi-clock-history"></i></span>
                        <span>Historial</span>
                    </NavLink>
                </nav>
