                <p class="menu__section">Conversaciones</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/conversaciones" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-chat-dots-fill"></i></span>
                        <span>Inbox</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/conversaciones/plantillas" Match="NavLinkMatch.All">
