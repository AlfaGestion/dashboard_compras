                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Contactos</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/contactos" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-person-lines-fill"></i></span>
                        <span>Agenda de contactos</span>
                    </NavLink>
                </nav>
            }
            else if (_currentModule == "ventas")
            {
                <a class="menu__back" href="/">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Ventas</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/ventas" Match="NavLinkMatch.All">
                        <span class="menu__icon"><i class="bi bi-graph-up-arrow"></i></span>
                        <span>Inicio</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/ventas/clientes">
                        <span class="menu__icon"><i class="bi bi-people-fill"></i></span>
                        <span>Clientes</span>
                    </NavLink>
                    <NavLink class="menu__link" href="/ventas/rubros">
                        <span class="menu__icon"><i class="bi bi-tag-fill"></i></span>
