                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <span>Aplicaciones</span>
                </a>
                <p class="menu__section">Auditoría</p>
                <nav class="menu__nav">
                    <NavLink class="menu__link" href="/auditoria" Match="NavLinkMatch.All">
