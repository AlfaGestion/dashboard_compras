@if (Data.Count == 0)
{
    <p class="chart-empty">Sin datos para graficar.</p>
}
else
{
    <div class="line-chart" @key="_renderKey">
        <svg viewBox="0 0 640 290" class="line-chart__svg" role="img" aria-label="@Titulo">
            <defs>
                <linearGradient id="@_gradientId" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(14,165,233,0.40)" />
                    <stop offset="100%" stop-color="rgba(14,165,233,0.03)" />
                </linearGradient>
            </defs>

            @foreach (var g in _gridLines)
            {
                <line x1="70" y1="@F(g.Y)" x2="620" y2="@F(g.Y)"
                      class="line-chart__grid" style="transition:none;animation:none;" />
            }

            @if (ChartType == "bars")
            {
                @foreach (var bar in _bars)
                {
                    <rect x="@F(bar.X)" y="@F(bar.Y)"
                          width="@F(bar.W)" height="@F(bar.H)"
                          rx="3" class="line-chart__bar"
                          style="transition:none;animation:none;" />
                }
            }
            else
            {
                @if (ChartType == "area")
                {
                    <polygon points="@_areaPoints" fill="url(#@_gradientId)"
                             style="transition:none;animation:none;" />
                }
                <polyline points="@_linePoints" class="line-chart__path"
                          fill="none" style="transition:none;animation:none;" />

                @if (Data.Count <= 20)
                {
                    @foreach (var p in _points)
                    {
                        <circle cx="@F(p.X)" cy="@F(p.Y)" r="4.5"
                                class="line-chart__point"
                                style="transition:none;animation:none;" />
                    }
                }
            }

            @((MarkupString)_xLabels)
            @((MarkupString)_yLabels)
        </svg>
    </div>
}

@code {
    // Siempre InvariantCulture para atributos SVG — el separador decimal DEBE ser punto.
    // Si el servidor corre con es-AR (coma decimal), sin esto los puntos se interpretan
    // como múltiples coordenadas y el polígono queda completamente distorsionado.
    private static readonly System.Globalization.CultureInfo Inv =
        System.Globalization.CultureInfo.InvariantCulture;

    private static string F(double v) => v.ToString("F2", Inv);

    private readonly string _gradientId = $"g{Guid.NewGuid():N}";
    private int _renderKey;

    private string _linePoints = string.Empty;
    private string _areaPoints = string.Empty;
    private string _xLabels   = string.Empty;
    private string _yLabels   = string.Empty;
    private List<ChartPoint> _points    = [];
    private List<GridLine>   _gridLines = [];
    private List<BarRect>    _bars      = [];

    [Parameter, EditorRequired] public IReadOnlyList<MonthlyPointDto> Data { get; set; } = [];
    [Parameter] public string Titulo        { get; set; } = "Evolución";
    [Parameter] public string Subtitulo     { get; set; } = string.Empty;
    [Parameter] public bool   MostrarMoneda { get; set; } = true;
    // "area" | "line" | "bars"
    [Parameter] public string ChartType     { get; set; } = "area";

    protected override void OnParametersSet()
    {
        _renderKey++;

        if (Data.Count == 0)
        {
            _points = []; _gridLines = []; _bars = [];
            _linePoints = _areaPoints = _xLabels = _yLabels = string.Empty;
            return;
        }

        const double chartW = 550;
        const double chartH = 176;
        const double startX = 70;
        const double startY = 26;
        const double bottom = startY + chartH; // 202

        var max   = Math.Max(Data.Max(x => x.Total), 1);
        var min   = ChartType == "bars" ? 0m : Math.Min(Data.Min(x => x.Total), 0);
        var range = Math.Max(max - min, 1);

        _points = Data.Select((item, i) =>
        {
            var x = startX + chartW / Math.Max(Data.Count - 1, 1) * i;
            var y = startY + chartH - (double)((item.Total - min) / range) * chartH;
            return new ChartPoint(x, y, item.Periodo);
        }).ToList();

        // polyline points — InvariantCulture garantiza "x.xx,y.yy" con punto decimal
        _linePoints = string.Join(" ", _points.Select(p => $"{F(p.X)},{F(p.Y)}"));
        _areaPoints = _linePoints
            + $" {F(_points[^1].X)},{F(bottom)} {F(_points[0].X)},{F(bottom)}";

        // bars
        var barGap = chartW / Data.Count;
        var barW   = barGap * 0.65;
        _bars = Data.Select((item, i) =>
        {
            var h = (double)(item.Total / max) * chartH;
            return new BarRect(
                X: startX + barGap * i + barGap * 0.175,
                Y: bottom - h,
                W: barW,
                H: Math.Max(h, 1));
        }).ToList();

        // grid
        _gridLines = Enumerable.Range(0, 4)
            .Select(i =>
            {
                var value = min + (max - min) / 3m * i;
                var y = startY + chartH - (double)((value - min) / range) * chartH;
                return new GridLine(y, value);
            })
            .Reverse()
            .ToList();

        const int MaxLabels = 12;
        var step = Math.Max(1, (int)Math.Ceiling((double)Data.Count / MaxLabels));
        var labelPoints = _points.Where((_, i) => i % step == 0 || i == Data.Count - 1).ToList();

        _xLabels = string.Join("", labelPoints.Select(p =>
            $"<text x=\"{F(p.X)}\" y=\"278\" class=\"line-chart__label-svg\" text-anchor=\"middle\">" +
            $"{System.Net.WebUtility.HtmlEncode(FmtXLabel(p.Label))}</text>"));

        _yLabels = string.Join("", _gridLines.Select(g =>
            $"<text x=\"66\" y=\"{F(g.Y + 4)}\" class=\"line-chart__axis-svg\" text-anchor=\"end\">" +
            $"{System.Net.WebUtility.HtmlEncode(FormatearValor(g.Value))}</text>"));
    }

    private string FormatearValor(decimal valor)
    {
        var c = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
        var prefix = MostrarMoneda ? "$ " : "";
        return valor switch
        {
            >= 1_000_000_000m => $"{prefix}{(valor / 1_000_000_000m).ToString("N1", c)}B",
            >= 1_000_000m     => $"{prefix}{(valor / 1_000_000m).ToString("N0", c)}M",
            >= 1_000m         => $"{prefix}{(valor / 1_000m).ToString("N0", c)}K",
            _                 => MostrarMoneda ? valor.ToString("$ #,##0", c) : valor.ToString("#,##0", c)
        };
    }

    private static string FmtXLabel(string label)
    {
        var esAr = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
        if (DateTime.TryParseExact(label, "yyyy-MM", Inv, System.Globalization.DateTimeStyles.None, out var m))
        {
            var mes = m.ToString("MMM", esAr);
            return $"{char.ToUpper(mes[0])}{mes[1..]} '{m.ToString("yy", Inv)}";
        }
        if (DateTime.TryParseExact(label, "dd/MM/yyyy", esAr, System.Globalization.DateTimeStyles.None, out var d))
            return d.ToString("dd/MM", esAr);
        return label;
    }

    private sealed record ChartPoint(double X, double Y, string Label);
    private sealed record GridLine(double Y, decimal Value);
    private sealed record BarRect(double X, double Y, double W, double H);
}
