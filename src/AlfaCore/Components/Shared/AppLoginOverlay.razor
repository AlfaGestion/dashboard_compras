@using AlfaCore.Models

@if (Open)
{
    <div class="drawer-overlay app-login-overlay"></div>

    <div class="app-login-modal" role="dialog" aria-label="Ingreso al sistema">
        <div class="app-login-modal__header">
            <div>
                <p class="shell__eyebrow">Alfa Gestión</p>
                <h2 class="app-login-modal__title">Ingresar a la base activa</h2>
            </div>
        </div>

        <div class="app-login-modal__body">
            <div class="usuarios-empty">
                <strong>Base activa</strong>
                <p>@SqlSessionLabel</p>
                <small>Si cambiás de base, se cierra la sesión funcional actual y tenés que volver a ingresar.</small>
            </div>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="editor-msg editor-msg--error">
                    <div>
                        <strong>No se pudo iniciar sesión</strong>
                        <p>@ErrorMessage</p>
                    </div>
                </div>
            }

            <div class="field">
                <label>Usuario del sistema</label>
                <input value="@UserName"
                       @oninput="OnUserNameInput"
                       placeholder="Ej: albert"
                       disabled="@IsBusy" />
            </div>

            <div class="field">
                <label>Contraseña</label>
                <div class="drawer-new__password">
                    <input type="@(ShowPassword ? "text" : "password")"
                           value="@Password"
                           @oninput="OnPasswordInput"
                           placeholder="Contraseña"
                           disabled="@IsBusy" />
                    <button type="button"
                            class="drawer-new__eye"
                            @onclick="TogglePassword"
                            title="@(ShowPassword ? "Ocultar" : "Mostrar")"
                            disabled="@IsBusy">
                        <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
            </div>

            <div class="actions app-login-modal__actions">
                <button type="button" class="btn btn--primary" @onclick="SubmitAsync" disabled="@IsBusy">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>@(IsBusy ? "Ingresando..." : "Ingresar")</span>
                </button>
                <button type="button" class="btn btn--ghost" @onclick="OpenSqlSessionsAsync" disabled="@IsBusy">
                    <i class="bi bi-database"></i>
                    <span>Cambiar base</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string SqlSessionLabel { get; set; } = string.Empty;
    [Parameter] public string UserName { get; set; } = string.Empty;
    [Parameter] public string Password { get; set; } = string.Empty;
    [Parameter] public string ErrorMessage { get; set; } = string.Empty;
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public bool ShowPassword { get; set; }
    [Parameter] public EventCallback<string> UserNameChanged { get; set; }
    [Parameter] public EventCallback<string> PasswordChanged { get; set; }
    [Parameter] public EventCallback<bool> ShowPasswordChanged { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnOpenSqlSessions { get; set; }

    private async Task SubmitAsync() => await OnSubmit.InvokeAsync();

    private async Task OpenSqlSessionsAsync() => await OnOpenSqlSessions.InvokeAsync();

    private async Task TogglePassword()
        => await ShowPasswordChanged.InvokeAsync(!ShowPassword);

    private async Task OnUserNameInput(ChangeEventArgs args)
        => await UserNameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private async Task OnPasswordInput(ChangeEventArgs args)
        => await PasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}
