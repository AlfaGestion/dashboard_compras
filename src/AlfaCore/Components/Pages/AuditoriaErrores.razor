@using Microsoft.AspNetCore.Components.Forms
@page "/auditoria/errores"
@inject AlfaCore.Services.IAuditoriaService AuditoriaSvc
@inject AlfaCore.Services.IAppUiOperationService UiOps

<PageTitle>Errores | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando errores…
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">Errores</h2>
                <p class="page-intro__text">Filtrá `AUX_ERR` por fecha, usuario, proceso, equipo y texto técnico para investigar incidentes.</p>
            </div>
        </section>

        @if (_feedback is not null)
        {
            <div class="conversations-inline @GetFeedbackClass(_feedback)">
                <strong>@_feedback.Title</strong>
                <div>@_feedback.Message</div>
                @if (_feedback.HasCode)
                {
                    <div>Código: @_feedback.Code</div>
                }
                @if (_feedback.HasSuggestion)
                {
                    <div>@_feedback.Suggestion</div>
                }
            </div>
        }

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Filtros</h3>
                    <p class="panel-card__subtitle">Aplicá combinaciones para encontrar incidentes rápido.</p>
                </div>
                <div class="actions">
                    <button class="btn btn--ghost" @onclick="LimpiarFiltros">
                        <i class="bi bi-eraser"></i>
                        <span>Limpiar</span>
                    </button>
                    <button class="btn btn--primary" @onclick="BuscarAsync">
                        <i class="bi bi-search"></i>
                        <span>Buscar</span>
                    </button>
                </div>
            </div>

            <div class="filters-grid filters-grid--wide">
                <div class="field">
                    <label class="field__label">Desde</label>
                    <InputDate class="field__control" @bind-Value="_desde" />
                </div>
                <div class="field">
                    <label class="field__label">Hasta</label>
                    <InputDate class="field__control" @bind-Value="_hasta" />
                </div>
                <div class="field">
                    <label class="field__label">Usuario</label>
                    <select class="field__control" @bind="_usuario">
                        <option value="">Todos</option>
                        @foreach (var item in _usuarios)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label class="field__label">Proceso</label>
                    <select class="field__control" @bind="_proceso">
                        <option value="">Todos</option>
                        @foreach (var item in _procesos)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label class="field__label">PC</label>
                    <input class="field__control" @bind="_pc" placeholder="Equipo o IP..." />
                </div>
                <div class="field">
                    <label class="field__label">Código error</label>
                    <input class="field__control" type="number" @bind="_errorCodigoText" placeholder="Ej: 208" />
                </div>
                <div class="field field--full">
                    <label class="field__label">Texto</label>
                    <input class="field__control" @bind="_texto" @bind:event="oninput" placeholder="Buscar en descripción, SQL, proceso o usuario..." />
                </div>
            </div>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Resultados</h3>
                    <p class="panel-card__subtitle">@_rows.Count error(es) cargado(s).</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Proceso</th>
                            <th>Usuario</th>
                            <th>PC</th>
                            <th>Error</th>
                            <th>Descripción</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _rows)
                        {
                            <tr>
                                <td><a class="action-link" href="/auditoria/error/@item.Id">@item.Fecha.ToString("dd/MM/yyyy HH:mm")</a></td>
                                <td>@item.Proceso</td>
                                <td>@item.Usuario</td>
                                <td>@item.Pc</td>
                                <td>@item.ErrorCodigo</td>
                                <td>@item.Descripcion</td>
                                <td>
                                    <a class="btn btn--ghost btn--sm" href="/auditoria/error/@item.Id">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                        <span>Ver detalle</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
}

@code {
    private bool _loading = true;
    private AlfaCore.Models.AppUiMessage? _feedback;
    private IReadOnlyList<string> _usuarios = [];
    private IReadOnlyList<string> _procesos = [];
    private IReadOnlyList<AuditoriaErrorRowDto> _rows = [];
    private DateTime? _desde = DateTime.Today.AddDays(-7);
    private DateTime? _hasta = DateTime.Today;
    private string _usuario = string.Empty;
    private string _proceso = string.Empty;
    private string _pc = string.Empty;
    private string _errorCodigoText = string.Empty;
    private string _texto = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var result = await UiOps.RunAsync(async () =>
        {
            _usuarios = await AuditoriaSvc.GetUsuariosAsync();
            _procesos = await AuditoriaSvc.GetProcesosAsync();
            await BuscarAsync();
        }, "No se pudo cargar el listado de errores.");

        _feedback = result.Success ? null : result.Feedback;
        _loading = false;
    }

    private async Task BuscarAsync()
    {
        _feedback = null;
        var result = await UiOps.RunAsync(async () =>
        {
            _rows = await AuditoriaSvc.SearchErrorsAsync(new AuditoriaErrorFilterDto
            {
                Desde = _desde,
                Hasta = _hasta,
                Usuario = _usuario,
                Proceso = _proceso,
                Pc = _pc,
                ErrorCodigo = int.TryParse(_errorCodigoText, out var code) ? code : null,
                Texto = _texto,
                MaxRows = 500
            });
        }, "No se pudieron cargar los errores filtrados.");

        _feedback = result.Feedback;
    }

    private async Task LimpiarFiltros()
    {
        _desde = DateTime.Today.AddDays(-7);
        _hasta = DateTime.Today;
        _usuario = string.Empty;
        _proceso = string.Empty;
        _pc = string.Empty;
        _errorCodigoText = string.Empty;
        _texto = string.Empty;
        await BuscarAsync();
    }

    private static string GetFeedbackClass(AlfaCore.Models.AppUiMessage message)
        => message.Severity switch
        {
            AlfaCore.Models.AppUiFeedbackSeverity.Success => "conversations-inline--ok",
            AlfaCore.Models.AppUiFeedbackSeverity.Warning => "conversations-inline--error",
            AlfaCore.Models.AppUiFeedbackSeverity.Error => "conversations-inline--error",
            _ => "conversations-inline--ok"
        };
}
