@page "/compras"

@inject AlfaCore.Services.IComprasDashboardService DashboardService
@inject AlfaCore.Services.FilterStateService FilterState

<PageTitle>Inicio | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Resumen general</h2>
            <p class="page-intro__text">Panel ejecutivo con KPIs, evolución y accesos directos a proveedores, rubros, artículos y comprobantes. <a class="help-link" href="/ayuda#4-inicio--resumen-ejecutivo">Ver ayuda</a></p>
        </div>
    </div>

    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (_error is not null)
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Conexión</span>
            <h3>No fue posible cargar el dashboard</h3>
            <p>@_error</p>
        </div>
    }
    else if (_dashboard is null)
    {
        <div class="loading">Cargando indicadores...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Total" Valor="@Moneda(_dashboard.TotalComprado)" Icono="$" />
            <KpiCard Titulo="Netos" Valor="@Moneda(_dashboard.NetoTotal)" Icono="N" />
            <KpiCard Titulo="IVA" Valor="@Moneda(_dashboard.IvaTotal)" Icono="%" />
            <KpiCard Titulo="Otros" Valor="@Moneda(_dashboard.TotalComprado - _dashboard.NetoTotal - _dashboard.IvaTotal)" Icono="+" />
            <KpiCard Titulo="Comprobantes" Valor="@_dashboard.CantidadComprobantes.ToString("N0")" Icono="C" />
            <KpiCard Titulo="Artículos" Valor="@_dashboard.CantidadArticulos.ToString("N0")" Icono="A" />
            <KpiCard Titulo="Proveedores" Valor="@_dashboard.ProveedoresActivos.ToString("N0")" Icono="P" />
            <KpiCard Titulo="Ticket promedio" Valor="@Moneda(_dashboard.TicketPromedio)" Icono="T" />
        </div>

        <div class="chart-grid">
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Evolución mensual</h3>
                        <p class="panel-card__subtitle">Últimos 12 meses consolidados</p>
                    </div>
                </div>
                <LineChart Data="_dashboard.EvolucionMensual" Titulo="Evolución mensual" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Top proveedores</h3>
                        <p class="panel-card__subtitle">Drill down a proveedores</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_dashboard.TopProveedores" LinkSelector="ProveedorChartLink" LinkLabel="Ver" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Top rubros</h3>
                        <p class="panel-card__subtitle">Drill down a rubros</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_dashboard.TopRubros" LinkSelector="RubroChartLink" LinkLabel="Ver" />
            </section>
        </div>

        <DataTable Titulo="Top artículos" Subtitulo="Acceso rápido a historial y proveedores asociados">
            <Header>
                <tr>
                    <th>Artículo</th>
                    <th style="text-align:right;">Total</th>
                    <th style="text-align:right;">Participación</th>
                    <th></th>
                </tr>
            </Header>
            <Rows>
                @foreach (var item in _dashboard.TopArticulos)
                {
                    <tr>
                        <td>@item.Categoria</td>
                        <td style="text-align:right;">@Moneda(item.Total)</td>
                        <td style="text-align:right;">@Porcentaje(item.Participacion)</td>
                        <td><a class="action-link" href="@ArticuloLink(item.Codigo ?? item.Categoria)">Historial</a></td>
                    </tr>
                }
            </Rows>
        </DataTable>
    }
</section>

@code {
    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private DashboardSummaryDto? _dashboard;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _error = null;

        try
        {
            _options = await DashboardService.GetFilterOptionsAsync();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _dashboard = null;
            _options = new FilterOptionsDto();
        }
    }

    private async Task LoadAsync()
    {
        _error = null;
        try
        {
            _dashboard = await DashboardService.GetDashboardAsync(_filters);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Porcentaje(decimal valor) => valor.ToString("P1", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string ProveedorLink(string cuenta) => $"/proveedores?proveedor={Uri.EscapeDataString(cuenta)}";
    private static string RubroLink(string rubro) => $"/rubros?rubro={Uri.EscapeDataString(rubro)}";
    private static string ArticuloLink(string articulo) => $"/articulos?articulo={Uri.EscapeDataString(articulo)}";
    private static string? ProveedorChartLink(CategoryTotalDto item) => string.IsNullOrWhiteSpace(item.Codigo) ? null : ProveedorLink(item.Codigo);
    private static string? RubroChartLink(CategoryTotalDto item) => string.IsNullOrWhiteSpace(item.Codigo) ? null : RubroLink(item.Codigo);
}
