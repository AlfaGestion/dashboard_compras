@page "/ventas/comparativo"
@inject AlfaCore.Services.IGestionDashboardService GestionSvc
@inject AlfaCore.Services.GestionFilterStateService FilterState

<PageTitle>Comparativo Ventas / Compras | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Comparativo</h2>
            <p class="page-intro__text">Ventas vs. compras para el período seleccionado — evolución mensual y balance.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Período</h3>
                <p class="panel-card__subtitle">El comparativo usa los mismos filtros de fecha que el dashboard de ventas.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("hoy")'>Hoy</button>
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("semana")'>Esta semana</button>
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("mes")'>Este mes</button>
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("mes-anterior")'>Mes anterior</button>
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("ultimos-3")'>Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick='() => ApplyQuickRangeAsync("anio")'>Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
        </div>

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
        </div>
    </section>

    @if (_loading)
    {
        <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Cargando comparativo…</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="consultas-error"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }
    else
    {
        var balanceCss = _comp.Balance >= 0 ? "kpi-card--balance-pos" : "kpi-card--balance-neg";

        <section class="kpi-grid">
            <article class="kpi-card">
                <div class="kpi-card__label">Total ventas período</div>
                <div class="kpi-card__value">@FmtMoney(_comp.TotalVentas)</div>
            </article>
            <article class="kpi-card kpi-card--compras">
                <div class="kpi-card__label">Total compras período</div>
                <div class="kpi-card__value">@FmtMoney(_comp.TotalCompras)</div>
            </article>
            <article class="kpi-card @balanceCss">
                <div class="kpi-card__label">Balance (ventas − compras)</div>
                <div class="kpi-card__value">@FmtMoney(_comp.Balance)</div>
            </article>
        </section>

        <article class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Ventas vs. Compras por mes</h3>
                    <p class="panel-card__subtitle">Barras agrupadas — azul: ventas · naranja: compras</p>
                </div>
            </div>
            <DualBarChart Data="_comp.EvolucionMensual" />
        </article>

        <section class="two-grid">
            <article class="panel-card">
                <LineChart Data="_ventasMensuales" Titulo="Evolución ventas" Subtitulo="Últimos 12 meses" ChartType="line" />
            </article>
            <article class="panel-card">
                <LineChart Data="_comprasMensuales" Titulo="Evolución compras" Subtitulo="Últimos 12 meses" ChartType="line" />
            </article>
        </section>

        <article class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Detalle mensual</h3>
                    <p class="panel-card__subtitle">Ventas vs. compras mes a mes</p>
                </div>
            </div>
            <table class="comparativo-table">
                <thead>
                    <tr>
                        <th>Período</th>
                        <th>Ventas</th>
                        <th>Compras</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _comp.EvolucionMensual)
                    {
                        var bal = row.Ventas - row.Compras;
                        <tr>
                            <td>@FmtPeriodo(row.Periodo)</td>
                            <td>@FmtMoney(row.Ventas)</td>
                            <td>@FmtMoney(row.Compras)</td>
                            <td class="@(bal >= 0 ? "balance-pos" : "balance-neg")">@FmtMoney(bal)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    }
</div>

@code {
    private bool _loading = true;
    private string _error = string.Empty;

    private ComparativoVentasComprasDto _comp = new();
    private VentasDashboardFilters _filters = null!;

    private IReadOnlyList<MonthlyPointDto> _ventasMensuales  = [];
    private IReadOnlyList<MonthlyPointDto> _comprasMensuales = [];

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Ventas;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = string.Empty;
        try
        {
            _comp = await GestionSvc.GetComparativoAsync(_filters);
            _ventasMensuales  = _comp.EvolucionMensual
                .Select(m => new MonthlyPointDto { Periodo = m.Periodo, Total = m.Ventas })
                .ToList();
            _comprasMensuales = _comp.EvolucionMensual
                .Select(m => new MonthlyPointDto { Periodo = m.Periodo, Total = m.Compras })
                .ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ApplyQuickRangeAsync(string key)
    {
        var today = DateTime.Today;
        switch (key)
        {
            case "hoy":
                _filters.FechaDesde = today;
                _filters.FechaHasta = today;
                break;
            case "semana":
                var diff = ((int)today.DayOfWeek + 6) % 7;
                _filters.FechaDesde = today.AddDays(-diff);
                _filters.FechaHasta = today;
                break;
            case "mes":
                _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
                _filters.FechaHasta = today;
                break;
            case "mes-anterior":
                var first = new DateTime(today.Year, today.Month, 1);
                _filters.FechaDesde = first.AddMonths(-1);
                _filters.FechaHasta = first.AddDays(-1);
                break;
            case "ultimos-3":
                _filters.FechaDesde = today.AddMonths(-3);
                _filters.FechaHasta = today;
                break;
            case "anio":
                _filters.FechaDesde = new DateTime(today.Year, 1, 1);
                _filters.FechaHasta = today;
                break;
        }
        await LoadAsync();
    }

    private static string FmtMoney(decimal value)
        => value.ToString("$ #,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private static string FmtPeriodo(string periodo)
    {
        var inv  = System.Globalization.CultureInfo.InvariantCulture;
        var esAr = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
        if (DateTime.TryParseExact(periodo, "yyyy-MM", inv,
                System.Globalization.DateTimeStyles.None, out var m))
        {
            var mes = m.ToString("MMMM", esAr);
            return $"{char.ToUpper(mes[0])}{mes[1..]} {m.Year}";
        }
        return periodo;
    }
}
