@page "/compras/rubros"
@inject AlfaCore.Services.IComprasDashboardService DashboardService
@inject AlfaCore.Services.FilterStateService FilterState

<PageTitle>Rubros | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Rubros</h2>
            <p class="page-intro__text">Visión estratégica del gasto por categoría, concentración, variación y movimiento reciente. <a class="help-link" href="/ayuda#7-rubros">Ver ayuda</a></p>
        </div>
    </div>
    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (_page?.Kpis is not null)
    {
        <div class="kpi-grid kpi-grid--6">
            <KpiCard Titulo="Total comprado" Valor="@Moneda(_page.Kpis.TotalComprado)" Icono="$" />
            <KpiCard Titulo="Rubros activos" Valor="@_page.Kpis.CantidadRubrosActivos.ToString("N0")" Icono="R" />
            <KpiCard Titulo="Rubro principal" Valor="@_page.Kpis.RubroPrincipal" Icono="★" Destacado="true" />
            <KpiCard Titulo="Participación líder" Valor="@Porcentaje(_page.Kpis.ParticipacionRubroPrincipal)" Icono="%" />
            <KpiCard Titulo="Variación total" Valor="@RenderVariacionTexto(_page.Kpis.VariacionTotalVsAnterior)" Icono="Δ" />
            <KpiCard Titulo="Concentración top 3" Valor="@Porcentaje(_page.Kpis.ConcentracionTop3)" Icono="3" />
            <KpiCard Titulo="Mayor crecimiento" Valor="@RenderMayorVariacion(_page.Kpis.RubroMayorCrecimiento, _page.Kpis.RubroMayorCrecimientoVariacion)" Icono="▲" />
            <KpiCard Titulo="Mayor caída" Valor="@RenderMayorVariacion(_page.Kpis.RubroMayorCaida, _page.Kpis.RubroMayorCaidaVariacion)" Icono="▼" />
        </div>
    }

    @if (_page?.Insights?.Any() == true)
    {
        <div class="alert-band">
            @foreach (var insight in _page.Insights)
            {
                <span class="alert-chip">@insight.Mensaje</span>
            }
        </div>
    }

    @if (_page is null)
    {
        <div class="loading">Cargando rubros...</div>
    }
    else
    {
        <div class="three-grid">
            <section class="panel-card"><HorizontalBarChart Data="_page.TopRubros" Titulo="Top rubros por total" Subtitulo="Categorías con mayor gasto" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.DistribucionGasto" Titulo="Distribución del gasto" Subtitulo="Participación de cada rubro" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.ConcentracionTop3VsResto" Titulo="Concentración top 3" Subtitulo="Top 3 rubros vs resto" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.VariacionesPositivas" Titulo="Rubros en crecimiento" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.VariacionesNegativas" Titulo="Rubros en caída" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
        </div>

        <div class="split-grid">
            <DataTable Titulo="Rubros" Subtitulo="Lectura ejecutiva por gasto, concentración y variación">
                <Header>
                    <tr>
                        <th>Rubro</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">% total</th>
                        <th style="text-align:right;">Comprobantes</th>
                        <th style="text-align:right;">Artículos</th>
                        <th style="text-align:center;">Variación</th>
                        <th style="text-align:right;">Ticket prom.</th>
                        <th>Última compra</th>
                        <th></th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in _page.Rubros)
                    {
                        <tr class="@GetRubroRowClass(item)">
                            <td><strong>@item.Rubro</strong></td>
                            <td style="text-align:right;">@Moneda(item.TotalComprado)</td>
                            <td style="text-align:right;">@Porcentaje(item.Participacion)</td>
                            <td style="text-align:right;">@item.CantidadComprobantes.ToString("N0")</td>
                            <td style="text-align:right;">@item.CantidadArticulos</td>
                            <td style="text-align:center;">@((MarkupString)RenderVariacionBadge(item.VariacionVsAnterior))</td>
                            <td style="text-align:right;">@Moneda(item.TicketPromedio)</td>
                            <td>@Fecha(item.UltimaCompra)</td>
                            <td><button class="btn btn--ghost" @onclick="() => SelectAsync(item.Rubro)">Detalle</button></td>
                        </tr>
                    }
                </Rows>
            </DataTable>

            @if (_detalle is not null)
            {
                <DetailCard Titulo="@_detalle.Resumen.Rubro" Subtitulo="Detalle del rubro">
                    <div class="detail-row"><span class="detail-row__label">Total</span><strong>@Moneda(_detalle.Resumen.TotalComprado)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Participación</span><strong>@Porcentaje(_detalle.Resumen.Participacion)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Variación</span><strong>@((MarkupString)RenderVariacionBadge(_detalle.Resumen.VariacionVsAnterior))</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Comprobantes</span><strong>@_detalle.Resumen.CantidadComprobantes.ToString("N0")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Artículos</span><strong>@_detalle.Resumen.CantidadArticulos</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Ticket promedio</span><strong>@Moneda(_detalle.Resumen.TicketPromedio)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Última compra</span><strong>@Fecha(_detalle.Resumen.UltimaCompra)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Drill down</span><a class="action-link" href="/compras/articulos?rubro=@Uri.EscapeDataString(_detalle.Resumen.Rubro)">Ver artículos</a></div>
                </DetailCard>
            }
        </div>

        @if (_detalle is not null)
        {
            <div class="split-grid">
                <section class="panel-card"><LineChart Data="_detalle.EvolucionMensual" Titulo="Evolución del rubro" Subtitulo="Últimos 12 meses consolidados" /></section>
                <section class="panel-card"><HorizontalBarChart Data="_detalle.TopArticulos" Titulo="Artículos principales" Subtitulo="Top artículos del rubro por total" /></section>
            </div>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Últimos comprobantes del rubro</h3>
                        <p class="panel-card__subtitle">Movimientos recientes asociados a esta categoría</p>
                    </div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>TC</th>
                            <th>Comprobante</th>
                            <th>Proveedor</th>
                            <th style="text-align:right;">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _detalle.UltimosComprobantes)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Tc</td>
                                <td>@item.IdComprobante</td>
                                <td>@item.RazonSocial</td>
                                <td style="text-align:right;">@Moneda(item.ImporteDashboard)</td>
                                <td><a class="action-link" href="/compras/comprobantes?tc=@item.Tc&id=@item.IdComprobante&cuenta=@Uri.EscapeDataString(item.Cuenta)">Abrir</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "rubro")] public string? RubroQuery { get; set; }
    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private RubrosPageDto? _page;
    private RubroDetalleDto? _detalle;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        if (!string.IsNullOrWhiteSpace(RubroQuery))
            _filters.Rubro = RubroQuery;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _page = await DashboardService.GetRubrosPageDataAsync(_filters);
        _detalle = !string.IsNullOrWhiteSpace(_filters.Rubro) ? await DashboardService.GetRubroDetalleAsync(_filters.Rubro, _filters) : null;
    }

    private async Task SelectAsync(string rubro)
    {
        _filters.Rubro = rubro;
        _detalle = await DashboardService.GetRubroDetalleAsync(rubro, _filters);
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Porcentaje(decimal valor) => valor.ToString("P1", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Fecha(DateTime? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "Sin dato";

    private static string RenderVariacionTexto(decimal? variacion)
    {
        if (!variacion.HasValue)
            return "Sin base";

        var signo = variacion.Value > 0 ? "+" : string.Empty;
        return $"{signo}{(variacion.Value * 100m):N1}%";
    }

    private static string RenderMayorVariacion(string? rubro, decimal? variacion)
    {
        if (string.IsNullOrWhiteSpace(rubro) || !variacion.HasValue)
            return "Sin datos";

        return $"{rubro} · {(variacion.Value * 100m):N1}%";
    }

    private static string GetRubroRowClass(RubroResumenDto item)
    {
        if (item.VariacionVsAnterior is >= 0.20m or <= -0.20m)
            return "row--warning";

        return string.Empty;
    }

    private static string RenderVariacionBadge(decimal? variacion)
    {
        if (!variacion.HasValue)
            return "<span class=\"var-badge var-badge--new\">Sin base</span>";

        var clase = variacion.Value switch
        {
            > 0.005m => "var-badge var-badge--up",
            < -0.005m => "var-badge var-badge--down",
            _ => "var-badge var-badge--flat"
        };

        var signo = variacion.Value > 0 ? "+" : string.Empty;
        return $"<span class=\"{clase}\">{signo}{(variacion.Value * 100m):N1}%</span>";
    }
}
