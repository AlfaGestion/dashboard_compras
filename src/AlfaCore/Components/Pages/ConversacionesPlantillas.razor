@page "/conversaciones/plantillas"
@inject AlfaCore.Services.IConversacionesService ConversacionesSvc

<PageTitle>Plantillas de WhatsApp | Alfa Gestión</PageTitle>

<section class="page-grid templates-page templates-page--odoo">
    <div class="page-intro conversations-topbar">
        <div>
            <h2 class="page-intro__title">Plantillas de WhatsApp</h2>
            <p class="page-intro__text">Creá borradores, envialos a aprobación de Meta y sincronizá su estado para retomar conversaciones fuera de la ventana de 24 horas.</p>
        </div>
        <div class="actions">
            <a class="btn btn--ghost" href="/conversaciones">
                <i class="bi bi-inbox-fill"></i> Inbox
            </a>
            <button type="button" class="btn btn--primary" @onclick="NuevaPlantilla">
                <i class="bi bi-plus-circle-fill"></i> Nueva plantilla
            </button>
            <button type="button" class="btn btn--ghost" @onclick="AplicarModeloCobranzaAsync">
                <i class="bi bi-receipt"></i> Modelo cobranza
            </button>
        </div>
    </div>

    @if (_loadError is not null)
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Plantillas</span>
            <h3>No fue posible cargar las plantillas</h3>
            <p>@_loadError</p>
            @if (IsInitializationPending(_loadError))
            {
                <p>Ejecutá <code>docs/conversaciones_modelo_inicial.sql</code> en la base activa y recargá esta pantalla.</p>
            }
        </div>
    }
    else
    {
        <section class="panel-card templates-filters">
            <div class="conversations-filters__fields">
                <div class="field">
                    <label for="tpl-search">Buscar</label>
                    <input id="tpl-search" type="search" placeholder="Nombre, identificador Meta o texto..."
                           @bind="_filters.Search" @bind:event="oninput" @onkeydown="HandleSearchEnter" />
                </div>
                <div class="field">
                    <label for="tpl-state">Estado Meta</label>
                    <select id="tpl-state" @bind="_filters.EstadoMeta">
                        <option value="">Todos</option>
                        <option value="DRAFT">Borrador</option>
                        <option value="PENDING">Pendiente</option>
                        <option value="APPROVED">Aprobada</option>
                        <option value="REJECTED">Rechazada</option>
                        <option value="PAUSED">Pausada</option>
                        <option value="DISABLED">Deshabilitada</option>
                    </select>
                </div>
                <label class="field templates-toggle">
                    <span>Incluir inactivas</span>
                    <input type="checkbox" @bind="_filters.IncluirInactivas" />
                </label>
                <button type="button" class="btn btn--primary" @onclick="LoadTemplatesAsync" disabled="@_loading">
                    <i class="bi bi-funnel"></i> Aplicar
                </button>
            </div>
        </section>

        <div class="conversations-layout templates-layout">
            <aside class="panel-card conversations-list">
                <div class="conversations-list__header">
                    <div>
                        <h3 class="panel-card__title">Plantillas</h3>
                        <p class="panel-card__subtitle">@_templates.Count plantilla(s)</p>
                    </div>
                </div>

                @if (_loading)
                {
                    <div class="loading">Cargando plantillas...</div>
                }
                else if (_templates.Count == 0)
                {
                    <div class="conversations-empty">No hay plantillas para los filtros seleccionados.</div>
                }
                else
                {
                    <div class="conversations-list__items">
                        @foreach (var item in _templates)
                        {
                            <button type="button"
                                    class="conversation-row @(item.IdPlantilla == _selectedId ? "is-selected" : string.Empty)"
                                    @onclick="() => SelectTemplateAsync(item.IdPlantilla)">
                                <div class="conversation-row__top">
                                    <span class="conversation-row__name">@item.NombreVisible</span>
                                    <span class="conversation-row__date">@FormatDate(item.FechaHoraGrabacion)</span>
                                </div>
                                <div class="conversation-row__meta">
                                    <span>@item.NombreMeta</span>
                                    <span>• @item.Idioma</span>
                                </div>
                                <div class="conversation-row__badges">
                                    <span class="conversation-badge conversation-badge--state">@GetMetaStatusLabel(item.EstadoMeta)</span>
                                    <span class="conversation-badge">@GetCategoryLabel(item.Categoria)</span>
                                </div>
                                <p class="conversation-row__summary">@item.CuerpoTexto</p>
                            </button>
                        }
                    </div>
                }
            </aside>

            <section class="panel-card conversations-chat templates-editor">
                <header class="conversations-chat__header">
                    <div>
                        <h3 class="panel-card__title">@(_selectedId > 0 ? "Editar plantilla" : "Nueva plantilla")</h3>
                        <p class="panel-card__subtitle">Idioma fijo: español de Argentina. El teléfono se toma siempre desde la conversación seleccionada al enviar.</p>
                    </div>
                    <div class="conversations-chat__chips">
                        <span class="conversation-badge conversation-badge--state">@GetMetaStatusLabel(_formEstadoMeta)</span>
                    </div>
                </header>

                <div class="conversations-composer templates-form">
                    <div class="field">
                        <label for="tpl-name">Nombre visible</label>
                        <input id="tpl-name" @bind="_form.NombreVisible" placeholder="Ej: Retomar conversación" />
                    </div>
                    <div class="field">
                        <label for="tpl-meta-name">Nombre Meta</label>
                        <input id="tpl-meta-name" @bind="_form.NombreMeta" placeholder="retomar_conversacion" />
                    </div>
                    <div class="field">
                        <label for="tpl-category">Categoría</label>
                        <select id="tpl-category" @bind="_form.Categoria">
                            <option value="@ConversacionPlantillaCategorias.Marketing">Marketing</option>
                            <option value="@ConversacionPlantillaCategorias.Utility">Utilidad</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="tpl-header">Encabezado de texto</label>
                        <input id="tpl-header" maxlength="60" @bind="_form.EncabezadoTexto" placeholder="Opcional" />
                    </div>
                    <div class="field">
                        <label for="tpl-body">Cuerpo</label>
                        <textarea id="tpl-body" rows="5" @bind="_form.CuerpoTexto"
                                  placeholder="Hola {{1}}, te escribimos para continuar con la conversación pendiente."></textarea>
                        <div class="templates-body-limit @(IsBodyTooLong ? "is-danger" : string.Empty)">
                            <span>@BodyLength / @MetaBodyMaxLength caracteres</span>
                            @if (IsBodyTooLong)
                            {
                                <strong>Meta permite hasta @MetaBodyMaxLength caracteres en el cuerpo.</strong>
                            }
                        </div>
                    </div>
                    <div class="field">
                        <label for="tpl-footer">Pie de página</label>
                        <input id="tpl-footer" maxlength="60" @bind="_form.PieTexto" placeholder="Opcional" />
                    </div>
                    <div class="field">
                        <label for="tpl-examples">Ejemplos para variables</label>
                        <textarea id="tpl-examples" rows="3" @bind="_examplesText"
                                  placeholder="Un valor por línea. Ej: Evelyn"></textarea>
                    </div>
                    <div class="templates-variable-guide">
                        <span class="context-card__label">Variables automáticas sugeridas</span>
                        <button type="button" class="templates-variable-chip" @onclick='() => InsertVariable("{{1}}")'>@("{{1}} Nombre")</button>
                        <button type="button" class="templates-variable-chip" @onclick='() => InsertVariable("{{2}}")'>@("{{2}} Detalle de deuda")</button>
                        <button type="button" class="templates-variable-chip" @onclick='() => InsertVariable("{{3}}")'>@("{{3}} Forma de pago")</button>
                    </div>
                    <label class="field">
                        <span>Plantilla activa</span>
                        <input type="checkbox" @bind="_form.Activa" />
                    </label>
                    <div class="conversations-composer__actions">
                        <button type="button" class="btn btn--primary" @onclick="SaveAsync" disabled="@(!CanSaveDraft)">
                            <i class="bi bi-save-fill"></i> Guardar borrador
                        </button>
                        <button type="button" class="btn btn--ghost" @onclick="SubmitAsync" disabled="@(_busy || _selectedId <= 0 || IsBodyTooLong)">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Enviar a aprobación
                        </button>
                        <button type="button" class="btn btn--ghost" @onclick="SyncAsync" disabled="@(_busy || _selectedId <= 0)">
                            <i class="bi bi-arrow-repeat"></i> Sincronizar
                        </button>
                    </div>

                    @if (_feedback is not null)
                    {
                        <div class="conversations-inline conversations-inline--ok">@_feedback</div>
                    }
                    @if (_error is not null)
                    {
                        <div class="conversations-inline conversations-inline--error">@_error</div>
                    }
                </div>
            </section>

            <aside class="panel-card conversations-context templates-preview">
                <div class="conversations-context__section">
                    <h3 class="panel-card__title">Vista previa</h3>
                    <p class="panel-card__subtitle">Así se verá el cuerpo principal con ejemplos.</p>
                </div>
                <article class="message-card message-card--outgoing">
                    @if (!string.IsNullOrWhiteSpace(_form.EncabezadoTexto))
                    {
                        <strong>@_form.EncabezadoTexto</strong>
                    }
                    <p class="message-card__text">@PreviewBody</p>
                    @if (!string.IsNullOrWhiteSpace(_form.PieTexto))
                    {
                        <div class="message-card__footer">@_form.PieTexto</div>
                    }
                </article>
                <div class="context-card">
                    <span class="context-card__label">Estado</span>
                    <strong>@GetMetaStatusLabel(_formEstadoMeta)</strong>
                    <span class="context-card__muted">@DisplayOrFallback(_form.MetaTemplateId)</span>
                    @if (!string.IsNullOrWhiteSpace(_form.MetaRechazoMotivo))
                    {
                        <span class="context-card__muted">@_form.MetaRechazoMotivo</span>
                    }
                </div>
            </aside>
        </div>
    }
</section>

@code {
    private ConversacionPlantillaFilters _filters = new();
    private List<ConversacionPlantillaDto> _templates = [];
    private ConversacionPlantillaDto _form = NewForm();
    private long _selectedId;
    private bool _loading;
    private bool _busy;
    private string _examplesText = string.Empty;
    private string _formEstadoMeta = "DRAFT";
    private string? _loadError;
    private string? _feedback;
    private string? _error;

    private const string MultiValueSeparator = "---";
    private const int MetaBodyMaxLength = 550;

    private static readonly string CobranzaTemplateBody = string.Join(Environment.NewLine,
    [
        "Estimado {{1}}",
        "Esperamos que se encuentre bien.",
        string.Empty,
        "Le recordamos que registra facturas pendientes. Para continuar brindandole el servicio, solicitamos realizar el pago o transferencia a la brevedad.",
        string.Empty,
        "Detalle de cuenta:",
        string.Empty,
        "{{2}}",
        string.Empty,
        "Si ya realizo el pago, envie el comprobante respondiendo este mensaje o a administracion@alfagestion.com.ar.",
        string.Empty,
        "Alfa Net Plus",
        "Soluciones Informaticas",
        "Marta Ester Saez",
        "whatsapp:+5491151480148",
        string.Empty,
        "Datos para transferencia:",
        "{{3}}",
        string.Empty,
        "Por favor enviar comprobante de pago por este chat."
    ]);

    private static readonly string CobranzaDetalleEjemplo = string.Join(Environment.NewLine,
    [
        "SALDO ACTUAL............................................: 1,520,963.04",
        "Cantidad de comprobantes pendientes de pago: 3",
        "Dias de atraso...............................................: 73",
        "Fecha comprobante mas antiguo....................: 01/03/2026"
    ]);

    private static readonly string CobranzaFormaPagoEjemplo = string.Join(Environment.NewLine,
    [
        "FORMA DE PAGO:",
        "TRANSFERENCIAS",
        "Alias",
        "alfa.net.plus.mp",
        "CVU",
        "0000003100085700504735",
        string.Empty,
        "ANTUNEZ ALBERTO FAVIO"
    ]);

    private string PreviewBody => RenderPreview(_form.CuerpoTexto, ParseExamples(_examplesText));
    private int BodyLength => _form.CuerpoTexto?.Length ?? 0;
    private bool IsBodyTooLong => BodyLength > MetaBodyMaxLength;
    private bool CanSaveDraft
        => !_busy
           && !string.IsNullOrWhiteSpace(_form.NombreVisible)
           && !string.IsNullOrWhiteSpace(_form.NombreMeta)
           && !string.IsNullOrWhiteSpace(_form.CuerpoTexto);

    protected override async Task OnInitializedAsync()
        => await LoadTemplatesAsync();

    private async Task LoadTemplatesAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            _templates = (await ConversacionesSvc.GetTemplatesAsync(_filters)).ToList();
            if (_selectedId > 0 && _templates.All(x => x.IdPlantilla != _selectedId))
                NuevaPlantilla();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSearchEnter(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await LoadTemplatesAsync();
    }

    private async Task SelectTemplateAsync(long idPlantilla)
    {
        _busy = true;
        _feedback = null;
        _error = null;
        try
        {
            var item = await ConversacionesSvc.GetTemplateAsync(idPlantilla);
            if (item is null)
            {
                _error = "La plantilla seleccionada ya no existe.";
                return;
            }

            _selectedId = item.IdPlantilla;
            _form = item;
            _examplesText = ExamplesToText(item.EjemplosVariablesJson);
            _formEstadoMeta = string.IsNullOrWhiteSpace(item.EstadoMeta) ? "DRAFT" : item.EstadoMeta;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void NuevaPlantilla()
    {
        _selectedId = 0;
        _form = NewForm();
        _examplesText = "Evelyn";
        _formEstadoMeta = "DRAFT";
        _feedback = null;
        _error = null;
    }

    private async Task AplicarModeloCobranzaAsync()
    {
        var model = NewCobranzaForm();
        var existing = _templates.FirstOrDefault(x =>
            string.Equals(x.NombreMeta, model.NombreMeta, StringComparison.OrdinalIgnoreCase)
            && string.Equals(x.Idioma, model.Idioma, StringComparison.OrdinalIgnoreCase));

        _selectedId = existing?.IdPlantilla ?? 0;
        model.IdPlantilla = _selectedId;
        _form = model;
        _examplesText = JoinMultilineValues(
        [
            "ANTU MALAL- ROLO GUAJARDO",
            CobranzaDetalleEjemplo,
            CobranzaFormaPagoEjemplo
        ]);
        _formEstadoMeta = "DRAFT";
        _feedback = _selectedId > 0
            ? "Modelo de cobranza cargado sobre la plantilla existente. Revisa y guarda los cambios."
            : "Modelo de cobranza cargado. Revisa los ejemplos y guarda el borrador.";
        _error = null;

        await Task.CompletedTask;
    }

    private void InsertVariable(string variable)
    {
        _form.CuerpoTexto = string.IsNullOrWhiteSpace(_form.CuerpoTexto)
            ? variable
            : $"{_form.CuerpoTexto}{Environment.NewLine}{variable}";
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _feedback = null;
        _error = null;
        try
        {
            var id = await ConversacionesSvc.SaveTemplateDraftAsync(new ConversacionPlantillaSaveRequest
            {
                IdPlantilla = _selectedId,
                NombreVisible = _form.NombreVisible,
                NombreMeta = _form.NombreMeta,
                Categoria = _form.Categoria,
                Idioma = _form.Idioma,
                EncabezadoTexto = _form.EncabezadoTexto,
                CuerpoTexto = _form.CuerpoTexto,
                PieTexto = _form.PieTexto,
                EjemplosVariablesJson = _examplesText,
                Activa = _form.Activa
            });

            _feedback = "Plantilla guardada.";
            await LoadTemplatesAsync();
            await SelectTemplateAsync(id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_selectedId <= 0)
            return;

        _busy = true;
        _feedback = null;
        _error = null;
        try
        {
            if (IsBodyTooLong)
            {
                _error = $"Meta permite hasta {MetaBodyMaxLength} caracteres en el cuerpo. Acortá el texto antes de enviarlo a aprobación.";
                return;
            }

            await ConversacionesSvc.SubmitTemplateForApprovalAsync(new ConversacionPlantillaSubmitRequest
            {
                IdPlantilla = _selectedId
            });

            _feedback = "Plantilla enviada a aprobación de Meta.";
            await LoadTemplatesAsync();
            await SelectTemplateAsync(_selectedId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SyncAsync()
    {
        if (_selectedId <= 0)
            return;

        _busy = true;
        _feedback = null;
        _error = null;
        try
        {
            await ConversacionesSvc.SyncTemplateStatusAsync(_selectedId);
            _feedback = "Estado sincronizado con Meta.";
            await LoadTemplatesAsync();
            await SelectTemplateAsync(_selectedId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static ConversacionPlantillaDto NewForm()
        => new()
        {
            Categoria = ConversacionPlantillaCategorias.Marketing,
            Idioma = "es_AR",
            Activa = true,
            EstadoMeta = "DRAFT",
            CuerpoTexto = "Hola {{1}}, te escribimos para continuar con la conversación pendiente. Respondé este mensaje y seguimos desde donde quedamos."
        };

    private static ConversacionPlantillaDto NewCobranzaForm()
        => new()
        {
            NombreVisible = "Recordatorio de deuda",
            NombreMeta = "recordatorio_deuda",
            Categoria = ConversacionPlantillaCategorias.Utility,
            Idioma = "es_AR",
            Activa = true,
            EstadoMeta = "DRAFT",
            CuerpoTexto = CobranzaTemplateBody
        };

    private static string RenderPreview(string text, IReadOnlyList<string> values)
    {
        var result = string.IsNullOrWhiteSpace(text) ? "Escribí el cuerpo de la plantilla." : text;
        for (var i = 0; i < values.Count; i++)
            result = result.Replace("{{" + (i + 1) + "}}", values[i], StringComparison.Ordinal);

        return result;
    }

    private static List<string> ParseExamples(string value)
        => ParseMultilineValues(value);

    private static string ExamplesToText(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return string.Empty;

        try
        {
            var values = System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? [];
            return JoinMultilineValues(values);
        }
        catch
        {
            return json;
        }
    }

    private static List<string> ParseMultilineValues(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        var normalized = value.Replace("\r\n", "\n").Replace('\r', '\n');
        if (normalized.Split('\n').Any(x => string.Equals(x.Trim(), MultiValueSeparator, StringComparison.Ordinal)))
        {
            var result = new List<string>();
            var current = new List<string>();

            foreach (var line in normalized.Split('\n'))
            {
                if (string.Equals(line.Trim(), MultiValueSeparator, StringComparison.Ordinal))
                {
                    AddBlock(result, current);
                    current.Clear();
                    continue;
                }

                current.Add(line);
            }

            AddBlock(result, current);
            return result;
        }

        return normalized
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => x.Length > 0)
            .ToList();
    }

    private static string JoinMultilineValues(IEnumerable<string> values)
        => string.Join($"{Environment.NewLine}{MultiValueSeparator}{Environment.NewLine}",
            values.Select(x => (x ?? string.Empty).Trim()).Where(x => x.Length > 0));

    private static void AddBlock(List<string> result, List<string> lines)
    {
        var block = string.Join(Environment.NewLine, lines).Trim();
        if (block.Length > 0)
            result.Add(block);
    }

    private static string GetMetaStatusLabel(string value)
        => (value ?? string.Empty).ToUpperInvariant() switch
        {
            "DRAFT" => "Borrador",
            "PENDING" => "Pendiente",
            "APPROVED" => "Aprobada",
            "REJECTED" => "Rechazada",
            "PAUSED" => "Pausada",
            "DISABLED" => "Deshabilitada",
            _ => DisplayOrFallback(value)
        };

    private static string GetCategoryLabel(string value)
        => string.Equals(value, ConversacionPlantillaCategorias.Utility, StringComparison.OrdinalIgnoreCase)
            ? "Utilidad"
            : "Marketing";

    private static string FormatDate(DateTime value)
        => value == DateTime.MinValue ? "--" : value.ToString("dd/MM HH:mm");

    private static string DisplayOrFallback(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Sin dato" : value.Trim();

    private static bool IsInitializationPending(string message)
        => message.Contains("CONV_PLANTILLAS", StringComparison.OrdinalIgnoreCase)
           || message.Contains("CONV_*", StringComparison.OrdinalIgnoreCase)
           || message.Contains("inicializado", StringComparison.OrdinalIgnoreCase);
}
