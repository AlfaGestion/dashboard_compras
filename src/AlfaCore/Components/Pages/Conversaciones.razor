@page "/conversaciones"
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@inject AlfaCore.Services.IConversacionesService ConversacionesSvc
@inject AlfaCore.Services.IContactosService ContactosSvc
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Conversaciones | Alfa Gestión</PageTitle>

<section class="page-grid conversations-page conversations-page--odoo">
    @if (_loadError is not null)
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Conversaciones</span>
            <h3>No fue posible cargar el módulo</h3>
            <p>@_loadError</p>
            @if (IsInitializationPending(_loadError))
            {
                <p>Pasos sugeridos: ejecutar <code>docs/conversaciones_modelo_inicial.sql</code> en la base activa, recargar la pantalla y revisar <code>AUX_ERR</code> si el incidente persiste.</p>
            }
        </div>
    }
    else
    {
        <section class="panel-card conversations-filters">
            <div class="conversations-canal">
                <button type="button"
                        class="conversations-filter-pill @(_canalActivo == "WHATSAPP" ? "is-active" : string.Empty)"
                        @onclick='() => ChangeCanalAsync("WHATSAPP")'>
                    <i class="bi bi-whatsapp"></i> WhatsApp
                </button>
                <button type="button"
                        class="conversations-filter-pill @(_canalActivo == "INTERNO" ? "is-active" : string.Empty)"
                        @onclick='() => ChangeCanalAsync("INTERNO")'>
                    <i class="bi bi-people-fill"></i> Chat interno
                </button>
                @if (_canalActivo == "INTERNO")
                {
                    <button type="button" class="btn btn--primary btn--sm" @onclick='() => _showNuevoHilo = true'>
                        <i class="bi bi-plus-circle-fill"></i> Nuevo hilo
                    </button>
                }
            </div>

            <div class="conversations-module-actions">
                <button type="button" class="btn btn--ghost btn--sm conversations-context-button" @onclick="ToggleContextPanel" disabled="@(_selectedConversation is null)" title="Contexto">
                    <i class="bi bi-layout-sidebar-inset-reverse"></i>
                    <span>Contexto</span>
                </button>
                <button type="button" class="btn btn--ghost btn--sm" @onclick="RecargarAsync" disabled="@(_loadingInbox || _loadingConversation)" title="Recargar">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <div class="conversations-filters__modes">
                @foreach (var mode in _modeOptions)
                {
                    <button type="button"
                            class="conversations-filter-pill @(mode.Value == _filters.Modo ? "is-active" : string.Empty)"
                            @onclick="() => ChangeModeAsync(mode.Value)">
                        @mode.Label
                    </button>
                }
            </div>

            <div class="conversations-filters__fields">
                <div class="field">
                    <label for="conv-search">Buscar</label>
                    <input id="conv-search"
                           type="search"
                           placeholder="Teléfono, cliente, contacto o resumen…"
                           value="@_filters.Search"
                           @oninput="HandleSearchInputAsync"
                           @onkeydown="HandleSearchEnter"
                           @onfocus="() => _showContactSuggestions = ShouldShowContactSuggestions" />
                    @if (_showContactSuggestions)
                    {
                        <div class="conversations-contact-suggest">
                            @if (_loadingContactSuggestions)
                            {
                                <div class="conversations-contact-suggest__state">
                                    <i class="bi bi-hourglass-split"></i>
                                    <span>Buscando contactos...</span>
                                </div>
                            }
                            else if (_conversationSuggestions.Count > 0 || _contactSuggestions.Count > 0)
                            {
                                @if (_conversationSuggestions.Count > 0)
                                {
                                    <div class="conversations-contact-suggest__header">
                                        <span>Coincidencias encontradas</span>
                                        <button type="button" class="btn btn--ghost btn--sm" @onclick="CloseContactSuggestions" title="Cerrar">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                    @foreach (var conversation in _conversationSuggestions)
                                    {
                                        <div class="conversations-contact-suggest__item">
                                            <div class="conversations-contact-suggest__main">
                                                <strong>@GetDisplayName(conversation)</strong>
                                                <small>@DisplayOrFallback(conversation.TelefonoWhatsApp)</small>
                                            </div>
                                            <div class="conversations-contact-suggest__actions">
                                                <button type="button" class="btn btn--primary btn--sm" @onclick="() => SelectConversationFromSuggestionAsync(conversation.IdConversacion)">
                                                    <i class="bi bi-whatsapp"></i> Conversar
                                                </button>
                                                @if (!HasUsableLinkedContact(conversation))
                                                {
                                                    <button type="button" class="btn btn--ghost btn--sm" @onclick="() => OpenNewContactFromConversation(conversation)">
                                                        <i class="bi bi-person-plus-fill"></i> Crear contacto
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                @if (_contactSuggestions.Count > 0)
                                {
                                    <div class="conversations-contact-suggest__header">
                                        <span>Contactos encontrados</span>
                                        @if (_conversationSuggestions.Count == 0)
                                        {
                                            <button type="button" class="btn btn--ghost btn--sm" @onclick="CloseContactSuggestions" title="Cerrar">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                    @foreach (var contact in _contactSuggestions)
                                    {
                                        var phone = GetContactPhone(contact);
                                        <div class="conversations-contact-suggest__item">
                                            <div class="conversations-contact-suggest__main">
                                                <strong>@contact.NombreApellido</strong>
                                                <span>@DisplayOrFallback(contact.Cargo)</span>
                                                <small>@DisplayOrFallback(phone, contact.Email)</small>
                                            </div>
                                            <div class="conversations-contact-suggest__actions">
                                                <button type="button" class="btn btn--primary btn--sm" disabled="@string.IsNullOrWhiteSpace(phone)" @onclick="() => OpenWhatsAppForContactAsync(contact)">
                                                    <i class="bi bi-whatsapp"></i> Conversar
                                                </button>
                                                <button type="button" class="btn btn--ghost btn--sm" @onclick="() => OpenContactEditor(contact)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                var conversationMatch = GetBestConversationMatchForSearch();
                                <div class="conversations-contact-suggest__state">
                                    <i class="bi bi-person-plus"></i>
                                    <span>No encontramos contactos con ese texto.</span>
                                </div>
                                @if (conversationMatch is not null)
                                {
                                    <div class="conversations-contact-suggest__item">
                                        <div class="conversations-contact-suggest__main">
                                            <strong>@GetDisplayName(conversationMatch)</strong>
                                            <span>@("Ya existe conversaci\u00f3n sin contacto asociado")</span>
                                            <small>@DisplayOrFallback(conversationMatch.TelefonoWhatsApp)</small>
                                        </div>
                                        <div class="conversations-contact-suggest__actions">
                                            <button type="button" class="btn btn--primary btn--sm" @onclick="() => SelectConversationFromSuggestionAsync(conversationMatch.IdConversacion)">
                                                <i class="bi bi-whatsapp"></i> Conversar
                                            </button>
                                            <button type="button" class="btn btn--primary btn--sm" @onclick="() => OpenNewContactFromConversation(conversationMatch)">
                                                <i class="bi bi-person-plus-fill"></i> Crear contacto vinculado
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button type="button" class="btn btn--primary btn--sm" @onclick="OpenNewContactFromSearch">
                                        <i class="bi bi-plus-circle-fill"></i> Crear contacto nuevo
                                    </button>
                                }
                            }
                        </div>
                    }
                    @if (CanCreateWhatsAppFromSearch)
                    {
                        <button type="button"
                                class="btn btn--primary btn--sm"
                                style="margin-top: .45rem; width: fit-content;"
                                @onclick="CreateWhatsAppFromSearchAsync"
                                disabled="@_busyAction">
                            <i class="bi bi-plus-circle-fill"></i> Crear conversación con este celular
                        </button>
                    }
                </div>

                <div class="field">
                    <label for="conv-my-tech">Mi técnico</label>
                    <select id="conv-my-tech" @bind="_filters.IdTecnicoActual">
                        <option value="">Todos</option>
                        @foreach (var tech in _technicians)
                        {
                            <option value="@tech.IdTecnico">@tech.Nombre (@tech.IdTecnico)</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label for="conv-state-filter">Estado</label>
                    <select id="conv-state-filter" @bind="_filters.CodigoEstado">
                        <option value="">Todos</option>
                        @foreach (var state in _states)
                        {
                            <option value="@state.CodigoEstado">@state.Descripcion</option>
                        }
                    </select>
                </div>

                <button type="button" class="btn btn--primary" @onclick="LoadInboxAsync" disabled="_loadingInbox">
                    <i class="bi bi-funnel"></i> Aplicar
                </button>
            </div>
        </section>

        @if (_showContextPanel)
        {
            <button type="button" class="conversations-panel-backdrop" aria-label="Cerrar paneles" @onclick="CloseFloatingPanels"></button>
        }

        <div class="conversations-layout">
            <aside class="panel-card conversations-list">
                <div class="conversations-list__header">
                    <div>
                        <h3 class="panel-card__title">Inbox</h3>
                        <p class="panel-card__subtitle">@_inbox.Count conversación(es)</p>
                    </div>
                </div>

                @if (_loadingInbox)
                {
                    <div class="loading">Cargando conversaciones…</div>
                }
                else if (_inbox.Count == 0)
                {
                    <div class="conversations-empty">
                        No hay conversaciones para los filtros seleccionados.
                    </div>
                }
                else
                {
                    <div class="conversations-list__items">
                        @foreach (var item in _inbox)
                        {
                            <button type="button"
                                    class="conversation-row @(item.IdConversacion == _selectedConversationId ? "is-selected" : string.Empty)"
                                    @onclick="() => SelectConversationAsync(item.IdConversacion)">
                                <div class="conversation-row__top">
                                    <span class="conversation-row__name">@GetDisplayName(item)</span>
                                    <span class="conversation-row__side">
                                        <span class="conversation-row__date">@FormatShortDate(item.FechaHoraUltimoMensaje)</span>
                                        @if (GetConversationNewCount(item.IdConversacion) > 0)
                                        {
                                            <span class="conversation-row__new-count">@GetConversationNewCount(item.IdConversacion)</span>
                                        }
                                    </span>
                                </div>
                                <div class="conversation-row__meta">
                                    <span>@item.TelefonoWhatsApp</span>
                                    @if (!string.IsNullOrWhiteSpace(item.TecnicoNombre))
                                    {
                                        <span>• @item.TecnicoNombre</span>
                                    }
                                </div>
                                <div class="conversation-row__badges">
                                    <span class="conversation-badge conversation-badge--state">@item.EstadoDescripcion</span>
                                    @if (!item.VentanaWhatsAppActiva)
                                    {
                                        <span class="conversation-badge">Ventana vencida</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.ClienteNombre))
                                    {
                                        <span class="conversation-badge">@item.ClienteNombre</span>
                                    }
                                </div>
                                <p class="conversation-row__summary">@item.ResumenUltimoMensaje</p>
                            </button>
                        }
                    </div>
                }
            </aside>

            <section class="panel-card conversations-chat">
                @if (_loadingConversation)
                {
                    <div class="loading">Cargando conversación…</div>
                }
                else if (_selectedConversation is null)
                {
                    <div class="conversations-empty conversations-empty--center">
                        Seleccioná una conversación del panel izquierdo para verla y responder.
                    </div>
                }
                else
                {
                    <header class="conversations-chat__header">
                        <div>
                            <h3 class="panel-card__title">@GetConversationHeader(_selectedConversation)</h3>
                            @if (_selectedConversation.Canal != "INTERNO" && !string.IsNullOrWhiteSpace(_selectedConversation.TelefonoWhatsApp))
                            {
                                <p class="panel-card__subtitle">@_selectedConversation.TelefonoWhatsApp</p>
                            }
                        </div>
                        <div class="conversations-chat__chips">
                            <span class="conversation-badge conversation-badge--state">@_selectedConversation.EstadoDescripcion</span>
                            @if (_selectedConversation.Canal == "WHATSAPP")
                            {
                                <span class="conversation-badge">@GetWhatsAppWindowLabel(_selectedConversation)</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_selectedConversation.TecnicoNombre))
                            {
                                <span class="conversation-badge">@_selectedConversation.TecnicoNombre</span>
                            }
                        </div>
                    </header>

                    @if (_conversationError is not null)
                    {
                        <div class="conversations-error">@_conversationError</div>
                    }

                    @if (IsWhatsAppWindowExpired)
                    {
                        <div class="conversations-window-banner">
                            <span>Esta conversación superó la ventana de 24 horas de WhatsApp.</span>
                            <button type="button" class="btn btn--primary btn--sm" @onclick="OpenTemplatePanel" disabled="@(!CanOpenTemplatePanel)">
                                <i class="bi bi-send-fill"></i> Enviar plantilla
                            </button>
                        </div>
                    }

                    <div class="conversations-thread-shell">
                    <div class="conversations-thread" @ref="_threadElement">
                        @if (_messages.Count == 0)
                        {
                            <div class="conversations-empty conversations-empty--center">
                                La conversación todavía no tiene mensajes registrados.
                            </div>
                        }
                        else
                        {
                            @foreach (var message in VisibleMessages)
                            {
                                @if (_firstNewMessageId == message.IdMensaje)
                                {
                                    <div class="message-new-divider">
                                        <span>Nuevo</span>
                                    </div>
                                }

                                <div class="message-row @(IsOutgoingMessage(message) ? "message-row--outgoing" : "message-row--incoming")">
                                    <div class="message-bubble-shell">
                                <article class="message-card @GetMessageClass(message)">
                                    <div class="message-card__meta">
                                        <span>@GetMessageAuthor(message)</span>
                                        <span>@message.FechaHora.ToString("dd/MM HH:mm")</span>
                                    </div>
                                    @if (ShouldShowMessageText(message))
                                    {
                                        <p class="message-card__text">@GetMessageDisplayText(message)</p>
                                        @if (IsUnsupportedMessage(message))
                                        {
                                            <div class="message-card__footer">
                                                <span>@GetUnsupportedMessageTrace(message)</span>
                                            </div>
                                        }
                                    }
                                    @if (message.TieneAdjuntos && _adjuntosPorMensaje.TryGetValue(message.IdMensaje, out var adjuntos))
                                    {
                                        <div class="message-attachments">
                                            @foreach (var adj in adjuntos)
                                            {
                                                @if (IsImageAttachment(adj))
                                                {
                                                    <div class="message-attachment message-attachment--image">
                                                        <button type="button"
                                                                class="attachment-preview-button"
                                                                title="Ver imagen"
                                                                @onclick="() => OpenAttachmentPreview(adj)">
                                                            <img src="@GetAttachmentUrl(adj)" alt="@GetAttachmentLabel(adj)" loading="lazy" />
                                                        </button>
                                                        @if (IsStickerAttachment(adj))
                                                        {
                                                            <button type="button"
                                                                    class="btn btn--ghost btn--sm"
                                                                    title="Guardar sticker en favoritos"
                                                                    @onclick="() => SaveStickerFavoriteAsync(adj.IdAdjunto)">
                                                                <i class="bi bi-star"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="attachment-name">@adj.NombreArchivo</span>
                                                        }
                                                    </div>
                                                }
                                                else if (IsAudioAttachment(adj))
                                                {
                                                    <div class="message-attachment message-attachment--audio">
                                                        <audio controls preload="metadata">
                                                            <source src="@GetAttachmentUrl(adj)" type="@GetAttachmentMime(adj)" />
                                                            Tu navegador no puede reproducir este audio.
                                                        </audio>
                                                        <button type="button"
                                                                class="attachment-menu-button"
                                                                title="Opciones"
                                                                @onclick="() => ToggleAttachmentMenu(adj.IdAdjunto)">
                                                            <i class="bi bi-three-dots-vertical"></i>
                                                        </button>
                                                        @if (_openAttachmentMenuId == adj.IdAdjunto)
                                                        {
                                                            <div class="attachment-menu">
                                                                <a href="@GetAttachmentDownloadUrl(adj)" download="@adj.NombreArchivo">Descargar audio</a>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="message-attachment message-attachment--file">
                                                        <a class="attachment-link" href="@GetAttachmentDownloadUrl(adj)" download="@adj.NombreArchivo">
                                                            <i class="bi bi-file-earmark-arrow-down"></i>
                                                            <span>@adj.NombreArchivo</span>
                                                            @if (adj.TamanoBytes > 0)
                                                            {
                                                                <span class="attachment-link__size">@FormatFileSize(adj.TamanoBytes)</span>
                                                            }
                                                        </a>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    <div class="message-card__footer">
                                        <span>@GetMessageTypeLabel(message)</span>
                                        @if (!string.IsNullOrWhiteSpace(message.EstadoEnvio))
                                        {
                                            <span>• @message.EstadoEnvio</span>
                                        }
                                    </div>
                                    @if (IsOutgoingMessage(message))
                                    {
                                        <div class="message-card__delivery">
                                            <span class="message-delivery @GetDeliveryClass(message.EstadoEnvio)" title="@GetDeliveryLabel(message.EstadoEnvio)">
                                                <i class="bi @GetDeliveryIcon(message.EstadoEnvio)"></i>
                                                <span>@GetDeliveryLabel(message.EstadoEnvio)</span>
                                            </span>
                                        </div>
                                    }
                                </article>
                                        @if (GetInlineReactions(message).Count > 0)
                                        {
                                            <div class="message-reactions">
                                                @foreach (var reaction in GetInlineReactions(message))
                                                {
                                                    <span title="@reaction">@reaction</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                    @if (CanReactToMessage(message) || CanQuoteMessage(message))
                                    {
                                        <div class="message-actions">
                                            @if (CanReactToMessage(message))
                                            {
                                                <button type="button"
                                                        class="btn btn--ghost btn--sm message-action-button"
                                                        title="Reaccionar"
                                                        @onclick="() => ToggleReactionPicker(message.IdMensaje)">
                                                    <i class="bi bi-emoji-smile"></i>
                                                </button>
                                            }
                                            @if (CanQuoteMessage(message))
                                            {
                                                <button type="button"
                                                        class="btn btn--ghost btn--sm message-action-button"
                                                        title="Responder citando"
                                                        @onclick="() => QuoteMessage(message)">
                                                    <i class="bi bi-reply-fill"></i>
                                                </button>
                                            }
                                            @if (_openReactionMessageId == message.IdMensaje)
                                            {
                                                <div class="message-reaction-picker">
                                                    @foreach (var emoji in QuickReactionEmojis)
                                                    {
                                                        <button type="button"
                                                                class="btn btn--ghost btn--sm message-reaction-picker__emoji"
                                                                title="Reaccionar @emoji"
                                                                @onclick="() => SendReactionAsync(message, emoji)"
                                                                disabled="@_busyAction">
                                                            @emoji
                                                        </button>
                                                    }
                                                    <button type="button"
                                                            class="btn btn--ghost btn--sm message-reaction-picker__emoji"
                                                            title="Mas emojis"
                                                            @onclick="OpenComposerEmojiPanel">
                                                        <i class="bi bi-plus-lg"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @if (ShouldShowLatestButton)
                    {
                        <button type="button" class="conversations-latest-button" @onclick="ScrollToLatestAsync">
                            @if (_newMessagesCount > 0)
                            {
                                <span>Nuevo</span>
                                <strong>@_newMessagesCount</strong>
                            }
                            else
                            {
                                <span>Ir al final</span>
                            }
                            <i class="bi bi-arrow-down"></i>
                        </button>
                    }
                    </div>

                    <div class="conversations-composer conversations-composer--support">
                        @if (!IsWhatsAppWindowExpired)
                        {
                            <div class="field">
                                <label for="conv-message">
                                    @(_selectedConversation.Canal == "INTERNO" ? "Mensaje al equipo" : "Responder")
                                </label>
                                @if (_quotedMessage is not null)
                                {
                                    <div class="quoted-reply">
                                        <span>Respondiendo a <strong>@GetMessageAuthor(_quotedMessage)</strong>:</span>
                                        <span class="quoted-reply__preview">@GetQuotePreview(_quotedMessage)</span>
                                        <button type="button"
                                                class="btn btn--ghost btn--sm quoted-reply__clear"
                                                title="Quitar cita"
                                                @onclick="ClearQuotedMessage">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                                <textarea id="conv-message"
                                          @ref="_replyTextArea"
                                          rows="2"
                                          placeholder="@(_selectedConversation.Canal == "INTERNO" ? "Escribí un mensaje para el equipo…" : "Escribí una respuesta para WhatsApp…")"
                                          @onfocus="MarkSelectedConversationAsRead"
                                          @bind="_replyText"></textarea>
                            </div>
                            @if (_pendingAttachments.Count > 0)
                            {
                                <div class="conversations-pending-list">
                                    @foreach (var pending in _pendingAttachments)
                                    {
                                        <div class="conversations-pending-attachment @(pending.HasError ? "has-error" : string.Empty)">
                                            <i class="bi @GetPendingAttachmentIcon(pending.TipoArchivo)"></i>
                                            <span title="@pending.NombreArchivo">@pending.NombreArchivo</span>
                                            @if (pending.HasError)
                                            {
                                                <i class="bi bi-exclamation-circle-fill" title="@pending.Error"></i>
                                            }
                                            <button type="button" class="btn btn--ghost btn--sm" @onclick="() => RemovePendingAttachment(pending.Id)" title="Quitar adjunto">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="conversations-composer__actions">
                                <button type="button" class="btn btn--primary" @onclick="SendReplyAsync" disabled="@(!_canSendReply)" title="@(HasPendingAttachmentError ? "Reintentar envio" : (_selectedConversation.Canal == "INTERNO" ? "Enviar" : "Enviar mensaje"))">
                                    <i class="bi @(HasPendingAttachmentError ? "bi-arrow-clockwise" : "bi-send-fill")"></i>
                                </button>
                                <button type="button"
                                        class="btn btn--ghost"
                                        title="Más opciones"
                                        @onclick="ToggleComposerTools">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                            @if (_showComposerTools)
                            {
                                <div class="panel-card conversations-tools-panel">
                                    <div class="conversations-composer__actions conversations-tools-panel__tabs">
                                        <button type="button" class="conversations-filter-pill @(_composerToolTab == ComposerToolTabs.Emojis ? "is-active" : string.Empty)" @onclick='() => _composerToolTab = ComposerToolTabs.Emojis'><i class="bi bi-emoji-smile"></i> Emojis</button>
                                        <button type="button" class="conversations-filter-pill @(_composerToolTab == ComposerToolTabs.Stickers ? "is-active" : string.Empty)" @onclick='() => _composerToolTab = ComposerToolTabs.Stickers'><i class="bi bi-star-fill"></i> Stickers</button>
                                        <button type="button" class="conversations-filter-pill @(_composerToolTab == ComposerToolTabs.Adjuntos ? "is-active" : string.Empty)" @onclick='() => _composerToolTab = ComposerToolTabs.Adjuntos'><i class="bi bi-paperclip"></i> Adjuntos</button>
                                    </div>
                                    @if (_composerToolTab == ComposerToolTabs.Emojis)
                                    {
                                        <input type="search" placeholder="Buscar emoji" value="@_emojiSearch" @oninput="HandleEmojiSearchInput" style="margin-bottom:.8rem;" />
                                        @foreach (var group in FilteredEmojiGroups)
                                        {
