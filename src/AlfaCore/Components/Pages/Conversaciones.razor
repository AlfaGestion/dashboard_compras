            ? $"[{GetMessageTypeLabel(message)}]"
            : message.Texto.Trim();

        return text.Length <= 90 ? text : $"{text[..90]}...";
    }

    private static string GetUnsupportedMessageTrace(ConversacionMensajeDto message)
    {
        var parts = new List<string>();
        var originalType = ExtractPayloadString(message.PayloadJson, "type");
        if (!string.IsNullOrWhiteSpace(originalType))
            parts.Add($"Tipo recibido: {originalType}");

        var metaReason = ExtractUnsupportedReason(message.PayloadJson);
        if (!string.IsNullOrWhiteSpace(metaReason))
            parts.Add(metaReason);

        if (!string.IsNullOrWhiteSpace(message.WhatsAppMessageId))
            parts.Add($"ID WhatsApp: {message.WhatsAppMessageId}");

        return parts.Count == 0
            ? "Sin detalle técnico disponible en el webhook."
            : string.Join(" · ", parts);
    }

    private static bool IsUnsupportedMessage(ConversacionMensajeDto message)
    {
        var text = (message.Texto ?? string.Empty).Trim();
        return string.Equals(message.MessageType, "UNKNOWN", StringComparison.OrdinalIgnoreCase)
               || string.Equals(message.MessageType, "UNSUPPORTED", StringComparison.OrdinalIgnoreCase)
               || string.Equals(text, "[unsupported]", StringComparison.OrdinalIgnoreCase)
               || string.Equals(text, "[unknown]", StringComparison.OrdinalIgnoreCase);
    }

    private static string ExtractPayloadString(string payloadJson, string propertyName)
    {
        if (string.IsNullOrWhiteSpace(payloadJson))
            return string.Empty;

        try
        {
            using var doc = JsonDocument.Parse(payloadJson);
            return doc.RootElement.TryGetProperty(propertyName, out var prop)
                ? prop.GetString() ?? string.Empty
                : string.Empty;
        }
        catch (JsonException)
        {
            return string.Empty;
        }
    }

    private static string ExtractUnsupportedReason(string payloadJson)
    {
        if (string.IsNullOrWhiteSpace(payloadJson))
            return string.Empty;

        try
        {
            using var doc = JsonDocument.Parse(payloadJson);
            if (!doc.RootElement.TryGetProperty("errors", out var errors) || errors.ValueKind != JsonValueKind.Array)
                return string.Empty;

            foreach (var error in errors.EnumerateArray())
            {
                var title = error.TryGetProperty("title", out var titleProp) ? titleProp.GetString() ?? string.Empty : string.Empty;
                var message = error.TryGetProperty("message", out var messageProp) ? messageProp.GetString() ?? string.Empty : string.Empty;
                var details = string.Empty;
                if (error.TryGetProperty("error_data", out var errorData) &&
                    errorData.TryGetProperty("details", out var detailsProp))
                {
                    details = detailsProp.GetString() ?? string.Empty;
                }

                var reason = FirstNonEmpty(details, message, title);
                if (!string.IsNullOrWhiteSpace(reason))
                    return $"Motivo: {reason}";
            }
        }
        catch (JsonException)
        {
            return string.Empty;
        }

        return string.Empty;
    }

