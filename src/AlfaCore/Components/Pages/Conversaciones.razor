    private static async Task AddFilesToPendingAttachmentsAsync(InputFileChangeEventArgs e, List<PendingAttachment> target, string? forcedType = null)
    {
        const long maxSize = 25 * 1024 * 1024;
        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size == 0)
                continue;

            await using var stream = file.OpenReadStream(maxSize);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);

            target.Add(new PendingAttachment
            {
                NombreArchivo = file.Name,
                MimeType = file.ContentType,
                TipoArchivo = string.IsNullOrWhiteSpace(forcedType) ? InferTipoArchivo(file.ContentType) : forcedType,
                Contenido = buffer.ToArray(),
                TamanoBytes = file.Size
            });
        }
    }

