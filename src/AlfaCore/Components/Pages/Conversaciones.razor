    private IReadOnlyList<string> GetInlineReactions(ConversacionMensajeDto message)
    {
        if (string.IsNullOrWhiteSpace(message.WhatsAppMessageId))
            return [];

        return _messages
            .Where(IsReactionMessage)
            .Where(x => string.Equals(x.WhatsAppReplyToMessageId, message.WhatsAppMessageId, StringComparison.OrdinalIgnoreCase))
            .Select(ExtractReactionEmoji)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .ToList();
    }

    private static string ExtractReactionEmoji(ConversacionMensajeDto message)
    {
        var text = message.Texto ?? string.Empty;
        foreach (var emoji in QuickReactionEmojis)
        {
            if (text.Contains(emoji, StringComparison.Ordinal))
                return emoji;
        }

        return string.Empty;
    }

