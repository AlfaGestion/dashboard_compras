        if (!IsPotentialPhone(_filters.Search))
        {
            _actionError = "Ingresá un número de celular válido para iniciar la conversación.";
            return;
        }

        _busyAction = true;
        _actionMessage = null;
        _actionError = null;

        try
        {
            var result = await ConversacionesSvc.CreateOrGetWhatsAppConversationAsync(new ConversacionCrearWhatsAppRequest
            {
                TelefonoWhatsApp = _filters.Search
            });

            _canalActivo = "WHATSAPP";
            _filters.Canal = "WHATSAPP";
            _filters.Search = result.TelefonoWhatsApp;

            await LoadInboxAsync();
            await SelectConversationAsync(result.IdConversacion);

            var action = result.Creada ? "Conversación creada" : "Conversación existente abierta";
            var contact = result.ContactoAsociado ? " y asociada al contacto encontrado." : ". No se encontró un contacto existente para asociar.";
            _actionMessage = $"{action} para {DisplayOrFallback(result.NombreVisible, result.TelefonoWhatsApp)}{contact}";
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _busyAction = false;
        }
    }

