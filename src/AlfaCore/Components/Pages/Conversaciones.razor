    private async Task StartRecordingAsync()
    {
        try
        {
            _recording = await JS.InvokeAsync<bool>("conversacionesAudio.startRecording");
        }
        catch (Exception ex)
        {
            _actionError = $"No se pudo iniciar la grabación: {ex.Message}";
        }
    }

    private async Task StopAndUploadAudioAsync()
    {
        _recording = false;
        _uploadingAudio = true;
        _actionMessage = null;
        _actionError = null;

        try
        {
            var recording = await JS.InvokeAsync<RecordedAudioPayload>("conversacionesAudio.stopRecordingPayload");
            if (string.IsNullOrWhiteSpace(recording.Base64)) return;

            var bytes = Convert.FromBase64String(recording.Base64);
            var mimeType = string.IsNullOrWhiteSpace(recording.MimeType) ? "audio/webm" : recording.MimeType;
            var fileName = $"audio_{DateTime.Now:yyyyMMdd_HHmmss}{InferAudioExtension(mimeType)}";

            _pendingAttachments.Add(new PendingAttachment
            {
                NombreArchivo = fileName,
                MimeType = mimeType,
                TipoArchivo = "AUDIO",
                Contenido = bytes,
                TamanoBytes = bytes.Length
            });

            _actionMessage = "Audio listo para enviar.";
        }
        catch (Exception ex)
        {
            _actionError = $"No se pudo preparar el audio: {ex.Message}";
        }
        finally
        {
            _uploadingAudio = false;
        }
    }

