    private static string GetAttachmentUrl(ConversacionAdjuntoDto adjunto)
        => $"/api/conversaciones/adjuntos/{adjunto.IdAdjunto}";

    private static string GetAttachmentDownloadUrl(ConversacionAdjuntoDto adjunto)
        => $"/api/conversaciones/adjuntos/{adjunto.IdAdjunto}?download=1";

    private static string GetFavoriteStickerUrl(ConversacionStickerFavoritoDto sticker)
        => $"/api/conversaciones/adjuntos/{sticker.IdAdjunto}";

    private static string GetAttachmentMime(ConversacionAdjuntoDto adjunto)
    {
        if (!string.IsNullOrWhiteSpace(adjunto.MimeType))
            return adjunto.MimeType;

        if (string.Equals(adjunto.TipoArchivo, "STICKER", StringComparison.OrdinalIgnoreCase))
            return "image/webp";

        if (string.Equals(adjunto.TipoArchivo, "AUDIO", StringComparison.OrdinalIgnoreCase))
            return "audio/webm";

        if (string.Equals(adjunto.TipoArchivo, "IMAGE", StringComparison.OrdinalIgnoreCase))
            return "image/jpeg";

        return "application/octet-stream";
    }

    private static string GetAttachmentLabel(ConversacionAdjuntoDto adjunto)
        => string.IsNullOrWhiteSpace(adjunto.NombreArchivo) ? "Adjunto" : adjunto.NombreArchivo;

    private static string GetPendingAttachmentIcon(string tipoArchivo)
        => tipoArchivo switch
        {
            "IMAGE" => "bi-image",
            "STICKER" => "bi-sticky-fill",
            "AUDIO" => "bi-mic-fill",
            "VIDEO" => "bi-camera-video-fill",
            _ => "bi-file-earmark"
        };

    private static bool IsOutgoingMessage(ConversacionMensajeDto message)
        => string.Equals(message.Direction, "SALIENTE", StringComparison.OrdinalIgnoreCase);

    private static string GetDeliveryIcon(string estadoEnvio)
    {
        var state = (estadoEnvio ?? string.Empty).Trim().ToUpperInvariant();
        if (state.Contains("ERROR", StringComparison.OrdinalIgnoreCase) || state.Contains("FALL", StringComparison.OrdinalIgnoreCase))
            return "bi-exclamation-circle-fill";
        if (state is "PENDIENTE" or "PENDIENTE_CONFIG")
            return "bi-clock";
        if (state is "ENVIADO_META" or "ENTREGADO" or "LEIDO")
            return "bi-check2-all";
        return "bi-check2";
    }

    private static string GetDeliveryClass(string estadoEnvio)
    {
        var state = (estadoEnvio ?? string.Empty).Trim().ToUpperInvariant();
        if (state.Contains("ERROR", StringComparison.OrdinalIgnoreCase) || state.Contains("FALL", StringComparison.OrdinalIgnoreCase))
            return "is-error";
        if (state is "PENDIENTE" or "PENDIENTE_CONFIG")
            return "is-pending";
        if (state is "LEIDO")
            return "is-read";
        return "is-sent";
    }

    private static string GetDeliveryLabel(string estadoEnvio)
    {
        var state = (estadoEnvio ?? string.Empty).Trim().ToUpperInvariant();
        return state switch
        {
            "PENDIENTE" => "Enviando",
            "PENDIENTE_CONFIG" => "Sin configuración",
            "ENVIADO_META" or "ENVIADO" => "Enviado",
            "ENTREGADO" => "Entregado",
            "LEIDO" => "Leido",
            _ when state.Contains("ERROR", StringComparison.OrdinalIgnoreCase) => "Error",
            _ => string.IsNullOrWhiteSpace(estadoEnvio) ? "Enviado" : estadoEnvio
        };
    }

    private static string InferAudioExtension(string mimeType)
    {
        var normalized = (mimeType ?? string.Empty).ToLowerInvariant();
        if (normalized.Contains("ogg", StringComparison.OrdinalIgnoreCase)) return ".ogg";
        if (normalized.Contains("mp4", StringComparison.OrdinalIgnoreCase)) return ".m4a";
        if (normalized.Contains("mpeg", StringComparison.OrdinalIgnoreCase)) return ".mp3";
        return ".webm";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{bytes / 1024} KB";

        return $"{bytes / (1024 * 1024)} MB";
    }

    public async ValueTask DisposeAsync()
    {
        CancelSearchDebounce();
        CancelContactSearch();

        if (_pollingCts is null)
            return;

        await _pollingCts.CancelAsync();

        if (_pollingTask is not null)
        {
            try
            {
                await _pollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _pollingCts.Dispose();
        _dotNetRef?.Dispose();
    }

