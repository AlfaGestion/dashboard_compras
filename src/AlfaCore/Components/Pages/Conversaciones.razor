@code {
    private readonly (string Value, string Label)[] _modeOptions =
    [
        ("todas", "Todas"),
        ("sin_asignar", "Sin asignar"),
        ("asignadas_a_mi", "Asignadas a mí"),
        ("pendientes", "Pendientes"),
        ("cerradas", "Cerradas")
    ];

    private string _canalActivo = "WHATSAPP";
    private bool _showNuevoHilo;
    private bool _showContextPanel;
    private bool _showTemplatePanel;
    private string _nuevoHiloNombre = string.Empty;
    private string _nuevoHiloTecnico = string.Empty;
    private string? _nuevoHiloError;
    private bool _recording;
    private bool _uploadingFile;
    private bool _uploadingAudio;
    private Dictionary<long, List<ConversacionAdjuntoDto>> _adjuntosPorMensaje = [];
    private List<ConversacionPlantillaDto> _availableTemplates = [];
    private long _selectedTemplateId;
    private bool _loadingTemplates;
    private string _templateValuesText = string.Empty;
    private string? _templateAutoNotice;
    private bool _uploadingTemplateFile;

    private ConversacionesInboxFilters _filters = new() { Canal = "WHATSAPP" };
    private List<ConversacionTecnicoOptionDto> _technicians = [];
    private List<ConversacionEstadoOptionDto> _states = [];
    private List<ConversacionInboxItemDto> _inbox = [];
    private List<ConversacionMensajeDto> _messages = [];
    private List<ContactoGridItemDto> _contactSuggestions = [];
    private List<ConversacionInboxItemDto> _conversationSuggestions = [];
    private readonly Dictionary<long, ConversationViewCache> _conversationCache = [];
    private readonly Dictionary<string, ConversationChannelCache> _channelCache = [];
    private ConversacionDetalleDto? _selectedConversation;
    private long? _selectedConversationId;
    private bool _loadingInbox;
    private bool _loadingConversation;
    private bool _busyAction;
    private string? _loadError;
    private string? _conversationError;
    private string? _actionMessage;
    private string? _actionError;
    private string _replyText = string.Empty;
    private string _internalNoteText = string.Empty;
    private string _assignmentTechnicianId = string.Empty;
    private string _statusCode = "ABIERTA";
    private ElementReference _threadElement;
    private DotNetObjectReference<Conversaciones>? _dotNetRef;
    private CancellationTokenSource? _pollingCts;
    private Task? _pollingTask;
    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _contactSearchCts;
    private long? _scrollHandlerConversationId;
    private long? _firstNewMessageId;
    private int _newMessagesCount;
    private readonly Dictionary<long, int> _newMessagesByConversation = [];
    private bool _showReturnToLatest;
    private bool _scrollThreadToBottomAfterRender;
    private long? _openAttachmentMenuId;
    private long? _openReactionMessageId;
    private ConversacionMensajeDto? _quotedMessage;
    private ConversacionAdjuntoDto? _previewAttachment;
    private ElementReference _replyTextArea;
    private long? _replyEnterHandlerConversationId;
    private List<PendingAttachment> _pendingAttachments = [];
    private List<PendingAttachment> _templatePendingAttachments = [];
    private List<ConversacionStickerFavoritoDto> _favoriteStickers = [];
    private bool _showComposerTools;
    private string _composerToolTab = ComposerToolTabs.Emojis;
    private string _emojiSearch = string.Empty;
    private bool _showContactSuggestions;
    private bool _loadingContactSuggestions;
    private long? _startupConversationId;

    private static readonly TimeSpan PollingInterval = TimeSpan.FromSeconds(5);
    private static readonly string[] QuickReactionEmojis = ["👍", "❤️", "😂", "😮", "😢", "🙏"];
    private static readonly IReadOnlyList<EmojiGroup> EmojiGroups =
    [
        new("Recientes", ["🤣", "🥰", "👉", "😭", "😔", "😁", "🧘", "😩", "💔", "🙏", "🕯️", "😌", "😂", "😍", "😅", "🤩"]),
        new("Emoticones y personas", ["😀", "😃", "😄", "😁", "😆", "🥹", "😅", "😂", "🤣", "🙂", "😊", "😇", "😉", "😌", "😍", "🥰", "😘", "😗", "😙", "😚", "😋", "😜", "😝", "😛", "🧐", "🤓", "😎", "🥳", "😴"]),
        new("Gestos", ["👍", "👎", "👌", "👏", "🙌", "🤝", "🙏", "💪", "✌️", "🤞", "👋", "🤙", "☝️", "👇", "👈", "👉"]),
        new("Corazones", ["❤️", "🧡", "💛", "💚", "💙", "💜", "🖤", "🤍", "🤎", "💔", "💕", "💞", "💓", "💗", "💖", "💘"]),
        new("Objetos", ["✅", "❌", "⚠️", "📌", "📎", "🧾", "📄", "💬", "📞", "📱", "💻", "🔧", "🛠️", "💡", "🚀", "⏰"])
    ];
    private IReadOnlyList<EmojiGroup> FilteredEmojiGroups
        => string.IsNullOrWhiteSpace(_emojiSearch)
            ? EmojiGroups
            : EmojiGroups
                .Select(x => x.Nombre.Contains(_emojiSearch.Trim(), StringComparison.OrdinalIgnoreCase)
                    ? x
                    : new EmojiGroup(x.Nombre, x.Emojis.Where(e => e.Contains(_emojiSearch.Trim(), StringComparison.OrdinalIgnoreCase)).ToArray()))
                .Where(x => x.Emojis.Count > 0)
                .ToList();

    private bool _canSendReply => !_busyAction && _selectedConversation is not null && !IsWhatsAppWindowExpired && (HasReplyText || _pendingAttachments.Count > 0);
    private bool HasReplyText => !string.IsNullOrWhiteSpace(_replyText);
    private bool HasPendingAttachmentError => _pendingAttachments.Any(x => x.HasError);
    private bool _canAddNote => !_busyAction && _selectedConversation is not null && !string.IsNullOrWhiteSpace(_internalNoteText);
    private bool CanCreateWhatsAppFromSearch => _canalActivo == "WHATSAPP" && !_busyAction && IsPotentialPhone(_filters.Search);
    private bool ShouldShowContactSuggestions => _canalActivo == "WHATSAPP" && _filters.Search.Trim().Length >= 2;
    private bool ShouldShowLatestButton => _showReturnToLatest || _newMessagesCount > 0;
    private bool IsWhatsAppConversation
        => _selectedConversation is not null
           && _selectedConversation.Canal == "WHATSAPP";
    private bool IsWhatsAppWindowExpired
        => _selectedConversation is not null
           && _selectedConversation.Canal == "WHATSAPP"
           && !_selectedConversation.VentanaWhatsAppActiva;
    private bool CanOpenTemplatePanel
        => !_loadingTemplates && IsWhatsAppConversation;
    private IReadOnlyList<ConversacionMensajeDto> VisibleMessages
        => _messages.Where(x => !IsReactionMessage(x)).ToList();
    private ConversacionPlantillaDto? SelectedTemplate
        => _availableTemplates.FirstOrDefault(x => x.IdPlantilla == _selectedTemplateId);
    private IReadOnlyList<string> TemplateValues => ParseTemplateValues(_templateValuesText);
    private bool CanSendTemplate
        => !_busyAction
           && _selectedConversation is not null
           && SelectedTemplate is not null
           && HasRequiredTemplateValues(SelectedTemplate, TemplateValues);

    protected override async Task OnInitializedAsync()
    {
        ApplyStartupQuery();
        await Task.WhenAll(LoadLookupsAsync(), LoadFavoriteStickersAsync());
        if (_loadError is null)
        {
            await LoadInboxAsync();
            if (_startupConversationId.HasValue)
                await SelectConversationAsync(_startupConversationId.Value);
        }

        StartPolling();
    }

    private void ApplyStartupQuery()
    {
        var query = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        if (query.TryGetValue("id", out var idRaw)
            && long.TryParse(idRaw.ToString(), out var id)
            && id > 0)
        {
            _startupConversationId = id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_selectedConversationId.HasValue && _scrollHandlerConversationId != _selectedConversationId)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _scrollHandlerConversationId = _selectedConversationId;

            try
            {
                _showReturnToLatest = await JS.InvokeAsync<bool>("conversacionesUi.watchThreadScroll", _threadElement, _dotNetRef);
            }
            catch
            {
                _showReturnToLatest = false;
            }
        }

        if (_selectedConversationId.HasValue && _replyEnterHandlerConversationId != _selectedConversationId)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _replyEnterHandlerConversationId = _selectedConversationId;

            try
            {
                await JS.InvokeVoidAsync("conversacionesUi.bindReplyEnter", _replyTextArea, _dotNetRef);
            }
            catch
            {
                _replyEnterHandlerConversationId = null;
            }
        }

        if (_scrollThreadToBottomAfterRender)
        {
            _scrollThreadToBottomAfterRender = false;
            await ScrollThreadToBottomAsync();
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            _technicians = (await ConversacionesSvc.GetTechniciansAsync()).ToList();
            _states = (await ConversacionesSvc.GetStatesAsync()).ToList();
            _statusCode = _states.FirstOrDefault()?.CodigoEstado ?? "ABIERTA";
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private async Task RecargarAsync()
    {
        _actionMessage = null;
        _actionError = null;
        await LoadInboxAsync();
        if (_selectedConversationId.HasValue)
            await SelectConversationAsync(_selectedConversationId.Value);
    }

    private async Task ChangeModeAsync(string mode)
    {
        _filters.Modo = mode;
        await LoadInboxAsync();
    }

    private async Task HandleSearchEnter(KeyboardEventArgs args)
    {
        if (args.Key != "Enter")
            return;

        CancelSearchDebounce();
        CancelContactSearch();
        _showContactSuggestions = false;
        if (CanCreateWhatsAppFromSearch)
            await CreateWhatsAppFromSearchAsync();
        else
            await LoadInboxAsync();
    }

