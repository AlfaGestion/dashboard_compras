    private static string GetDisplayName(ConversacionInboxItemDto item)
        => FirstNonEmpty(item.ContactoNombre, item.ClienteNombre, item.NombreVisible, item.TelefonoWhatsApp);

    private static string GetConversationHeader(ConversacionDetalleDto item)
        => FirstNonEmpty(item.ContactoNombre, item.ClienteNombre, item.NombreVisible, item.TelefonoWhatsApp);

    private static string GetWhatsAppWindowLabel(ConversacionDetalleDto item)
    {
        if (item.VentanaWhatsAppActiva && item.FechaHoraVencimientoVentanaWhatsApp is DateTime expiration)
            return $"Ventana activa hasta {expiration:dd/MM HH:mm}";

        return "Ventana vencida";
    }

    private static string GetTemplateStatusLabel(string value)
        => string.Equals(value, "APPROVED", StringComparison.OrdinalIgnoreCase)
            ? "Aprobada"
            : "Pendiente";

    private static int CountTemplateVariables(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return 0;

        var max = 0;
        foreach (System.Text.RegularExpressions.Match match in System.Text.RegularExpressions.Regex.Matches(text, @"\{\{\s*(\d+)\s*\}\}"))
        {
            if (int.TryParse(match.Groups[1].Value, out var index))
                max = Math.Max(max, index);
        }

        return max;
    }

    private static IReadOnlyList<string> ParseTemplateValues(string? text)
        => (text ?? string.Empty)
            .Split(["\r\n", "\n", "\r"], StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => x.Length > 0)
            .ToList();

    private static bool HasRequiredTemplateValues(ConversacionPlantillaDto template, IReadOnlyList<string> values)
        => values.Count >= CountTemplateVariables(template.CuerpoTexto);

    private static string GetTemplateDefaultVariableValue(ConversacionDetalleDto? conversation)
    {
        if (conversation is null)
            return "cliente";

        var visibleName = IsPhoneLike(conversation.NombreVisible, conversation.TelefonoWhatsApp)
            ? string.Empty
            : conversation.NombreVisible;

        return FirstNonEmpty(
            conversation.ContactoNombre,
            visibleName,
            conversation.ClienteNombre,
            conversation.TelefonoWhatsApp,
            "cliente");
    }

    private static bool IsPhoneLike(string? value, string? phone)
    {
        var normalizedValue = OnlyDigits(value);
        if (normalizedValue.Length < 6)
            return false;

        var normalizedPhone = OnlyDigits(phone);
        return normalizedValue == normalizedPhone
               || normalizedValue.Length == (value ?? string.Empty).Count(char.IsDigit);
    }

    private static string OnlyDigits(string? value)
        => new((value ?? string.Empty).Where(char.IsDigit).ToArray());

    private static string RenderTemplatePreview(ConversacionPlantillaDto template, IReadOnlyList<string> values)
    {
        var result = template.CuerpoTexto ?? string.Empty;
        for (var i = 0; i < values.Count; i++)
        {
            result = System.Text.RegularExpressions.Regex.Replace(
                result,
                @"\{\{\s*" + (i + 1).ToString() + @"\s*\}\}",
                values[i]);
        }

        return result;
    }

    private static string GetMessageAuthor(ConversacionMensajeDto message)
        => message.Direction switch
        {
            "ENTRANTE" => "Cliente / Contacto",
            "NOTA_INTERNA" => FirstNonEmpty(message.TecnicoAutorNombre, message.UsuarioAutor, "Nota interna"),
            _ => FirstNonEmpty(message.TecnicoAutorNombre, message.UsuarioAutor, "Equipo Alfa")
        };

    private static string GetMessageTypeLabel(ConversacionMensajeDto message)
        => message.Direction switch
        {
            "NOTA_INTERNA" => "Nota interna",
            _ => message.MessageType
        };

    private static string GetMessageClass(ConversacionMensajeDto message)
        => message.Direction switch
        {
            "ENTRANTE" => "message-card--incoming",
            "NOTA_INTERNA" => "message-card--internal",
            _ => "message-card--outgoing"
        };

    private static string DisplayOrFallback(params string?[] values)
        => FirstNonEmpty(values) is { Length: > 0 } found ? found : "Sin dato";

    private static string FirstNonEmpty(params string?[] values)
        => values.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x))?.Trim() ?? string.Empty;

    private static string FormatShortDate(DateTime value)
        => value == DateTime.MinValue ? "—" : value.ToString("dd/MM HH:mm");

    private static bool IsInitializationPending(string? message)
        => !string.IsNullOrWhiteSpace(message)
           && message.Contains("todavia no esta inicializado", StringComparison.OrdinalIgnoreCase);

    private static string InferTipoArchivo(string mimeType)
    {
        if (mimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase)) return "IMAGE";
        if (mimeType.StartsWith("audio/", StringComparison.OrdinalIgnoreCase)) return "AUDIO";
        if (mimeType.StartsWith("video/", StringComparison.OrdinalIgnoreCase)) return "VIDEO";
        return "DOCUMENT";
    }

    private static bool IsImageAttachment(ConversacionAdjuntoDto adjunto)
        => string.Equals(adjunto.TipoArchivo, "IMAGE", StringComparison.OrdinalIgnoreCase)
           || string.Equals(adjunto.TipoArchivo, "STICKER", StringComparison.OrdinalIgnoreCase)
           || adjunto.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

    private static bool IsStickerAttachment(ConversacionAdjuntoDto adjunto)
        => string.Equals(adjunto.TipoArchivo, "STICKER", StringComparison.OrdinalIgnoreCase)
           || string.Equals(adjunto.MimeType, "image/webp", StringComparison.OrdinalIgnoreCase);

    private static bool IsAudioAttachment(ConversacionAdjuntoDto adjunto)
        => string.Equals(adjunto.TipoArchivo, "AUDIO", StringComparison.OrdinalIgnoreCase)
           || adjunto.MimeType.StartsWith("audio/", StringComparison.OrdinalIgnoreCase);

    private bool ShouldShowMessageText(ConversacionMensajeDto message)
    {
        if (string.IsNullOrWhiteSpace(message.Texto))
            return false;

        if (message.MessageType is "IMAGE" or "AUDIO" or "VIDEO" or "DOCUMENT" or "STICKER")
        {
            if (message.TieneAdjuntos)
                return false;
        }

        return true;
    }

    private void ToggleAttachmentMenu(long idAdjunto)
        => _openAttachmentMenuId = _openAttachmentMenuId == idAdjunto ? null : idAdjunto;

    private void OpenAttachmentPreview(ConversacionAdjuntoDto adjunto)
    {
        _openAttachmentMenuId = null;
        _previewAttachment = adjunto;
    }

    private void CloseAttachmentPreview()
        => _previewAttachment = null;

    private static string GetAttachmentUrl(ConversacionAdjuntoDto adjunto)
        => $"/api/conversaciones/adjuntos/{adjunto.IdAdjunto}";

    private static string GetAttachmentDownloadUrl(ConversacionAdjuntoDto adjunto)
        => $"/api/conversaciones/adjuntos/{adjunto.IdAdjunto}?download=1";

    private static string GetAttachmentMime(ConversacionAdjuntoDto adjunto)
    {
        if (!string.IsNullOrWhiteSpace(adjunto.MimeType))
            return adjunto.MimeType;

        if (string.Equals(adjunto.TipoArchivo, "STICKER", StringComparison.OrdinalIgnoreCase))
            return "image/webp";

        if (string.Equals(adjunto.TipoArchivo, "AUDIO", StringComparison.OrdinalIgnoreCase))
            return "audio/webm";

        if (string.Equals(adjunto.TipoArchivo, "IMAGE", StringComparison.OrdinalIgnoreCase))
            return "image/jpeg";

        return "application/octet-stream";
    }

    private static string GetAttachmentLabel(ConversacionAdjuntoDto adjunto)
        => string.IsNullOrWhiteSpace(adjunto.NombreArchivo) ? "Adjunto" : adjunto.NombreArchivo;

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{bytes / 1024} KB";

        return $"{bytes / (1024 * 1024)} MB";
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollingCts is null)
            return;

        await _pollingCts.CancelAsync();

        if (_pollingTask is not null)
        {
            try
            {
                await _pollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _pollingCts.Dispose();
        _dotNetRef?.Dispose();
    }
}
