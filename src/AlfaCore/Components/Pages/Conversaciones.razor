    private async Task PrepareTemplateValuesAsync(bool forceReload = false)
    {
        _templateAutoNotice = null;
        if (SelectedTemplate is null)
        {
            _templateValuesText = string.Empty;
            return;
        }

        var required = CountTemplateVariables(SelectedTemplate.CuerpoTexto);
        if (required <= 0)
        {
            _templateValuesText = string.Empty;
            return;
        }

        var current = ParseTemplateValues(_templateValuesText).ToList();
        if (!forceReload && current.Count >= required)
            return;

        List<string> automaticValues = [];
        if (_selectedConversation is not null)
        {
            try
            {
                var autoValues = await ConversacionesSvc.GetTemplateAutoValuesAsync(_selectedConversation.IdConversacion, required);
                automaticValues = autoValues.Valores.ToList();
                _templateAutoNotice = string.IsNullOrWhiteSpace(autoValues.Observaciones)
                    ? "Variables cargadas automáticamente desde la conversación y la cuenta del cliente."
                    : autoValues.Observaciones;
            }
            catch (Exception ex)
            {
                _templateAutoNotice = $"No se pudieron cargar variables automáticas: {ex.Message}";
            }
        }

        var fallback = GetTemplateDefaultVariableValue(_selectedConversation);
        current = forceReload ? [] : current;

        while (current.Count < required)
        {
            if (automaticValues.Count > current.Count && !string.IsNullOrWhiteSpace(automaticValues[current.Count]))
                current.Add(automaticValues[current.Count]);
            else
                current.Add(current.Count == 0 ? fallback : $"Dato {current.Count + 1}");
        }

        _templateValuesText = JoinTemplateValuesForEditing(current.Take(required));
    }

    private async Task SendTemplateAsync()
    {
        if (_selectedConversation is null || SelectedTemplate is null)
            return;

        _busyAction = true;
        _actionMessage = null;
        _actionError = null;

        try
        {
            await ConversacionesSvc.SendTemplateMessageAsync(new ConversacionPlantillaSendRequest
            {
                IdConversacion = _selectedConversation.IdConversacion,
                IdPlantilla = SelectedTemplate.IdPlantilla,
                ValoresVariables = TemplateValues.ToList(),
                IdTecnicoAutor = _assignmentTechnicianId
            });

            var templateAttachmentsToSend = _templatePendingAttachments.ToList();
            var selectedConversationId = _selectedConversation.IdConversacion;
            var previewText = RenderTemplatePreview(SelectedTemplate, TemplateValues);

            _showTemplatePanel = false;
            ClearTemplateSelection();

            if (templateAttachmentsToSend.Count > 0)
                await UploadPendingAttachmentsAsync(templateAttachmentsToSend, RemoveTemplatePendingAttachment, allowExpiredWhatsAppWindow: true);

            await SelectConversationAsync(selectedConversationId);
            await LoadInboxAsync();
            _actionMessage = templateAttachmentsToSend.Count == 0
                ? $"Plantilla enviada correctamente: {previewText}"
                : $"Plantilla y adjunto(s) enviados correctamente: {previewText}";
        }
        catch (Exception ex)
        {
            var error = ex.Message;
            if (_selectedConversation is not null)
            {
                await SelectConversationAsync(_selectedConversation.IdConversacion);
                await LoadInboxAsync();
            }

            _actionError = error;
        }
        finally
        {
            _busyAction = false;
        }
    }

