            return null;

        return _inbox.FirstOrDefault(x =>
            MatchesConversationSearch(x, search));
    }

    private static bool MatchesConversationSearch(ConversacionInboxItemDto item, string search)
    {
        return ContainsSearch(item.NombreVisible, search)
               || ContainsSearch(item.ContactoNombre, search)
               || ContainsSearch(item.ClienteNombre, search)
               || ContainsSearch(item.TelefonoWhatsApp, search)
               || ContainsPhoneSearch(item.TelefonoWhatsApp, search)
               || ContainsSearch(item.ResumenUltimoMensaje, search);
    }

    private static bool HasUsableLinkedContact(ConversacionInboxItemDto conversation)
        => conversation.IdContacto.HasValue && !string.IsNullOrWhiteSpace(conversation.ContactoNombre);

    private static bool ContainsSearch(string? value, string search)
        => !string.IsNullOrWhiteSpace(value)
           && value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private static bool IsSameContactSuggestion(ConversacionInboxItemDto conversation, ContactoGridItemDto contact)
    {
        if (conversation.IdContacto == contact.Id)
            return true;

        var contactPhone = GetContactPhone(contact);
        return ContainsPhoneSearch(conversation.TelefonoWhatsApp, contactPhone)
               || ContainsPhoneSearch(contactPhone, conversation.TelefonoWhatsApp);
    }

    private static bool ContainsPhoneSearch(string? value, string search)
    {
        var phone = DigitsOnly(value);
        var query = DigitsOnly(search);
        return query.Length >= 4 && phone.Contains(query, StringComparison.Ordinal);
    }

    private static string DigitsOnly(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? string.Empty
            : new string(value.Where(char.IsDigit).ToArray());

    private static string GetContactPhone(ContactoGridItemDto contact)
        => FirstNonEmpty(contact.Celular, contact.Telefono);

