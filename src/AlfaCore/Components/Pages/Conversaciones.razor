    private int GetConversationNewCount(long idConversacion)
    {
        var count = _newMessagesByConversation.TryGetValue(idConversacion, out var storedCount) ? storedCount : 0;
        if (_selectedConversationId == idConversacion)
            count = Math.Max(count, _newMessagesCount);

        return count;
    }

    private void RestoreSelectedNewMessageMarker(long idConversacion)
    {
        if (!_newMessagesByConversation.TryGetValue(idConversacion, out var count) || count <= 0)
            return;

        var unreadMessages = _messages
            .Where(IsIncomingMessage)
            .OrderByDescending(x => x.IdMensaje)
            .Take(count)
            .ToList();

        if (unreadMessages.Count == 0)
            return;

        _firstNewMessageId = unreadMessages.Min(x => x.IdMensaje);
        _newMessagesCount = unreadMessages.Count;
        _showReturnToLatest = true;
    }

