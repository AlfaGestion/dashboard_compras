    private async Task SendReplyAsync()
    {
        if (_selectedConversation is null)
            return;

        var textToSend = _replyText.Trim();
        var attachmentsToSend = _pendingAttachments.ToList();
        if (string.IsNullOrWhiteSpace(textToSend) && attachmentsToSend.Count == 0)
            return;

        _busyAction = true;
        _actionMessage = null;
        _actionError = null;

        try
        {
            if (!string.IsNullOrWhiteSpace(textToSend))
            {
                await ConversacionesSvc.SendMessageAsync(new ConversacionSendMessageRequest
                {
                    IdConversacion = _selectedConversation.IdConversacion,
                    Texto = textToSend,
                    MessageType = "TEXT",
                    WhatsAppReplyToMessageId = _quotedMessage?.WhatsAppMessageId,
                    IdTecnicoAutor = _assignmentTechnicianId
                });

                _replyText = string.Empty;
                _quotedMessage = null;
            }

            await UploadPendingAttachmentsAsync(attachmentsToSend, RemovePendingAttachment);

            _actionMessage = "Mensaje registrado correctamente.";
            await SelectConversationAsync(_selectedConversation.IdConversacion);
            await LoadInboxAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
            foreach (var pending in _pendingAttachments)
                pending.Error ??= "No se pudo enviar. Reintentá con el botón de enviar.";
        }
        finally
        {
            _busyAction = false;
        }
    }

