@page "/conversaciones"
@inject AlfaCore.Services.IConversacionesService ConversacionesSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Conversaciones | Alfa Gestión</PageTitle>

<section class="page-grid conversations-page conversations-page--odoo">
    @if (_loadError is not null)
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Conversaciones</span>
            <h3>No fue posible cargar el módulo</h3>
            <p>@_loadError</p>
            @if (IsInitializationPending(_loadError))
            {
                <p>Pasos sugeridos: ejecutar <code>docs/conversaciones_modelo_inicial.sql</code> en la base activa, recargar la pantalla y revisar <code>AUX_ERR</code> si el incidente persiste.</p>
            }
        </div>
    }
    else
    {
        <section class="panel-card conversations-filters">
            <div class="conversations-canal">
                <button type="button"
                        class="conversations-filter-pill @(_canalActivo == "WHATSAPP" ? "is-active" : string.Empty)"
                        @onclick='() => ChangeCanalAsync("WHATSAPP")'>
                    <i class="bi bi-whatsapp"></i> WhatsApp
                </button>
                <button type="button"
                        class="conversations-filter-pill @(_canalActivo == "INTERNO" ? "is-active" : string.Empty)"
                        @onclick='() => ChangeCanalAsync("INTERNO")'>
                    <i class="bi bi-people-fill"></i> Chat interno
                </button>
                @if (_canalActivo == "INTERNO")
                {
                    <button type="button" class="btn btn--primary btn--sm" @onclick='() => _showNuevoHilo = true'>
                        <i class="bi bi-plus-circle-fill"></i> Nuevo hilo
                    </button>
                }
            </div>

            <div class="conversations-module-actions">
                <a class="btn btn--ghost btn--sm" href="/conversaciones/configuracion" title="Configuración">
                    <i class="bi bi-sliders"></i>
                </a>
                <a class="btn btn--ghost btn--sm" href="/conversaciones/plantillas" title="Plantillas">
                    <i class="bi bi-chat-square-text-fill"></i>
                </a>
                <button type="button" class="btn btn--ghost btn--sm" @onclick="ToggleContextPanel" disabled="@(_selectedConversation is null)" title="Contexto">
                    <i class="bi bi-layout-sidebar-inset-reverse"></i>
                </button>
                <button type="button" class="btn btn--ghost btn--sm" @onclick="RecargarAsync" disabled="_loadingInbox || _loadingConversation" title="Recargar">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <div class="conversations-filters__modes">
                @foreach (var mode in _modeOptions)
                {
                    <button type="button"
                            class="conversations-filter-pill @(mode.Value == _filters.Modo ? "is-active" : string.Empty)"
                            @onclick="() => ChangeModeAsync(mode.Value)">
                        @mode.Label
                    </button>
                }
            </div>

            <div class="conversations-filters__fields">
                <div class="field">
                    <label for="conv-search">Buscar</label>
                    <input id="conv-search"
                           type="search"
                           placeholder="Teléfono, cliente, contacto o resumen…"
                           @bind="_filters.Search"
                           @bind:event="oninput"
                           @onkeydown="HandleSearchEnter" />
                </div>

                <div class="field">
                    <label for="conv-my-tech">Mi técnico</label>
                    <select id="conv-my-tech" @bind="_filters.IdTecnicoActual">
                        <option value="">Todos</option>
                        @foreach (var tech in _technicians)
                        {
                            <option value="@tech.IdTecnico">@tech.Nombre (@tech.IdTecnico)</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label for="conv-state-filter">Estado</label>
                    <select id="conv-state-filter" @bind="_filters.CodigoEstado">
                        <option value="">Todos</option>
                        @foreach (var state in _states)
                        {
                            <option value="@state.CodigoEstado">@state.Descripcion</option>
                        }
                    </select>
                </div>

                <button type="button" class="btn btn--primary" @onclick="LoadInboxAsync" disabled="_loadingInbox">
                    <i class="bi bi-funnel"></i> Aplicar
                </button>
            </div>
        </section>

        @if (_showContextPanel)
        {
            <button type="button" class="conversations-panel-backdrop" aria-label="Cerrar paneles" @onclick="CloseFloatingPanels"></button>
        }

        <div class="conversations-layout">
            <aside class="panel-card conversations-list">
                <div class="conversations-list__header">
                    <div>
                        <h3 class="panel-card__title">Inbox</h3>
                        <p class="panel-card__subtitle">@_inbox.Count conversación(es)</p>
                    </div>
                </div>

                @if (_loadingInbox)
                {
                    <div class="loading">Cargando conversaciones…</div>
                }
                else if (_inbox.Count == 0)
                {
                    <div class="conversations-empty">
                        No hay conversaciones para los filtros seleccionados.
                    </div>
                }
                else
                {
                    <div class="conversations-list__items">
                        @foreach (var item in _inbox)
                        {
                            <button type="button"
                                    class="conversation-row @(item.IdConversacion == _selectedConversationId ? "is-selected" : string.Empty)"
                                    @onclick="() => SelectConversationAsync(item.IdConversacion)">
                                <div class="conversation-row__top">
                                    <span class="conversation-row__name">@GetDisplayName(item)</span>
                                    <span class="conversation-row__date">@FormatShortDate(item.FechaHoraUltimoMensaje)</span>
                                </div>
                                <div class="conversation-row__meta">
                                    <span>@item.TelefonoWhatsApp</span>
                                    @if (!string.IsNullOrWhiteSpace(item.TecnicoNombre))
                                    {
                                        <span>• @item.TecnicoNombre</span>
                                    }
                                </div>
                                <div class="conversation-row__badges">
                                    <span class="conversation-badge conversation-badge--state">@item.EstadoDescripcion</span>
                                    @if (!item.VentanaWhatsAppActiva)
                                    {
                                        <span class="conversation-badge">Ventana vencida</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.ClienteNombre))
                                    {
                                        <span class="conversation-badge">@item.ClienteNombre</span>
                                    }
                                </div>
                                <p class="conversation-row__summary">@item.ResumenUltimoMensaje</p>
                            </button>
                        }
                    </div>
                }
            </aside>

            <section class="panel-card conversations-chat">
                @if (_loadingConversation)
                {
                    <div class="loading">Cargando conversación…</div>
                }
                else if (_selectedConversation is null)
                {
                    <div class="conversations-empty conversations-empty--center">
                        Seleccioná una conversación del panel izquierdo para verla y responder.
                    </div>
                }
                else
                {
                    <header class="conversations-chat__header">
                        <div>
                            <h3 class="panel-card__title">@GetConversationHeader(_selectedConversation)</h3>
                            @if (_selectedConversation.Canal != "INTERNO" && !string.IsNullOrWhiteSpace(_selectedConversation.TelefonoWhatsApp))
                            {
                                <p class="panel-card__subtitle">@_selectedConversation.TelefonoWhatsApp</p>
                            }
                        </div>
                        <div class="conversations-chat__chips">
                            <span class="conversation-badge conversation-badge--state">@_selectedConversation.EstadoDescripcion</span>
                            @if (_selectedConversation.Canal == "WHATSAPP")
                            {
                                <span class="conversation-badge">@GetWhatsAppWindowLabel(_selectedConversation)</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_selectedConversation.TecnicoNombre))
                            {
                                <span class="conversation-badge">@_selectedConversation.TecnicoNombre</span>
                            }
                        </div>
                    </header>

                    @if (_conversationError is not null)
                    {
                        <div class="conversations-error">@_conversationError</div>
                    }

                    @if (IsWhatsAppWindowExpired)
                    {
                        <div class="conversations-window-banner">
                            <span>Esta conversación superó la ventana de 24 horas de WhatsApp.</span>
                            <button type="button" class="btn btn--primary btn--sm" @onclick="OpenTemplatePanel" disabled="@(_loadingTemplates || _availableTemplates.Count == 0)">
                                <i class="bi bi-send-fill"></i> Enviar plantilla
                            </button>
                        </div>
                    }

                    <div class="conversations-thread-shell">
                    <div class="conversations-thread" @ref="_threadElement">
                        @if (_messages.Count == 0)
                        {
                            <div class="conversations-empty conversations-empty--center">
                                La conversación todavía no tiene mensajes registrados.
                            </div>
                        }
                        else
                        {
                            @foreach (var message in _messages)
                            {
                                @if (_firstNewMessageId == message.IdMensaje)
                                {
                                    <div class="message-new-divider">
                                        <span>Nuevo</span>
                                    </div>
                                }

                                <article class="message-card @GetMessageClass(message)">
                                    <div class="message-card__meta">
                                        <span>@GetMessageAuthor(message)</span>
                                        <span>@message.FechaHora.ToString("dd/MM HH:mm")</span>
                                    </div>
                                    @if (ShouldShowMessageText(message))
                                    {
                                        <p class="message-card__text">@message.Texto</p>
                                    }
                                    @if (message.TieneAdjuntos && _adjuntosPorMensaje.TryGetValue(message.IdMensaje, out var adjuntos))
                                    {
                                        <div class="message-attachments">
                                            @foreach (var adj in adjuntos)
                                            {
                                                @if (IsImageAttachment(adj))
                                                {
                                                    <div class="message-attachment message-attachment--image">
                                                        <button type="button"
                                                                class="attachment-preview-button"
                                                                title="Ver imagen"
                                                                @onclick="() => OpenAttachmentPreview(adj)">
                                                            <img src="@GetAttachmentUrl(adj)" alt="@GetAttachmentLabel(adj)" loading="lazy" />
                                                        </button>
                                                        @if (!IsStickerAttachment(adj))
                                                        {
                                                            <span class="attachment-name">@adj.NombreArchivo</span>
                                                        }
                                                    </div>
                                                }
                                                else if (IsAudioAttachment(adj))
                                                {
                                                    <div class="message-attachment message-attachment--audio">
                                                        <audio controls preload="metadata">
                                                            <source src="@GetAttachmentUrl(adj)" type="@GetAttachmentMime(adj)" />
                                                            Tu navegador no puede reproducir este audio.
                                                        </audio>
                                                        <button type="button"
                                                                class="attachment-menu-button"
                                                                title="Opciones"
                                                                @onclick="() => ToggleAttachmentMenu(adj.IdAdjunto)">
                                                            <i class="bi bi-three-dots-vertical"></i>
                                                        </button>
                                                        @if (_openAttachmentMenuId == adj.IdAdjunto)
                                                        {
                                                            <div class="attachment-menu">
                                                                <a href="@GetAttachmentDownloadUrl(adj)" download="@adj.NombreArchivo">Descargar audio</a>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="message-attachment message-attachment--file">
                                                        <a class="attachment-link" href="@GetAttachmentDownloadUrl(adj)" download="@adj.NombreArchivo">
                                                            <i class="bi bi-file-earmark-arrow-down"></i>
                                                            <span>@adj.NombreArchivo</span>
                                                            @if (adj.TamanoBytes > 0)
                                                            {
                                                                <span class="attachment-link__size">@FormatFileSize(adj.TamanoBytes)</span>
                                                            }
                                                        </a>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    <div class="message-card__footer">
                                        <span>@GetMessageTypeLabel(message)</span>
                                        @if (!string.IsNullOrWhiteSpace(message.EstadoEnvio))
                                        {
                                            <span>• @message.EstadoEnvio</span>
                                        }
                                    </div>
                                </article>
                            }
                        }
                    </div>

                    @if (ShouldShowLatestButton)
                    {
                        <button type="button" class="conversations-latest-button" @onclick="ScrollToLatestAsync">
                            @if (_newMessagesCount > 0)
                            {
                                <span>Nuevo</span>
                                <strong>@_newMessagesCount</strong>
                            }
                            else
                            {
                                <span>Ir al final</span>
                            }
                            <i class="bi bi-arrow-down"></i>
                        </button>
                    }
                    </div>

                    <div class="conversations-composer conversations-composer--support">
                        @if (!IsWhatsAppWindowExpired)
                        {
                            <div class="field">
                                <label for="conv-message">
                                    @(_selectedConversation.Canal == "INTERNO" ? "Mensaje al equipo" : "Responder")
                                </label>
                                <textarea id="conv-message"
                                          rows="2"
                                          placeholder="@(_selectedConversation.Canal == "INTERNO" ? "Escribí un mensaje para el equipo…" : "Escribí una respuesta para WhatsApp…")"
                                          @bind="_replyText"></textarea>
                            </div>
                            <div class="conversations-composer__actions">
                                <button type="button" class="btn btn--primary" @onclick="SendReplyAsync" disabled="@(!_canSendReply)">
                                    <i class="bi bi-send-fill"></i>
                                    @(_selectedConversation.Canal == "INTERNO" ? "Enviar" : "Enviar mensaje")
                                </button>
                                <label class="btn btn--ghost" title="Adjuntar archivo" style="cursor:pointer">
                                    <i class="bi @(_uploadingFile ? "bi-hourglass-split" : "bi-paperclip")"></i>
                                    <InputFile OnChange="HandleFileSelectedAsync" style="display:none"
                                               accept="image/*,audio/*,video/*,application/pdf,.doc,.docx,.xls,.xlsx,.zip,.rar" />
                                </label>
                                <button type="button"
                                        class="btn btn--ghost @(_recording ? "is-recording" : string.Empty)"
                                        @onclick="ToggleRecordingAsync"
                                        title="@(_recording ? "Detener y enviar audio" : "Grabar mensaje de voz")"
                                        disabled="@_uploadingAudio">
                                    <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-mic-fill")"></i>
                                </button>
                            </div>
                        }

                        <div class="field">
                            <label for="conv-note">Nota interna</label>
                            <textarea id="conv-note"
                                      rows="1"
                                      placeholder="Escribí una nota interna visible solo para el equipo…"
                                      @bind="_internalNoteText"></textarea>
                        </div>
                        <div class="conversations-composer__actions">
                            <button type="button" class="btn btn--ghost" @onclick="AddInternalNoteAsync" disabled="@(!_canAddNote)">
                                <i class="bi bi-journal-text"></i> Guardar nota
                            </button>
                        </div>
                    </div>
                }
            </section>

            <aside class="panel-card conversations-context conversations-context-drawer @(_showContextPanel ? "is-open" : string.Empty)">
                <button type="button" class="conversations-drawer-close" title="Cerrar contexto" @onclick="ToggleContextPanel">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="conversations-context__section">
                    <h3 class="panel-card__title">Contexto</h3>
                    <p class="panel-card__subtitle">Cliente, contacto y gestión</p>
                </div>

                @if (_selectedConversation is null)
                {
                    <div class="conversations-empty">
                        Seleccioná una conversación para ver sus datos.
                    </div>
                }
                else
                {
                    @if (_selectedConversation.Canal != "INTERNO")
                    {
                        <div class="context-card">
                            <span class="context-card__label">Cliente</span>
                            <strong>@DisplayOrFallback(_selectedConversation.ClienteNombre)</strong>
                            <span class="context-card__muted">@DisplayOrFallback(_selectedConversation.ClienteCodigo)</span>
                        </div>

                        <div class="context-card">
                            <span class="context-card__label">Contacto</span>
                            <strong>@DisplayOrFallback(_selectedConversation.ContactoNombre)</strong>
                            <span class="context-card__muted">@DisplayOrFallback(_selectedConversation.ContactoCargo)</span>
                            <span class="context-card__muted">@DisplayOrFallback(_selectedConversation.ContactoCelular, _selectedConversation.ContactoTelefono)</span>
                            <span class="context-card__muted">@DisplayOrFallback(_selectedConversation.ContactoEmail)</span>
                        </div>
                    }

                    <div class="conversations-context__section">
                        <h4 class="panel-card__title">Asignación</h4>
                        <div class="field">
                            <label for="conv-tech">Técnico</label>
                            <select id="conv-tech" @bind="_assignmentTechnicianId">
                                <option value="">Sin asignar</option>
                                @foreach (var tech in _technicians)
                                {
                                    <option value="@tech.IdTecnico">@tech.Nombre (@tech.IdTecnico)</option>
                                }
                            </select>
                        </div>
                        <button type="button" class="btn btn--ghost" @onclick="AssignAsync" disabled="_busyAction">
                            <i class="bi bi-person-check-fill"></i> Guardar asignación
                        </button>
                    </div>

                    <div class="conversations-context__section">
                        <h4 class="panel-card__title">Estado</h4>
                        <div class="field">
                            <label for="conv-state">Estado actual</label>
                            <select id="conv-state" @bind="_statusCode">
                                @foreach (var state in _states)
                                {
                                    <option value="@state.CodigoEstado">@state.Descripcion</option>
                                }
                            </select>
                        </div>
                        <div class="conversations-context__actions">
                            <button type="button" class="btn btn--ghost" @onclick="SaveStatusAsync" disabled="_busyAction">
                                <i class="bi bi-check2-circle"></i> Guardar estado
                            </button>
                            <button type="button" class="btn btn--ghost" @onclick="CloseConversationAsync" disabled="_busyAction">
                                <i class="bi bi-lock-fill"></i> Cerrar conversación
                            </button>
                        </div>
                    </div>

                    @if (_actionMessage is not null)
                    {
                        <div class="conversations-inline conversations-inline--ok">@_actionMessage</div>
                    }
                    @if (_actionError is not null)
                    {
                        <div class="conversations-inline conversations-inline--error">@_actionError</div>
                    }
                }
            </aside>
        </div>
    }
</section>

@if (_showTemplatePanel && IsWhatsAppWindowExpired)
{
    <div class="modal-overlay conversations-template-modal" @onclick="CloseTemplatePanel">
        <div class="modal-card conversations-template-modal__card" @onclick:stopPropagation>
            <header class="conversations-template-modal__header">
                <div>
                    <h3 class="modal-card__title">Enviar plantilla de WhatsApp</h3>
                    <p>La conversación queda visible detrás para revisar el contexto antes de enviar.</p>
                </div>
                <button type="button" class="btn btn--ghost btn--sm" @onclick="CloseTemplatePanel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="conversations-template-modal__body">
                <div class="conversations-template-modal__form">
                    <div class="field">
                        <label for="conv-template-modal">Plantilla</label>
                        <select id="conv-template-modal" @bind="_selectedTemplateId" @bind:after="OnTemplateChangedAsync" disabled="@(_loadingTemplates || _availableTemplates.Count == 0)">
                            @if (_loadingTemplates)
                            {
                                <option value="0">Cargando plantillas...</option>
                            }
                            else if (_availableTemplates.Count == 0)
                            {
                                <option value="0">No hay plantillas aprobadas</option>
                            }
                            else
                            {
                                <option value="0">Seleccioná una plantilla</option>
                                @foreach (var template in _availableTemplates)
                                {
                                    <option value="@template.IdPlantilla">@template.NombreVisible (@GetTemplateStatusLabel(template.EstadoMeta))</option>
                                }
                            }
                        </select>
                    </div>

                    @if (SelectedTemplate is not null && CountTemplateVariables(SelectedTemplate.CuerpoTexto) > 0)
                    {
                        <div class="field">
                            <label for="conv-template-values-modal">Variables editables</label>
                            <textarea id="conv-template-values-modal"
                                      rows="4"
                                      placeholder="Un valor por línea"
                                      @bind="_templateValuesText"></textarea>
                        </div>
                    }

                    <div class="context-card">
                        <span class="context-card__label">Destino</span>
                        <strong>@DisplayOrFallback(_selectedConversation?.NombreVisible, _selectedConversation?.ContactoNombre)</strong>
                        <span class="context-card__muted">@DisplayOrFallback(_selectedConversation?.TelefonoWhatsApp)</span>
                    </div>
                </div>

                <div class="conversations-template-phone-preview">
                    <span class="context-card__label">Vista previa</span>
                    <article class="message-card message-card--outgoing">
                        @if (SelectedTemplate is null)
                        {
                            <p class="message-card__text">Seleccioná una plantilla para ver el mensaje.</p>
                        }
                        else
                        {
                            <strong>@SelectedTemplate.NombreVisible</strong>
                            <p class="message-card__text">@RenderTemplatePreview(SelectedTemplate, TemplateValues)</p>
                        }
                    </article>
                </div>
            </div>

            <div class="modal-card__actions">
                <button type="button" class="btn btn--primary" @onclick="SendTemplateAsync" disabled="@(!CanSendTemplate)">
                    <i class="bi bi-send-fill"></i> Enviar mensaje
                </button>
                <button type="button" class="btn btn--ghost" @onclick="CloseTemplatePanel">
                    Cerrar
                </button>
            </div>
        </div>
    </div>
}

@if (_showNuevoHilo)
{
    <div class="modal-overlay" @onclick="CerrarNuevoHilo">
        <div class="modal-card" @onclick:stopPropagation>
            <h3 class="modal-card__title">Nuevo hilo interno</h3>
            <div class="field">
                <label for="hilo-nombre">Nombre del hilo</label>
                <input id="hilo-nombre" type="text" @bind="_nuevoHiloNombre"
                       placeholder="Ej: Revisión instalación cliente X…" />
            </div>
            <div class="field">
                <label for="hilo-tecnico">Asignar a técnico (opcional)</label>
                <select id="hilo-tecnico" @bind="_nuevoHiloTecnico">
                    <option value="">Sin asignar</option>
                    @foreach (var tech in _technicians)
                    {
                        <option value="@tech.IdTecnico">@tech.Nombre (@tech.IdTecnico)</option>
                    }
                </select>
            </div>
            @if (_nuevoHiloError is not null)
            {
                <div class="conversations-error">@_nuevoHiloError</div>
            }
            <div class="modal-card__actions">
                <button type="button" class="btn btn--primary" @onclick="CrearHiloInternoAsync" disabled="_busyAction">
                    <i class="bi bi-plus-circle-fill"></i> Crear hilo
                </button>
                <button type="button" class="btn btn--ghost" @onclick="CerrarNuevoHilo">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
}

@if (_previewAttachment is not null)
{
    <div class="attachment-preview-overlay" @onclick="CloseAttachmentPreview">
        <div class="attachment-preview-modal" @onclick:stopPropagation>
            <header class="attachment-preview-header">
                <span>@GetAttachmentLabel(_previewAttachment)</span>
                <div class="attachment-preview-actions">
                    <a class="btn btn--ghost btn--sm"
                       href="@GetAttachmentDownloadUrl(_previewAttachment)"
                       download="@_previewAttachment.NombreArchivo">
                        <i class="bi bi-download"></i> Descargar
                    </a>
                    <button type="button" class="btn btn--ghost btn--sm" @onclick="CloseAttachmentPreview">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </header>
            <img src="@GetAttachmentUrl(_previewAttachment)" alt="@GetAttachmentLabel(_previewAttachment)" />
        </div>
    </div>
}

@code {
    private readonly (string Value, string Label)[] _modeOptions =
    [
        ("todas", "Todas"),
        ("sin_asignar", "Sin asignar"),
        ("asignadas_a_mi", "Asignadas a mí"),
        ("pendientes", "Pendientes"),
        ("cerradas", "Cerradas")
    ];

    private string _canalActivo = "WHATSAPP";
    private bool _showNuevoHilo;
    private bool _showContextPanel;
    private bool _showTemplatePanel;
    private string _nuevoHiloNombre = string.Empty;
    private string _nuevoHiloTecnico = string.Empty;
    private string? _nuevoHiloError;
    private bool _recording;
    private bool _uploadingFile;
    private bool _uploadingAudio;
    private Dictionary<long, List<ConversacionAdjuntoDto>> _adjuntosPorMensaje = [];
    private List<ConversacionPlantillaDto> _availableTemplates = [];
    private long _selectedTemplateId;
    private bool _loadingTemplates;
    private string _templateValuesText = string.Empty;

