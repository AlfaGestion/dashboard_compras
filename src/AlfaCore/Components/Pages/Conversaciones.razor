    private async Task LoadInboxAsync()
        => await RefreshInboxAsync(showLoading: true, allowSelectionChange: true);

    private async Task RefreshInboxAsync(bool showLoading, bool allowSelectionChange)
    {
        if (showLoading)
            _loadingInbox = true;

        _loadError = null;

        try
        {
            _inbox = (await ConversacionesSvc.GetInboxAsync(_filters)).ToList();

            if (_selectedConversationId.HasValue && _inbox.Any(x => x.IdConversacion == _selectedConversationId.Value))
                return;

            if (allowSelectionChange && _inbox.Count > 0)
                await SelectConversationAsync(_inbox[0].IdConversacion);
            else if (allowSelectionChange)
                ClearSelection();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            if (showLoading)
                _loadingInbox = false;
        }
    }

    private async Task SelectConversationAsync(long idConversacion)
    {
        _showTemplatePanel = false;
        await LoadConversationAsync(idConversacion, showLoading: true, clearActionState: true);
    }

    private async Task LoadConversationAsync(long idConversacion, bool showLoading, bool clearActionState)
    {
        var conversationChanged = _selectedConversationId != idConversacion;
        _selectedConversationId = idConversacion;
        if (showLoading)
            _loadingConversation = true;

        _conversationError = null;
        if (clearActionState)
        {
            _actionMessage = null;
            _actionError = null;
        }

        try
        {
            _selectedConversation = await ConversacionesSvc.GetConversationAsync(idConversacion);
            _messages = (await ConversacionesSvc.GetMessagesAsync(idConversacion)).ToList();
            var adjuntos = await ConversacionesSvc.GetConversationAttachmentsAsync(idConversacion);
            _adjuntosPorMensaje = adjuntos
                .GroupBy(a => a.IdMensaje)
                .ToDictionary(g => g.Key, g => g.ToList());
            _assignmentTechnicianId = _selectedConversation?.IdTecnico ?? string.Empty;
            _statusCode = _selectedConversation?.CodigoEstado ?? (_states.FirstOrDefault()?.CodigoEstado ?? "ABIERTA");

            if (showLoading || clearActionState || conversationChanged)
            {
                ClearNewMessageState();
                _showReturnToLatest = false;
                _scrollThreadToBottomAfterRender = true;
                _scrollHandlerConversationId = null;
            }

            if (IsWhatsAppWindowExpired)
            {
                if (conversationChanged)
                    _templateValuesText = string.Empty;

                await LoadTemplatesForConversationAsync();
            }
            else
            {
                ClearTemplateSelection();
            }
        }
        catch (Exception ex)
        {
            _conversationError = ex.Message;
            _selectedConversation = null;
            _messages = [];
        }
        finally
        {
            if (showLoading)
                _loadingConversation = false;
        }
    }

    private void StartPolling()
    {
        if (_pollingTask is not null)
            return;

        _pollingCts = new CancellationTokenSource();
        _pollingTask = RunPollingAsync(_pollingCts.Token);
    }

    private async Task RunPollingAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(PollingInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
                await InvokeAsync(AutoRefreshAsync);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task AutoRefreshAsync()
    {
        if (ShouldSkipAutoRefresh())
            return;

        var selectedId = _selectedConversationId;
        var shouldKeepAtBottom = await IsThreadNearBottomAsync();
        var previousLastMessageId = GetLastMessageId();

        await RefreshInboxAsync(showLoading: false, allowSelectionChange: false);

        if (selectedId.HasValue && _selectedConversationId == selectedId)
            await LoadConversationAsync(selectedId.Value, showLoading: false, clearActionState: false);

        var currentLastMessageId = GetLastMessageId();
        var hasNewMessages = previousLastMessageId.HasValue
                             && currentLastMessageId.HasValue
                             && currentLastMessageId > previousLastMessageId;

        if (hasNewMessages && !shouldKeepAtBottom && previousLastMessageId is { } lastSeenMessageId)
        {
            var newMessages = _messages.Where(x => x.IdMensaje > lastSeenMessageId).ToList();
            _firstNewMessageId = newMessages.FirstOrDefault()?.IdMensaje;
            _newMessagesCount += newMessages.Count;
            _showReturnToLatest = true;
        }

        StateHasChanged();

        if (shouldKeepAtBottom)
            await ScrollThreadToBottomAsync();
    }

    private bool ShouldSkipAutoRefresh()
        => _loadingInbox
           || _loadingConversation
           || _busyAction
           || _uploadingFile
           || _uploadingAudio
           || _recording
           || _showNuevoHilo
           || _showTemplatePanel
           || IsWhatsAppWindowExpired;

    private async Task<bool> IsThreadNearBottomAsync()
    {
        if (_selectedConversationId is null)
            return false;

        try
        {
            return await JS.InvokeAsync<bool>("conversacionesUi.isNearBottom", _threadElement);
        }
        catch
        {
            return false;
        }
    }

    private async Task ScrollThreadToBottomAsync()
    {
        try
        {
            await Task.Yield();
            await JS.InvokeVoidAsync("conversacionesUi.scrollToBottom", _threadElement);
            ClearNewMessageState();
            _showReturnToLatest = false;
        }
        catch
        {
        }
    }

    private async Task ScrollToLatestAsync()
    {
        await ScrollThreadToBottomAsync();
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnThreadScrollStateChanged(bool isAwayFromBottom)
    {
        if (_showReturnToLatest == isAwayFromBottom && (isAwayFromBottom || _newMessagesCount == 0))
            return Task.CompletedTask;

        _showReturnToLatest = isAwayFromBottom;
        if (!isAwayFromBottom)
            ClearNewMessageState();

        return InvokeAsync(StateHasChanged);
    }

    private long? GetLastMessageId()
        => _messages.Count == 0 ? null : _messages.Max(x => x.IdMensaje);

    private void ClearNewMessageState()
    {
        _firstNewMessageId = null;
        _newMessagesCount = 0;
    }

    private async Task SendReplyAsync()
    {
        if (_selectedConversation is null)
            return;

        _busyAction = true;
        _actionMessage = null;
        _actionError = null;

        try
        {
            await ConversacionesSvc.SendMessageAsync(new ConversacionSendMessageRequest
            {
                IdConversacion = _selectedConversation.IdConversacion,
                Texto = _replyText.Trim(),
                MessageType = "TEXT",
                IdTecnicoAutor = _assignmentTechnicianId
            });

            _replyText = string.Empty;
            _actionMessage = "Mensaje registrado correctamente.";
            await SelectConversationAsync(_selectedConversation.IdConversacion);
            await LoadInboxAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _busyAction = false;
        }
    }

    private async Task LoadTemplatesForConversationAsync()
    {
        _loadingTemplates = true;

        try
        {
            _availableTemplates = (await ConversacionesSvc.GetTemplatesAsync(new ConversacionPlantillaFilters
            {
                IncluirInactivas = false
            }))
            .Where(x => string.Equals(x.EstadoMeta, "APPROVED", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(x.EstadoMeta, "PENDING", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => string.Equals(x.EstadoMeta, "APPROVED", StringComparison.OrdinalIgnoreCase))
            .ThenBy(x => x.NombreVisible)
            .ToList();

            if (_availableTemplates.Count == 0)
            {
                ClearTemplateSelection();
                return;
            }

            if (_selectedTemplateId <= 0 || _availableTemplates.All(x => x.IdPlantilla != _selectedTemplateId))
                _selectedTemplateId = _availableTemplates[0].IdPlantilla;

            PrepareTemplateValues();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _loadingTemplates = false;
        }
    }

    private Task OnTemplateChangedAsync()
    {
        PrepareTemplateValues();
        return Task.CompletedTask;
    }

    private void PrepareTemplateValues()
    {
        if (SelectedTemplate is null)
        {
            _templateValuesText = string.Empty;
            return;
        }

        var required = CountTemplateVariables(SelectedTemplate.CuerpoTexto);
        if (required <= 0)
        {
            _templateValuesText = string.Empty;
            return;
        }

        var current = ParseTemplateValues(_templateValuesText).ToList();
        if (current.Count >= required)
            return;

        var fallback = GetTemplateDefaultVariableValue(_selectedConversation);

        while (current.Count < required)
            current.Add(current.Count == 0 ? fallback : $"Dato {current.Count + 1}");

        _templateValuesText = string.Join(Environment.NewLine, current.Take(required));
    }

