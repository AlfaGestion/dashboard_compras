                                                <i class="bi @(_uploadingFile ? "bi-hourglass-split" : "bi-paperclip")"></i> Archivo
                                                <InputFile OnChange="HandleFileSelectedAsync" style="display:none" multiple accept="image/*,audio/*,video/*,application/pdf,.doc,.docx,.xls,.xlsx,.zip,.rar" />
                                            </label>
                                            <button type="button" class="btn btn--ghost @(_recording ? "is-recording" : string.Empty)" @onclick="ToggleRecordingAsync" title="@(_recording ? "Detener grabación" : "Grabar mensaje de voz")" disabled="@_uploadingAudio">
                                                <i class="bi @(_recording ? "bi-stop-circle-fill" : "bi-mic-fill")"></i> Audio
