           || adjunto.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

    private static bool IsStickerAttachment(ConversacionAdjuntoDto adjunto)
        => string.Equals(adjunto.TipoArchivo, "STICKER", StringComparison.OrdinalIgnoreCase)
           || string.Equals(adjunto.MimeType, "image/webp", StringComparison.OrdinalIgnoreCase);

    private static bool IsAudioAttachment(ConversacionAdjuntoDto adjunto)
        => string.Equals(adjunto.TipoArchivo, "AUDIO", StringComparison.OrdinalIgnoreCase)
           || adjunto.MimeType.StartsWith("audio/", StringComparison.OrdinalIgnoreCase);

