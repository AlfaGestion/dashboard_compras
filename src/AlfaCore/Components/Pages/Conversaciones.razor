    private async Task LoadInboxAsync()
        => await RefreshInboxAsync(showLoading: true, allowSelectionChange: true);

    private async Task RefreshInboxAsync(bool showLoading, bool allowSelectionChange)
    {
        if (showLoading)
            _loadingInbox = true;

        _loadError = null;

        try
        {
            var previousInbox = _inbox.ToDictionary(x => x.IdConversacion);
            var refreshedInbox = (await ConversacionesSvc.GetInboxAsync(_filters)).ToList();
            TrackInboxNewMessages(previousInbox, refreshedInbox, showLoading);
            _inbox = refreshedInbox;
            StoreChannelCache(_canalActivo);

            if (_selectedConversationId.HasValue && _inbox.Any(x => x.IdConversacion == _selectedConversationId.Value))
                return;

            if (allowSelectionChange && _inbox.Count > 0)
                await SelectConversationAsync(_inbox[0].IdConversacion);
            else if (allowSelectionChange)
                ClearSelection();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            if (showLoading)
                _loadingInbox = false;
        }
    }

    private void TrackInboxNewMessages(
        IReadOnlyDictionary<long, ConversacionInboxItemDto> previousInbox,
        IReadOnlyList<ConversacionInboxItemDto> refreshedInbox,
        bool showLoading)
    {
        if (showLoading || previousInbox.Count == 0)
            return;

        foreach (var item in refreshedInbox)
        {
            if (item.IdConversacion == _selectedConversationId)
                continue;

            if (!previousInbox.TryGetValue(item.IdConversacion, out var previous))
                continue;

            if (item.FechaHoraUltimoMensajeCliente is not DateTime currentClientMessage
                || previous.FechaHoraUltimoMensajeCliente is not DateTime previousClientMessage
                || currentClientMessage <= previousClientMessage)
                continue;

            _newMessagesByConversation[item.IdConversacion] =
                _newMessagesByConversation.TryGetValue(item.IdConversacion, out var count) ? count + 1 : 1;
        }
    }

    private async Task SelectConversationAsync(long idConversacion)
    {
        _showTemplatePanel = false;
        await LoadConversationAsync(idConversacion, showLoading: true, clearActionState: true);
    }

    private async Task LoadConversationAsync(long idConversacion, bool showLoading, bool clearActionState)
    {
        var conversationChanged = _selectedConversationId != idConversacion;
        _selectedConversationId = idConversacion;
        var hasWarmCache = _conversationCache.TryGetValue(idConversacion, out var cachedConversation);

        if (hasWarmCache && cachedConversation is not null)
        {
            ApplyConversationCache(idConversacion, cachedConversation);
            showLoading = false;
        }

        if (showLoading)
            _loadingConversation = true;

        _conversationError = null;
        if (clearActionState)
        {
            _actionMessage = null;
            _actionError = null;
        }

        try
        {
            var conversationTask = ConversacionesSvc.GetConversationAsync(idConversacion);
            var messagesTask = ConversacionesSvc.GetMessagesAsync(idConversacion);
            var attachmentsTask = ConversacionesSvc.GetConversationAttachmentsAsync(idConversacion);

            await Task.WhenAll(conversationTask, messagesTask, attachmentsTask);

            _selectedConversation = await conversationTask;
            _messages = (await messagesTask).ToList();
            var adjuntos = await attachmentsTask;
            _adjuntosPorMensaje = adjuntos
                .GroupBy(a => a.IdMensaje)
                .ToDictionary(g => g.Key, g => g.ToList());
            StoreConversationCache(idConversacion);
            _assignmentTechnicianId = _selectedConversation?.IdTecnico ?? string.Empty;
            _statusCode = _selectedConversation?.CodigoEstado ?? (_states.FirstOrDefault()?.CodigoEstado ?? "ABIERTA");

            if (showLoading || clearActionState || conversationChanged)
            {
                ClearNewMessageState();
                _showReturnToLatest = false;
                _scrollThreadToBottomAfterRender = true;
                _scrollHandlerConversationId = null;
                RestoreSelectedNewMessageMarker(idConversacion);
            }

            if (IsWhatsAppConversation)
            {
                if (conversationChanged)
                    _templateValuesText = string.Empty;
            }
            else
            {
                ClearTemplateSelection();
            }
        }
        catch (Exception ex)
        {
            _conversationError = ex.Message;
            _selectedConversation = null;
            _messages = [];
        }
        finally
        {
            if (showLoading)
                _loadingConversation = false;
        }
    }

    private async Task DebounceContactSuggestionsAsync()
    {
        CancelContactSearch();

        if (!ShouldShowContactSuggestions)
        {
            _showContactSuggestions = false;
            _contactSuggestions = [];
            _conversationSuggestions = [];
            return;
        }

        _showContactSuggestions = true;
        _loadingContactSuggestions = true;
        var cts = new CancellationTokenSource();
        _contactSearchCts = cts;

        try
        {
            await Task.Delay(220, cts.Token);
            var contactTask = ContactosSvc.SearchAsync(new ContactosFilters
            {
                Texto = _filters.Search.Trim(),
                Activo = true,
                PageNumber = 1,
                PageSize = 6
            }, cts.Token);
            var conversationTask = ConversacionesSvc.GetInboxAsync(new ConversacionesInboxFilters
            {
                Canal = _canalActivo,
                Modo = _filters.Modo,
                Search = _filters.Search.Trim(),
                IdTecnicoActual = _filters.IdTecnicoActual,
                CodigoEstado = _filters.CodigoEstado,
                Limit = 6
            }, cts.Token);

            await Task.WhenAll(contactTask, conversationTask);

            if (!cts.IsCancellationRequested)
            {
                _conversationSuggestions = (await conversationTask)
                    .Where(x => MatchesConversationSearch(x, _filters.Search.Trim()))
                    .Take(6)
                    .ToList();
                _contactSuggestions = (await contactTask).Items
                    .Where(contact => !_conversationSuggestions.Any(conversation => IsSameContactSuggestion(conversation, contact)))
                    .Take(6)
                    .ToList();
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _contactSuggestions = [];
            _conversationSuggestions = [];
            _actionError = ex.Message;
        }
        finally
        {
            if (_contactSearchCts == cts)
            {
                _loadingContactSuggestions = false;
                _contactSearchCts = null;
            }
        }
    }

    private void StoreConversationCache(long idConversacion)
    {
        if (_selectedConversation is null)
            return;

        _conversationCache[idConversacion] = new ConversationViewCache(
            _selectedConversation,
            _messages.ToList(),
            _adjuntosPorMensaje.ToDictionary(x => x.Key, x => x.Value.ToList()));

        const int maxCachedConversations = 8;
        if (_conversationCache.Count <= maxCachedConversations)
            return;

        var firstKey = _conversationCache.Keys.FirstOrDefault(x => x != idConversacion);
        if (firstKey > 0)
            _conversationCache.Remove(firstKey);
    }

    private void ApplyConversationCache(long idConversacion, ConversationViewCache cache)
    {
        _selectedConversation = cache.Conversation;
        _messages = cache.Messages.ToList();
        _adjuntosPorMensaje = cache.AttachmentsByMessage.ToDictionary(x => x.Key, x => x.Value.ToList());
        _assignmentTechnicianId = _selectedConversation.IdTecnico;
        _statusCode = _selectedConversation.CodigoEstado;
        _conversationError = null;
        _scrollThreadToBottomAfterRender = true;
        _scrollHandlerConversationId = null;
        RestoreSelectedNewMessageMarker(idConversacion);
    }

    private void StoreChannelCache(string canal)
    {
        _channelCache[canal] = new ConversationChannelCache(
            CloneFilters(_filters),
            _inbox.ToList(),
            _selectedConversationId);
    }

    private bool TryApplyChannelCache(string canal)
    {
        if (!_channelCache.TryGetValue(canal, out var cache))
            return false;

        _filters = CloneFilters(cache.Filters);
        _filters.Canal = canal;
        _inbox = cache.Inbox.ToList();

        if (cache.SelectedConversationId is long selectedId
            && _conversationCache.TryGetValue(selectedId, out var conversationCache))
        {
            _selectedConversationId = selectedId;
            ApplyConversationCache(selectedId, conversationCache);
        }
        else
        {
            ClearSelection();
        }

        return true;
    }

    private static ConversacionesInboxFilters CloneFilters(ConversacionesInboxFilters filters)
        => new()
        {
            Modo = filters.Modo,
            Search = filters.Search,
            IdTecnicoActual = filters.IdTecnicoActual,
            CodigoEstado = filters.CodigoEstado,
            Canal = filters.Canal,
            Limit = filters.Limit,
            Offset = filters.Offset
        };

    private void StartPolling()
    {
        if (_pollingTask is not null)
            return;

        _pollingCts = new CancellationTokenSource();
        _pollingTask = RunPollingAsync(_pollingCts.Token);
    }

    private async Task RunPollingAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(PollingInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
                await InvokeAsync(AutoRefreshAsync);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task AutoRefreshAsync()
    {
        if (ShouldSkipAutoRefresh())
            return;

        var selectedId = _selectedConversationId;
        var shouldKeepAtBottom = await IsThreadNearBottomAsync();
        var previousLastMessageId = GetLastMessageId();

        await RefreshInboxAsync(showLoading: false, allowSelectionChange: false);

        if (selectedId.HasValue && _selectedConversationId == selectedId)
            await LoadConversationAsync(selectedId.Value, showLoading: false, clearActionState: false);

        var currentLastMessageId = GetLastMessageId();
        var hasNewMessages = previousLastMessageId.HasValue
                             && currentLastMessageId.HasValue
                             && currentLastMessageId > previousLastMessageId;

        if (hasNewMessages && previousLastMessageId is { } lastSeenMessageId)
        {
            var newMessages = _messages
                .Where(x => x.IdMensaje > lastSeenMessageId && IsIncomingMessage(x))
                .ToList();
            if (newMessages.Count > 0)
            {
                _firstNewMessageId ??= newMessages.FirstOrDefault()?.IdMensaje;
                _newMessagesCount += newMessages.Count;
                _showReturnToLatest = true;
            }
        }

        StateHasChanged();

        if (shouldKeepAtBottom)
            await ScrollThreadToBottomAsync();
    }

    private bool ShouldSkipAutoRefresh()
        => _loadingInbox
           || _loadingConversation
           || _busyAction
           || _uploadingFile
           || _uploadingAudio
           || _recording
           || _showNuevoHilo
           || _showTemplatePanel
           || IsWhatsAppWindowExpired;

