@page "/compras/comprobantes"
@inject AlfaCore.Services.IComprasDashboardService DashboardService
@inject AlfaCore.Services.FilterStateService FilterState

<PageTitle>Comprobantes | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Comprobantes</h2>
            <p class="page-intro__text">Grilla filtrable con detalle del comprobante y sus artículos asociados. <a class="help-link" href="/ayuda#6-comprobantes">Ver ayuda</a></p>
        </div>
    </div>

    <GlobalFiltersBar Model="_filtro" Options="_options" OnApply="BuscarAsync" />

    @if (_overview is not null)
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Importe total" Valor="@Moneda(_overview.TotalComprado)" Icono="$" />
            <KpiCard Titulo="Comprobantes" Valor="@_overview.CantidadComprobantes.ToString("N0")" Icono="C" />
            <KpiCard Titulo="Proveedores" Valor="@_overview.ProveedoresActivos.ToString("N0")" Icono="P" />
            <KpiCard Titulo="Ticket promedio" Valor="@Moneda(_overview.TicketPromedio)" Icono="T" />
            <KpiCard Titulo="En cero" Valor="@_overview.ComprobantesEnCero.ToString("N0")" Icono="0" />
            <KpiCard Titulo="Sin detalle" Valor="@_overview.ComprobantesSinDetalle.ToString("N0")" Icono="D" />
            <KpiCard Titulo="Comprobante máximo" Valor="@Moneda(_overview.ComprobanteMaximo)" Icono="!" />
            <KpiCard Titulo="TC predominante" Valor="@_overview.TcPredominante" Descripcion="@_overview.TcPredominanteParticipacion.ToString("P1", Cultura)" Icono="TC" />
        </div>

        @if (_overview.Alertas.Count > 0)
        {
            <div class="alert-band">
                @foreach (var alerta in _overview.Alertas)
                {
                    <span class="alert-chip alert-chip--@alerta.Tipo"><strong>@alerta.Titulo:</strong> @alerta.Descripcion</span>
                }
            </div>
        }

        <div class="chart-grid">
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Evolución semanal</h3>
                        <p class="panel-card__subtitle">Importe total por semana del período filtrado</p>
                    </div>
                </div>
                <LineChart Data="_overview.EvolucionSemanal" Titulo="Evolución semanal" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Tipos predominantes</h3>
                        <p class="panel-card__subtitle">Participación por TC</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_overview.ComposicionTipos" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Top comprobantes</h3>
                        <p class="panel-card__subtitle">Mayores importes del período</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_overview.TopComprobantes" />
            </section>
        </div>
    }

    <section class="panel-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros rápidos de control</h3>
                <p class="panel-card__subtitle">Aplicá un recorte operativo sobre la grilla actual.</p>
            </div>
        </div>
        <div class="quick-filter-bar">
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.Todos)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.Todos)">Todos</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.Criticos)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.Criticos)">Solo críticos</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.ConDetalle)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.ConDetalle)">Con detalle</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.Contables)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.Contables)">Contables</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.EnCero)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.EnCero)">En cero</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.IvaCero)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.IvaCero)">IVA 0</button>
            <button type="button" class="@QuickFilterButtonCss(QuickFilterMode.SinDetalle)" @onclick="() => SetQuickFilterAsync(QuickFilterMode.SinDetalle)">Sin detalle</button>
        </div>
    </section>

    <DataTable Titulo="Listado de comprobantes" Subtitulo="@GetGridSubtitle()">
        <Toolbar>
            @if (_resultado is not null && _resultado.TotalPaginas > 0)
            {
                <div class="pagination">
                    <button class="btn btn--ghost" @onclick="PaginaAnteriorAsync" disabled="@(_resultado.PaginaActual <= 1)">Anterior</button>
                    <span>Página @_resultado.PaginaActual de @_resultado.TotalPaginas</span>
                    <button class="btn btn--ghost" @onclick="PaginaSiguienteAsync" disabled="@(_resultado.PaginaActual >= _resultado.TotalPaginas)">Siguiente</button>
                </div>
            }
        </Toolbar>
        <Header>
            <tr>
                <th>Fecha</th>
                <th>TC</th>
                <th>Comprobante</th>
                <th>Proveedor</th>
                <th>Cuenta</th>
                <th style="text-align:right;">Neto</th>
                <th style="text-align:right;">IVA</th>
                <th style="text-align:right;">Total</th>
                <th>Estado</th>
                <th>Detalle</th>
                <th style="text-align:right;">Ítems</th>
                <th>Tipo carga</th>
                <th>Alerta</th>
                <th>Depósito</th>
                <th>Usuario</th>
                <th></th>
            </tr>
        </Header>
        <Rows>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <tr>
                    <td colspan="15">
                        <div class="empty-state">
                            <span class="empty-state__eyebrow">Consulta</span>
                            <h3>No fue posible cargar los comprobantes</h3>
                            <p>@_error</p>
                        </div>
                    </td>
                </tr>
            }
            else if (_isLoading && _resultado is null)
            {
                <tr>
                    <td colspan="15">
                        <div class="loading">Cargando comprobantes...</div>
                    </td>
                </tr>
            }
            else if (_resultado is not null && _resultado.Items.Count == 0)
            {
                <tr>
                    <td colspan="15">
                        <div class="empty-state">
                            <span class="empty-state__eyebrow">Resultados</span>
                            <h3>No se encontraron comprobantes</h3>
                            <p>Probá ampliar el rango de fechas o ajustar los filtros seleccionados.</p>
                        </div>
                    </td>
                </tr>
            }
            else if (_resultado is not null)
            {
                @foreach (var item in FilteredItems)
                {
                    <tr class="@GetRowCss(item)">
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@item.Tc</td>
                        <td>@item.IdComprobante</td>
                        <td><strong>@item.RazonSocial</strong></td>
                        <td>@item.Cuenta</td>
                        <td style="text-align:right;">@Moneda(item.NetoDashboard)</td>
                        <td style="text-align:right;">@Moneda(item.IvaDashboard)</td>
                        <td style="text-align:right;">@Moneda(item.ImporteDashboard)</td>
                        <td><span class="@EstadoCss(item.EstadoComprobante)">@item.EstadoComprobante</span></td>
                        <td><span class="@FlagCss(item.TieneDetalle)">@FlagLabel(item.TieneDetalle)</span></td>
                        <td style="text-align:right;">@item.CantidadItems</td>
                        <td><span class="@TipoCargaCss(item.EsContable)">@TipoCargaLabel(item.EsContable)</span></td>
                        <td>@((MarkupString)RenderAlerta(item))</td>
                        <td>@item.Deposito</td>
                        <td>@item.Usuario</td>
                        <td><button class="btn btn--ghost" @onclick="() => VerDetalleAsync(item)">Detalle</button></td>
                    </tr>
                }
            }
        </Rows>
    </DataTable>

    @if (_detalle is not null)
    {
        <div class="split-grid">
            <DetailCard Titulo="@($"{_detalle.Cabecera.Tc} {_detalle.Cabecera.IdComprobante}")" Subtitulo="Cabecera del comprobante">
                <div class="detail-row"><span class="detail-row__label">Proveedor</span><strong>@_detalle.Cabecera.RazonSocial</strong></div>
                <div class="detail-row"><span class="detail-row__label">Fecha</span><strong>@_detalle.Cabecera.Fecha.ToString("dd/MM/yyyy")</strong></div>
                <div class="detail-row"><span class="detail-row__label">Neto</span><strong>@Moneda(_detalle.Cabecera.NetoDashboard)</strong></div>
                <div class="detail-row"><span class="detail-row__label">IVA</span><strong>@Moneda(_detalle.Cabecera.IvaDashboard)</strong></div>
                <div class="detail-row"><span class="detail-row__label">Total</span><strong>@Moneda(_detalle.Cabecera.ImporteDashboard)</strong></div>
                <div class="detail-row"><span class="detail-row__label">Estado</span><strong>@_detalle.Cabecera.EstadoComprobante</strong></div>
                <div class="detail-row"><span class="detail-row__label">Tiene detalle</span><strong>@FlagLabel(_detalle.Cabecera.TieneDetalle)</strong></div>
                <div class="detail-row"><span class="detail-row__label">Tipo carga</span><strong>@TipoCargaLabel(_detalle.Cabecera.EsContable)</strong></div>
                <div class="detail-row"><span class="detail-row__label">Cantidad ítems</span><strong>@_detalle.Items.Count</strong></div>
            </DetailCard>

            <DataTable Titulo="Artículos asociados" Subtitulo="@($"{_detalle.Items.Count} ítems del comprobante")">
                <Header><tr><th>Código</th><th>Descripción</th><th>Rubro</th><th>Familia</th><th style="text-align:right;">Cantidad</th><th style="text-align:right;">Costo</th><th style="text-align:right;">Total</th></tr></Header>
                <Rows>
                    @foreach (var item in _detalle.Items)
                    {
                        <tr>
                            <td>@item.IdArticulo</td>
                            <td>@item.DescripcionArticulo</td>
                            <td>@item.Rubro</td>
                            <td>@item.Familia</td>
                            <td style="text-align:right;">@item.Cantidad.ToString("N2")</td>
                            <td style="text-align:right;">@Moneda(item.Costo)</td>
                            <td style="text-align:right;">@Moneda(item.Total)</td>
                        </tr>
                    }
                </Rows>
            </DataTable>
        </div>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "tc")] public string? TcQuery { get; set; }
    [SupplyParameterFromQuery(Name = "id")] public string? IdQuery { get; set; }
    [SupplyParameterFromQuery(Name = "cuenta")] public string? CuentaQuery { get; set; }
    [SupplyParameterFromQuery(Name = "proveedor")] public string? ProveedorQuery { get; set; }

    private readonly ComprobantesFilter _filtro = new();
    private FilterOptionsDto _options = new();
    private ComprobantesResultDto? _resultado;
    private ComprobanteDetalleDto? _detalle;
    private ComprobantesOverviewDto? _overview;
    private string? _error;
    private bool _isLoading;
    private static readonly System.Globalization.CultureInfo Cultura = System.Globalization.CultureInfo.GetCultureInfo("es-AR");
    private QuickFilterMode _quickFilter = QuickFilterMode.Todos;

    private IReadOnlyList<ComprobanteDto> FilteredItems =>
        _resultado?.Items.Where(MatchesQuickFilter).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        _options = await DashboardService.GetFilterOptionsAsync();
        _filtro.FechaDesde = FilterState.Current.FechaDesde ?? _filtro.FechaDesde;
        _filtro.FechaHasta = FilterState.Current.FechaHasta ?? _filtro.FechaHasta;
        _filtro.Articulo = FilterState.Current.Articulo;
        _filtro.Rubro = FilterState.Current.Rubro;
        _filtro.Familia = FilterState.Current.Familia;
        _filtro.Usuario = FilterState.Current.Usuario;
        _filtro.Sucursal = FilterState.Current.Sucursal;
        _filtro.Deposito = FilterState.Current.Deposito;
        _filtro.Estado = FilterState.Current.Estado;
        _filtro.TipoComprobante = FilterState.Current.TipoComprobante;
        _filtro.Proveedor = ProveedorQuery;
        await BuscarAsync();

        if (!string.IsNullOrWhiteSpace(TcQuery) && !string.IsNullOrWhiteSpace(IdQuery) && !string.IsNullOrWhiteSpace(CuentaQuery))
        {
            _detalle = await DashboardService.GetComprobanteDetalleAsync(TcQuery, IdQuery, CuentaQuery);
        }
    }

    private async Task BuscarAsync()
    {
        _isLoading = true;
        _error = null;
        _detalle = null;
        _filtro.Pagina = Math.Max(1, _filtro.Pagina);
        EnsureDateRange();
        CopyToFilterState();

        try
        {
            var resultadoTask = DashboardService.GetComprobantesAsync(_filtro);
            var overviewTask = DashboardService.GetComprobantesOverviewAsync(_filtro);
            await Task.WhenAll(resultadoTask, overviewTask);
            _resultado = resultadoTask.Result;
            _overview = overviewTask.Result;
        }
        catch (Exception ex)
        {
            _resultado = new ComprobantesResultDto
            {
                Items = [],
                PaginaActual = _filtro.Pagina,
                TamanioPagina = _filtro.TamanioPagina
            };
            _overview = null;
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task VerDetalleAsync(ComprobanteDto item)
    {
        _detalle = await DashboardService.GetComprobanteDetalleAsync(item.Tc, item.IdComprobante, item.Cuenta);
    }

    private async Task PaginaAnteriorAsync()
    {
        if (_filtro.Pagina <= 1) return;
        _filtro.Pagina--;
        await BuscarAsync();
    }

    private async Task PaginaSiguienteAsync()
    {
        if (_resultado is null || _filtro.Pagina >= _resultado.TotalPaginas) return;
        _filtro.Pagina++;
        await BuscarAsync();
    }

    private Task SetQuickFilterAsync(QuickFilterMode mode)
    {
        _quickFilter = mode;
        return Task.CompletedTask;
    }

    private void EnsureDateRange()
    {
        if (_filtro.FechaDesde.HasValue && _filtro.FechaHasta.HasValue)
        {
            return;
        }

        var today = DateTime.Today;
        _filtro.FechaDesde ??= new DateTime(today.Year, today.Month, 1);
        _filtro.FechaHasta ??= today;
    }

    private void CopyToFilterState()
    {
        FilterState.Current.FechaDesde = _filtro.FechaDesde;
        FilterState.Current.FechaHasta = _filtro.FechaHasta;
        FilterState.Current.Proveedor = _filtro.Proveedor;
        FilterState.Current.Articulo = _filtro.Articulo;
        FilterState.Current.Rubro = _filtro.Rubro;
        FilterState.Current.Familia = _filtro.Familia;
        FilterState.Current.Usuario = _filtro.Usuario;
        FilterState.Current.Sucursal = _filtro.Sucursal;
        FilterState.Current.Deposito = _filtro.Deposito;
        FilterState.Current.Estado = _filtro.Estado;
        FilterState.Current.TipoComprobante = _filtro.TipoComprobante;
    }

    private string GetGridSubtitle()
    {
        if (!string.IsNullOrWhiteSpace(_error))
        {
            return "No se pudo completar la consulta";
        }

        if (_isLoading && _resultado is null)
        {
            return "Cargando...";
        }

        return _resultado is null
            ? "Sin datos cargados"
            : $"{FilteredItems.Count} visibles de {_resultado.TotalRegistros} registros encontrados";
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string FlagLabel(bool value) => value ? "Sí" : "No";
    private static string FlagCss(bool value) => value ? "badge-state badge-state--ok" : "badge-state badge-state--danger";
    private static string TipoCargaLabel(bool esContable) => esContable ? "Contable" : "Con detalle";
    private static string TipoCargaCss(bool esContable) => esContable ? "badge-state badge-state--warn" : "badge-state badge-state--ok";
    private string QuickFilterButtonCss(QuickFilterMode mode)
        => mode == _quickFilter ? "btn btn--primary quick-filter-btn" : "btn btn--ghost quick-filter-btn";

    private bool MatchesQuickFilter(ComprobanteDto item) => _quickFilter switch
    {
        QuickFilterMode.Criticos => IsCritical(item),
        QuickFilterMode.ConDetalle => item.TieneDetalle,
        QuickFilterMode.Contables => item.EsContable,
        QuickFilterMode.EnCero => item.ImporteDashboard == 0,
        QuickFilterMode.IvaCero => item.IvaEnCero,
        QuickFilterMode.SinDetalle => !item.TieneDetalle,
        _ => true
    };

    private static string GetRowCss(ComprobanteDto item)
    {
        if (item.ImporteDashboard == 0)
        {
            return "row--critical";
        }

        if (!item.TieneDetalle || item.IvaEnCero)
        {
            return "row--warning";
        }

        return string.Empty;
    }

    private static bool IsCritical(ComprobanteDto item)
        => item.ImporteDashboard == 0 || !item.TieneDetalle || item.IvaEnCero;

    private static string RenderAlerta(ComprobanteDto item)
    {
        if (string.IsNullOrWhiteSpace(item.AlertaOperativa))
        {
            return "<span class=\"table-alert table-alert--neutral\">Sin alerta</span>";
        }

        return item.AlertaOperativa switch
        {
            "En cero" => "<span class=\"table-alert table-alert--danger\"><span class=\"table-alert__dot\"></span>En cero</span>",
            "Sin detalle" => "<span class=\"table-alert table-alert--warn\"><span class=\"table-alert__dot\"></span>Sin detalle</span>",
            "IVA 0" => "<span class=\"table-alert table-alert--info\"><span class=\"table-alert__dot\"></span>IVA 0</span>",
            _ => $"<span class=\"table-alert table-alert--neutral\">{item.AlertaOperativa}</span>"
        };
    }

    private static string EstadoCss(string estado) => estado switch
    {
        "Cerrada" or "Finalizada" => "badge-state badge-state--ok",
        "Aprobada" or "Pendiente" => "badge-state badge-state--warn",
        _ => "badge-state badge-state--danger"
    };

    private enum QuickFilterMode
    {
        Todos,
        Criticos,
        ConDetalle,
        Contables,
        EnCero,
        IvaCero,
        SinDetalle
    }
}
