@page "/contactos"
@using AlfaCore.Models
@using AlfaCore.Services
@inject IContactosService ContactosSvc
@inject IAppUiOperationService UiOps
@inject IAppUserSessionService AppUserSession
@implements IDisposable

<PageTitle>Contactos | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Contactos</h2>
            <p class="page-intro__text">Administrá la agenda general del sistema con datos de contacto, observaciones y baja lógica.</p>
        </div>
        <div class="actions">
            <button type="button" class="btn btn--primary" @onclick="BeginNew">
                <i class="bi bi-plus-circle"></i> Nuevo contacto
            </button>
            <button type="button" class="btn btn--ghost" @onclick="RecargarAsync" disabled="@_loadingList">
                <i class="bi bi-arrow-clockwise"></i> Recargar
            </button>
        </div>
    </section>

    @if (_feedback is not null)
    {
        <section class="panel-card">
            <div class="editor-msg @GetFeedbackClass(_feedback)">
                <div>
                    <strong>@_feedback.Title</strong>
                    <p>@_feedback.Message</p>
                    @if (_feedback.HasSuggestion)
                    {
                        <small>@_feedback.Suggestion</small>
                    }
                    @if (_feedback.HasCode)
                    {
                        <small>Código: @_feedback.Code</small>
                    }
                </div>
            </div>
        </section>
    }

    <section class="panel-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros</h3>
                <p class="panel-card__subtitle">Buscá por nombre, localidad, email o teléfonos. La grilla muestra activos por defecto.</p>
            </div>
        </div>

        <div class="filters-grid">
            <div class="field field--wide">
                <label>Buscar</label>
                <input type="search"
                       placeholder="Nombre, localidad, email o teléfono..."
                       @bind="_filters.Texto"
                       @bind:event="oninput" />
            </div>
            <div class="field">
                <label>Estado</label>
                <select @bind="_activoFiltro">
                    <option value="1">Activos</option>
                    <option value="">Todos</option>
                    <option value="0">Inactivos</option>
                </select>
            </div>
            <div class="actions">
                <button type="button" class="btn btn--primary" @onclick="AplicarFiltrosAsync" disabled="@_loadingList">
                    <i class="bi bi-funnel"></i> Aplicar
                </button>
                <button type="button" class="btn btn--ghost" @onclick="LimpiarFiltros" disabled="@_loadingList">
                    <i class="bi bi-eraser"></i> Limpiar
                </button>
            </div>
        </div>
    </section>

    @if (_showViewSettings && !_showEditor)
    {
        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Configuración de vista</h3>
                    <p class="panel-card__subtitle">Elegí columnas visibles, su orden y agrupación para la grilla de contactos.</p>
                </div>
            </div>

            <div class="usuarios-view-settings">
                <div class="field">
                    <label>Agrupar por</label>
                    <select @bind="_draftAgruparPor">
                        <option value="@ContactosViewGroupKeys.None">Sin agrupar</option>
                        <option value="@ContactosViewGroupKeys.Activo">Estado (Activo / Inactivo)</option>
                    </select>
                </div>

                <div class="usuarios-view-settings__list">
                    @foreach (var column in _viewSettingsDraft.OrderBy(c => c.Order))
                    {
                        <div class="usuarios-view-settings__item">
                            <label class="checkbox">
                                <input type="checkbox" checked="@column.Visible" @onchange="args => ToggleViewColumn(column.Key, args)" />
                                <span>@column.Label</span>
                            </label>
                            <div class="actions">
                                <button type="button" class="btn btn--ghost btn--sm" @onclick="() => MoveViewColumn(column.Key, -1)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button type="button" class="btn btn--ghost btn--sm" @onclick="() => MoveViewColumn(column.Key, 1)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="actions">
                    <button type="button" class="btn btn--primary" @onclick="GuardarConfiguracionVistaAsync">
                        <i class="bi bi-floppy"></i> Guardar vista
                    </button>
                    <button type="button" class="btn btn--ghost" @onclick="CancelarConfiguracionVista">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
            </div>
        </section>
    }

    @if (_showEditor)
    {
        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">@(_isNewMode ? "Nuevo contacto" : $"Editar {_form.NombreApellido}")</h3>
                    <p class="panel-card__subtitle">@(_isNewMode ? "Completá los datos principales del contacto." : $"Código interno: {_selectedId} · Estado: {(_selectedActivo ? "Activo" : "Inactivo")}")</p>
                </div>
                <div class="actions">
                    <button type="button" class="btn btn--ghost" @onclick="CerrarEditor" disabled="@_saving">
                        <i class="bi bi-arrow-left"></i>
                        <span>Volver al listado</span>
                    </button>
                </div>
            </div>

            <div class="contactos-tabs">
                <button type="button"
                        class="btn @(_activeTab == ContactoTab.Datos ? "btn--primary" : "btn--ghost")"
                        @onclick="() => _activeTab = ContactoTab.Datos">
                    Datos generales
                </button>
                <button type="button"
                        class="btn @(_activeTab == ContactoTab.Observaciones ? "btn--primary" : "btn--ghost")"
                        @onclick="() => _activeTab = ContactoTab.Observaciones">
                    Observaciones
                </button>
            </div>

            @if (_activeTab == ContactoTab.Datos)
            {
                <div class="contactos-form">
                    <div class="contactos-form__grid">
                        <div class="field">
                            <label>Nombre y apellido</label>
                            <input type="text" class="@GetFieldInputClass("nombre")" maxlength="100" @bind="_form.NombreApellido" disabled="@_saving" />
                            @if (HasFieldError("nombre"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("nombre")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Domicilio</label>
                            <input type="text" class="@GetFieldInputClass("domicilio")" maxlength="100" @bind="_form.Domicilio" disabled="@_saving" />
                            @if (HasFieldError("domicilio"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("domicilio")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Localidad</label>
                            <input type="text" class="@GetFieldInputClass("localidad")" maxlength="100" @bind="_form.Localidad" disabled="@_saving" />
                            @if (HasFieldError("localidad"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("localidad")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Código postal</label>
                            <input type="text" class="@GetFieldInputClass("codigo-postal")" maxlength="20" @bind="_form.CodigoPostal" disabled="@_saving" />
                            @if (HasFieldError("codigo-postal"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("codigo-postal")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Provincia</label>
                            <select class="@GetFieldInputClass("provincia")" @bind="_form.ProvinciaCodigo" disabled="@_saving || _loadingProvincias">
                                <option value="">Seleccionar...</option>
                                @foreach (var item in _provincias)
                                {
                                    <option value="@item.Codigo">@item.Descripcion</option>
                                }
                            </select>
                            @if (HasFieldError("provincia"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("provincia")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Nro. documento</label>
                            <input type="text" class="@GetFieldInputClass("numero-documento")" maxlength="13" @bind="_form.NumeroDocumento" disabled="@_saving" />
                            @if (HasFieldError("numero-documento"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("numero-documento")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Teléfono</label>
                            <input type="text" class="@GetFieldInputClass("telefono")" maxlength="100" @bind="_form.Telefono" disabled="@_saving" />
                            @if (HasFieldError("telefono"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("telefono")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Tel. alternativo</label>
                            <input type="text" class="@GetFieldInputClass("telefono-alternativo")" maxlength="100" @bind="_form.TelefonoAlternativo" disabled="@_saving" />
                            @if (HasFieldError("telefono-alternativo"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("telefono-alternativo")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Celular</label>
                            <input type="text" class="@GetFieldInputClass("celular")" maxlength="100" @bind="_form.Celular" disabled="@_saving" />
                            @if (HasFieldError("celular"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("celular")</small>
                            }
                        </div>
                        <div class="field">
                            <label>E-mail</label>
                            <input type="email" class="@GetFieldInputClass("email")" maxlength="100" @bind="_form.Email" disabled="@_saving" />
                            @if (HasFieldError("email"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("email")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Página web</label>
                            <input type="text" class="@GetFieldInputClass("website")" maxlength="100" @bind="_form.Website" disabled="@_saving" />
                            @if (HasFieldError("website"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("website")</small>
                            }
                        </div>
                        <div class="field">
                            <label>Cargo</label>
                            <input type="text" class="@GetFieldInputClass("cargo")" maxlength="100" @bind="_form.Cargo" disabled="@_saving" />
                            @if (HasFieldError("cargo"))
                            {
                                <small class="usuarios-field-error">@GetFieldError("cargo")</small>
                            }
                        </div>
                    </div>

                    <div class="contactos-flags">
                        <label class="checkbox">
                            <input type="checkbox" @bind="_form.MailPagosCobranzas" disabled="@_saving" />
                            <span>Pagos/Cobranzas</span>
                        </label>
                        <label class="checkbox">
                            <input type="checkbox" @bind="_form.MailOrdenCompra" disabled="@_saving" />
                            <span>Órdenes de compra</span>
                        </label>
                        <label class="checkbox">
                            <input type="checkbox" @bind="_form.MailOrdenTrabajo" disabled="@_saving" />
                            <span>Órdenes de trabajo</span>
                        </label>
                    </div>
                </div>
            }
            else
            {
                <div class="field">
                    <label>Observaciones</label>
                    <textarea class="contactos-observaciones" @bind="_form.Observaciones" disabled="@_saving"></textarea>
                </div>
            }

            <div class="actions usuarios-editor__actions">
                <button type="button" class="btn btn--primary" @onclick="GuardarAsync" disabled="@_saving">
                    <i class="bi bi-floppy"></i>
                    <span>@(_saving ? "Guardando..." : "Guardar contacto")</span>
                </button>
                <button type="button" class="btn btn--ghost" @onclick="ResetForm" disabled="@_saving">
                    <i class="bi bi-eraser"></i>
                    <span>@(_isNewMode ? "Limpiar" : "Revertir")</span>
                </button>
                @if (!_isNewMode && _selectedActivo)
                {
                    <button type="button" class="btn btn--ghost usuarios-btn-danger" @onclick="DarDeBajaAsync" disabled="@_saving">
                        <i class="bi bi-person-dash"></i>
                        <span>Dar de baja</span>
                    </button>
                }
            </div>
        </section>
    }
    else
    {
        var visibleColumns = GetVisibleColumns();
        var groups = BuildGridGroups();

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Contactos</h3>
                    <p class="panel-card__subtitle">@_pagedTotal registro(s) · Página @_pageNumber de @_totalPages · doble clic para abrir la ficha.</p>
                </div>
                <div class="actions">
                    <button type="button" class="btn btn--ghost" @onclick="AbrirConfiguracionVista">
                        <i class="bi bi-sliders"></i> Configurar vista
                    </button>
                    <span class="panel-card__subtitle">Agrupación: @GetGroupingLabel(_viewSettings.AgruparPor)</span>
                </div>
            </div>

            @if (_loadingList)
            {
                <div class="usuarios-empty">Cargando contactos...</div>
            }
            else if (_items.Count == 0)
            {
                <div class="usuarios-empty">No hay contactos para los filtros seleccionados.</div>
            }
            else
            {
                <div class="usuarios-table-wrap">
                    <table class="data-table usuarios-table">
                        <thead>
                            <tr>
                                @foreach (var col in visibleColumns)
                                {
                                    <th>@col.Label</th>
                                }
                            </tr>
                        </thead>
                        @foreach (var group in groups)
                        {
                            <tbody>
                                @if (group.ShowHeader)
                                {
                                    <tr class="usuarios-group-row">
                                        <td colspan="@visibleColumns.Count">@group.Label</td>
                                    </tr>
                                }
                                @foreach (var item in group.Items)
                                {
                                    <tr class="@(_selectedId == item.Id ? "usuarios-table__row is-selected" : "usuarios-table__row")"
                                        @onclick="() => _selectedId = item.Id"
                                        @ondblclick="() => AbrirEditorAsync(item.Id)">
                                        @foreach (var col in visibleColumns)
                                        {
                                            <td>
                                                @switch (col.Key)
                                                {
                                                    case ContactosViewColumnKeys.Nombre:
                                                        <strong>@item.NombreApellido</strong>
                                                        break;
                                                    case ContactosViewColumnKeys.Localidad:
                                                        @(string.IsNullOrWhiteSpace(item.Localidad) ? "—" : item.Localidad)
                                                        break;
                                                    case ContactosViewColumnKeys.Provincia:
                                                        @(string.IsNullOrWhiteSpace(item.ProvinciaDescripcion) ? item.ProvinciaCodigo : item.ProvinciaDescripcion)
                                                        break;
                                                    case ContactosViewColumnKeys.Telefono:
                                                        @(string.IsNullOrWhiteSpace(item.Telefono) ? "—" : item.Telefono)
                                                        break;
                                                    case ContactosViewColumnKeys.Celular:
                                                        @(string.IsNullOrWhiteSpace(item.Celular) ? "—" : item.Celular)
                                                        break;
                                                    case ContactosViewColumnKeys.Email:
                                                        @(string.IsNullOrWhiteSpace(item.Email) ? "—" : item.Email)
                                                        break;
                                                    case ContactosViewColumnKeys.Cargo:
                                                        @(string.IsNullOrWhiteSpace(item.Cargo) ? "—" : item.Cargo)
                                                        break;
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        }
                    </table>
                </div>

                <div class="result-pagination">
                    <span class="result-pagination__info">@_pagedTotal registro(s)</span>
                    <div class="result-pagination__controls">
                        <button class="result-pagination__btn" title="Página anterior"
                                @onclick="() => CambiarPaginaAsync(_pageNumber - 1)"
                                disabled="@(!_hasPrev || _loadingList)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span class="result-pagination__btn result-pagination__btn--active">@_pageNumber / @_totalPages</span>
                        <button class="result-pagination__btn" title="Página siguiente"
                                @onclick="() => CambiarPaginaAsync(_pageNumber + 1)"
                                disabled="@(!_hasNext || _loadingList)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                    <select class="result-pagination__size" title="Registros por página"
                            value="@_filters.PageSize"
                            @onchange="OnPageSizeChangedAsync"
                            disabled="@_loadingList">
                        <option value="25">25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            }
        </section>
    }
</div>

@code {
    private readonly ContactosFilters _filters = new();
    private readonly ContactoSaveRequest _form = new();
    private readonly List<ContactoGridItemDto> _items = [];
    private readonly List<ProvinciaOptionDto> _provincias = [];
    private readonly List<ContactoViewColumnDto> _viewSettingsDraft = [];
    private readonly Dictionary<string, string> _fieldErrors = new(StringComparer.OrdinalIgnoreCase);
    private AppUiMessage? _feedback;
    private ContactosViewSettingsDto _viewSettings = BuildDefaultViewSettings();
    private bool _loadingList;
    private bool _loadingProvincias;
    private bool _saving;
    private bool _isNewMode = true;
    private bool _showEditor;
    private bool _showViewSettings;
    private bool _viewSettingsLoaded;
    private bool _selectedActivo = true;
    private int _selectedId;
    private int _pagedTotal;
    private int _pageNumber = 1;
    private int _totalPages = 1;
    private bool _hasPrev;
    private bool _hasNext;
    private string _activoFiltro = "1";
    private string _draftAgruparPor = ContactosViewGroupKeys.None;
    private string _viewSettingsUserName = string.Empty;
    private ContactoTab _activeTab = ContactoTab.Datos;

    protected override async Task OnInitializedAsync()
    {
        AppUserSession.StateChanged += OnAppUserSessionChanged;
        await EnsureViewSettingsLoadedAsync();
        await CargarProvinciasAsync();
        await BuscarAsync();
    }

    public void Dispose()
        => AppUserSession.StateChanged -= OnAppUserSessionChanged;

    private void OnAppUserSessionChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await EnsureViewSettingsLoadedAsync(force: true);
            StateHasChanged();
        });
    }

    private async Task CargarProvinciasAsync()
    {
        _loadingProvincias = true;
        try
        {
            var result = await UiOps.RunAsync(() => ContactosSvc.GetProvinciasAsync(), "No se pudieron cargar las provincias.");
            if (!result.Success || result.Value is null)
            {
                SetFeedback(result.Feedback);
                return;
            }

            _provincias.Clear();
            _provincias.AddRange(result.Value);
        }
        finally
        {
            _loadingProvincias = false;
        }
    }

    private async Task RecargarAsync()
    {
        await CargarProvinciasAsync();
        await BuscarAsync();
        if (!_isNewMode && _selectedId > 0)
            await SeleccionarAsync(_selectedId);
    }

    private async Task AplicarFiltrosAsync()
    {
        _filters.PageNumber = 1;
        await BuscarAsync();
    }

    private async Task BuscarAsync()
    {
        _loadingList = true;
        SyncFilters();

        try
        {
            var result = await UiOps.RunAsync(() => ContactosSvc.SearchAsync(_filters), "No se pudieron cargar los contactos.");
            if (!result.Success || result.Value is null)
            {
                SetFeedback(result.Feedback);
                return;
            }

            _items.Clear();
            _items.AddRange(result.Value.Items);
            _pagedTotal  = result.Value.Total;
            _pageNumber  = result.Value.PageNumber;
            _totalPages  = result.Value.TotalPages;
            _hasPrev     = result.Value.HasPrev;
            _hasNext     = result.Value.HasNext;
        }
        finally
        {
            _loadingList = false;
        }
    }

    private async Task CambiarPaginaAsync(int page)
    {
        if (page < 1 || page > _totalPages || _loadingList)
            return;
        _filters.PageNumber = page;
        await BuscarAsync();
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size) && size > 0)
            _filters.PageSize = size;
        _filters.PageNumber = 1;
        await BuscarAsync();
    }

    private async Task SeleccionarAsync(int id)
    {
        if (id <= 0)
            return;

        var result = await UiOps.RunAsync(() => ContactosSvc.GetByIdAsync(id), "No se pudo cargar el contacto.");
        if (!result.Success)
        {
            SetFeedback(result.Feedback);
            return;
        }

        if (result.Value is null)
        {
            SetFeedback(new AppUiMessage
            {
                Severity = AppUiFeedbackSeverity.Warning,
                Title = "Contacto no disponible",
                Message = "El contacto seleccionado ya no existe en la base activa."
            });
            await BuscarAsync();
            BeginNew();
            return;
        }

        MapDetailToForm(result.Value);
    }

    private void BeginNew()
    {
        ClearFieldErrors();
        _showEditor = true;
        _isNewMode = true;
        _activeTab = ContactoTab.Datos;
        _selectedId = 0;
        _selectedActivo = true;

        _form.Id = null;
        _form.NombreApellido = string.Empty;
        _form.Domicilio = string.Empty;
        _form.Localidad = string.Empty;
        _form.ProvinciaCodigo = string.Empty;
        _form.CodigoPostal = string.Empty;
        _form.NumeroDocumento = string.Empty;
        _form.Telefono = string.Empty;
        _form.TelefonoAlternativo = string.Empty;
        _form.Celular = string.Empty;
        _form.Email = string.Empty;
        _form.MailPagosCobranzas = false;
        _form.MailOrdenCompra = false;
        _form.MailOrdenTrabajo = false;
        _form.Website = string.Empty;
        _form.Cargo = string.Empty;
        _form.Observaciones = string.Empty;
    }

    private void CerrarEditor()
    {
        ClearFieldErrors();
        _showEditor = false;
    }

    private void ResetForm()
    {
        ClearFieldErrors();
        if (_isNewMode)
        {
            BeginNew();
            return;
        }

        _ = SeleccionarAsync(_selectedId);
    }

    private async Task GuardarAsync()
    {
        ClearFieldErrors();
        _saving = true;
        try
        {
            try
            {
                var savedId = await ContactosSvc.SaveAsync(_form);
                SetFeedback(AppUiMessage.Success("Contacto guardado", $"El contacto #{savedId} se guardó correctamente."));
                await BuscarAsync();
                await SeleccionarAsync(savedId);
            }
            catch (AppValidationException validationEx)
            {
                ApplyFieldErrors(validationEx.Validation);
                SetFeedback(new AppUiMessage
                {
                    Severity = AppUiFeedbackSeverity.Warning,
                    Title = "Revisá los datos del contacto",
                    Message = validationEx.UserMessage,
                    Suggestion = "Corregí los campos marcados y volvé a intentar."
                });
            }
            catch (Exception ex)
            {
                SetFeedback(UiOps.BuildMessage(ex, "No se pudo guardar el contacto."));
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AbrirEditorAsync(int id)
    {
        _showEditor = true;
        await SeleccionarAsync(id);
    }

    private async Task DarDeBajaAsync()
    {
        if (_isNewMode || _selectedId <= 0)
            return;

        _saving = true;
        try
        {
            var result = await UiOps.RunAsync(() => ContactosSvc.DeactivateAsync(_selectedId), "No se pudo dar de baja el contacto.");
            if (!result.Success)
            {
                SetFeedback(result.Feedback);
                return;
            }

            SetFeedback(AppUiMessage.Success("Contacto dado de baja", $"El contacto #{_selectedId} quedó inactivo."));
            BeginNew();
            _showEditor = false;
            await BuscarAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private void LimpiarFiltros()
    {
        _filters.Texto = string.Empty;
        _activoFiltro = "1";
    }

    private void SyncFilters()
    {
        _filters.Activo = _activoFiltro switch
        {
            "1" => true,
            "0" => false,
            _ => null
        };
    }

    private void MapDetailToForm(ContactoDetailDto detail)
    {
        ClearFieldErrors();
        _isNewMode = false;
        _showEditor = true;
        _activeTab = ContactoTab.Datos;
        _selectedId = detail.Id;
        _selectedActivo = detail.Activo;

        _form.Id = detail.Id;
        _form.NombreApellido = detail.NombreApellido;
        _form.Domicilio = detail.Domicilio;
        _form.Localidad = detail.Localidad;
        _form.ProvinciaCodigo = detail.ProvinciaCodigo;
        _form.CodigoPostal = detail.CodigoPostal;
        _form.NumeroDocumento = detail.NumeroDocumento;
        _form.Telefono = detail.Telefono;
        _form.TelefonoAlternativo = detail.TelefonoAlternativo;
        _form.Celular = detail.Celular;
        _form.Email = detail.Email;
        _form.MailPagosCobranzas = detail.MailPagosCobranzas;
        _form.MailOrdenCompra = detail.MailOrdenCompra;
        _form.MailOrdenTrabajo = detail.MailOrdenTrabajo;
        _form.Website = detail.Website;
        _form.Cargo = detail.Cargo;
        _form.Observaciones = detail.Observaciones;
    }

    private void ClearFieldErrors()
        => _fieldErrors.Clear();

    private void ApplyFieldErrors(ValidationResult validation)
    {
        ClearFieldErrors();
        foreach (var issue in validation.Issues)
        {
            if (!string.IsNullOrWhiteSpace(issue.FieldKey))
                _fieldErrors[issue.FieldKey.Trim()] = issue.Message;
        }
    }

    private bool HasFieldError(string key)
        => !string.IsNullOrWhiteSpace(key) && _fieldErrors.ContainsKey(key.Trim());

    private string GetFieldError(string key)
        => HasFieldError(key) ? _fieldErrors[key.Trim()] : string.Empty;

    private string GetFieldInputClass(string key)
        => HasFieldError(key) ? "usuarios-input usuarios-input--invalid" : "usuarios-input";

    private void SetFeedback(AppUiMessage? message)
        => _feedback = message;

    private static string GetFeedbackClass(AppUiMessage message)
        => message.Severity switch
        {
            AppUiFeedbackSeverity.Success => "editor-msg--ok",
            AppUiFeedbackSeverity.Warning => "editor-msg--warning",
            _ => "editor-msg--error"
        };

    private async Task EnsureViewSettingsLoadedAsync(bool force = false)
    {
        var currentUser = AppUserSession.GetCurrentUserName(string.Empty).Trim();
        if (!force && _viewSettingsLoaded && string.Equals(_viewSettingsUserName, currentUser, StringComparison.OrdinalIgnoreCase))
            return;

        if (string.IsNullOrWhiteSpace(currentUser))
        {
            ApplyViewSettings(BuildDefaultViewSettings(), string.Empty);
            return;
        }

        var result = await UiOps.RunAsync(() => ContactosSvc.GetViewSettingsAsync(currentUser), "No se pudo cargar la configuración de vista.");
        if (!result.Success || result.Value is null)
        {
            ApplyViewSettings(BuildDefaultViewSettings(), currentUser);
            return;
        }

        ApplyViewSettings(result.Value, currentUser);
    }

    private void ApplyViewSettings(ContactosViewSettingsDto settings, string userName)
    {
        _viewSettings = settings;
        _viewSettingsUserName = userName;
        _viewSettingsLoaded = true;
        _draftAgruparPor = settings.AgruparPor;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(CloneColumns(settings.Columnas));
    }

    private void AbrirConfiguracionVista()
    {
        _showViewSettings = true;
        _draftAgruparPor = _viewSettings.AgruparPor;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(CloneColumns(_viewSettings.Columnas));
    }

    private void CancelarConfiguracionVista()
    {
        _showViewSettings = false;
    }

    private void ToggleViewColumn(string key, ChangeEventArgs args)
    {
        var column = _viewSettingsDraft.FirstOrDefault(c => string.Equals(c.Key, key, StringComparison.OrdinalIgnoreCase));
        if (column is null) return;
        column.Visible = args.Value is bool flag && flag;
        if (!_viewSettingsDraft.Any(c => c.Visible))
            column.Visible = true;
    }

    private void MoveViewColumn(string key, int offset)
    {
        var ordered = _viewSettingsDraft.OrderBy(c => c.Order).ToList();
        var index = ordered.FindIndex(c => string.Equals(c.Key, key, StringComparison.OrdinalIgnoreCase));
        if (index < 0) return;
        var target = index + offset;
        if (target < 0 || target >= ordered.Count) return;
        (ordered[index], ordered[target]) = (ordered[target], ordered[index]);
        for (var i = 0; i < ordered.Count; i++) ordered[i].Order = i;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(ordered);
    }

    private async Task GuardarConfiguracionVistaAsync()
    {
        var currentUser = AppUserSession.GetCurrentUserName(string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(currentUser))
        {
            SetFeedback(new AppUiMessage { Severity = AppUiFeedbackSeverity.Warning, Title = "Sesión requerida", Message = "Necesitás iniciar sesión para guardar la configuración de vista." });
            return;
        }

        var settings = new ContactosViewSettingsDto { AgruparPor = _draftAgruparPor, Columnas = CloneColumns(_viewSettingsDraft) };
        var result = await UiOps.RunAsync(async () => { await ContactosSvc.SaveViewSettingsAsync(currentUser, settings); return true; }, "No se pudo guardar la configuración de vista.");
        if (!result.Success) { SetFeedback(result.Feedback); return; }

        ApplyViewSettings(settings, currentUser);
        _showViewSettings = false;
        SetFeedback(AppUiMessage.Success("Vista guardada", "La configuración de la grilla quedó actualizada para tu usuario."));
    }

    private IReadOnlyList<ContactoViewColumnDto> GetVisibleColumns()
        => _viewSettings.Columnas.Where(c => c.Visible).OrderBy(c => c.Order).ToList();

    private IReadOnlyList<ContactoGridGroup> BuildGridGroups()
    {
        if (_viewSettings.AgruparPor != ContactosViewGroupKeys.Activo)
            return [new ContactoGridGroup { Label = string.Empty, ShowHeader = false, Items = _items.ToList() }];

        return _items
            .GroupBy(item => item.Activo ? "Activos" : "Inactivos")
            .OrderByDescending(g => g.Key)
            .Select(g => new ContactoGridGroup { Label = g.Key, ShowHeader = true, Items = g.ToList() })
            .ToList();
    }

    private static string GetGroupingLabel(string grouping)
        => grouping == ContactosViewGroupKeys.Activo ? "Estado" : "Sin agrupar";

    private static ContactosViewSettingsDto BuildDefaultViewSettings()
        => new()
        {
            AgruparPor = ContactosViewGroupKeys.None,
            Columnas =
            [
                new() { Key = ContactosViewColumnKeys.Nombre,    Label = "Nombre",    Visible = true,  Order = 0 },
                new() { Key = ContactosViewColumnKeys.Localidad, Label = "Localidad", Visible = true,  Order = 1 },
                new() { Key = ContactosViewColumnKeys.Provincia, Label = "Provincia", Visible = true,  Order = 2 },
                new() { Key = ContactosViewColumnKeys.Telefono,  Label = "Teléfono",  Visible = true,  Order = 3 },
                new() { Key = ContactosViewColumnKeys.Celular,   Label = "Celular",   Visible = true,  Order = 4 },
                new() { Key = ContactosViewColumnKeys.Email,     Label = "Email",     Visible = true,  Order = 5 },
                new() { Key = ContactosViewColumnKeys.Cargo,     Label = "Cargo",     Visible = false, Order = 6 }
            ]
        };

    private static List<ContactoViewColumnDto> CloneColumns(IEnumerable<ContactoViewColumnDto> columns)
        => columns.OrderBy(c => c.Order)
                  .Select(c => new ContactoViewColumnDto { Key = c.Key, Label = c.Label, Visible = c.Visible, Order = c.Order })
                  .ToList();

    private sealed class ContactoGridGroup
    {
        public string Label { get; init; } = string.Empty;
        public bool ShowHeader { get; init; }
        public List<ContactoGridItemDto> Items { get; init; } = [];
    }

    private enum ContactoTab
    {
        Datos = 0,
        Observaciones = 1
    }
}
