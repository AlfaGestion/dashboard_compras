@page "/costos/lotes/{Id:int}"
@using AlfaCore.Models
@inject AlfaCore.Services.ICostosService CostosSvc
@inject AlfaCore.Services.IAppUiOperationService UiOps

<PageTitle>Lote de Costos | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando lote…
    </div>
}
else if (_detail is null)
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> Lote no encontrado.
        <a href="/costos">Volver al módulo</a>
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">@_detail.Batch.ProviderName</h2>
                <p class="page-intro__text">
                    Lote #@_detail.Batch.Id
                    @if (_detail.Profile is not null)
                    {
                        <span> · Perfil: @_detail.Profile.ProviderName@(string.IsNullOrWhiteSpace(_detail.Profile.ProviderAccount) ? string.Empty : $" [{_detail.Profile.ProviderAccount}]")</span>
                    }
                    <span> · @_detail.Batch.SourceFileName · @_detail.Batch.Status</span>
                </p>
            </div>
            <div class="actions">
                <a class="btn btn--secondary"
                   href="/api/costos/importaciones/@_detail.Batch.Id/descargar-archivo"
                   target="_blank">
                    <i class="bi bi-file-earmark-arrow-down"></i>
                    <span>Archivo original</span>
                </a>
                <button class="btn btn--primary" @onclick="ProcesarMatchingAsync" disabled="@_busy">
                    <i class="bi bi-diagram-3"></i>
                    <span>Procesar matching</span>
                </button>
                <button class="btn btn--ghost" @onclick="DeshacerAplicacionAsync" disabled="@(_busy || !_detail.Rows.Any(r => string.Equals(r.Status, "APLICADO", StringComparison.OrdinalIgnoreCase)))">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    <span>Deshacer aplicación</span>
                </button>
            </div>
        </section>

        <section class="kpi-grid">
            <article class="kpi-card">
                <div class="kpi-card__label">Filas leídas</div>
                <div class="kpi-card__value">@_detail.Batch.TotalRowsRead</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Con costo</div>
                <div class="kpi-card__value">@_detail.Batch.TotalRowsWithCost</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Elegidas</div>
                <div class="kpi-card__value">@_detail.Rows.Count(r => r.HasChosenArticle)</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Chequeadas</div>
                <div class="kpi-card__value">@_checkedRows.Count</div>
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Revisión del lote</h3>
                    <p class="panel-card__subtitle">Compará lo leído del Excel contra SQL, elegí artículo, chequeá filas y aplicá en lote.</p>
                </div>
                <div class="actions">
                    <button class="btn btn--ghost" @onclick="ToggleVisibleChecks" disabled="@(_busy || !FilteredRows.Any(r => r.CanBeChecked))">
                        <i class="bi bi-check2-square"></i>
                        <span>@(AreAllVisibleChecked ? "Desmarcar visibles" : "Marcar visibles")</span>
                    </button>
                    <button class="btn btn--ghost" @onclick="ClearChecks" disabled="@(_busy || _checkedRows.Count == 0)">
                        <i class="bi bi-eraser"></i>
                        <span>Limpiar checks</span>
                    </button>
                    <button class="btn btn--primary" @onclick="AplicarSeleccionadasAsync" disabled="@(_busy || _checkedRows.Count == 0)">
                        <i class="bi bi-check2-square"></i>
                        <span>Aplicar chequeadas</span>
                    </button>
                </div>
            </div>

            @if (_busy && _matchingProgress > 0)
            {
                <div style="margin-bottom:1rem;">
                    <div style="width:100%; height:8px; background:var(--color-border); border-radius:4px; overflow:hidden;">
                        <div style="width:@(_matchingProgress)%; height:100%; background:var(--color-primary); border-radius:4px; transition:width .25s ease;"></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:.3rem;">
                        <small style="color:var(--color-muted);">@_matchingProgress%</small>
                        <button class="btn-link btn-link--danger" @onclick="CancelarMatching" style="font-size:.82rem;">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                    </div>
                </div>
            }

            <div class="filters-grid costos-lote__filters">
                <div class="field">
                    <label class="field__label">Filtro</label>
                    <select class="field__control" @bind="_statusFilter">
                        <option value="todos">Todos (@_detail.Rows.Count)</option>
                        <option value="confirmado">Elegidas (@CountRows("CONFIRMADO"))</option>
                        <option value="matcheado">Matcheadas (@CountRows("MATCHEADO"))</option>
                        <option value="sin_match">Sin match (@CountRows("SIN_MATCH"))</option>
                        <option value="descartado">Descartadas (@CountRows("DESCARTADO"))</option>
                        <option value="aplicado">Aplicadas (@CountRows("APLICADO"))</option>
                        <option value="error">Con error (@CountRows("ERROR"))</option>
                    </select>
                </div>
                <div class="field">
                    <label class="field__label">Buscar</label>
                    <input class="field__control" @bind="_searchText" @bind:event="oninput" placeholder="Código, descripción, código proveedor SQL o artículo..." />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="editor-msg @(_isError ? "editor-msg--error" : "editor-msg--ok")" style="margin-bottom:1rem;">
                    <i class="bi @(_isError ? "bi-exclamation-circle" : "bi-check-circle")"></i> @_message
                </div>
            }

            <div class="costos-lote__grid-shell">
                <div class="table-wrap costos-lote__table-wrap">
                    <table class="data-table costos-lote__table">
                        <thead>
                            <tr>
                                <th class="costos-lote__check-cell">
                                    <button type="button" class="costos-lote__sort-btn" @onclick="ToggleVisibleChecks">
                                        <i class="bi bi-check2-square"></i>
                                    </button>
                                </th>
                                <th>@SortButton("Fila", "fila")</th>
                                <th>@SortButton("Estado", "estado")</th>
                                <th>@SortButton("Código", "codigo")</th>
                                <th>@SortButton("Descripción", "descripcion")</th>
                                <th>@SortButton("Costo leído", "costo")</th>
                                <th>@SortButton("% variación", "variacion")</th>
                                <th>@SortButton("Costo actual", "costoactual")</th>
                                <th>@SortButton("CodigoArtProveedor", "codigosql")</th>
                                <th>@SortButton("Descripción SQL", "descripcionsql")</th>
                                <th>@SortButton("IdArticulo", "articulo")</th>
                                <th>@SortButton("Score", "score")</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredRows)
                            {
                                <tr class="@BuildRowClass(row)">
                                    <td class="costos-lote__check-cell">
                                        <input type="checkbox"
                                               checked="@_checkedRows.Contains(row.RowNumber)"
                                               disabled="@(_busy || !row.CanBeChecked)"
                                               @onchange="e => ToggleRowCheck(row, e.Value is true)" />
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">@row.RowNumber</td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <span class="costos-lote__state @StateClass(row.Status)">@FormatStatus(row.Status)</span>
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <strong>@(string.IsNullOrWhiteSpace(row.ProviderCodeRead) ? "—" : row.ProviderCodeRead)</strong>
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <div class="costos-lote__text">@row.DescriptionRead</div>
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        @(row.CostRead?.ToString("N2") ?? "—")
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <span class="costos-lote__variation @VariationClass(row.VariationPct)">
                                            @FormatVariation(row.VariationPct)
                                        </span>
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        @(row.CurrentCost?.ToString("N2") ?? "—")
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        @(string.IsNullOrWhiteSpace(row.ArticleProviderCode) ? "—" : row.ArticleProviderCode)
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <div class="costos-lote__text">@(!string.IsNullOrWhiteSpace(row.ArticleDescription) ? row.ArticleDescription : "—")</div>
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        @(string.IsNullOrWhiteSpace(row.ArticleId) ? "—" : row.ArticleId)
                                    </td>
                                    <td @onclick="() => SeleccionarFilaAsync(row)">
                                        <span class="costos-lote__score @ScoreClass(row.MatchType, row.MatchScore)">@row.MatchScore.ToString("N1")</span>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn--ghost btn--sm" @onclick="() => AbrirCandidatosAsync(row)">
                                            <i class="bi bi-search"></i>
                                            <span>Buscar</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>
}

@if (_showCandidatesModal)
{
    <div class="costos-lote__modal-backdrop" @onclick="CerrarCandidatos"></div>
    <section class="costos-lote__modal" role="dialog" aria-modal="true" aria-label="Candidatos">
        <div class="panel-card costos-lote__modal-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Búsqueda de artículos</h3>
                    <p class="panel-card__subtitle">
                        Fila seleccionada: @(_selectedRow?.RowNumber.ToString() ?? "—")
                    </p>
                </div>
                <button type="button" class="btn btn--ghost btn--sm" @onclick="CerrarCandidatos">
                    <i class="bi bi-x-lg"></i>
                    <span>Cerrar</span>
                </button>
            </div>

            @if (_selectedRow is not null)
            {
                <div class="costos-lote__summary">
                    <div>
                        <span class="costos-lote__summary-label">Excel</span>
                        <strong>@(string.IsNullOrWhiteSpace(_selectedRow.ProviderCodeRead) ? "Sin código" : _selectedRow.ProviderCodeRead)</strong>
                        <div class="costos-lote__text">@_selectedRow.DescriptionRead</div>
                        <small>Costo leído: @(_selectedRow.CostRead?.ToString("N2") ?? "—")</small>
                    </div>
                    <div>
                        <span class="costos-lote__summary-label">SQL actual</span>
                        <strong>@(string.IsNullOrWhiteSpace(_selectedRow.ArticleProviderCode) ? "Sin artículo elegido" : _selectedRow.ArticleProviderCode)</strong>
                        <div class="costos-lote__text">@(!string.IsNullOrWhiteSpace(_selectedRow.ArticleDescription) ? _selectedRow.ArticleDescription : "—")</div>
                        <small>Id: @(!string.IsNullOrWhiteSpace(_selectedRow.ArticleId) ? _selectedRow.ArticleId : "—")</small>
                    </div>
                </div>

                <div class="filters-grid costos-lote__candidate-tools">
                    <div class="field">
                        <label class="field__label">Buscar candidatos</label>
                        <input class="field__control"
                               @bind="_candidateSearch"
                               @bind:event="oninput"
                               placeholder="Probá otra descripción, código proveedor o artículo..." />
                    </div>
                    <div class="field">
                        <label class="field__label">Búsqueda</label>
                        <label class="costos-lote__fallback">
                            <input type="checkbox" @bind="_includeFallbackSearch" />
                            <span>Ampliar fuera del proveedor</span>
                        </label>
                    </div>
                </div>

                <div class="actions" style="margin-bottom:1rem;">
                    <button class="btn btn--ghost btn--sm" @onclick="BuscarCandidatosAsync" disabled="@_busy">
                        <i class="bi bi-search"></i>
                        <span>Actualizar candidatos</span>
                    </button>
                    <button class="btn btn--primary btn--sm" @onclick="ElegirCandidatoAsync" disabled="@(_busy || _selectedCandidate is null)">
                        <i class="bi bi-check2-circle"></i>
                        <span>Elegir artículo</span>
                    </button>
                    <button class="btn btn--ghost btn--sm" @onclick="DescartarFilaAsync" disabled="@_busy">
                        <i class="bi bi-x-circle"></i>
                        <span>Descartar fila</span>
                    </button>
                </div>

                <div class="table-wrap costos-lote__modal-table-wrap">
                    <table class="data-table costos-lote__table">
                        <thead>
                            <tr>
                                <th>Artículo</th>
                                <th>CodigoArtProveedor</th>
                                <th>Descripción</th>
                                <th>Costo actual</th>
                                <th>Score</th>
                                <th>% var.</th>
                                <th>Origen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var candidate in _candidates)
                            {
                                <tr class="@(_selectedCandidate?.ArticleId == candidate.ArticleId ? "table-row-selected" : string.Empty)"
                                    style="cursor:pointer"
                                    @onclick="() => _selectedCandidate = candidate">
                                    <td>@candidate.ArticleId</td>
                                    <td>@candidate.ProviderCode</td>
                                    <td><div class="costos-lote__text">@candidate.Description</div></td>
                                    <td>@(candidate.CurrentCost?.ToString("N2") ?? "—")</td>
                                    <td><span class="costos-lote__score @ScoreClass(candidate.MatchType, candidate.Score)">@candidate.Score.ToString("N1")</span></td>
                                    <td><span class="costos-lote__variation @VariationClass(candidate.VariationPct)">@FormatVariation(candidate.VariationPct)</span></td>
                                    <td>@(candidate.SearchScope == "plan_b" ? "Plan B" : "Proveedor")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private bool _busy;
    private int _matchingProgress;
    private CancellationTokenSource? _matchingCts;
    private CostosBatchDetailDto? _detail;
    private CostosBatchDetailRowDto? _selectedRow;
    private IReadOnlyList<CostosMatchCandidateDto> _candidates = [];
    private CostosMatchCandidateDto? _selectedCandidate;
    private readonly HashSet<int> _checkedRows = [];
    private string _message = string.Empty;
    private bool _isError;
    private string _statusFilter = "todos";
    private string _searchText = string.Empty;
    private string _candidateSearch = string.Empty;
    private bool _includeFallbackSearch;
    private string _sortColumn = "score";
    private bool _sortDescending = true;
    private bool _showCandidatesModal;
    private AlfaCore.Models.AppUiMessage? _feedback;

    private List<CostosBatchDetailRowDto> FilteredRows =>
        SortRows((_detail?.Rows ?? [])
            .Where(MatchesStatusFilter)
            .Where(MatchesSearch))
            .ToList();

    private bool AreAllVisibleChecked =>
        FilteredRows.Where(r => r.CanBeChecked).Any()
        && FilteredRows.Where(r => r.CanBeChecked).All(r => _checkedRows.Contains(r.RowNumber));

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        var result = await UiOps.RunAsync(
            () => CostosSvc.GetBatchDetailAsync(Id),
            "No se pudo cargar el lote de costos.");

        if (!result.Success)
        {
            _feedback = result.Feedback;
            _isError = true;
            _message = BuildFeedbackText(result.Feedback);
            return;
        }

        _feedback = null;
        _detail = result.Value;
        if (_detail is null)
            return;

        SyncCheckedRows();

        if (_selectedRow is not null)
        {
            _selectedRow = _detail.Rows.FirstOrDefault(r => r.RowNumber == _selectedRow.RowNumber);
            if (_selectedRow is not null)
            {
                await LoadCandidatesAsync(_selectedRow.RowNumber);
            }
        }
    }

    private void SyncCheckedRows()
    {
        if (_detail is null)
            return;

        _checkedRows.RemoveWhere(rowNumber => !_detail.Rows.Any(r => r.RowNumber == rowNumber && r.CanBeChecked));
        if (_checkedRows.Count == 0)
        {
            foreach (var row in _detail.Rows.Where(r => string.Equals(r.Status, "CONFIRMADO", StringComparison.OrdinalIgnoreCase)))
            {
                _checkedRows.Add(row.RowNumber);
            }
        }
    }

    private void CancelarMatching() => _matchingCts?.Cancel();

    private async Task ProcesarMatchingAsync()
    {
        _busy = true;
        _matchingProgress = 0;
        _message = string.Empty;
        _isError = false;
        _matchingCts?.Dispose();
        _matchingCts = new CancellationTokenSource();

        var progress = new Progress<int>(pct =>
        {
            _matchingProgress = pct;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            await CostosSvc.ProcessMatchingAsync(Id, Environment.UserName, progress, _matchingCts.Token);
            await ReloadAsync();
            _message = "Matching procesado correctamente.";
        }
        catch (OperationCanceledException)
        {
            _isError = true;
            _message = "Matching cancelado.";
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo procesar el matching del lote.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
            _matchingProgress = 0;
            _matchingCts?.Dispose();
            _matchingCts = null;
        }
    }

    private async Task SeleccionarFilaAsync(CostosBatchDetailRowDto row)
    {
        _selectedRow = row;
    }

    private async Task AbrirCandidatosAsync(CostosBatchDetailRowDto row)
    {
        _selectedRow = row;
        _showCandidatesModal = true;
        _candidateSearch = row.DescriptionRead;
        await LoadCandidatesAsync(row.RowNumber);
    }

    private async Task BuscarCandidatosAsync()
    {
        if (_selectedRow is null)
            return;

        await LoadCandidatesAsync(_selectedRow.RowNumber);
    }

    private async Task LoadCandidatesAsync(int rowNumber)
    {
        var result = await UiOps.RunAsync(
            () => CostosSvc.GetCandidatesAsync(Id, rowNumber, _candidateSearch, _includeFallbackSearch),
            "No se pudieron cargar los candidatos para la fila seleccionada.");

        if (!result.Success || result.Value is null)
        {
            _feedback = result.Feedback;
            _isError = true;
            _message = BuildFeedbackText(result.Feedback);
            return;
        }

        _feedback = null;
        _candidates = result.Value;
        _selectedCandidate = _candidates.FirstOrDefault(c => string.Equals(c.ArticleId, _selectedRow?.ArticleId, StringComparison.OrdinalIgnoreCase))
            ?? _candidates.FirstOrDefault();
    }

    private async Task ElegirCandidatoAsync()
    {
        if (_selectedRow is null)
            return;

        _busy = true;
        _message = string.Empty;
        _isError = false;
        try
        {
            await CostosSvc.ConfirmRowAsync(Id, _selectedRow.RowNumber, _selectedCandidate?.ArticleId, Environment.UserName);
            await ReloadAsync();
            if (_selectedRow is not null)
            {
                _checkedRows.Add(_selectedRow.RowNumber);
            }
            _message = $"Fila {_selectedRow?.RowNumber} preparada para aplicar.";
            _showCandidatesModal = false;
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo confirmar el artículo para la fila.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DescartarFilaAsync()
    {
        if (_selectedRow is null)
            return;

        _busy = true;
        _message = string.Empty;
        _isError = false;
        try
        {
            await CostosSvc.DiscardRowAsync(Id, _selectedRow.RowNumber, Environment.UserName);
            _checkedRows.Remove(_selectedRow.RowNumber);
            await ReloadAsync();
            _message = $"Fila {_selectedRow.RowNumber} descartada.";
            _showCandidatesModal = false;
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo descartar la fila seleccionada.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AplicarSeleccionadasAsync()
    {
        _busy = true;
        _message = string.Empty;
        _isError = false;
        try
        {
            var result = await CostosSvc.ApplySelectedRowsAsync(Id, _checkedRows.ToArray(), Environment.UserName);
            await ReloadAsync();
            _message = $"Aplicación finalizada. Actualizadas: {result.Updated}, sin cambio: {result.Same}, errores: {result.Errors}. Estado: {result.Status}.";
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudieron aplicar las filas seleccionadas.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeshacerAplicacionAsync()
    {
        _busy = true;
        _message = string.Empty;
        _isError = false;
        try
        {
            var result = await CostosSvc.UndoLastApplyAsync(Id, Environment.UserName);
            await ReloadAsync();
            _message = $"Deshacer finalizado. Revertidas: {result.Reverted}, errores: {result.Errors}. Estado: {result.Status}.";
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo deshacer la última aplicación del lote.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private void ToggleRowCheck(CostosBatchDetailRowDto row, bool isChecked)
    {
        if (!row.CanBeChecked)
            return;

        if (isChecked)
        {
            _checkedRows.Add(row.RowNumber);
        }
        else
        {
            _checkedRows.Remove(row.RowNumber);
        }
    }

    private void ToggleVisibleChecks()
    {
        var visible = FilteredRows.Where(r => r.CanBeChecked).Select(r => r.RowNumber).ToArray();
        if (visible.Length == 0)
            return;

        if (visible.All(rowNumber => _checkedRows.Contains(rowNumber)))
        {
            foreach (var rowNumber in visible)
            {
                _checkedRows.Remove(rowNumber);
            }
        }
        else
        {
            foreach (var rowNumber in visible)
            {
                _checkedRows.Add(rowNumber);
            }
        }
    }

    private void ClearChecks() => _checkedRows.Clear();

    private void CerrarCandidatos()
    {
        _showCandidatesModal = false;
    }

    private RenderFragment SortButton(string label, string column) => builder =>
    {
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", $"costos-lote__sort-btn {(_sortColumn == column ? "is-active" : string.Empty)}");
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => SetSort(column)));
        builder.AddContent(4, label);
        if (_sortColumn == column)
        {
            builder.AddMarkupContent(5, _sortDescending ? " <i class=\"bi bi-sort-down\"></i>" : " <i class=\"bi bi-sort-up\"></i>");
        }
        builder.CloseElement();
    };

    private void SetSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortDescending = !_sortDescending;
            return;
        }

        _sortColumn = column;
        _sortDescending = column switch
        {
            "fila" => false,
            "codigo" => false,
            "descripcion" => false,
            "codigosql" => false,
            "descripcionsql" => false,
            "articulo" => false,
            _ => true
        };
    }

    private IEnumerable<CostosBatchDetailRowDto> SortRows(IEnumerable<CostosBatchDetailRowDto> rows)
    {
        var ordered = _sortColumn switch
        {
            "fila" => _sortDescending ? rows.OrderByDescending(r => r.RowNumber) : rows.OrderBy(r => r.RowNumber),
            "estado" => _sortDescending ? rows.OrderByDescending(r => r.Status) : rows.OrderBy(r => r.Status),
            "codigo" => _sortDescending ? rows.OrderByDescending(r => r.ProviderCodeRead) : rows.OrderBy(r => r.ProviderCodeRead),
            "descripcion" => _sortDescending ? rows.OrderByDescending(r => r.DescriptionRead) : rows.OrderBy(r => r.DescriptionRead),
            "costo" => _sortDescending ? rows.OrderByDescending(r => r.CostRead ?? decimal.MinValue) : rows.OrderBy(r => r.CostRead ?? decimal.MaxValue),
            "costoactual" => _sortDescending ? rows.OrderByDescending(r => r.CurrentCost ?? decimal.MinValue) : rows.OrderBy(r => r.CurrentCost ?? decimal.MaxValue),
            "codigosql" => _sortDescending ? rows.OrderByDescending(r => r.ArticleProviderCode) : rows.OrderBy(r => r.ArticleProviderCode),
            "descripcionsql" => _sortDescending ? rows.OrderByDescending(r => r.ArticleDescription) : rows.OrderBy(r => r.ArticleDescription),
            "articulo" => _sortDescending ? rows.OrderByDescending(r => r.ArticleId) : rows.OrderBy(r => r.ArticleId),
            "variacion" => _sortDescending ? rows.OrderByDescending(r => r.VariationPct ?? double.MinValue) : rows.OrderBy(r => r.VariationPct ?? double.MaxValue),
            _ => _sortDescending ? rows.OrderByDescending(r => r.MatchScore) : rows.OrderBy(r => r.MatchScore)
        };

        return ordered.ThenBy(r => r.RowNumber);
    }

    private int CountRows(string status) =>
        _detail?.Rows.Count(r => string.Equals(r.Status, status, StringComparison.OrdinalIgnoreCase)) ?? 0;

    private bool MatchesStatusFilter(CostosBatchDetailRowDto row) =>
        _statusFilter switch
        {
            "confirmado" => string.Equals(row.Status, "CONFIRMADO", StringComparison.OrdinalIgnoreCase),
            "matcheado" => string.Equals(row.Status, "MATCHEADO", StringComparison.OrdinalIgnoreCase),
            "sin_match" => string.Equals(row.Status, "SIN_MATCH", StringComparison.OrdinalIgnoreCase),
            "descartado" => string.Equals(row.Status, "DESCARTADO", StringComparison.OrdinalIgnoreCase),
            "aplicado" => string.Equals(row.Status, "APLICADO", StringComparison.OrdinalIgnoreCase),
            "error" => string.Equals(row.Status, "ERROR", StringComparison.OrdinalIgnoreCase),
            _ => true
        };

    private bool MatchesSearch(CostosBatchDetailRowDto row)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
            return true;

        var text = _searchText.Trim();
        return Contains(row.ProviderCodeRead, text)
            || Contains(row.DescriptionRead, text)
            || Contains(row.ArticleProviderCode, text)
            || Contains(row.ArticleId, text)
            || Contains(row.ArticleDescription, text)
            || Contains(row.ApplyResult, text);
    }

    private static bool Contains(string? source, string text) =>
        !string.IsNullOrWhiteSpace(source) && source.Contains(text, StringComparison.OrdinalIgnoreCase);

    private string BuildRowClass(CostosBatchDetailRowDto row)
    {
        var classes = new List<string>();
        if (_selectedRow?.RowNumber == row.RowNumber)
            classes.Add("table-row-selected");
        classes.Add(StateClass(row.Status));
        return string.Join(' ', classes);
    }

    private static string FormatStatus(string status) => status switch
    {
        "CONFIRMADO" => "Elegida",
        "MATCHEADO" => "Matcheada",
        "SIN_MATCH" => "Sin match",
        "DESCARTADO" => "Descartada",
        "APLICADO" => "Aplicada",
        "ERROR" => "Error",
        _ => status
    };

    private static string StateClass(string status) => status.ToUpperInvariant() switch
    {
        "CONFIRMADO" => "is-confirmed",
        "MATCHEADO" => "is-matched",
        "SIN_MATCH" => "is-missing",
        "DESCARTADO" => "is-discarded",
        "APLICADO" => "is-applied",
        "ERROR" => "is-error",
        _ => string.Empty
    };

    private static string ScoreClass(string matchType, double score)
    {
        if (string.Equals(matchType, "provider_code_exact", StringComparison.OrdinalIgnoreCase))
            return "is-exact";
        if (score >= 85)
            return "is-good";
        if (score >= 65)
            return "is-mid";
        return "is-low";
    }

    private static string VariationClass(double? variation)
    {
        if (variation is null)
            return "is-flat";
        if (variation > 0.01)
            return Math.Abs(variation.Value) >= 40 ? "is-up-strong" : "is-up";
        if (variation < -0.01)
            return Math.Abs(variation.Value) >= 40 ? "is-down-strong" : "is-down";
        return "is-flat";
    }

    private static string FormatVariation(double? variation) =>
        variation is null ? "—" : $"{variation.Value:+0.0;-0.0;0.0}%";

    private static string BuildFeedbackText(AlfaCore.Models.AppUiMessage? feedback)
    {
        if (feedback is null)
            return string.Empty;

        var parts = new List<string> { feedback.Message };
        if (feedback.HasSuggestion)
            parts.Add(feedback.Suggestion);
        if (feedback.HasCode)
            parts.Add($"Código: {feedback.Code}");
        return string.Join(" ", parts.Where(static part => !string.IsNullOrWhiteSpace(part)));
    }
}
