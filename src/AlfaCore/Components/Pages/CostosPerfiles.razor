@page "/costos/perfiles"
@inject AlfaCore.Services.ICostosService CostosSvc
@inject AlfaCore.Services.IAppUiOperationService UiOps

<PageTitle>Perfiles de Costos | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando perfiles…
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">Perfiles de importación</h2>
                <p class="page-intro__text">Administrá los perfiles de `V_Ta_InterODBC` para definir cómo se interpretan las listas de proveedores.</p>
            </div>
            <div class="actions">
                <button class="btn btn--primary" @onclick="NuevoPerfil">
                    <i class="bi bi-plus-circle"></i>
                    <span>Nuevo perfil</span>
                </button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <section class="panel-card">
                <div class="editor-msg @(_isError ? "editor-msg--error" : "editor-msg--ok")">
                    <i class="bi @(_isError ? "bi-exclamation-circle" : "bi-check-circle")"></i> @_message
                </div>
            </section>
        }

        <section class="split-grid">
            <div class="panel-card costos-perfiles__list">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Listado</h3>
                        <p class="panel-card__subtitle">@_profiles.Count perfiles disponibles.</p>
                    </div>
                </div>

                <div class="field" style="margin-bottom:1rem;">
                    <label class="field__label">Buscar</label>
                    <input class="field__control" @bind="_searchText" @bind:event="oninput" placeholder="Nombre del perfil o código..." />
                </div>

                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Perfil</th>
                                <th>Código proveedor</th>
                                <th>Reglas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var profile in FilteredProfiles)
                            {
                                <tr class="@(_editId == profile.Id ? "table-row-selected" : string.Empty)"
                                    style="cursor:pointer"
                                    @onclick="() => Seleccionar(profile)">
                                    <td>@profile.ProviderName</td>
                                    <td>@(string.IsNullOrWhiteSpace(profile.ProviderAccount) ? "—" : profile.ProviderAccount)</td>
                                    <td>@BuildRules(profile)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel-card costos-perfiles__editor">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">@(_editId == 0 ? "Nuevo perfil" : $"Editar perfil #{_editId}")</h3>
                        <p class="panel-card__subtitle">Configuración operativa para importar costos por perfil.</p>
                    </div>
                </div>

                <div class="costos-perfiles__form">
                    <div class="field costos-perfiles__field costos-perfiles__field--full">
                        <label class="field__label">Nombre del perfil</label>
                        <input class="field__control costos-perfiles__input-lg" @bind="_providerName" placeholder="Ej: Lista Luca marzo 2026" />
                    </div>
                    <div class="field costos-perfiles__field costos-perfiles__field--code">
                        <label class="field__label">Código del proveedor</label>
                        <input class="field__control"
                               @bind="_providerAccount"
                               @bind:event="oninput"
                               @bind:after="BuscarProveedoresAsync"
                               placeholder="Escribí código o nombre..."
                               list="proveedores-sugeridos" />
                        <div class="field__hint">Opcional. Si lo completás, debe existir en la base.</div>

                        @if (_providerMatches.Count > 0)
                        {
                            <datalist id="proveedores-sugeridos">
                                @foreach (var item in _providerMatches)
                                {
                                    <option value="@item.Code">@item.Name</option>
                                }
                            </datalist>

                            <div class="costos-perfiles__lookup">
                                @foreach (var item in _providerMatches)
                                {
                                    <button type="button" class="costos-perfiles__lookup-item" @onclick="() => TomarProveedor(item)">
                                        <span class="costos-perfiles__lookup-code">@item.Code</span>
                                        <span class="costos-perfiles__lookup-name">@item.Name</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <div class="costos-perfiles__provider-preview">
                        <div>
                            <p class="costos-perfiles__provider-label">Proveedor asociado</p>
                            <strong>@SelectedProviderText</strong>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_providerAccount))
                        {
                            <button type="button" class="btn btn--ghost btn--sm" @onclick="LimpiarProveedor">
                                <i class="bi bi-x-circle"></i>
                                <span>Quitar código</span>
                            </button>
                        }
                    </div>

                    <div class="costos-perfiles__toggles">
                        <label class="checkbox costos-perfiles__toggle">
                        <input type="checkbox" @bind="_onlyAdd" />
                        <span>Solo altas</span>
                        </label>
                        <label class="checkbox costos-perfiles__toggle">
                        <input type="checkbox" @bind="_onlyModify" />
                        <span>Solo modificación</span>
                        </label>
                    </div>

                    <div class="field costos-perfiles__field costos-perfiles__field--full">
                        <label class="field__label">Notas</label>
                        <textarea class="field__control costos-perfiles__notes" rows="6" @bind="_notes" placeholder="Observaciones internas del perfil..."></textarea>
                    </div>
                </div>

                <div class="actions costos-perfiles__actions">
                    <button class="btn btn--primary" @onclick="GuardarAsync" disabled="@_busy">
                        <i class="bi bi-save"></i>
                        <span>@(_editId == 0 ? "Crear perfil" : "Guardar cambios")</span>
                    </button>
                    @if (_editId > 0)
                    {
                        <button class="btn btn--ghost" @onclick="DuplicarPerfilActual" disabled="@_busy">
                            <i class="bi bi-copy"></i>
                            <span>Duplicar como nuevo</span>
                        </button>
                    }
                    <button class="btn btn--ghost" @onclick="NuevoPerfil" disabled="@_busy">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        <span>Limpiar</span>
                    </button>
                    @if (_editId > 0)
                    {
                        <button class="btn btn--ghost" @onclick="EliminarAsync" disabled="@_busy">
                            <i class="bi bi-trash"></i>
                            <span>Eliminar</span>
                        </button>
                    }
                </div>
            </div>
        </section>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _isError;
    private string _message = string.Empty;
    private string _searchText = string.Empty;
    private IReadOnlyList<CostosProfileDto> _profiles = [];
    private IReadOnlyList<CostosProviderLookupDto> _providerMatches = [];
    private CostosProviderLookupDto? _selectedProvider;

    private int _editId;
    private string _providerName = string.Empty;
    private string _providerAccount = string.Empty;
    private string _notes = string.Empty;
    private bool _onlyAdd;
    private bool _onlyModify;
    private AlfaCore.Models.AppUiMessage? _feedback;

    private string SelectedProviderText =>
        _selectedProvider is not null
            ? $"{_selectedProvider.Name} [{_selectedProvider.Code}]"
            : string.IsNullOrWhiteSpace(_providerAccount)
                ? "Sin código asociado"
                : $"Código seleccionado: {_providerAccount}";

    private IEnumerable<CostosProfileDto> FilteredProfiles =>
        _profiles.Where(p =>
            string.IsNullOrWhiteSpace(_searchText)
            || p.ProviderName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || p.ProviderAccount.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var result = await UiOps.RunAsync(
            () => LoadProfilesAsync(),
            "No se pudieron cargar los perfiles de costos.");
        _feedback = result.Feedback;
        if (!result.Success)
        {
            _isError = true;
            _message = BuildFeedbackText(result.Feedback);
        }
        _loading = false;
    }

    private async Task LoadProfilesAsync()
    {
        _profiles = await CostosSvc.GetProfilesAsync();
    }

    private void NuevoPerfil()
    {
        _editId = 0;
        _providerName = string.Empty;
        _providerAccount = string.Empty;
        _providerMatches = [];
        _selectedProvider = null;
        _notes = string.Empty;
        _onlyAdd = false;
        _onlyModify = false;
        _message = string.Empty;
        _isError = false;
        _feedback = null;
    }

    private void Seleccionar(CostosProfileDto profile)
    {
        _editId = profile.Id;
        _providerName = profile.ProviderName;
        _providerAccount = profile.ProviderAccount;
        _providerMatches = [];
        _selectedProvider = string.IsNullOrWhiteSpace(profile.ProviderAccount)
            ? null
            : new CostosProviderLookupDto { Code = profile.ProviderAccount, Name = profile.ProviderAccount };
        _notes = profile.Notes;
        _onlyAdd = profile.OnlyAdd;
        _onlyModify = profile.OnlyModify;
        _message = string.Empty;
        _isError = false;
        _feedback = null;
    }

    private async Task GuardarAsync()
    {
        _busy = true;
        _message = string.Empty;
        _isError = false;
        _feedback = null;

        try
        {
            var profile = new CostosProfileDto
            {
                Id = _editId,
                ProviderName = _providerName,
                ProviderAccount = _providerAccount,
                Notes = _notes,
                OnlyAdd = _onlyAdd,
                OnlyModify = _onlyModify
            };

            if (_editId == 0)
            {
                var newId = await CostosSvc.CreateProfileAsync(profile);
                await LoadProfilesAsync();
                var created = _profiles.FirstOrDefault(p => p.Id == newId);
                if (created is not null)
                    Seleccionar(created);
                _message = $"Perfil #{newId} creado correctamente.";
            }
            else
            {
                await CostosSvc.UpdateProfileAsync(profile);
                await LoadProfilesAsync();
                var updated = _profiles.FirstOrDefault(p => p.Id == _editId);
                if (updated is not null)
                    Seleccionar(updated);
                _message = $"Perfil #{_editId} actualizado correctamente.";
            }
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo guardar el perfil de costos.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task BuscarProveedoresAsync()
    {
        if (string.IsNullOrWhiteSpace(_providerAccount) || _providerAccount.Trim().Length < 2)
        {
            _providerMatches = [];
            return;
        }

        try
        {
            _providerMatches = await CostosSvc.SearchProvidersAsync(_providerAccount.Trim());
            var exact = _providerMatches.FirstOrDefault(x => string.Equals(x.Code, _providerAccount.Trim(), StringComparison.OrdinalIgnoreCase));
            if (exact is not null)
                _selectedProvider = exact;
        }
        catch
        {
            _providerMatches = [];
        }
    }

    private void TomarProveedor(CostosProviderLookupDto item)
    {
        _providerAccount = item.Code;
        _selectedProvider = item;
        _providerMatches = [];
    }

    private void LimpiarProveedor()
    {
        _providerAccount = string.Empty;
        _selectedProvider = null;
        _providerMatches = [];
    }

    private void DuplicarPerfilActual()
    {
        if (_editId <= 0)
            return;

        _editId = 0;
        _message = "Perfil cargado para duplicar como nuevo.";
        _isError = false;
    }

    private async Task EliminarAsync()
    {
        if (_editId <= 0)
            return;

        _busy = true;
        _message = string.Empty;
        _isError = false;
        _feedback = null;

        try
        {
            var currentId = _editId;
            await CostosSvc.DeleteProfileAsync(currentId);
            await LoadProfilesAsync();
            NuevoPerfil();
            _message = $"Perfil #{currentId} eliminado correctamente.";
        }
        catch (Exception ex)
        {
            _feedback = UiOps.BuildMessage(ex, "No se pudo eliminar el perfil de costos.");
            _isError = true;
            _message = BuildFeedbackText(_feedback);
        }
        finally
        {
            _busy = false;
        }
    }

    private static string BuildRules(CostosProfileDto profile)
    {
        var parts = new List<string>();
        if (profile.OnlyAdd) parts.Add("SoloAlta");
        if (profile.OnlyModify) parts.Add("SoloModificación");
        if (parts.Count == 0) parts.Add("Sin reglas");
        return string.Join(" · ", parts);
    }

    private static string BuildFeedbackText(AlfaCore.Models.AppUiMessage? feedback)
    {
        if (feedback is null)
            return string.Empty;

        var parts = new List<string> { feedback.Message };
        if (feedback.HasSuggestion)
            parts.Add(feedback.Suggestion);
        if (feedback.HasCode)
            parts.Add($"Código: {feedback.Code}");
        return string.Join(" ", parts.Where(static part => !string.IsNullOrWhiteSpace(part)));
    }
}
