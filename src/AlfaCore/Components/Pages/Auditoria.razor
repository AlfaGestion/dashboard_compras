@page "/auditoria"
@inject AlfaCore.Services.IAuditoriaService AuditoriaSvc

<PageTitle>Auditoría | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando auditoría…
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> @_error
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">Auditoría de errores</h2>
                <p class="page-intro__text">Consultá `AUX_ERR`, detectá procesos inestables y revisá el detalle técnico de cada incidente desde una sola app.</p>
            </div>
            <div class="actions">
                <a class="btn btn--primary" href="/auditoria/errores">
                    <i class="bi bi-bug"></i>
                    <span>Ver errores</span>
                </a>
            </div>
        </section>

        <section class="kpi-grid">
            <article class="kpi-card">
                <div class="kpi-card__label">Errores hoy</div>
                <div class="kpi-card__value">@_resumen.ErrorsToday</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Últimos 7 días</div>
                <div class="kpi-card__value">@_resumen.ErrorsLast7Days</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Proceso más frecuente</div>
                <div class="kpi-card__value">@_resumen.TopProcess</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Usuario más afectado</div>
                <div class="kpi-card__value">@_resumen.TopUser</div>
            </article>
        </section>

        <section class="three-grid">
            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Errores por día</h3>
                        <p class="panel-card__subtitle">Últimas dos semanas.</p>
                    </div>
                </div>
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Día</th>
                                <th>Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _resumen.ErrorsByDay)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td>@item.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Procesos con más errores</h3>
                        <p class="panel-card__subtitle">Ventana de 30 días.</p>
                    </div>
                </div>
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Proceso</th>
                                <th>Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _resumen.TopProcesses)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td>@item.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Usuarios con más errores</h3>
                        <p class="panel-card__subtitle">Ventana de 30 días.</p>
                    </div>
                </div>
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _resumen.TopUsers)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td>@item.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Últimos errores</h3>
                    <p class="panel-card__subtitle">Acceso rápido a los incidentes más recientes.</p>
                </div>
                <a class="action-link" href="/auditoria/errores">Ver listado completo</a>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Proceso</th>
                            <th>Usuario</th>
                            <th>Error</th>
                            <th>Descripción</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _latest)
                        {
                            <tr>
                                <td><a class="action-link" href="/auditoria/error/@item.Id">@item.Fecha.ToString("dd/MM/yyyy HH:mm")</a></td>
                                <td>@item.Proceso</td>
                                <td>@item.Usuario</td>
                                <td>@item.ErrorCodigo</td>
                                <td>@item.Descripcion</td>
                                <td>
                                    <a class="btn btn--ghost btn--sm" href="/auditoria/error/@item.Id">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                        <span>Detalle</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
}

@code {
    private bool _loading = true;
    private string _error = string.Empty;
    private AuditoriaResumenDto _resumen = new();
    private IReadOnlyList<AuditoriaErrorRowDto> _latest = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _resumen = await AuditoriaSvc.GetResumenAsync();
            _latest = await AuditoriaSvc.SearchErrorsAsync(new AuditoriaErrorFilterDto { MaxRows = 12 });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
