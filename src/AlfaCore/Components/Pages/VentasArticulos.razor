@page "/ventas/articulos"
@inject AlfaCore.Services.IGestionDashboardService GestionSvc
@inject AlfaCore.Services.GestionFilterStateService FilterState

<PageTitle>Artículos | Ventas</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Artículos más vendidos</h2>
            <p class="page-intro__text">Artículos líderes por importe y cantidad, con lectura rápida de actividad reciente.</p>
        </div>
    </div>

    <VentasFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" Titulo="Filtros de artículos" Subtitulo="Aplicá filtros comerciales para analizar artículos vendidos." />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state"><p>@_error</p></div>
    }
    else if (_page is null)
    {
        <div class="loading">Cargando artículos...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Total vendido" Valor="@Moneda(_page.TotalVendido)" Icono="$" />
            <KpiCard Titulo="Artículos activos" Valor="@_page.ArticulosActivos.ToString("N0")" Icono="A" />
            <KpiCard Titulo="Cantidad vendida" Valor="@_page.CantidadVendida.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))" Icono="Q" />
        </div>

        <div class="three-grid">
            <section class="panel-card">
                <HorizontalBarChart Data="_page.TopPorTotal" Titulo="Top por total" Subtitulo="Artículos con mayor facturación" />
            </section>
            <section class="panel-card">
                <HorizontalBarChart Data="_page.TopPorCantidad" Titulo="Top por cantidad" Subtitulo="Artículos con mayor volumen" Formato="numero" />
            </section>
        </div>

        <DataTable Titulo="Listado de artículos" Subtitulo="Impacto económico y volumen vendido">
            <Header>
                <tr>
                    <th>Artículo</th>
                    <th style="text-align:right;">Cantidad</th>
                    <th style="text-align:right;">Total</th>
                    <th style="text-align:right;">Comprobantes</th>
                    <th>Última venta</th>
                </tr>
            </Header>
            <Rows>
                @foreach (var item in _page.Articulos)
                {
                    <tr>
                        <td><strong>@item.Descripcion</strong><div class="text-muted">@item.IdArticulo</div></td>
                        <td style="text-align:right;">@item.CantidadVendida.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</td>
                        <td style="text-align:right;">@Moneda(item.TotalVendido)</td>
                        <td style="text-align:right;">@item.CantidadComprobantes.ToString("N0")</td>
                        <td>@Fecha(item.UltimaVenta)</td>
                    </tr>
                }
            </Rows>
        </DataTable>
    }
</section>

@code {
    private VentasDashboardFilters _filters = null!;
    private VentasFilterOptionsDto _options = new();
    private VentasArticulosPageDto? _page;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Ventas;
        _options = await GestionSvc.GetVentasFilterOptionsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        try { _page = await GestionSvc.GetVentasArticulosAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Fecha(DateTime? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "Sin dato";
}
