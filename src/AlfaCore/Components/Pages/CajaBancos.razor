@page "/caja-bancos"
@inject AlfaCore.Services.IGestionDashboardService GestionSvc
@inject AlfaCore.Services.IAppUiOperationService UiOps
@inject AlfaCore.Services.GestionFilterStateService FilterState

<PageTitle>Caja y Bancos | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Caja y Bancos</h2>
            <p class="page-intro__text">Caja disponible, saldos bancarios y pendientes de cobro/pago en una vista financiera corta.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros de caja y bancos</h3>
                <p class="panel-card__subtitle">Liquidez, cuentas y movimientos financieros sin mezclar lógica de artículos.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
                <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
                <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
                <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
                <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
            <div class="filters-toggle-wrap">
                <button type="button" class="btn btn--ghost filters-toggle" @onclick="ToggleAdvanced">
                    @(_showAdvanced ? "Ocultar filtros" : "Mostrar filtros")
                </button>
            </div>
        </div>

        <div class="filters-summary" aria-live="polite">
            <span class="filters-summary__label">Filtros activos</span>
            <span class="filters-summary__text">@BuildSummary()</span>
        </div>

        @if (_showAdvanced)
        {
            <div class="filters-grid filters-grid--wide">
                <div class="field">
                    <label>Caja</label>
                    <InputSelect @bind-Value="_filters.Caja">
                        <option value="">Todas</option>
                        @foreach (var item in _options.Cajas)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Cuenta bancaria</label>
                    <InputSelect @bind-Value="_filters.BancoCuenta">
                        <option value="">Todas</option>
                        @foreach (var item in _options.Bancos)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Texto / detalle</label>
                    <InputText @bind-Value="_filters.Texto" />
                </div>
            </div>
        }

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
            <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
        </div>
    </section>

    @if (_loading)
    {
        <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Cargando caja y bancos…</div>
    }
    else
    {
        @if (_feedback is not null)
        {
            <div class="conversations-inline @GetFeedbackClass(_feedback)">
                <strong>@_feedback.Title</strong>
                <div>@_feedback.Message</div>
                @if (_feedback.HasCode)
                {
                    <div>Código: @_feedback.Code</div>
                }
                @if (_feedback.HasSuggestion)
                {
                    <div>@_feedback.Suggestion</div>
                }
            </div>
        }

        <section class="kpi-grid">
            <article class="kpi-card"><div class="kpi-card__label">Saldo cajas</div><div class="kpi-card__value">@FmtMoney(_data.SaldoCajas)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Saldo bancos</div><div class="kpi-card__value">@FmtMoney(_data.SaldoBancos)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Pendiente cobro</div><div class="kpi-card__value">@FmtMoney(_data.PendienteCobro)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Pendiente pago</div><div class="kpi-card__value">@FmtMoney(_data.PendientePago)</div></article>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <LineChart Data="_data.EvolucionDiaria" Titulo="Flujo diario de caja" Subtitulo="Según filtros aplicados" />
            </article>
            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Movimientos recientes</h3>
                        <p class="panel-card__subtitle">Ingresos y egresos del período filtrado.</p>
                    </div>
                </div>
                <div class="detail-grid">
                    <div><strong>Ingresos período</strong><br />@FmtMoney(_data.Ingresos7Dias)</div>
                    <div><strong>Egresos período</strong><br />@FmtMoney(_data.Egresos7Dias)</div>
                    <div><strong>Neto período</strong><br />@FmtMoney(_data.Ingresos7Dias - _data.Egresos7Dias)</div>
                    <div><strong>Liquidez inmediata</strong><br />@FmtMoney(_data.SaldoCajas + _data.SaldoBancos)</div>
                </div>
            </article>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <HorizontalBarChart Data="_data.TopCajas" Titulo="Cajas" Subtitulo="Saldos por caja" />
            </article>
            <article class="panel-card">
                <HorizontalBarChart Data="_data.TopBancos" Titulo="Bancos" Subtitulo="Saldos por cuenta bancaria" />
            </article>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private AlfaCore.Models.AppUiMessage? _feedback;
    private bool _showAdvanced;
    private CajaBancosDashboardDto _data = new();
    private CajaBancosDashboardFilters _filters = null!;
    private CajaBancosFilterOptionsDto _options = new();

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.CajaBancos;
        var result = await UiOps.RunAsync(async () =>
        {
            _options = await GestionSvc.GetCajaBancosFilterOptionsAsync();
            await LoadAsync();
        }, "No se pudo cargar caja y bancos.");

        _feedback = result.Success ? null : result.Feedback;
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _feedback = null;

        var result = await UiOps.RunAsync(
            () => GestionSvc.GetCajaBancosAsync(_filters),
            "No se pudieron cargar los datos de caja y bancos.");

        if (result.Success && result.Value is not null)
            _data = result.Value;
        else
            _feedback = result.Feedback;

        _loading = false;
    }

    private Task HoyAsync() => ApplyQuickRangeAsync("hoy");
    private Task SemanaAsync() => ApplyQuickRangeAsync("semana");
    private Task MesAsync() => ApplyQuickRangeAsync("mes");
    private Task MesAnteriorAsync() => ApplyQuickRangeAsync("mes-anterior");
    private Task UltimosTresAsync() => ApplyQuickRangeAsync("ultimos-3");
    private Task AnioAsync() => ApplyQuickRangeAsync("anio");
    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
        _filters.FechaHasta = today;
        _filters.Caja = null;
        _filters.BancoCuenta = null;
        _filters.Texto = null;
        await LoadAsync();
    }

    private async Task ApplyQuickRangeAsync(string key)
    {
        var today = DateTime.Today;
        switch (key)
        {
            case "hoy":
                _filters.FechaDesde = today;
                _filters.FechaHasta = today;
                break;
            case "semana":
                var diff = ((int)today.DayOfWeek + 6) % 7;
                _filters.FechaDesde = today.AddDays(-diff);
                _filters.FechaHasta = today;
                break;
            case "mes":
                _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
                _filters.FechaHasta = today;
                break;
            case "mes-anterior":
                var firstThisMonth = new DateTime(today.Year, today.Month, 1);
                _filters.FechaDesde = firstThisMonth.AddMonths(-1);
                _filters.FechaHasta = firstThisMonth.AddDays(-1);
                break;
            case "ultimos-3":
                _filters.FechaDesde = today.AddMonths(-3);
                _filters.FechaHasta = today;
                break;
            case "anio":
                _filters.FechaDesde = new DateTime(today.Year, 1, 1);
                _filters.FechaHasta = today;
                break;
        }

        await LoadAsync();
    }

    private string BuildSummary()
    {
        var parts = new List<string>();
        if (_filters.FechaDesde.HasValue || _filters.FechaHasta.HasValue)
        {
            parts.Add($"Fecha: {_filters.FechaDesde:dd/MM/yyyy} a {_filters.FechaHasta:dd/MM/yyyy}");
        }

        AddIfPresent(parts, "Caja", _filters.Caja);
        AddIfPresent(parts, "Banco", _filters.BancoCuenta);
        AddIfPresent(parts, "Texto", _filters.Texto);

        return parts.Count == 0 ? "Sin filtros seleccionados." : string.Join(" | ", parts);
    }

    private static void AddIfPresent(List<string> parts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add($"{label}: {value}");
        }
    }

    private static string FmtMoney(decimal value) => value.ToString("$ #,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private static string GetFeedbackClass(AlfaCore.Models.AppUiMessage message)
        => message.Severity switch
        {
            AlfaCore.Models.AppUiFeedbackSeverity.Success => "conversations-inline--ok",
            AlfaCore.Models.AppUiFeedbackSeverity.Warning => "conversations-inline--error",
            AlfaCore.Models.AppUiFeedbackSeverity.Error => "conversations-inline--error",
            _ => "conversations-inline--ok"
        };
}
