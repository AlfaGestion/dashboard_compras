@page "/contabilidad/posicion-iva"
@inject AlfaCore.Services.IGestionDashboardService GestionSvc
@inject AlfaCore.Services.GestionFilterStateService FilterState

<PageTitle>Posición de IVA | Contabilidad</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Posición de IVA</h2>
            <p class="page-intro__text">Comparativa débito fiscal (ventas) vs. crédito fiscal (compras). Saldo a pagar o a favor según el período.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros</h3>
                <p class="panel-card__subtitle">Período y sucursal. Los libros IVA no filtran por cuenta, usuario ni tipo.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
                <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
                <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
                <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
                <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
        </div>

        <div class="filters-summary" aria-live="polite">
            <span class="filters-summary__label">Filtros activos</span>
            <span class="filters-summary__text">@BuildSummary()</span>
        </div>

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
            <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
        </div>
    </section>

    @if (_loading)
    {
        <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Calculando posición de IVA…</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="consultas-error"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }
    else if (_iva is not null)
    {
        <section class="kpi-grid kpi-grid--3">
            <article class="kpi-card">
                <div class="kpi-card__icon">D</div>
                <div class="kpi-card__body">
                    <p class="kpi-card__label">IVA Ventas — Débito fiscal</p>
                    <h3 class="kpi-card__value">@FmtCompact(_iva.TotalIvaVentas)</h3>
                    <p class="kpi-card__description">@FmtMoney(_iva.TotalIvaVentas)</p>
                    <p class="kpi-card__description">Neto: @FmtMoney(_iva.NetoGravadoVentas)</p>
                </div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__icon">C</div>
                <div class="kpi-card__body">
                    <p class="kpi-card__label">IVA Compras — Crédito fiscal</p>
                    <h3 class="kpi-card__value">@FmtCompact(_iva.TotalIvaCompras)</h3>
                    <p class="kpi-card__description">@FmtMoney(_iva.TotalIvaCompras)</p>
                    <p class="kpi-card__description">Neto: @FmtMoney(_iva.NetoGravadoCompras)</p>
                </div>
            </article>
            <article class="kpi-card @(_iva.Saldo >= 0 ? "kpi-card--iva-pagar" : "kpi-card--iva-favor")">
                <div class="kpi-card__icon">@(_iva.Saldo >= 0 ? "!" : "✓")</div>
                <div class="kpi-card__body">
                    <p class="kpi-card__label">@(_iva.Saldo >= 0 ? "Saldo a pagar a AFIP" : "Saldo a favor")</p>
                    <h3 class="kpi-card__value">@FmtCompact(Math.Abs(_iva.Saldo))</h3>
                    <p class="kpi-card__description">@FmtMoney(Math.Abs(_iva.Saldo))</p>
                    <p class="kpi-card__description">Débito − Crédito</p>
                </div>
            </article>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <HorizontalBarChart Data="Comparativa" Titulo="Comparativa del período" Subtitulo="Débito vs. crédito fiscal" />
            </article>
            <article class="panel-card">
                <LineChart Data="_iva.EvolucionSaldo" Titulo="Saldo IVA — últimos 12 meses" Subtitulo="Diferencia mensual débito − crédito" />
            </article>
        </section>

        @if (_iva.Filas.Any(f => f.Ventas != 0 || f.Compras != 0))
        {
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Detalle por concepto</h3>
                        <p class="panel-card__subtitle">Solo se muestran los conceptos con movimiento en el período. Solo se muestran los filas con valores != 0.</p>
                    </div>
                </div>
                <div class="table-scroll">
                    <table class="data-table posicion-iva-table">
                        <thead>
                            <tr>
                                <th>Concepto</th>
                                <th class="col-num">Ventas (Débito)</th>
                                <th class="col-num">Compras (Crédito)</th>
                                <th class="col-num">Diferencia</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fila in _iva.Filas.Where(f => f.Ventas != 0 || f.Compras != 0))
                            {
                                <tr>
                                    <td>@fila.Concepto</td>
                                    <td class="col-num">@FmtMoney(fila.Ventas)</td>
                                    <td class="col-num">@FmtMoney(fila.Compras)</td>
                                    <td class="col-num @(fila.Diferencia < 0 ? "text-danger" : "")">@FmtMoney(fila.Diferencia)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="row-totals">
                                <td><strong>TOTAL IVA</strong></td>
                                <td class="col-num"><strong>@FmtMoney(_iva.TotalIvaVentas)</strong></td>
                                <td class="col-num"><strong>@FmtMoney(_iva.TotalIvaCompras)</strong></td>
                                <td class="col-num @(_iva.Saldo < 0 ? "text-danger" : "")"><strong>@FmtMoney(_iva.Saldo)</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </section>
        }
        else
        {
            <div class="panel-card empty-state"><p>Sin movimientos de IVA en el período seleccionado.</p></div>
        }

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Ventas — Resumen por alícuota</h3>
                    <p class="panel-card__subtitle">IVA débito fiscal agrupado por condición IVA y alícuota. Columnas FC / NC / ND según tipo de comprobante.</p>
                </div>
            </div>
            <ResumenIvaTable Data="_iva.ResumenVentas" FcLabel="FC" />
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Compras — Resumen por alícuota</h3>
                    <p class="panel-card__subtitle">IVA crédito fiscal agrupado por condición IVA y alícuota.</p>
                </div>
            </div>
            <ResumenIvaTable Data="_iva.ResumenCompras" FcLabel="FC" />
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private string _error = string.Empty;
    private PosicionIvaDto? _iva;
    private ContabilidadDashboardFilters _filters = null!;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Contabilidad;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try { _iva = await GestionSvc.GetPosicionIvaAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
        _filters.FechaHasta = today;
        await LoadAsync();
    }

    private Task HoyAsync()       { var t = DateTime.Today; _filters.FechaDesde = t; _filters.FechaHasta = t; return LoadAsync(); }
    private Task SemanaAsync()    { var t = DateTime.Today; _filters.FechaDesde = t.AddDays(-(((int)t.DayOfWeek + 6) % 7)); _filters.FechaHasta = t; return LoadAsync(); }
    private Task MesAsync()       { var t = DateTime.Today; _filters.FechaDesde = new DateTime(t.Year, t.Month, 1); _filters.FechaHasta = t; return LoadAsync(); }
    private Task MesAnteriorAsync(){ var f = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1); _filters.FechaDesde = f.AddMonths(-1); _filters.FechaHasta = f.AddDays(-1); return LoadAsync(); }
    private Task UltimosTresAsync(){ var t = DateTime.Today; _filters.FechaDesde = t.AddMonths(-3); _filters.FechaHasta = t; return LoadAsync(); }
    private Task AnioAsync()      { var t = DateTime.Today; _filters.FechaDesde = new DateTime(t.Year, 1, 1); _filters.FechaHasta = t; return LoadAsync(); }

    private string BuildSummary()
    {
        var parts = new List<string>();
        if (_filters.FechaDesde.HasValue || _filters.FechaHasta.HasValue)
            parts.Add($"Fecha: {_filters.FechaDesde:dd/MM/yyyy} a {_filters.FechaHasta:dd/MM/yyyy}");
        if (!string.IsNullOrWhiteSpace(_filters.Sucursal))
            parts.Add($"Sucursal: {_filters.Sucursal}");
        return parts.Count == 0 ? "Sin filtros seleccionados." : string.Join(" | ", parts);
    }

    private IReadOnlyList<CategoryTotalDto> Comparativa =>
        _iva is null ? Array.Empty<CategoryTotalDto>() : new[]
        {
            new CategoryTotalDto { Categoria = "Débito fiscal (Ventas)", Total = _iva.TotalIvaVentas },
            new CategoryTotalDto { Categoria = "Crédito fiscal (Compras)", Total = _iva.TotalIvaCompras },
            new CategoryTotalDto { Categoria = _iva.Saldo >= 0 ? "Saldo (a pagar)" : "Saldo (a favor)", Total = Math.Abs(_iva.Saldo) },
        };

    private static readonly System.Globalization.CultureInfo _esAr =
        System.Globalization.CultureInfo.GetCultureInfo("es-AR");

    private static string FmtMoney(decimal v) => v.ToString("$ #,##0", _esAr);

    private static string FmtCompact(decimal v) => v switch
    {
        >= 1_000_000_000m => $"$ {(v / 1_000_000_000m).ToString("N1", _esAr)}B",
        >= 1_000_000m     => $"$ {(v / 1_000_000m).ToString("N1", _esAr)}M",
        >= 1_000m         => $"$ {(v / 1_000m).ToString("N1", _esAr)}K",
        _                 => FmtMoney(v)
    };
}
