@page "/"
<PageTitle>Aplicaciones | Alfa Gestión</PageTitle>

<div class="launcher">
    <div class="launcher__header">
        <p class="launcher__eyebrow">Alfa Gestión</p>
        <h1 class="launcher__title">Aplicaciones</h1>
        <p class="launcher__subtitle">Seleccioná el módulo al que querés ingresar.</p>
    </div>

    <div class="launcher__grid">
        <a class="app-card" href="/compras">
            <div class="app-card__icon app-card__icon--compras">
                <i class="bi bi-cart-fill"></i>
            </div>
            <span class="app-card__name">Compras</span>
            <span class="app-card__desc">Dashboard de compras, proveedores, artículos e informes IA</span>
        </a>

        <a class="app-card" href="/ventas">
            <div class="app-card__icon app-card__icon--ventas">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <span class="app-card__name">Ventas</span>
            <span class="app-card__desc">Facturación, clientes, artículos vendidos y cobranza pendiente</span>
        </a>

        <a class="app-card" href="/stock">
            <div class="app-card__icon app-card__icon--stock">
                <i class="bi bi-box-seam"></i>
            </div>
            <span class="app-card__name">Stock</span>
            <span class="app-card__desc">Valorización, análisis de movimiento y artículos críticos</span>
        </a>

        <a class="app-card" href="/caja-bancos">
            <div class="app-card__icon app-card__icon--caja">
                <i class="bi bi-bank"></i>
            </div>
            <span class="app-card__name">Caja y Bancos</span>
            <span class="app-card__desc">Liquidez, saldos, ingresos, egresos y pendientes financieros</span>
        </a>

        <a class="app-card" href="/contabilidad">
            <div class="app-card__icon app-card__icon--contabilidad">
                <i class="bi bi-journal-bookmark-fill"></i>
            </div>
            <span class="app-card__name">Contabilidad</span>
            <span class="app-card__desc">Vista gerencial del debe, haber, saldo y actividad contable</span>
        </a>

        <a class="app-card" href="/consultas">
            <div class="app-card__icon app-card__icon--consultas">
                <i class="bi bi-table"></i>
            </div>
            <span class="app-card__name">Diseñador de consultas</span>
            <span class="app-card__desc">Ejecutá y exportá las consultas guardadas del sistema</span>
        </a>

        <a class="app-card" href="/costos">
            <div class="app-card__icon app-card__icon--compras">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <span class="app-card__name">Actualización de costos</span>
            <span class="app-card__desc">Importá listas de proveedores y registrá corridas para revisión y auditoría</span>
        </a>

        <a class="app-card" href="/auditoria">
            <div class="app-card__icon app-card__icon--consultas">
                <i class="bi bi-shield-exclamation"></i>
            </div>
            <span class="app-card__name">Auditoría</span>
            <span class="app-card__desc">Revisá errores técnicos centralizados, filtrá por usuario, fecha y proceso</span>
        </a>

        <a class="app-card" href="/conversaciones">
            <div class="app-card__icon app-card__icon--ventas">
                <i class="bi bi-chat-dots-fill"></i>
            </div>
            <span class="app-card__name">Conversaciones</span>
            <span class="app-card__desc">Inbox operativo de WhatsApp con asignación por técnico, contexto del contacto y seguimiento de estado</span>
        </a>

        <a class="app-card" href="/interfaces">
            <div class="app-card__icon app-card__icon--caja">
                <i class="bi bi-folder2-open"></i>
            </div>
            <span class="app-card__name">Interfaces</span>
            <span class="app-card__desc">Recepción documental de comprobantes, liquidaciones, listas y adjuntos con trazabilidad</span>
        </a>

        <a class="app-card" href="/actualizaciones">
            <div class="app-card__icon app-card__icon--consultas">
                <i class="bi bi-cloud-arrow-up"></i>
            </div>
            <span class="app-card__name">Actualizaciones</span>
            <span class="app-card__desc">Aplicá scripts SQL versionados, controlá FECHAUPDATE y revisá el historial de corridas</span>
        </a>

        <a class="app-card" href="/usuarios">
            <div class="app-card__icon app-card__icon--usuarios">
                <i class="bi bi-people-fill"></i>
            </div>
            <span class="app-card__name">Usuarios</span>
            <span class="app-card__desc">Alta, edición y baja lógica de usuarios y grupos del sistema con contraseña compatible e imagen opcional</span>
        </a>

        <a class="app-card" href="/contactos">
            <div class="app-card__icon app-card__icon--contactos">
                <i class="bi bi-person-lines-fill"></i>
            </div>
            <span class="app-card__name">Contactos</span>
            <span class="app-card__desc">Agenda general del sistema con datos de contacto, domicilio, teléfonos y baja lógica</span>
        </a>
    </div>
</div>
