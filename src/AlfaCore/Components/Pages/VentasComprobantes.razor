@page "/ventas/comprobantes"
@inject AlfaCore.Services.IGestionDashboardService GestionSvc
@inject AlfaCore.Services.GestionFilterStateService FilterState

<PageTitle>Comprobantes | Ventas</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Comprobantes de ventas</h2>
            <p class="page-intro__text">Totales agrupados por tipo de comprobante con apertura de netos, IVA y retenciones del período.</p>
        </div>
    </div>

    <VentasFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync"
                      Titulo="Filtros de comprobantes"
                      Subtitulo="Acotá por fecha, cliente, tipo de comprobante u otros criterios." />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state"><p>@_error</p></div>
    }
    else if (_page is null)
    {
        <div class="loading">Cargando comprobantes...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Total período" Valor="@Moneda(_page.TotalGeneral)" Icono="$" />
            <KpiCard Titulo="Comprobantes" Valor="@_page.TotalComprobantes.ToString("N0")" Icono="C" />
        </div>

        @if (_page.Filas.Count == 0)
        {
            <div class="panel-card empty-state"><p>Sin comprobantes para el período seleccionado.</p></div>
        }
        else
        {
            <div class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Resumen por tipo de comprobante</h3>
                        <p class="panel-card__subtitle">FP y NCFP (proforma) sólo muestran el total; no pasan al libro IVA.</p>
                    </div>
                </div>
                <div class="table-scroll">
                    <table class="data-table resumen-tc-table">
                        <thead>
                            <tr>
                                <th>TC</th>
                                <th class="col-num">Cant.</th>
                                <th class="col-num">Neto Grav.</th>
                                <th class="col-num">No Grav.</th>
                                <th class="col-num">IVA 21%</th>
                                <th class="col-num">IVA 10,5%</th>
                                <th class="col-num">IVA Rec.</th>
                                <th class="col-num">Ret. IIBB</th>
                                <th class="col-num">Ret. Gan.</th>
                                <th class="col-num">Ret. IVA</th>
                                <th class="col-num col-total">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in _page.Filas)
                            {
                                var esFP = f.Tc is "FP" or "NCFP";
                                <tr>
                                    <td><span class="badge-tc">@f.Tc</span></td>
                                    <td class="col-num text-muted">@f.Cantidad.ToString("N0")</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.NetoGravado))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.NetoNoGravado))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.Iva21))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.Iva105))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.IvaRec))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.RetIIBB))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.RetGanancias))</td>
                                    <td class="col-num">@(esFP ? "" : Moneda(f.RetIVA))</td>
                                    <td class="col-num col-total"><strong>@Moneda(f.Total)</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="row-totals">
                                <td><strong>TOTAL</strong></td>
                                <td class="col-num text-muted">@_page.TotalComprobantes.ToString("N0")</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.NetoGravado))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.NetoNoGravado))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.Iva21))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.Iva105))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.IvaRec))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.RetIIBB))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.RetGanancias))</td>
                                <td class="col-num">@Moneda(_page.Filas.Sum(x => x.RetIVA))</td>
                                <td class="col-num col-total"><strong>@Moneda(_page.TotalGeneral)</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }
    }
</section>

@code {
    private VentasDashboardFilters _filters = null!;
    private VentasFilterOptionsDto _options = new();
    private VentasResumenTcPageDto? _page;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Ventas;
        _options = await GestionSvc.GetVentasFilterOptionsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        _page = null;
        try { _page = await GestionSvc.GetVentasResumenPorTcAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string Moneda(decimal v) =>
        v.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
