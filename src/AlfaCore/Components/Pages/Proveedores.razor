@page "/compras/proveedores"
@inject AlfaCore.Services.IComprasDashboardService DashboardService
@inject AlfaCore.Services.FilterStateService FilterState

<PageTitle>Proveedores | Dashboard de Compras</PageTitle>

<section class="page-grid">

    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Proveedores</h2>
            <p class="page-intro__text">Ranking, concentración, variación y ficha de cada proveedor. <a class="help-link" href="/ayuda#5-proveedores">Ver ayuda</a></p>
        </div>
    </div>

    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state"><p>@_error</p></div>
    }
    else if (_data is null)
    {
        <div class="loading">Cargando proveedores...</div>
    }
    else if (_data.Proveedores.Count == 0)
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Sin resultados</span>
            <h3>No hay proveedores en el período seleccionado</h3>
        </div>
    }
    else
    {
        <div class="kpi-grid kpi-grid--6">
            <KpiCard Titulo="Total comprado"
                     Valor="@Moneda(_data.Kpis.TotalComprado)"
                     Icono="<i class='bi bi-cash-stack'></i>" />

            <KpiCard Titulo="Proveedores activos"
                     Valor="@_data.Kpis.ProveedoresActivos.ToString("N0")"
                     Icono="<i class='bi bi-people-fill'></i>" />

            <KpiCard Titulo="Top proveedor"
                     Valor="@_data.Kpis.TopProveedorNombre"
                     Descripcion="@Moneda(_data.Kpis.TopProveedorTotal)"
                     Icono="<i class='bi bi-trophy-fill'></i>" />

            <KpiCard Titulo="Concentración top 5"
                     Valor="@Pct(_data.Kpis.ConcentracionTop5)"
                     Descripcion="del total"
                     Icono="<i class='bi bi-pie-chart-fill'></i>" />

            <KpiCard Titulo="Var. vs período anterior"
                     Valor="@VariacionStr(_data.Kpis.VariacionTotalVsAnterior)"
                     Descripcion="@PeriodoAnteriorLabel()"
                     Icono="<i class='bi bi-graph-up-arrow'></i>" />

            @if (_data.Kpis.MayorCaidaNombre is not null)
            {
                <KpiCard Titulo="Mayor caída"
                         Valor="@_data.Kpis.MayorCaidaNombre"
                         Descripcion="@VariacionStr(_data.Kpis.MayorCaidaVariacion)"
                         Icono="<i class='bi bi-arrow-down-right-circle-fill'></i>" />
            }
            else if (_data.Kpis.MayorCrecimientoNombre is not null)
            {
                <KpiCard Titulo="Mayor crecimiento"
                         Valor="@_data.Kpis.MayorCrecimientoNombre"
                         Descripcion="@VariacionStr(_data.Kpis.MayorCrecimientoVariacion)"
                         Icono="<i class='bi bi-arrow-up-right-circle-fill'></i>" />
            }
            else
            {
                <KpiCard Titulo="Comprobantes"
                         Valor="@_data.Proveedores.Sum(p => p.CantidadComprobantes).ToString("N0")"
                         Icono="<i class='bi bi-receipt'></i>" />
            }
        </div>

        <div class="split-grid">
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Ranking de proveedores</h3>
                        <p class="panel-card__subtitle">Top 10 por total comprado en el período</p>
                    </div>
                </div>
                <HorizontalBarChart Data="@RankingChartData()" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Concentración</h3>
                        <p class="panel-card__subtitle">Top 5 vs resto — % del gasto total</p>
                    </div>
                </div>
                <div class="bar-chart">
                    @foreach (var item in ConcentracionItems)
                    {
                        var barW = Math.Clamp((double)(item.Participacion * 100), 4d, 100d);
                        <div class="bar-chart__row">
                            <div class="bar-chart__header">
                                <span class="bar-chart__label">@item.Nombre</span>
                                <strong>@item.Participacion.ToString("P1", Cultura)</strong>
                            </div>
                            <div class="bar-chart__track">
                                <div class="@(item.EsResto ? "bar-chart__fill bar-chart__fill--muted" : "bar-chart__fill")"
                                     style="width:@barW.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%">
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>

        @if (AlertasItems.Count > 0)
        {
            <div class="alert-band">
                @foreach (var a in AlertasItems)
                {
                    <span class="alert-chip alert-chip--@a.Tipo">@((MarkupString)a.Icono) @a.Mensaje</span>
                }
            </div>
        }

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Listado de proveedores</h3>
                    <p class="panel-card__subtitle">@_data.Proveedores.Count proveedores en el período · clic en Ficha para ver detalle</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Proveedor</th>
                            <th style="text-align:right;">Total</th>
                            <th style="text-align:right;">% s/ total</th>
                            <th style="text-align:right;">Comprobantes</th>
                            <th style="text-align:right;">Ticket prom.</th>
                            <th>Última compra</th>
                            <th style="text-align:center;">Var. vs anterior</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _data.Proveedores.Select((item, index) => new { item, rank = index + 1 }))
                        {
                            var item = row.item;
                            var isSelected = _detalle?.Resumen.Cuenta == item.Cuenta;
                            <tr class="@(isSelected ? "row--selected" : "")">
                                <td class="rank-cell">@row.rank</td>
                                <td>
                                    <strong>@item.RazonSocial</strong>
                                    <span class="text-muted">@item.Cuenta</span>
                                </td>
                                <td style="text-align:right;">@Moneda(item.TotalComprado)</td>
                                <td style="text-align:right;">
                                    <div class="pct-cell">
                                        <span>@item.Participacion.ToString("P1", Cultura)</span>
                                        <div class="pct-bar">
                                            <div class="pct-bar__fill"
                                                 style="width:@Math.Clamp((double)(item.Participacion * 100), 0, 100).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%">
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td style="text-align:right;">@item.CantidadComprobantes</td>
                                <td style="text-align:right;">@Moneda(item.TicketPromedio)</td>
                                <td>@item.UltimaCompra?.ToString("dd/MM/yyyy")</td>
                                <td style="text-align:center;">@((MarkupString)RenderVariacion(item))</td>
                                <td>
                                    <button class="btn btn--ghost btn--sm"
                                            @onclick="() => SelectProveedorAsync(item.Cuenta)">
                                        Ficha
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @if (_detalle is not null)
        {
            var prov = _data.Proveedores.FirstOrDefault(p => p.Cuenta == _detalle.Resumen.Cuenta);

            <div class="split-grid">
                <section class="panel-card">
                    <div class="panel-card__header">
                        <div>
                            <h3 class="panel-card__title">@_detalle.Resumen.RazonSocial</h3>
                            <p class="panel-card__subtitle">@_detalle.Resumen.Cuenta</p>
                        </div>
                        <a class="btn btn--ghost btn--sm"
                           href="/compras/comprobantes?proveedor=@Uri.EscapeDataString(_detalle.Resumen.Cuenta)">
                            <i class="bi bi-receipt"></i> Ver comprobantes
                        </a>
                    </div>

                    <div class="detail-list">
                        <div class="detail-row">
                            <span class="detail-row__label">Total período</span>
                            <strong>@Moneda(_detalle.Resumen.TotalComprado)</strong>
                        </div>
                        @if (prov is not null)
                        {
                            <div class="detail-row">
                                <span class="detail-row__label">Participación</span>
                                <strong>@prov.Participacion.ToString("P1", Cultura)</strong>
                            </div>
                            <div class="detail-row">
                                <span class="detail-row__label">Var. vs anterior</span>
                                <strong>@((MarkupString)RenderVariacion(prov))</strong>
                            </div>
                        }
                        <div class="detail-row">
                            <span class="detail-row__label">Comprobantes</span>
                            <strong>@_detalle.Resumen.CantidadComprobantes</strong>
                        </div>
                        <div class="detail-row">
                            <span class="detail-row__label">Ticket promedio</span>
                            <strong>@Moneda(_detalle.Resumen.TicketPromedio)</strong>
                        </div>
                        <div class="detail-row">
                            <span class="detail-row__label">Primera compra</span>
                            <strong>@(_detalle.Resumen.PrimeraCompra?.ToString("dd/MM/yyyy") ?? "—")</strong>
                        </div>
                        <div class="detail-row">
                            <span class="detail-row__label">Última compra</span>
                            <strong>@(_detalle.Resumen.UltimaCompra?.ToString("dd/MM/yyyy") ?? "—")</strong>
                        </div>
                    </div>

                    @if (_detalle.UltimosComprobantes.Count > 0)
                    {
                        <div class="panel-card__header" style="margin-top:1.25rem; margin-bottom:0.5rem;">
                            <h4 class="panel-card__title" style="font-size:0.88rem; color:var(--color-muted);">
                                ÚLTIMOS COMPROBANTES
                            </h4>
                        </div>
                        <div class="detail-list">
                            @foreach (var cpte in _detalle.UltimosComprobantes)
                            {
                                <div class="detail-row">
                                    <span class="detail-row__label">
                                        @cpte.Fecha.ToString("dd/MM/yy") · @cpte.Tc @cpte.IdComprobante
                                    </span>
                                    <span>@Moneda(cpte.ImporteDashboard)</span>
                                </div>
                            }
                        </div>
                    }
                </section>

                <section class="panel-card">
                    <div class="panel-card__header">
                        <div>
                            <h3 class="panel-card__title">Evolución mensual</h3>
                            <p class="panel-card__subtitle">Últimos 12 meses · @_detalle.Resumen.RazonSocial</p>
                        </div>
                    </div>
                    <LineChart Data="_detalle.EvolucionMensual" Titulo="Evolución del proveedor" />
                </section>
            </div>
        }
    }

</section>

@code {
    [SupplyParameterFromQuery(Name = "proveedor")] public string? ProveedorQuery { get; set; }

    private static readonly System.Globalization.CultureInfo Cultura =
        System.Globalization.CultureInfo.GetCultureInfo("es-AR");

    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private ProveedoresPageDto? _data;
    private ProveedorDetalleDto? _detalle;
    private string? _error;

    private IReadOnlyList<ConcentracionItem> ConcentracionItems =>
        ConcentracionData();

    private IReadOnlyList<AlertaDto> AlertasItems =>
        BuildAlertas();

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        if (!string.IsNullOrWhiteSpace(ProveedorQuery))
            _filters.Proveedor = ProveedorQuery;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        _detalle = null;
        try
        {
            _data = await DashboardService.GetProveedoresPageDataAsync(_filters);
            if (_data.Proveedores.Count > 0 && !string.IsNullOrWhiteSpace(_filters.Proveedor))
                await SelectProveedorAsync(_data.Proveedores[0].Cuenta);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SelectProveedorAsync(string cuenta)
    {
        _detalle = await DashboardService.GetProveedorDetalleAsync(cuenta, _filters);
    }

    private IReadOnlyList<CategoryTotalDto> RankingChartData()
    {
        if (_data is null) return [];
        return _data.Proveedores.Take(10).Select(p => new CategoryTotalDto
        {
            Categoria = p.RazonSocial,
            Codigo = p.Cuenta,
            Total = p.TotalComprado
        }).ToList();
    }

    private record ConcentracionItem(string Nombre, decimal Participacion, bool EsResto = false);

    private IReadOnlyList<ConcentracionItem> ConcentracionData()
    {
        if (_data is null || _data.Proveedores.Count == 0) return [];
        var top5 = _data.Proveedores.Take(5).ToList();
        var resto = _data.Proveedores.Skip(5).Sum(p => p.Participacion);
        var items = top5.Select(p => new ConcentracionItem(p.RazonSocial, p.Participacion)).ToList();
        if (resto > 0)
            items.Add(new ConcentracionItem("Resto", resto, true));
        return items;
    }

    private record AlertaDto(string Tipo, string Icono, string Mensaje);

    private IReadOnlyList<AlertaDto> BuildAlertas()
    {
        if (_data is null) return [];
        var lista = new List<AlertaDto>();
        var hoy = DateTime.Today;

        if (_data.Proveedores.Count > 0 && _data.Proveedores[0].Participacion >= 0.40m)
        {
            var top = _data.Proveedores[0];
            lista.Add(new AlertaDto("warn",
                "<i class='bi bi-exclamation-triangle-fill'></i>",
                $"{top.RazonSocial} concentra el {top.Participacion.ToString("P0", Cultura)} del gasto"));
        }

        var inactivos = _data.Proveedores
            .Where(p => p.UltimaCompra.HasValue && (hoy - p.UltimaCompra.Value).TotalDays > 60)
            .ToList();

        if (inactivos.Count == 1)
            lista.Add(new AlertaDto("info",
                "<i class='bi bi-clock'></i>",
                $"{inactivos[0].RazonSocial} sin compras hace {(int)(hoy - inactivos[0].UltimaCompra!.Value).TotalDays} días"));
        else if (inactivos.Count > 1)
            lista.Add(new AlertaDto("info",
                "<i class='bi bi-clock'></i>",
                $"{inactivos.Count} proveedores sin compras en más de 60 días"));

        var nuevos = _data.Proveedores.Where(p => p.EsNuevo).ToList();
        if (nuevos.Count == 1)
            lista.Add(new AlertaDto("success",
                "<i class='bi bi-star-fill'></i>",
                $"{nuevos[0].RazonSocial} es un proveedor nuevo en el período"));
        else if (nuevos.Count > 1)
            lista.Add(new AlertaDto("success",
                "<i class='bi bi-star-fill'></i>",
                $"{nuevos.Count} proveedores nuevos en el período"));

        if (_data.Kpis.MayorCrecimientoNombre is not null && _data.Kpis.MayorCrecimientoVariacion >= 0.50m)
            lista.Add(new AlertaDto("success",
                "<i class='bi bi-arrow-up-right-circle-fill'></i>",
                $"{_data.Kpis.MayorCrecimientoNombre} creció {_data.Kpis.MayorCrecimientoVariacion.Value.ToString("P0", Cultura)} vs período anterior"));

        if (_data.Kpis.MayorCaidaNombre is not null && _data.Kpis.MayorCaidaVariacion <= -0.30m)
            lista.Add(new AlertaDto("danger",
                "<i class='bi bi-arrow-down-right-circle-fill'></i>",
                $"{_data.Kpis.MayorCaidaNombre} cayó {Math.Abs(_data.Kpis.MayorCaidaVariacion!.Value).ToString("P0", Cultura)} vs período anterior"));

        return lista;
    }

    private static string Moneda(decimal valor) =>
        valor.ToString("$ #,##0.##", Cultura);

    private static string Pct(decimal valor) =>
        valor.ToString("P1", Cultura);

    private static string VariacionStr(decimal? v)
    {
        if (!v.HasValue) return "Sin dato";
        return v.Value >= 0
            ? $"▲ +{v.Value.ToString("P1", Cultura)}"
            : $"▼ {v.Value.ToString("P1", Cultura)}";
    }

    private string PeriodoAnteriorLabel()
    {
        var hoy = DateTime.Today;
        var desde = _filters.FechaDesde ?? new DateTime(hoy.Year, hoy.Month, 1);
        var hasta = _filters.FechaHasta ?? hoy;
        var span = hasta - desde;
        var antH = desde.AddDays(-1);
        var antD = antH - span;
        return $"vs {antD:dd/MM} – {antH:dd/MM}";
    }

    private static string RenderVariacion(ProveedorResumenDto item)
    {
        if (item.EsNuevo)
            return "<span class=\"var-badge var-badge--new\">Nuevo</span>";
        if (!item.VariacionVsAnterior.HasValue)
            return "<span class=\"var-badge var-badge--flat\">—</span>";

        var v = item.VariacionVsAnterior.Value;
        var signo = v >= 0 ? "+" : "";
        var str = $"{signo}{v.ToString("P1", Cultura)}";

        if (v > 0.05m) return $"<span class=\"var-badge var-badge--up\">▲ {str}</span>";
        if (v < -0.05m) return $"<span class=\"var-badge var-badge--down\">▼ {str}</span>";
        return $"<span class=\"var-badge var-badge--flat\">{str}</span>";
    }
}
