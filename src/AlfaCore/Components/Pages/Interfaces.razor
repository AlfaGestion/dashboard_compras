    private sealed class PendingUploadFile
    {
        private PendingUploadFile(
            string nombreArchivo,
            string mimeType,
            long tamanoBytes,
            byte[] contenido,
            string signature)
        {
            NombreArchivo = nombreArchivo;
            MimeType = mimeType;
            TamanoBytes = tamanoBytes;
            Contenido = contenido;
            Signature = signature;
        }

        public Guid Id { get; } = Guid.NewGuid();
        public string NombreArchivo { get; }
        public string MimeType { get; }
        public long TamanoBytes { get; }
        public byte[] Contenido { get; }
        public string Signature { get; }

        public static async Task<PendingUploadFile> CreateAsync(IBrowserFile file, long maxBytes)
        {
            await using var source = file.OpenReadStream(maxBytes);
            await using var ms = new MemoryStream();
            await source.CopyToAsync(ms);

            return new PendingUploadFile(
                file.Name,
                file.ContentType,
                file.Size,
                ms.ToArray(),
                $"{file.Name}|{file.Size}|{file.LastModified.UtcDateTime.Ticks}");
        }

        public Stream OpenReadStream()
            => new MemoryStream(Contenido, writable: false);
    }

