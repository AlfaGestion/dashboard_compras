@page "/interfaces"
@using AlfaCore.Models
@inject AlfaCore.Services.IInterfacesService InterfacesSvc
@inject AlfaCore.Services.IAppUiOperationService UiOps
@inject AlfaCore.Services.IAppUserSessionService AppUserSession
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>Interfaces | Alfa Gestión</PageTitle>

<div class="page-grid interfaces-page interfaces-list-page">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Recepción documental</h2>
            <p class="page-intro__text">Listado principal del módulo con formato estándar del sistema: filtros, grilla configurable y acceso a la ficha completa del documento.</p>
        </div>
        <div class="actions">
            <a class="btn btn--primary" href="/interfaces/nuevo">
                <i class="bi bi-plus-circle"></i> Nuevo
            </a>
            <a class="btn btn--ghost" href="/interfaces/configuracion">
                <i class="bi bi-sliders"></i> Configuración
            </a>
            <button type="button" class="btn btn--ghost" @onclick="RecargarAsync" disabled="@_loadingList">
                <i class="bi bi-arrow-clockwise"></i> Recargar
            </button>
        </div>
    </section>

    @if (_feedback is not null)
    {
        <section class="panel-card">
            <div class="editor-msg @GetFeedbackClass(_feedback)">
                <div>
                    <strong>@_feedback.Title</strong>
                    <p>@_feedback.Message</p>
                    @if (_feedback.HasSuggestion)
                    {
                        <small>@_feedback.Suggestion</small>
                    }
                    @if (_feedback.HasCode)
                    {
                        <small>Código: @_feedback.Code</small>
                    }
                </div>
            </div>
        </section>
    }

    <div class="interfaces-mobile-toolbar">
        <button type="button" class="btn btn--ghost" @onclick="ToggleMobileFilters">
            <i class="bi bi-funnel"></i> Filtros
        </button>
        <button type="button" class="btn btn--ghost" @onclick="ToggleMobileBulkActions">
            <i class="bi bi-lightning-charge"></i> Acciones
        </button>
    </div>

    <section class="panel-card @GetMobileFiltersSectionClass()">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros</h3>
                <p class="panel-card__subtitle">La búsqueda muestra primero los documentos más recientes y permite filtrar por rango, estado, tipo y texto.</p>
            </div>
        </div>

        <div class="filters-grid">
            <div class="field">
                <label>Desde</label>
                <input type="date" @bind="_filtersDesde" />
            </div>
            <div class="field">
                <label>Hasta</label>
                <input type="date" @bind="_filtersHasta" />
            </div>
            <div class="field">
                <label>Estado</label>
                <select @bind="_filters.IdEstado">
                    <option value="">Todos</option>
                    @foreach (var item in _states)
                    {
                        <option value="@item.IdEstado">@item.Descripcion</option>
                    }
                </select>
            </div>
            <div class="field">
                <label>Tipo</label>
                <select @bind="_filters.IdTipoDocumento">
                    <option value="">Todos</option>
                    @foreach (var item in _documentTypes)
                    {
                        <option value="@item.IdTipoDocumento">@item.Descripcion</option>
                    }
                </select>
            </div>
            <div class="field field--wide">
                <label>Buscar</label>
                <input type="search"
                       placeholder="Observación, usuario o número interno..."
                       @bind="_filters.Texto"
                       @bind:event="oninput" />
            </div>
            <div class="actions">
                <button type="button" class="btn btn--primary" @onclick="AplicarFiltrosAsync" disabled="@_loadingList">
                    <i class="bi bi-funnel"></i> Aplicar
                </button>
                <button type="button" class="btn btn--ghost" @onclick="LimpiarFiltros" disabled="@_loadingList">
                    <i class="bi bi-eraser"></i> Limpiar
                </button>
            </div>
        </div>
    </section>

    @if (_showViewSettings)
    {
        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Configuración de vista</h3>
                    <p class="panel-card__subtitle">Elegí columnas visibles, orden y agrupación para la grilla de recepción documental.</p>
                </div>
            </div>

            <div class="usuarios-view-settings">
                <div class="field">
                    <label>Agrupar por</label>
                    <select @bind="_draftAgruparPor">
                        <option value="@InterfacesViewGroupKeys.None">Sin agrupar</option>
                        <option value="@InterfacesViewGroupKeys.Estado">Estado</option>
                        <option value="@InterfacesViewGroupKeys.Tipo">Tipo</option>
                    </select>
                </div>

                <div class="usuarios-view-settings__list">
                    @foreach (var column in _viewSettingsDraft.OrderBy(c => c.Order))
                    {
                        <div class="usuarios-view-settings__item">
                            <label class="checkbox">
                                <input type="checkbox" checked="@column.Visible" @onchange="args => ToggleViewColumn(column.Key, args)" />
                                <span>@column.Label</span>
                            </label>
                            <div class="actions">
                                <button type="button" class="btn btn--ghost btn--sm" @onclick="() => MoveViewColumn(column.Key, -1)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button type="button" class="btn btn--ghost btn--sm" @onclick="() => MoveViewColumn(column.Key, 1)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="actions">
                    <button type="button" class="btn btn--primary" @onclick="GuardarConfiguracionVistaAsync">
                        <i class="bi bi-floppy"></i> Guardar vista
                    </button>
                    <button type="button" class="btn btn--ghost" @onclick="CancelarConfiguracionVista">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
            </div>
        </section>
    }

    @{
        var visibleColumns = GetVisibleColumns();
        var groups = BuildGridGroups();
    }

    <section class="panel-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Documentos recibidos</h3>
                <p class="panel-card__subtitle">@_pagedTotal registro(s) · Página @_pageNumber de @_totalPages · podés abrir la ficha con el botón editar o con doble clic.</p>
            </div>
            <div class="actions">
                <button type="button" class="btn btn--ghost" @onclick="AbrirConfiguracionVista">
                    <i class="bi bi-sliders"></i> Configurar vista
                </button>
                <span class="panel-card__subtitle">Agrupación: @GetGroupingLabel(_viewSettings.AgruparPor)</span>
            </div>
        </div>

        <div class="interfaces-bulkbar @GetMobileBulkbarClass()">
            <div class="field interfaces-bulkbar__field">
                <label>Acciones masivas</label>
                <select @bind="_bulkAction" disabled="@(_loadingList || _selectedIds.Count == 0)">
                    <option value="@BulkActionDelete">Eliminar seleccionados</option>
                </select>
            </div>
            <button type="button"
                    class="btn btn--ghost interfaces-bulkbar__apply"
                    @onclick="EjecutarAccionSeleccionadaAsync"
                    disabled="@(_loadingList || _selectedIds.Count == 0)">
                <i class="bi bi-lightning-charge"></i> Aplicar
            </button>
            <span class="panel-card__subtitle">@GetSelectionSummary()</span>
        </div>

        @if (_loadingList)
        {
            <div class="usuarios-empty">Cargando documentos...</div>
        }
        else if (_items.Count == 0)
        {
            <div class="usuarios-empty">No hay documentos para los filtros seleccionados.</div>
        }
        else
        {
            <div class="interfaces-mobile-list">
                @foreach (var group in groups)
                {
                    @if (group.ShowHeader)
                    {
                        <div class="interfaces-mobile-group">@group.Label</div>
                    }

                    @foreach (var item in group.Items)
                    {
                        <article class="@GetMobileCardClass(item)"
                                 @onclick="() => _selectedId = item.IdComprobanteRecibido">
                            <div class="interfaces-mobile-card__head">
                                <label class="interfaces-mobile-card__check" @onclick:stopPropagation="true">
                                    <input type="checkbox"
                                           class="interfaces-table__checkbox"
                                           checked="@_selectedIds.Contains(item.IdComprobanteRecibido)"
                                           @onchange="args => ToggleRowSelection(item.IdComprobanteRecibido, args)" />
                                    <span></span>
                                </label>
                                <div class="interfaces-mobile-card__identity">
                                    <strong>#@item.IdComprobanteRecibido</strong>
                                    <span>@item.TipoDocumentoDescripcion</span>
                                </div>
                                <span class="interfaces-status-pill @GetStateCssClass(item.EstadoCodigo, item.EstadoDescripcion)">@item.EstadoDescripcion</span>
                            </div>

                            <p class="interfaces-mobile-card__summary">@GetSummary(item.Observacion)</p>

                            <div class="interfaces-mobile-card__meta">
                                <span><i class="bi bi-clock"></i> @item.FechaHoraGrabacion.ToString("dd/MM/yyyy HH:mm")</span>
                                <span><i class="bi bi-person"></i> @(string.IsNullOrWhiteSpace(item.UsuarioAlta) ? "—" : item.UsuarioAlta)</span>
                                <span><i class="bi bi-paperclip"></i> @item.CantidadAdjuntos adj.</span>
                            </div>

                            <div class="interfaces-mobile-card__actions" @onclick:stopPropagation="true">
                                <button type="button"
                                        class="btn btn--ghost btn--sm"
                                        @onclick="() => AbrirFicha(item.IdComprobanteRecibido)">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                            </div>
                        </article>
                    }
                }
            </div>

            <div class="usuarios-table-wrap">
                <table class="data-table usuarios-table">
                    <thead>
                        <tr>
                            <th class="interfaces-table__selector">
                                <input type="checkbox"
                                       class="interfaces-table__checkbox"
                                       checked="@AreAllCurrentPageSelected"
                                       @onchange="ToggleSelectAll"
                                       title="Seleccionar todos los documentos visibles" />
                            </th>
                            @foreach (var col in visibleColumns)
                            {
                                <th>@col.Label</th>
                            }
                            <th class="interfaces-table__actions">Acciones</th>
                        </tr>
                    </thead>
                    @foreach (var group in groups)
                    {
                        <tbody>
                            @if (group.ShowHeader)
                            {
                                <tr class="usuarios-group-row">
                                    <td colspan="@GetGridColumnSpan(visibleColumns.Count)">@group.Label</td>
                                </tr>
                            }

                            @foreach (var item in group.Items)
                            {
                                <tr class="@(_selectedId == item.IdComprobanteRecibido ? "usuarios-table__row is-selected" : "usuarios-table__row")"
                                    @onclick="() => _selectedId = item.IdComprobanteRecibido"
                                    @ondblclick="() => AbrirFicha(item.IdComprobanteRecibido)">
                                    <td class="interfaces-table__selector" @onclick:stopPropagation="true">
                                        <input type="checkbox"
                                               class="interfaces-table__checkbox"
                                               checked="@_selectedIds.Contains(item.IdComprobanteRecibido)"
                                               @onchange="args => ToggleRowSelection(item.IdComprobanteRecibido, args)"
                                               title="Seleccionar documento" />
                                    </td>
                                    @foreach (var col in visibleColumns)
                                    {
                                        <td>
                                            @switch (col.Key)
                                            {
                                                case InterfacesViewColumnKeys.Numero:
                                                    <strong>#@item.IdComprobanteRecibido</strong>
                                                    break;
                                                case InterfacesViewColumnKeys.Fecha:
                                                    @item.FechaHoraGrabacion.ToString("dd/MM/yyyy HH:mm")
                                                    break;
                                                case InterfacesViewColumnKeys.Tipo:
                                                    @item.TipoDocumentoDescripcion
                                                    break;
                                                case InterfacesViewColumnKeys.Estado:
                                                    <span class="interfaces-status-pill @GetStateCssClass(item.EstadoCodigo, item.EstadoDescripcion)">@item.EstadoDescripcion</span>
                                                    break;
                                                case InterfacesViewColumnKeys.Usuario:
                                                    @(string.IsNullOrWhiteSpace(item.UsuarioAlta) ? "—" : item.UsuarioAlta)
                                                    break;
                                                case InterfacesViewColumnKeys.Observacion:
                                                    @GetSummary(item.Observacion)
                                                    break;
                                                case InterfacesViewColumnKeys.Adjuntos:
                                                    @item.CantidadAdjuntos
                                                    break;
                                            }
                                        </td>
                                    }
                                    <td class="interfaces-table__actions" @onclick:stopPropagation="true">
                                        <button type="button"
                                                class="btn btn--ghost btn--sm interfaces-table__edit"
                                                title="Editar documento"
                                                @onclick="() => AbrirFicha(item.IdComprobanteRecibido)">
                                            <i class="bi bi-pencil-square"></i>
                                            <span>Editar</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }
                </table>
            </div>

            <div class="result-pagination">
                <span class="result-pagination__info">@_pagedTotal registro(s)</span>
                <div class="result-pagination__controls">
                    <button class="result-pagination__btn" title="Página anterior"
                            @onclick="() => CambiarPaginaAsync(_pageNumber - 1)"
                            disabled="@(!_hasPrev || _loadingList)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="result-pagination__btn result-pagination__btn--active">@_pageNumber / @_totalPages</span>
                    <button class="result-pagination__btn" title="Página siguiente"
                            @onclick="() => CambiarPaginaAsync(_pageNumber + 1)"
                            disabled="@(!_hasNext || _loadingList)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <select class="result-pagination__size" title="Registros por página"
                        value="@_filters.PageSize"
                        @onchange="OnPageSizeChangedAsync"
                        disabled="@_loadingList">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        }
    </section>
</div>

@code {
    private readonly InterfacesFilters _filters = new();
    private readonly List<InterfacesInboxItemDto> _items = [];
    private readonly List<InterfacesEstadoOptionDto> _states = [];
    private readonly List<InterfacesTipoDocumentoOptionDto> _documentTypes = [];
    private readonly List<InterfacesViewColumnDto> _viewSettingsDraft = [];
    private readonly HashSet<long> _selectedIds = [];
    private AppUiMessage? _feedback;
    private InterfacesViewSettingsDto _viewSettings = BuildDefaultViewSettings();
    private bool _loadingList;
    private bool _showViewSettings;
    private bool _viewSettingsLoaded;
    private long _selectedId;
    private int _pagedTotal;
    private int _pageNumber = 1;
    private int _totalPages = 1;
    private bool _hasPrev;
    private bool _hasNext;
    private bool _showMobileFilters;
    private bool _showMobileBulkActions;
    private string _draftAgruparPor = InterfacesViewGroupKeys.None;
    private string _viewSettingsUserName = string.Empty;
    private string _bulkAction = BulkActionDelete;
    private DateTime? _filtersDesde = DateTime.Today.AddDays(-30);
    private DateTime? _filtersHasta = DateTime.Today;
    private bool AreAllCurrentPageSelected => _items.Count > 0 && _items.All(item => _selectedIds.Contains(item.IdComprobanteRecibido));

    protected override async Task OnInitializedAsync()
    {
        AppUserSession.StateChanged += OnAppUserSessionChanged;
        await EnsureViewSettingsLoadedAsync();
        await CargarCatalogosAsync();
        await BuscarAsync();
    }

    public void Dispose()
        => AppUserSession.StateChanged -= OnAppUserSessionChanged;

    private async Task CargarCatalogosAsync()
    {
        var statesResult = await UiOps.RunAsync(() => InterfacesSvc.GetStatesAsync(), "No se pudieron cargar los estados.");
        if (statesResult.Success && statesResult.Value is not null)
        {
            _states.Clear();
            _states.AddRange(statesResult.Value);
        }

        var typesResult = await UiOps.RunAsync(() => InterfacesSvc.GetDocumentTypesAsync(), "No se pudieron cargar los tipos documentales.");
        if (typesResult.Success && typesResult.Value is not null)
        {
            _documentTypes.Clear();
            _documentTypes.AddRange(typesResult.Value);
        }
    }

    private async Task RecargarAsync()
    {
        await CargarCatalogosAsync();
        await BuscarAsync();
    }

    private async Task AplicarFiltrosAsync()
    {
        _filters.PageNumber = 1;
        await BuscarAsync();
    }

    private async Task BuscarAsync()
    {
        _loadingList = true;
        _filters.Desde = _filtersDesde;
        _filters.Hasta = _filtersHasta;

        try
        {
            var result = await UiOps.RunAsync(() => InterfacesSvc.SearchAsync(_filters), "No se pudieron cargar los documentos.");
            if (!result.Success || result.Value is null)
            {
                SetFeedback(result.Feedback);
                return;
            }

            _items.Clear();
            _items.AddRange(result.Value.Items);
            _selectedIds.IntersectWith(_items.Select(item => item.IdComprobanteRecibido));
            if (_selectedId > 0 && !_items.Any(item => item.IdComprobanteRecibido == _selectedId))
                _selectedId = 0;
            _pagedTotal = result.Value.Total;
            _pageNumber = result.Value.PageNumber;
            _totalPages = result.Value.TotalPages;
            _hasPrev = result.Value.HasPrev;
            _hasNext = result.Value.HasNext;
        }
        finally
        {
            _loadingList = false;
        }
    }

    private void AbrirFicha(long id)
        => Navigation.NavigateTo($"/interfaces/{id}");

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private async Task CambiarPaginaAsync(int page)
    {
        if (page < 1 || page > _totalPages || _loadingList)
            return;

        _filters.PageNumber = page;
        await BuscarAsync();
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size) && size > 0)
            _filters.PageSize = size;
        _filters.PageNumber = 1;
        await BuscarAsync();
    }

    private void LimpiarFiltros()
    {
        _filters.Texto = string.Empty;
        _filters.IdEstado = null;
        _filters.IdTipoDocumento = null;
        _filtersDesde = DateTime.Today.AddDays(-30);
        _filtersHasta = DateTime.Today;
    }

    private void ToggleMobileFilters() => _showMobileFilters = !_showMobileFilters;

    private void ToggleMobileBulkActions() => _showMobileBulkActions = !_showMobileBulkActions;

    private void ToggleRowSelection(long idComprobanteRecibido, ChangeEventArgs args)
    {
        if (args.Value is bool flag && flag)
            _selectedIds.Add(idComprobanteRecibido);
        else
            _selectedIds.Remove(idComprobanteRecibido);
    }

    private void ToggleSelectAll(ChangeEventArgs args)
    {
        var shouldSelect = args.Value is bool flag && flag;
        foreach (var id in _items.Select(item => item.IdComprobanteRecibido))
        {
            if (shouldSelect)
                _selectedIds.Add(id);
            else
                _selectedIds.Remove(id);
        }
    }

    private async Task EjecutarAccionSeleccionadaAsync()
    {
        if (_selectedIds.Count == 0 || _loadingList)
            return;

        if (!string.Equals(_bulkAction, BulkActionDelete, StringComparison.OrdinalIgnoreCase))
            return;

        var confirm = await Js.InvokeAsync<bool>(
            "confirm",
            $"Se van a eliminar {_selectedIds.Count} documento(s) seleccionados junto con adjuntos e historial relacionados. ¿Querés continuar?");

        if (!confirm)
            return;

        var user = AppUserSession.GetCurrentUserName(Environment.UserName);
        var pc = Environment.MachineName;
        var selectedIds = _selectedIds.OrderBy(id => id).ToArray();

        var result = await UiOps.RunAsync(
            () => InterfacesSvc.DeleteAsync(new InterfacesEliminarComprobantesRequest
            {
                IdsComprobanteRecibido = selectedIds,
                UsuarioAccion = user,
                PcAccion = pc
            }),
            "No se pudieron eliminar los documentos seleccionados.");

        if (!result.Success)
        {
            SetFeedback(result.Feedback);
            return;
        }

        _selectedIds.Clear();
        if (selectedIds.Contains(_selectedId))
            _selectedId = 0;

        SetFeedback(AppUiMessage.Success("Documentos eliminados", $"Se eliminaron {result.Value} documento(s) seleccionados."));
        await BuscarAsync();
    }

    private void OnAppUserSessionChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await EnsureViewSettingsLoadedAsync(force: true);
            StateHasChanged();
        });
    }

    private async Task EnsureViewSettingsLoadedAsync(bool force = false)
    {
        var currentUser = AppUserSession.GetCurrentUserName(string.Empty).Trim();
        if (!force && _viewSettingsLoaded && string.Equals(_viewSettingsUserName, currentUser, StringComparison.OrdinalIgnoreCase))
            return;

        if (string.IsNullOrWhiteSpace(currentUser))
        {
            ApplyViewSettings(BuildDefaultViewSettings(), string.Empty);
            return;
        }

        var result = await UiOps.RunAsync(() => InterfacesSvc.GetViewSettingsAsync(currentUser), "No se pudo cargar la configuración de vista.");
        if (!result.Success || result.Value is null)
        {
            ApplyViewSettings(BuildDefaultViewSettings(), currentUser);
            return;
        }

        ApplyViewSettings(result.Value, currentUser);
    }

    private void ApplyViewSettings(InterfacesViewSettingsDto settings, string userName)
    {
        _viewSettings = settings;
        _viewSettingsUserName = userName;
        _viewSettingsLoaded = true;
        _draftAgruparPor = settings.AgruparPor;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(CloneColumns(settings.Columnas));
    }

    private void AbrirConfiguracionVista()
    {
        _showViewSettings = true;
        _draftAgruparPor = _viewSettings.AgruparPor;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(CloneColumns(_viewSettings.Columnas));
    }

    private void CancelarConfiguracionVista()
    {
        _showViewSettings = false;
    }

    private void ToggleViewColumn(string key, ChangeEventArgs args)
    {
        var column = _viewSettingsDraft.FirstOrDefault(c => string.Equals(c.Key, key, StringComparison.OrdinalIgnoreCase));
        if (column is null) return;
        column.Visible = args.Value is bool flag && flag;
        if (!_viewSettingsDraft.Any(c => c.Visible))
            column.Visible = true;
    }

    private void MoveViewColumn(string key, int offset)
    {
        var ordered = _viewSettingsDraft.OrderBy(c => c.Order).ToList();
        var index = ordered.FindIndex(c => string.Equals(c.Key, key, StringComparison.OrdinalIgnoreCase));
        if (index < 0) return;
        var target = index + offset;
        if (target < 0 || target >= ordered.Count) return;
        (ordered[index], ordered[target]) = (ordered[target], ordered[index]);
        for (var i = 0; i < ordered.Count; i++) ordered[i].Order = i;
        _viewSettingsDraft.Clear();
        _viewSettingsDraft.AddRange(ordered);
    }

    private async Task GuardarConfiguracionVistaAsync()
    {
        var currentUser = AppUserSession.GetCurrentUserName(string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(currentUser))
        {
            SetFeedback(new AppUiMessage { Severity = AppUiFeedbackSeverity.Warning, Title = "Sesión requerida", Message = "Necesitás iniciar sesión para guardar la configuración de vista." });
            return;
        }

        var settings = new InterfacesViewSettingsDto { AgruparPor = _draftAgruparPor, Columnas = CloneColumns(_viewSettingsDraft) };
        var result = await UiOps.RunAsync(async () => { await InterfacesSvc.SaveViewSettingsAsync(currentUser, settings); return true; }, "No se pudo guardar la configuración de vista.");
        if (!result.Success) { SetFeedback(result.Feedback); return; }

        ApplyViewSettings(settings, currentUser);
        _showViewSettings = false;
        SetFeedback(AppUiMessage.Success("Vista guardada", "La configuración de la grilla quedó actualizada para tu usuario."));
    }

    private IReadOnlyList<InterfacesViewColumnDto> GetVisibleColumns()
        => _viewSettings.Columnas.Where(c => c.Visible).OrderBy(c => c.Order).ToList();

    private static int GetGridColumnSpan(int visibleColumnsCount) => visibleColumnsCount + 2;

    private IReadOnlyList<InterfacesGridGroup> BuildGridGroups()
    {
        if (_viewSettings.AgruparPor == InterfacesViewGroupKeys.None)
            return [new InterfacesGridGroup { Label = string.Empty, ShowHeader = false, Items = _items.ToList() }];

        return _items
            .GroupBy(item => ResolveGroupValue(item, _viewSettings.AgruparPor))
            .OrderBy(group => group.Key, StringComparer.CurrentCultureIgnoreCase)
            .Select(group => new InterfacesGridGroup { Label = group.Key, ShowHeader = true, Items = group.ToList() })
            .ToList();
    }

    private static string ResolveGroupValue(InterfacesInboxItemDto item, string grouping)
        => grouping switch
        {
            InterfacesViewGroupKeys.Estado => item.EstadoDescripcion,
            InterfacesViewGroupKeys.Tipo => item.TipoDocumentoDescripcion,
            _ => string.Empty
        };

    private static string GetGroupingLabel(string grouping)
        => grouping switch
        {
            InterfacesViewGroupKeys.Estado => "Estado",
            InterfacesViewGroupKeys.Tipo => "Tipo",
            _ => "Sin agrupar"
        };

    private static InterfacesViewSettingsDto BuildDefaultViewSettings()
        => new()
        {
            AgruparPor = InterfacesViewGroupKeys.None,
            Columnas =
            [
                new() { Key = InterfacesViewColumnKeys.Numero, Label = "Número", Visible = true, Order = 0 },
                new() { Key = InterfacesViewColumnKeys.Fecha, Label = "Fecha", Visible = true, Order = 1 },
                new() { Key = InterfacesViewColumnKeys.Tipo, Label = "Tipo", Visible = true, Order = 2 },
                new() { Key = InterfacesViewColumnKeys.Estado, Label = "Estado", Visible = true, Order = 3 },
                new() { Key = InterfacesViewColumnKeys.Usuario, Label = "Usuario", Visible = true, Order = 4 },
                new() { Key = InterfacesViewColumnKeys.Observacion, Label = "Observación", Visible = true, Order = 5 },
                new() { Key = InterfacesViewColumnKeys.Adjuntos, Label = "Adjuntos", Visible = true, Order = 6 }
            ]
        };

    private static List<InterfacesViewColumnDto> CloneColumns(IEnumerable<InterfacesViewColumnDto> columns)
        => columns.OrderBy(c => c.Order)
                  .Select(c => new InterfacesViewColumnDto { Key = c.Key, Label = c.Label, Visible = c.Visible, Order = c.Order })
                  .ToList();

    private static string GetSummary(string value)
    {
        var normalized = string.IsNullOrWhiteSpace(value) ? "Sin observación." : value.Trim().Replace(Environment.NewLine, " ").Replace('\n', ' ');
        return normalized.Length > 100 ? normalized[..97] + "..." : normalized;
    }

    private static string GetFeedbackClass(AppUiMessage message)
        => message.Severity switch
        {
            AppUiFeedbackSeverity.Success => "editor-msg--ok",
            AppUiFeedbackSeverity.Warning => "editor-msg--warning",
            _ => "editor-msg--error"
        };

    private static string GetStateCssClass(string estadoCodigo, string estadoDescripcion)
    {
        var key = $"{estadoCodigo} {estadoDescripcion}".ToUpperInvariant();
        if (key.Contains("ANUL"))
            return "interfaces-status-pill--danger";
        if (key.Contains("PEND") || key.Contains("PROCES"))
            return "interfaces-status-pill--warning";
        if (key.Contains("FINAL") || key.Contains("CERR") || key.Contains("APROB"))
            return "interfaces-status-pill--success";
        return "interfaces-status-pill--info";
    }

    private void SetFeedback(AppUiMessage? message)
        => _feedback = message;

    private string GetMobileFiltersSectionClass()
        => _showMobileFilters ? "interfaces-mobile-section is-open" : "interfaces-mobile-section";

    private string GetMobileBulkbarClass()
        => _showMobileBulkActions ? "is-mobile-open" : string.Empty;

    private string GetMobileCardClass(InterfacesInboxItemDto item)
        => _selectedId == item.IdComprobanteRecibido
            ? "interfaces-mobile-card is-selected"
            : "interfaces-mobile-card";

    private string GetSelectionSummary()
        => _selectedIds.Count == 0
            ? "Seleccioná uno o más documentos para ejecutar acciones."
            : $"{_selectedIds.Count} documento(s) seleccionado(s).";

