@page "/actividad"
@inject DashboardCompras.Services.IComprasDashboardService DashboardService
@inject DashboardCompras.Services.FilterStateService FilterState

<PageTitle>Actividad | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Actividad</h2>
            <p class="page-intro__text">Seguimiento operativo de carga por usuario, volumen de trabajo y ritmo de actividad. <a class="help-link" href="/ayuda#10-actividad">Ver ayuda</a></p>
        </div>
    </div>

    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state">
            <span class="empty-state__eyebrow">Consulta</span>
            <h3>No fue posible cargar la actividad</h3>
            <p>@_error</p>
        </div>
    }
    else if (_page is null)
    {
        <div class="loading">Cargando actividad...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Comprobantes cargados" Valor="@_page.Kpis.CantidadComprobantes.ToString("N0")" Icono="C" />
            <KpiCard Titulo="Ítems cargados" Valor="@_page.Kpis.CantidadItems.ToString("N0")" Icono="I" />
            <KpiCard Titulo="Usuarios activos" Valor="@_page.Kpis.UsuariosActivos.ToString("N0")" Icono="U" />
            <KpiCard Titulo="Promedio ítems/cpte" Valor="@_page.Kpis.PromedioItemsPorComprobante.ToString("N2", Cultura)" Icono="%" />
            <KpiCard Titulo="Promedio cpte/usuario" Valor="@_page.Kpis.PromedioComprobantesPorUsuario.ToString("N2", Cultura)" Icono="P" />
            <KpiCard Titulo="Día con mayor actividad" Valor="@_page.Kpis.DiaMayorActividad" Icono="D" />
            <KpiCard Titulo="Usuario más activo" Valor="@_page.Kpis.UsuarioMasActivo" Icono="*" />
            <KpiCard Titulo="Más carga con detalle" Valor="@_page.Kpis.UsuarioMasDetalle" Descripcion="@DetalleUsuarioMasTrabajo()" Icono="+" Destacado="true" />
        </div>

        @if (_page.Insights.Count > 0)
        {
            <div class="alert-band">
                @foreach (var insight in _page.Insights)
                {
                    <span class="alert-chip alert-chip--@insight.Tipo">@insight.Mensaje</span>
                }
            </div>
        }

        <div class="chart-grid">
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Comprobantes por día</h3>
                        <p class="panel-card__subtitle">Cantidad diaria de comprobantes cargados</p>
                    </div>
                </div>
                <LineChart Data="_page.SerieComprobantesPorDia" Titulo="Comprobantes por día" MostrarMoneda="false" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Ítems por día</h3>
                        <p class="panel-card__subtitle">Volumen diario de registros cargados</p>
                    </div>
                </div>
                <LineChart Data="_page.SerieItemsPorDia" Titulo="Ítems por día" MostrarMoneda="false" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Tipo de carga</h3>
                        <p class="panel-card__subtitle">Con detalle vs comprobantes contables</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_page.SegmentacionTipoCarga" Formato="numero" />
            </section>
        </div>

        <div class="split-grid">
            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Comprobantes por usuario</h3>
                        <p class="panel-card__subtitle">Ranking de volumen por usuario</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_page.ComprobantesPorUsuario" Formato="numero" />
            </section>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Ítems por usuario</h3>
                        <p class="panel-card__subtitle">Carga de detalle registrada</p>
                    </div>
                </div>
                <HorizontalBarChart Data="_page.ItemsPorUsuario" Formato="numero" />
            </section>
        </div>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Actividad por usuario</h3>
                    <p class="panel-card__subtitle">Hacé clic en Ver detalle para abrir la ficha del usuario y sus comprobantes.</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th style="text-align:right;">Comprobantes</th>
                            <th style="text-align:right;">Ítems</th>
                            <th style="text-align:right;">Prom. ítems/cpte</th>
                            <th style="text-align:right;">Importe total</th>
                            <th style="text-align:right;">Con detalle</th>
                            <th style="text-align:right;">Contables</th>
                            <th style="text-align:right;">% detalle</th>
                            <th>Última actividad</th>
                            <th style="text-align:right;">Días activos</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _page.Usuarios)
                        {
                            <tr class="@(_detalle?.Resumen.Usuario == row.Usuario ? "row--selected" : string.Empty)">
                                <td><strong>@row.Usuario</strong></td>
                                <td style="text-align:right;">@row.CantidadComprobantes.ToString("N0")</td>
                                <td style="text-align:right;">@row.CantidadItems.ToString("N0")</td>
                                <td style="text-align:right;">@row.PromedioItemsPorComprobante.ToString("N2", Cultura)</td>
                                <td style="text-align:right;">@Moneda(row.ImporteTotal)</td>
                                <td style="text-align:right;">@row.ComprobantesConDetalle.ToString("N0")</td>
                                <td style="text-align:right;">@row.ComprobantesContables.ToString("N0")</td>
                                <td style="text-align:right;">@row.PorcentajeConDetalle.ToString("P1", Cultura)</td>
                                <td>@(row.UltimaActividad?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td style="text-align:right;">@row.DiasConActividad.ToString("N0")</td>
                                <td><button class="btn btn--ghost btn--sm" @onclick="() => SelectUsuarioAsync(row.Usuario)">Ver detalle</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @if (_detalle is not null)
        {
            <div class="split-grid">
                <DetailCard Titulo="@_detalle.Resumen.Usuario" Subtitulo="Ficha de actividad del usuario">
                    <div class="detail-row"><span class="detail-row__label">Comprobantes</span><strong>@_detalle.Resumen.CantidadComprobantes.ToString("N0")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Ítems</span><strong>@_detalle.Resumen.CantidadItems.ToString("N0")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Promedio ítems/cpte</span><strong>@_detalle.Resumen.PromedioItemsPorComprobante.ToString("N2", Cultura)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Importe total</span><strong>@Moneda(_detalle.Resumen.ImporteTotal)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Con detalle</span><strong>@_detalle.Resumen.ComprobantesConDetalle.ToString("N0")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Contables</span><strong>@_detalle.Resumen.ComprobantesContables.ToString("N0")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Última actividad</span><strong>@(_detalle.Resumen.UltimaActividad?.ToString("dd/MM/yyyy") ?? "—")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Días con actividad</span><strong>@_detalle.Resumen.DiasConActividad.ToString("N0")</strong></div>
                </DetailCard>

                <section class="panel-card">
                    <div class="panel-card__header">
                        <div>
                            <h3 class="panel-card__title">Evolución del usuario</h3>
                            <p class="panel-card__subtitle">Comprobantes e ítems cargados por día</p>
                        </div>
                    </div>
                    <div class="three-grid">
                        <section class="panel-card">
                            <h4 class="panel-card__title">Comprobantes</h4>
                            <LineChart Data="_detalle.SerieComprobantesPorDia" Titulo="Comprobantes del usuario" MostrarMoneda="false" />
                        </section>
                        <section class="panel-card">
                            <h4 class="panel-card__title">Ítems</h4>
                            <LineChart Data="_detalle.SerieItemsPorDia" Titulo="Ítems del usuario" MostrarMoneda="false" />
                        </section>
                        <section class="panel-card">
                            <h4 class="panel-card__title">Últimos comprobantes</h4>
                            <div class="detail-list">
                                @foreach (var cpte in _detalle.Comprobantes.Take(8))
                                {
                                    <div class="detail-row">
                                        <span class="detail-row__label">@cpte.Fecha.ToString("dd/MM/yy") · @cpte.Tc @cpte.IdComprobante</span>
                                        <span>@Moneda(cpte.ImporteDashboard)</span>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>
                </section>
            </div>

            <DataTable Titulo="Comprobantes del usuario" Subtitulo="@($"{_detalle.Comprobantes.Count} comprobantes más recientes")">
                <Header>
                    <tr>
                        <th>Fecha</th>
                        <th>TC</th>
                        <th>Comprobante</th>
                        <th>Proveedor</th>
                        <th style="text-align:right;">Total</th>
                        <th>Detalle</th>
                        <th style="text-align:right;">Ítems</th>
                        <th>Tipo carga</th>
                        <th>Alerta</th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in _detalle.Comprobantes)
                    {
                        <tr class="@GetActividadRowCss(item)">
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Tc</td>
                            <td>@item.IdComprobante</td>
                            <td><strong>@item.RazonSocial</strong><span class="text-muted">@item.Cuenta</span></td>
                            <td style="text-align:right;">@Moneda(item.ImporteDashboard)</td>
                            <td><span class="@ActividadFlagCss(item.TieneDetalle)">@ActividadFlagLabel(item.TieneDetalle)</span></td>
                            <td style="text-align:right;">@item.CantidadItems.ToString("N0")</td>
                            <td><span class="@ActividadTipoCargaCss(item.EsContable)">@ActividadTipoCargaLabel(item.EsContable)</span></td>
                            <td>@((MarkupString)RenderActividadAlerta(item))</td>
                        </tr>
                    }
                </Rows>
            </DataTable>
        }
    }
</section>

@code {
    private static readonly System.Globalization.CultureInfo Cultura = System.Globalization.CultureInfo.GetCultureInfo("es-AR");

    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private ActividadPageDto? _page;
    private ActividadUsuarioDetalleDto? _detalle;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        _detalle = null;

        try
        {
            _page = await DashboardService.GetActividadPageAsync(_filters);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SelectUsuarioAsync(string usuario)
    {
        _detalle = await DashboardService.GetActividadUsuarioDetalleAsync(usuario, _filters);
    }

    private string DetalleUsuarioMasTrabajo()
        => _page is null
            ? string.Empty
            : $"{_page.Kpis.ComprobantesConDetalleMaximos:N0} cptes con detalle · {_page.Kpis.ItemsDelUsuarioMasDetalle:N0} ítems";

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", Cultura);
    private static string ActividadFlagLabel(bool value) => value ? "Sí" : "No";
    private static string ActividadFlagCss(bool value) => value ? "badge-state badge-state--ok" : "badge-state badge-state--danger";
    private static string ActividadTipoCargaLabel(bool esContable) => esContable ? "Contable" : "Con detalle";
    private static string ActividadTipoCargaCss(bool esContable) => esContable ? "badge-state badge-state--warn" : "badge-state badge-state--ok";

    private static string GetActividadRowCss(ComprobanteDto item)
    {
        if (item.ImporteDashboard == 0)
        {
            return "row--critical";
        }

        if (!item.TieneDetalle || item.IvaEnCero)
        {
            return "row--warning";
        }

        return string.Empty;
    }

    private static string RenderActividadAlerta(ComprobanteDto item)
    {
        if (string.IsNullOrWhiteSpace(item.AlertaOperativa))
        {
            return "<span class=\"table-alert table-alert--neutral\">Sin alerta</span>";
        }

        return item.AlertaOperativa switch
        {
            "En cero" => "<span class=\"table-alert table-alert--danger\"><span class=\"table-alert__dot\"></span>En cero</span>",
            "Sin detalle" => "<span class=\"table-alert table-alert--warn\"><span class=\"table-alert__dot\"></span>Sin detalle</span>",
            "IVA 0" => "<span class=\"table-alert table-alert--info\"><span class=\"table-alert__dot\"></span>IVA 0</span>",
            _ => $"<span class=\"table-alert table-alert--neutral\">{item.AlertaOperativa}</span>"
        };
    }
}
