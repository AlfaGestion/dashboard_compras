@page "/compras/informesia/resultado/{ExecutionId:guid}"
@inject DashboardCompras.Services.IInformesIaService InformesIaService
@inject IJSRuntime JS

<PageTitle>Resultado InformesIA | Dashboard de Compras</PageTitle>

<section class="page-grid ia-page">
    @if (_result is null)
    {
        <div class="loading">Cargando informe...</div>
    }
    else
    {
        <section class="panel-card ia-report @(_result.Exitoso ? string.Empty : "ia-report--error")">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">@_result.Titulo</h3>
                    <p class="panel-card__subtitle">@_result.Subtitulo</p>
                </div>
                <div class="ia-report__toolbar no-print">
                    <button class="btn btn--ghost" @onclick="ExportResultPdfAsync">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Exportar PDF</span>
                    </button>
                </div>
            </div>

            <div class="ia-report-meta">
                <div>
                    <span class="ia-report-meta__label">Consulta</span>
                    <strong>@_result.ConsultaOriginal</strong>
                </div>
                <div>
                    <span class="ia-report-meta__label">Generado</span>
                    <strong>@_result.GeneradoEn.ToString("dd/MM/yyyy HH:mm")</strong>
                </div>
                <div>
                    <span class="ia-report-meta__label">Filtros</span>
                    <strong>@FormatFilters(_result.FiltrosAplicados)</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_result.NotaSeguridad))
            {
                <div class="ia-inline-message ia-inline-message--safe">@_result.NotaSeguridad</div>
            }

            @if (!string.IsNullOrWhiteSpace(_result.Mensaje))
            {
                <div class="ia-inline-message @(_result.Exitoso ? "ia-inline-message--info" : "ia-inline-message--error")">@_result.Mensaje</div>
            }

            @if (!string.IsNullOrWhiteSpace(_result.Resumen))
            {
                <div class="ia-summary">
                    <span class="ia-summary__label">Resumen</span>
                    <p>@_result.Resumen</p>
                </div>
            }

            @if (_result.Exitoso && _result.Grafico is not null)
            {
                <section class="panel-card ia-chart">
                    @if (_result.Grafico.Tipo == "line")
                    {
                        <LineChart Data="_result.Grafico.Linea" Titulo="@_result.Grafico.Titulo" Subtitulo="@_result.Grafico.Subtitulo" />
                    }
                    else
                    {
                        <HorizontalBarChart Data="_result.Grafico.Barras" Titulo="@_result.Grafico.Titulo" Subtitulo="@_result.Grafico.Subtitulo" Formato="@_result.Grafico.Formato" />
                    }
                </section>
            }

            @if (_result.Columnas.Count > 0)
            {
                <DataTable Titulo="Resultado" Subtitulo="@($"{_result.Filas.Count} fila(s) devueltas")">
                    <Header>
                        <tr>
                            @foreach (var column in _result.Columnas)
                            {
                                <th style="text-align:@column.Align;">@column.Label</th>
                            }
                        </tr>
                    </Header>
                    <Rows>
                        @foreach (var row in _result.Filas)
                        {
                            <tr>
                                @for (var i = 0; i < _result.Columnas.Count; i++)
                                {
                                    <td style="text-align:@_result.Columnas[i].Align;">@row.Values[i]</td>
                                }
                            </tr>
                        }
                    </Rows>
                </DataTable>
            }

            @if (_result.SugerenciasRelacionadas.Any())
            {
                <div class="ia-related">
                    <span class="ia-summary__label">Probar también</span>
                    <div class="ia-chip-list">
                        @foreach (var item in _result.SugerenciasRelacionadas)
                        {
                            <a class="ia-chip ia-chip--secondary" href="/compras/informesia">
                                <span class="ia-chip__title">@item.Texto</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </section>
    }
</section>

@code {
    [Parameter] public Guid ExecutionId { get; set; }
    private InformeIaResultDto? _result;

    protected override async Task OnInitializedAsync()
    {
        _result = await InformesIaService.GetExecutionResultAsync(ExecutionId) ?? new InformeIaResultDto
        {
            ExecutionId = ExecutionId,
            Exitoso = false,
            Titulo = "Informes IA",
            Subtitulo = "Resultado no disponible",
            Mensaje = "No encontré un resultado guardado para esta ejecución. Probablemente ya no esté disponible o el enlace sea inválido."
        };
    }

    private async Task ExportResultPdfAsync()
    {
        await JS.InvokeVoidAsync("dashboardExport.printCurrentPage", "Resultado Informes IA");
    }

    private static string FormatFilters(DashboardFilters filters)
    {
        var parts = new List<string>();
        if (filters.FechaDesde.HasValue || filters.FechaHasta.HasValue)
        {
            parts.Add($"Fecha {filters.FechaDesde:dd/MM/yyyy} a {filters.FechaHasta:dd/MM/yyyy}");
        }

        AddFilter(parts, "Proveedor", filters.Proveedor);
        AddFilter(parts, "Artículo", filters.Articulo ?? filters.ArticuloDescripcion ?? filters.ArticuloCodigo);
        AddFilter(parts, "Rubro", filters.Rubro);
        AddFilter(parts, "Familia", filters.Familia);
        AddFilter(parts, "Usuario", filters.Usuario);
        AddFilter(parts, "Sucursal", filters.Sucursal);
        AddFilter(parts, "Depósito", filters.Deposito);
        AddFilter(parts, "Estado", filters.Estado);
        AddFilter(parts, "TC", filters.TipoComprobante);
        return parts.Count == 0 ? "Sin filtros adicionales" : string.Join(" · ", parts);
    }

    private static void AddFilter(List<string> parts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add($"{label}: {value}");
        }
    }
}
