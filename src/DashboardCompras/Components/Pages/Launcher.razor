@page "/"
<PageTitle>Aplicaciones | Alfa Gestión</PageTitle>

<div class="launcher">
    <div class="launcher__header">
        <p class="launcher__eyebrow">Alfa Gestión</p>
        <h1 class="launcher__title">Aplicaciones</h1>
        <p class="launcher__subtitle">Seleccioná el módulo al que querés ingresar.</p>
    </div>

    <div class="launcher__grid">
        <a class="app-card" href="/compras">
            <div class="app-card__icon app-card__icon--compras">
                <i class="bi bi-cart-fill"></i>
            </div>
            <span class="app-card__name">Compras</span>
            <span class="app-card__desc">Dashboard de compras, proveedores, artículos e informes IA</span>
        </a>

        <div class="app-card app-card--disabled">
            <div class="app-card__icon app-card__icon--ventas">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <span class="app-card__name">Ventas</span>
            <span class="app-card__desc">Próximamente</span>
        </div>

        <div class="app-card app-card--disabled">
            <div class="app-card__icon app-card__icon--stock">
                <i class="bi bi-box-seam"></i>
            </div>
            <span class="app-card__name">Stock</span>
            <span class="app-card__desc">Próximamente</span>
        </div>

        <div class="app-card app-card--disabled">
            <div class="app-card__icon app-card__icon--caja">
                <i class="bi bi-bank"></i>
            </div>
            <span class="app-card__name">Caja y Bancos</span>
            <span class="app-card__desc">Próximamente</span>
        </div>

        <div class="app-card app-card--disabled">
            <div class="app-card__icon app-card__icon--contabilidad">
                <i class="bi bi-journal-bookmark-fill"></i>
            </div>
            <span class="app-card__name">Contabilidad</span>
            <span class="app-card__desc">Próximamente</span>
        </div>

        <a class="app-card" href="/consultas">
            <div class="app-card__icon app-card__icon--consultas">
                <i class="bi bi-table"></i>
            </div>
            <span class="app-card__name">Diseñador de consultas</span>
            <span class="app-card__desc">Ejecutá y exportá las consultas guardadas del sistema</span>
        </a>

        <a class="app-card" href="/costos">
            <div class="app-card__icon app-card__icon--compras">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <span class="app-card__name">Actualización de costos</span>
            <span class="app-card__desc">Importá listas de proveedores y registrá corridas para revisión y auditoría</span>
        </a>
    </div>
</div>
