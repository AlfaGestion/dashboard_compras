@page "/contabilidad"
@inject DashboardCompras.Services.IGestionDashboardService GestionSvc
@inject DashboardCompras.Services.GestionFilterStateService FilterState

<PageTitle>Contabilidad | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Contabilidad</h2>
            <p class="page-intro__text">Mirada gerencial de movimiento contable, cuentas más activas y asientos recientes.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros contables</h3>
                <p class="panel-card__subtitle">Cuentas, detalle, usuario y sucursal para una lectura gerencial más precisa.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
                <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
                <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
                <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
                <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
            <div class="filters-toggle-wrap">
                <button type="button" class="btn btn--ghost filters-toggle" @onclick="ToggleAdvanced">
                    @(_showAdvanced ? "Ocultar filtros" : "Mostrar filtros")
                </button>
            </div>
        </div>

        <div class="filters-summary" aria-live="polite">
            <span class="filters-summary__label">Filtros activos</span>
            <span class="filters-summary__text">@BuildSummary()</span>
        </div>

        @if (_showAdvanced)
        {
            <div class="filters-grid filters-grid--wide">
                <div class="field">
                    <label>Cuenta contable</label>
                    <InputText @bind-Value="_filters.CuentaContable" />
                </div>
                <div class="field">
                    <label>Detalle</label>
                    <InputText @bind-Value="_filters.Detalle" />
                </div>
                <div class="field">
                    <label>Usuario</label>
                    <InputSelect @bind-Value="_filters.Usuario">
                        <option value="">Todos</option>
                        @foreach (var item in _options.Usuarios)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Sucursal</label>
                    <InputSelect @bind-Value="_filters.Sucursal">
                        <option value="">Todas</option>
                        @foreach (var item in _options.Sucursales)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Tipo</label>
                    <InputSelect @bind-Value="_filters.Tipo">
                        <option value="">Todos</option>
                        @foreach (var item in _options.Tipos)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
            </div>
        }

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
            <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
        </div>
    </section>

    @if (_loading)
    {
        <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Cargando contabilidad…</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="consultas-error"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }
    else
    {
        <section class="kpi-grid">
            <article class="kpi-card"><div class="kpi-card__label">Debe período</div><div class="kpi-card__value">@FmtMoney(_data.DebeMes)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Haber período</div><div class="kpi-card__value">@FmtMoney(_data.HaberMes)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Saldo neto</div><div class="kpi-card__value">@FmtMoney(_data.SaldoNetoMes)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Asientos</div><div class="kpi-card__value">@_data.AsientosMes</div></article>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <LineChart Data="_data.EvolucionMensual" Titulo="Evolución contable" Subtitulo="Según filtros aplicados" />
            </article>
            <article class="panel-card">
                <HorizontalBarChart Data="_data.TopCuentas" Titulo="Cuentas con más movimiento" Subtitulo="Mayor incidencia del período" />
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Últimos asientos</h3>
                    <p class="panel-card__subtitle">Referencia rápida para seguimiento gerencial.</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead><tr><th>Fecha</th><th>Cuenta</th><th>Detalle</th><th>Tipo</th><th>Importe</th></tr></thead>
                    <tbody>
                    @foreach (var item in _data.UltimosAsientos)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Cuenta</td>
                            <td>@item.Detalle</td>
                            <td>@item.Tipo</td>
                            <td>@FmtMoney(item.Importe)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private string _error = string.Empty;
    private bool _showAdvanced;
    private ContabilidadDashboardDto _data = new();
    private ContabilidadDashboardFilters _filters = null!;
    private ContabilidadFilterOptionsDto _options = new();

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Contabilidad;
        try
        {
            _options = await GestionSvc.GetContabilidadFilterOptionsAsync();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try { _data = await GestionSvc.GetContabilidadAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private Task HoyAsync() => ApplyQuickRangeAsync("hoy");
    private Task SemanaAsync() => ApplyQuickRangeAsync("semana");
    private Task MesAsync() => ApplyQuickRangeAsync("mes");
    private Task MesAnteriorAsync() => ApplyQuickRangeAsync("mes-anterior");
    private Task UltimosTresAsync() => ApplyQuickRangeAsync("ultimos-3");
    private Task AnioAsync() => ApplyQuickRangeAsync("anio");
    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
        _filters.FechaHasta = today;
        _filters.CuentaContable = null;
        _filters.Detalle = null;
        _filters.Usuario = null;
        _filters.Sucursal = null;
        _filters.Tipo = null;
        await LoadAsync();
    }

    private async Task ApplyQuickRangeAsync(string key)
    {
        var today = DateTime.Today;
        switch (key)
        {
            case "hoy":
                _filters.FechaDesde = today;
                _filters.FechaHasta = today;
                break;
            case "semana":
                var diff = ((int)today.DayOfWeek + 6) % 7;
                _filters.FechaDesde = today.AddDays(-diff);
                _filters.FechaHasta = today;
                break;
            case "mes":
                _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
                _filters.FechaHasta = today;
                break;
            case "mes-anterior":
                var firstThisMonth = new DateTime(today.Year, today.Month, 1);
                _filters.FechaDesde = firstThisMonth.AddMonths(-1);
                _filters.FechaHasta = firstThisMonth.AddDays(-1);
                break;
            case "ultimos-3":
                _filters.FechaDesde = today.AddMonths(-3);
                _filters.FechaHasta = today;
                break;
            case "anio":
                _filters.FechaDesde = new DateTime(today.Year, 1, 1);
                _filters.FechaHasta = today;
                break;
        }

        await LoadAsync();
    }

    private string BuildSummary()
    {
        var parts = new List<string>();
        if (_filters.FechaDesde.HasValue || _filters.FechaHasta.HasValue)
        {
            parts.Add($"Fecha: {_filters.FechaDesde:dd/MM/yyyy} a {_filters.FechaHasta:dd/MM/yyyy}");
        }

        AddIfPresent(parts, "Cuenta", _filters.CuentaContable);
        AddIfPresent(parts, "Detalle", _filters.Detalle);
        AddIfPresent(parts, "Usuario", _filters.Usuario);
        AddIfPresent(parts, "Sucursal", _filters.Sucursal);
        AddIfPresent(parts, "Tipo", _filters.Tipo);

        return parts.Count == 0 ? "Sin filtros seleccionados." : string.Join(" | ", parts);
    }

    private static void AddIfPresent(List<string> parts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add($"{label}: {value}");
        }
    }

    private static string FmtMoney(decimal value) => value.ToString("$ #,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
