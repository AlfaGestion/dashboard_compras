@page "/contabilidad"
@inject DashboardCompras.Services.IGestionDashboardService GestionSvc
@inject DashboardCompras.Services.GestionFilterStateService FilterState

<PageTitle>Contabilidad | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Contabilidad</h2>
            <p class="page-intro__text">Balance general de saldos agrupado por niveles del plan de cuentas.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros</h3>
                <p class="panel-card__subtitle">Período y sucursal.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
                <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
                <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
                <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
                <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
            <div class="field">
                <label>Sucursal</label>
                <InputSelect @bind-Value="_filters.Sucursal">
                    <option value="">Todas</option>
                    @foreach (var item in _options.Sucursales)
                    {
                        <option value="@item">@item</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="filters-summary" aria-live="polite">
            <span class="filters-summary__label">Filtros activos</span>
            <span class="filters-summary__text">@BuildSummary()</span>
        </div>

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
            <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
        </div>
    </section>

    <section class="panel-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Balance General de Saldos</h3>
                <p class="panel-card__subtitle">
                    Saldos agrupados por nivel del plan de cuentas (configurado en TA_CONFIGURACION).
                </p>
            </div>
            <div class="balance-nivel-selector">
                <label class="balance-nivel-selector__label">Nivel</label>
                <InputSelect @bind-Value="_nivelBalance" class="balance-nivel-selector__select">
                    <option value="1">1 — Capítulo</option>
                    <option value="2">2 — Sub-capítulo</option>
                    <option value="3">3 — Rubro</option>
                    <option value="4">4 — Sub-rubro</option>
                </InputSelect>
                <button class="btn btn--ghost btn--sm" @onclick="LoadBalanceAsync">Actualizar</button>
            </div>
        </div>

        @if (_loadingBalance)
        {
            <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Calculando balance…</div>
        }
        else if (!string.IsNullOrWhiteSpace(_errorBalance))
        {
            <div class="consultas-error"><i class="bi bi-exclamation-triangle"></i> @_errorBalance</div>
        }
        else if (_balance is not null && _balance.Filas.Count > 0)
        {
            <section class="kpi-grid kpi-grid--4">
                <article class="kpi-card">
                    <div class="kpi-card__icon">A</div>
                    <div class="kpi-card__body">
                        <p class="kpi-card__label">Total Activo</p>
                        <h3 class="kpi-card__value">@FmtCompact(_balance.TotalActivo)</h3>
                        <p class="kpi-card__description">@FmtSaldo(_balance.TotalActivo)</p>
                    </div>
                </article>
                <article class="kpi-card">
                    <div class="kpi-card__icon">P</div>
                    <div class="kpi-card__body">
                        <p class="kpi-card__label">Total Pasivo</p>
                        <h3 class="kpi-card__value">@FmtCompact(Math.Abs(_balance.TotalPasivo))</h3>
                        <p class="kpi-card__description">@FmtSaldo(_balance.TotalPasivo)</p>
                    </div>
                </article>
                <article class="kpi-card">
                    <div class="kpi-card__icon">N</div>
                    <div class="kpi-card__body">
                        <p class="kpi-card__label">Patrimonio Neto</p>
                        <h3 class="kpi-card__value">@FmtCompact(Math.Abs(_balance.PatrimonioNeto))</h3>
                        <p class="kpi-card__description">@FmtSaldo(_balance.PatrimonioNeto)</p>
                    </div>
                </article>
                <article class="kpi-card @(_balance.TotalResultados >= 0 ? "" : "kpi-card--warning")">
                    <div class="kpi-card__icon">R</div>
                    <div class="kpi-card__body">
                        <p class="kpi-card__label">Resultados</p>
                        <h3 class="kpi-card__value">@FmtCompact(Math.Abs(_balance.TotalResultados))</h3>
                        <p class="kpi-card__description">@FmtSaldo(_balance.TotalResultados)</p>
                    </div>
                </article>
            </section>

            <div class="table-scroll">
                <table class="data-table balance-saldos-table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Descripción</th>
                            @for (int i = _balance.NivelAplicado - 1; i >= 0; i--)
                            {
                                <th class="col-num">@_nivelNombres[i]</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var fila in _balance.Filas)
                    {
                        bool esCapitulo = fila.Codigo.Length == _balance.DigitosCapitulo;
                        int rowNivel = GetNivelIndex(fila.Codigo);
                        <tr class="@(esCapitulo ? "balance-row--capitulo" : "balance-row--detalle")">
                            <td class="balance-col-codigo">@fila.Codigo</td>
                            <td>@fila.Descripcion</td>
                            @for (int i = _balance.NivelAplicado - 1; i >= 0; i--)
                            {
                                if (i == rowNivel)
                                {
                                    <td class="col-num @(fila.Saldo < 0 ? "text-danger" : "")">@FmtSaldo(fila.Saldo)</td>
                                }
                                else
                                {
                                    <td class="col-num balance-col-empty"></td>
                                }
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else if (_balance is not null)
        {
            <p class="chart-empty">Sin saldos para el período y filtros seleccionados.</p>
        }
    </section>
</div>

@code {
    private bool _loadingBalance = true;
    private string _errorBalance = string.Empty;
    private BalanceSaldosDto? _balance;
    private int _nivelBalance = 2;
    private ContabilidadDashboardFilters _filters = null!;
    private ContabilidadFilterOptionsDto _options = new();

    // Nombres de nivel en orden ascendente (índice 0 = más alto = Capítulo)
    private static readonly string[] _nivelNombres = ["Capítulo", "Sub-Capítulo", "Rubro", "Sub-Rubro"];

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Contabilidad;
        try { _options = await GestionSvc.GetContabilidadFilterOptionsAsync(); }
        catch { /* opciones no críticas, no bloquea la carga */ }
        await LoadAsync();
    }

    private Task LoadAsync() => LoadBalanceAsync();

    private async Task LoadBalanceAsync()
    {
        _loadingBalance = true;
        _errorBalance = string.Empty;
        StateHasChanged();
        try { _balance = await GestionSvc.GetBalanceSaldosAsync(_filters, _nivelBalance); }
        catch (Exception ex) { _errorBalance = ex.Message; }
        finally { _loadingBalance = false; }
    }

    // Devuelve el índice de nivel (0=Capítulo, 1=Sub-Capítulo, ...) según la longitud del código
    private int GetNivelIndex(string codigo)
    {
        if (_balance is null) return 0;
        for (int i = 0; i < _balance.DigitosCumulativos.Count; i++)
        {
            if (codigo.Length == _balance.DigitosCumulativos[i]) return i;
        }
        return _balance.NivelAplicado - 1;
    }

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
        _filters.FechaHasta = today;
        _filters.Sucursal = null;
        await LoadAsync();
    }

    private Task HoyAsync()         { var t = DateTime.Today; _filters.FechaDesde = t; _filters.FechaHasta = t; return LoadAsync(); }
    private Task SemanaAsync()      { var t = DateTime.Today; _filters.FechaDesde = t.AddDays(-(((int)t.DayOfWeek + 6) % 7)); _filters.FechaHasta = t; return LoadAsync(); }
    private Task MesAsync()         { var t = DateTime.Today; _filters.FechaDesde = new DateTime(t.Year, t.Month, 1); _filters.FechaHasta = t; return LoadAsync(); }
    private Task MesAnteriorAsync() { var f = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1); _filters.FechaDesde = f.AddMonths(-1); _filters.FechaHasta = f.AddDays(-1); return LoadAsync(); }
    private Task UltimosTresAsync() { var t = DateTime.Today; _filters.FechaDesde = t.AddMonths(-3); _filters.FechaHasta = t; return LoadAsync(); }
    private Task AnioAsync()        { var t = DateTime.Today; _filters.FechaDesde = new DateTime(t.Year, 1, 1); _filters.FechaHasta = t; return LoadAsync(); }

    private string BuildSummary()
    {
        var parts = new List<string>();
        if (_filters.FechaDesde.HasValue || _filters.FechaHasta.HasValue)
            parts.Add($"Fecha: {_filters.FechaDesde:dd/MM/yyyy} a {_filters.FechaHasta:dd/MM/yyyy}");
        if (!string.IsNullOrWhiteSpace(_filters.Sucursal))
            parts.Add($"Sucursal: {_filters.Sucursal}");
        return parts.Count == 0 ? "Sin filtros seleccionados." : string.Join(" | ", parts);
    }

    private static readonly System.Globalization.CultureInfo _esAr =
        System.Globalization.CultureInfo.GetCultureInfo("es-AR");

    private static string FmtMoney(decimal v) => v.ToString("$ #,##0", _esAr);

    private static string FmtSaldo(decimal v) =>
        v < 0 ? $"($ {(-v).ToString("#,##0.00", _esAr)})" : v.ToString("$ #,##0.00", _esAr);

    private static string FmtCompact(decimal v) => v switch
    {
        >= 1_000_000_000m => $"$ {(v / 1_000_000_000m).ToString("N1", _esAr)}B",
        >= 1_000_000m     => $"$ {(v / 1_000_000m).ToString("N1", _esAr)}M",
        >= 1_000m         => $"$ {(v / 1_000m).ToString("N1", _esAr)}K",
        _                 => FmtMoney(v)
    };
}
