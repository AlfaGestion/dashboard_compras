@page "/familias"
@inject DashboardCompras.Services.IComprasDashboardService DashboardService
@inject DashboardCompras.Services.FilterStateService FilterState

<PageTitle>Familias | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro"><div><h2 class="page-intro__title">Familias</h2><p class="page-intro__text">Estructura jerárquica, concentración del gasto y variación por familia y subfamilia. <a class="help-link" href="/ayuda#8-familias">Ver ayuda</a></p></div></div>
    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (_page?.Kpis is not null)
    {
        <div class="kpi-grid kpi-grid--6">
            <KpiCard Titulo="Total comprado" Valor="@Moneda(_page.Kpis.TotalComprado)" Icono="$" />
            <KpiCard Titulo="Familias activas" Valor="@_page.Kpis.CantidadFamiliasActivas.ToString("N0")" Icono="F" />
            <KpiCard Titulo="Familia principal" Valor="@_page.Kpis.FamiliaPrincipal" Icono="★" Destacado="true" />
            <KpiCard Titulo="Participación líder" Valor="@Porcentaje(_page.Kpis.ParticipacionFamiliaPrincipal)" Icono="%" />
            <KpiCard Titulo="Variación total" Valor="@RenderVariacionTexto(_page.Kpis.VariacionTotalVsAnterior)" Icono="Δ" />
            <KpiCard Titulo="Concentración top 5" Valor="@Porcentaje(_page.Kpis.ConcentracionTop5)" Icono="5" />
            <KpiCard Titulo="Mayor crecimiento" Valor="@RenderMayorVariacion(_page.Kpis.FamiliaMayorCrecimiento, _page.Kpis.FamiliaMayorCrecimientoVariacion)" Icono="▲" />
            <KpiCard Titulo="Mayor caída" Valor="@RenderMayorVariacion(_page.Kpis.FamiliaMayorCaida, _page.Kpis.FamiliaMayorCaidaVariacion)" Icono="▼" />
        </div>
    }

    @if (_page?.Insights?.Any() == true)
    {
        <div class="alert-band">
            @foreach (var insight in _page.Insights)
            {
                <span class="alert-chip">@insight.Mensaje</span>
            }
        </div>
    }

    @if (_page is null)
    {
        <div class="loading">Cargando familias...</div>
    }
    else
    {
        <div class="three-grid">
            <section class="panel-card"><HorizontalBarChart Data="_page.TopFamilias" Titulo="Top familias por total" Subtitulo="Ramas con mayor impacto económico" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.DistribucionGasto" Titulo="Distribución del gasto" Subtitulo="Participación por familia" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.ConcentracionTop5VsResto" Titulo="Concentración top 5" Subtitulo="Top 5 familias vs resto" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.VariacionesPositivas" Titulo="Familias en crecimiento" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.VariacionesNegativas" Titulo="Familias en caída" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
        </div>

        <div class="split-grid">
            <DataTable Titulo="Familias" Subtitulo="Visión jerárquica del gasto por familia y subfamilia">
                <Header>
                    <tr>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Padre</th>
                        <th style="text-align:right;">Nivel</th>
                        <th style="text-align:center;">Hijos</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">% total</th>
                        <th style="text-align:right;">Comprob.</th>
                        <th style="text-align:right;">Artículos</th>
                        <th style="text-align:center;">Variación</th>
                        <th style="text-align:right;">Ticket prom.</th>
                        <th>Última compra</th>
                        <th></th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in _page.Familias)
                    {
                        <tr class="@GetFamiliaRowClass(item)">
                            <td><strong>@item.Familia</strong></td>
                            <td>
                                <strong>@item.Descripcion</strong>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.PadreIdFamilia) ? "-" : item.PadreIdFamilia)</td>
                            <td style="text-align:right;">@item.NivelJerarquico</td>
                            <td style="text-align:center;">@(item.TieneHijos ? "Sí" : "No")</td>
                            <td style="text-align:right;">@Moneda(item.TotalComprado)</td>
                            <td style="text-align:right;">@Porcentaje(item.Participacion)</td>
                            <td style="text-align:right;">@item.CantidadComprobantes</td>
                            <td style="text-align:right;">@item.CantidadArticulos</td>
                            <td style="text-align:center;">@((MarkupString)RenderVariacionBadge(item.VariacionVsAnterior))</td>
                            <td style="text-align:right;">@Moneda(item.TicketPromedio)</td>
                            <td>@Fecha(item.UltimaCompra)</td>
                            <td><button class="btn btn--ghost" @onclick="() => SelectAsync(item.Familia)">Detalle</button></td>
                        </tr>
                    }
                </Rows>
            </DataTable>

            @if (_detalle is not null)
            {
                <DetailCard Titulo="@_detalle.Resumen.Descripcion" Subtitulo="Resumen de familia">
                    <div class="detail-row"><span class="detail-row__label">Código</span><strong>@_detalle.Resumen.Familia</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Padre</span><strong>@(string.IsNullOrWhiteSpace(_detalle.Resumen.PadreIdFamilia) ? "-" : _detalle.Resumen.PadreIdFamilia)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Nivel</span><strong>@_detalle.Resumen.NivelJerarquico</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Tiene hijos</span><strong>@(_detalle.Resumen.TieneHijos ? "Sí" : "No")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Total</span><strong>@Moneda(_detalle.Resumen.TotalComprado)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Participación</span><strong>@Porcentaje(_detalle.Resumen.Participacion)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Variación</span><strong>@((MarkupString)RenderVariacionBadge(_detalle.Resumen.VariacionVsAnterior))</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Comprobantes</span><strong>@_detalle.Resumen.CantidadComprobantes</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Artículos</span><strong>@_detalle.Resumen.CantidadArticulos</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Ticket promedio</span><strong>@Moneda(_detalle.Resumen.TicketPromedio)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Última compra</span><strong>@Fecha(_detalle.Resumen.UltimaCompra)</strong></div>
                    @if (_detalle.Resumen.TieneHijos)
                    {
                        <div class="detail-row"><span class="detail-row__label">Drill down</span><a class="action-link" href="/familias?familia=@Uri.EscapeDataString(_detalle.Resumen.Familia)">Ver rama</a></div>
                    }
                    <div class="detail-row"><span class="detail-row__label">Artículos</span><a class="action-link" href="/articulos?familia=@Uri.EscapeDataString(_detalle.Resumen.Familia)">Ver artículos</a></div>
                </DetailCard>
            }
        </div>

        @if (_detalle is not null)
        {
            <div class="three-grid">
                <section class="panel-card"><LineChart Data="_detalle.EvolucionMensual" Titulo="Evolución de la familia" Subtitulo="Últimos 12 meses de la rama seleccionada" /></section>
                <section class="panel-card"><HorizontalBarChart Data="_detalle.ComposicionInterna" Titulo="Composición interna" Subtitulo="@(_detalle.Resumen.TieneHijos ? "Subfamilias directas de la rama" : "Sin subfamilias con movimiento")" /></section>
                <section class="panel-card"><HorizontalBarChart Data="_detalle.Articulos" Titulo="Artículos principales" Subtitulo="Top artículos de la rama" /></section>
            </div>

            <section class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Últimos comprobantes de la familia</h3>
                        <p class="panel-card__subtitle">Movimientos recientes de la rama seleccionada</p>
                    </div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>TC</th>
                            <th>Comprobante</th>
                            <th>Proveedor</th>
                            <th style="text-align:right;">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _detalle.UltimosComprobantes)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Tc</td>
                                <td>@item.IdComprobante</td>
                                <td>@item.RazonSocial</td>
                                <td style="text-align:right;">@Moneda(item.ImporteDashboard)</td>
                                <td><a class="action-link" href="/comprobantes?tc=@item.Tc&id=@item.IdComprobante&cuenta=@Uri.EscapeDataString(item.Cuenta)">Abrir</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "familia")] public string? FamiliaQuery { get; set; }
    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private FamiliasPageDto? _page;
    private FamiliaDetalleDto? _detalle;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        if (!string.IsNullOrWhiteSpace(FamiliaQuery))
            _filters.Familia = FamiliaQuery;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _page = await DashboardService.GetFamiliasPageDataAsync(_filters);
        _detalle = !string.IsNullOrWhiteSpace(_filters.Familia) ? await DashboardService.GetFamiliaDetalleAsync(_filters.Familia, _filters) : null;
    }

    private async Task SelectAsync(string familia)
    {
        _filters.Familia = familia;
        _detalle = await DashboardService.GetFamiliaDetalleAsync(familia, _filters);
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Porcentaje(decimal valor) => valor.ToString("P1", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Fecha(DateTime? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "Sin dato";

    private static string RenderVariacionTexto(decimal? variacion)
    {
        if (!variacion.HasValue)
            return "Sin base";

        var signo = variacion.Value > 0 ? "+" : string.Empty;
        return $"{signo}{(variacion.Value * 100m):N1}%";
    }

    private static string RenderMayorVariacion(string? familia, decimal? variacion)
    {
        if (string.IsNullOrWhiteSpace(familia) || !variacion.HasValue)
            return "Sin datos";

        return $"{familia} · {(variacion.Value * 100m):N1}%";
    }

    private static string GetFamiliaRowClass(FamiliaResumenDto item)
    {
        if (item.VariacionVsAnterior is >= 0.20m or <= -0.20m)
            return "row--warning";

        return string.Empty;
    }

    private static string RenderVariacionBadge(decimal? variacion)
    {
        if (!variacion.HasValue)
            return "<span class=\"var-badge var-badge--new\">Sin base</span>";

        var clase = variacion.Value switch
        {
            > 0.005m => "var-badge var-badge--up",
            < -0.005m => "var-badge var-badge--down",
            _ => "var-badge var-badge--flat"
        };

        var signo = variacion.Value > 0 ? "+" : string.Empty;
        return $"<span class=\"{clase}\">{signo}{(variacion.Value * 100m):N1}%</span>";
    }
}
