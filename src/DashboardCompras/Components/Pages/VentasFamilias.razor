@page "/ventas/familias"
@inject DashboardCompras.Services.IGestionDashboardService GestionSvc
@inject DashboardCompras.Services.GestionFilterStateService FilterState

<PageTitle>Familias | Ventas</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Familias más vendidas</h2>
            <p class="page-intro__text">Análisis comercial por familia para entender composición y concentración de ventas.</p>
        </div>
    </div>

    <VentasFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" Titulo="Filtros de familias" Subtitulo="Evaluá familias vendidas con los mismos filtros comerciales." />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state"><p>@_error</p></div>
    }
    else if (_page is null)
    {
        <div class="loading">Cargando familias...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Total vendido" Valor="@Moneda(_page.TotalVendido)" Icono="$" />
            <KpiCard Titulo="Familias activas" Valor="@_page.FamiliasActivas.ToString("N0")" Icono="F" />
        </div>

        <div class="split-grid">
            <section class="panel-card">
                <HorizontalBarChart Data="_page.TopFamilias" Titulo="Top familias" Subtitulo="Familias con mayor incidencia" />
            </section>

            <DataTable Titulo="Listado de familias" Subtitulo="Participación comercial por familia">
                <Header>
                    <tr>
                        <th>Familia</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">% total</th>
                        <th style="text-align:right;">Artículos</th>
                        <th style="text-align:right;">Comprobantes</th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in _page.Familias)
                    {
                        <tr>
                            <td>
                                <strong>@item.Familia</strong>
                                @if (!string.IsNullOrWhiteSpace(item.DescripcionFamilia))
                                {
                                    <br /><span class="text-muted" style="font-size:0.8em;">@item.DescripcionFamilia</span>
                                }
                            </td>
                            <td style="text-align:right;">@Moneda(item.TotalVendido)</td>
                            <td style="text-align:right;">@Porcentaje(item.Participacion)</td>
                            <td style="text-align:right;">@item.CantidadArticulos.ToString("N0")</td>
                            <td style="text-align:right;">@item.CantidadComprobantes.ToString("N0")</td>
                        </tr>
                    }
                </Rows>
            </DataTable>
        </div>
    }
</section>

@code {
    private VentasDashboardFilters _filters = null!;
    private VentasFilterOptionsDto _options = new();
    private VentasFamiliasPageDto? _page;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Ventas;
        _options = await GestionSvc.GetVentasFilterOptionsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        try { _page = await GestionSvc.GetVentasFamiliasAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Porcentaje(decimal valor) => valor.ToString("P1", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
