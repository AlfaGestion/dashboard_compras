@page "/auditoria/error/{Id:int}"
@using Microsoft.AspNetCore.Components.Forms
@inject DashboardCompras.Services.IAuditoriaService AuditoriaSvc

<PageTitle>Detalle de Error | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando error…
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> @_error
    </div>
}
else if (_item is null)
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> No se encontró el error solicitado.
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">Error #@_item.Id</h2>
                <p class="page-intro__text">@_item.Proceso · @_item.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</p>
            </div>
            <div class="actions">
                <a class="btn btn--ghost" href="/auditoria/errores">
                    <i class="bi bi-arrow-left"></i>
                    <span>Volver a errores</span>
                </a>
            </div>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Datos principales</h3>
                    </div>
                </div>
                <div class="detail-grid">
                    <div><strong>Fecha</strong><br />@_item.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</div>
                    <div><strong>Proceso</strong><br />@_item.Proceso</div>
                    <div><strong>Usuario</strong><br />@_item.Usuario</div>
                    <div><strong>PC</strong><br />@_item.Pc</div>
                    <div><strong>Código</strong><br />@_item.ErrorCodigo</div>
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-card__header">
                    <div>
                        <h3 class="panel-card__title">Descripción</h3>
                    </div>
                </div>
                <div class="auditoria__block">
                    @_item.Descripcion
                </div>
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Instrucción SQL / detalle técnico</h3>
                    <p class="panel-card__subtitle">Campo `Sql` de `AUX_ERR`, preparado para copiar y pegar.</p>
                </div>
            </div>
            <textarea class="auditoria__textarea" readonly rows="18">@_item.Sql</textarea>
        </section>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private string _error = string.Empty;
    private AuditoriaErrorRowDto? _item;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            _item = await AuditoriaSvc.GetErrorByIdAsync(Id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
