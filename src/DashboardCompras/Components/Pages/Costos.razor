@page "/costos"
@inject DashboardCompras.Services.ICostosService CostosSvc

<PageTitle>Actualización de Costos | Alfa Gestión</PageTitle>

@if (_loading)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando módulo…
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> @_error
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-intro">
            <div>
                <h2 class="page-intro__title">Actualización de Costos</h2>
                <p class="page-intro__text">Importá listas de proveedores, apoyate en perfiles de `V_Ta_InterODBC` y dejá trazabilidad de cada corrida para revisión y aplicación controlada.</p>
            </div>
            <div class="actions">
                <a class="btn btn--primary" href="/costos/nueva">
                    <i class="bi bi-upload"></i>
                    <span>Nueva importación</span>
                </a>
                <a class="btn btn--ghost" href="/costos/perfiles">
                    <i class="bi bi-sliders"></i>
                    <span>Perfiles</span>
                </a>
            </div>
        </section>

        <section class="kpi-grid">
            <article class="kpi-card">
                <div class="kpi-card__label">Perfiles activos</div>
                <div class="kpi-card__value">@_profiles.Count</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Corridas recientes</div>
                <div class="kpi-card__value">@_batches.Count</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Último estado</div>
                <div class="kpi-card__value">@(_batches.FirstOrDefault()?.Status ?? "—")</div>
            </article>
            <article class="kpi-card">
                <div class="kpi-card__label">Historial cargado</div>
                <div class="kpi-card__value">@_history.Count</div>
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Perfiles de importación</h3>
                    <p class="panel-card__subtitle">Configuración tomada desde `V_Ta_InterODBC`.</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Perfil</th>
                            <th>Código proveedor</th>
                            <th>Reglas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var profile in _profiles.Take(10))
                        {
                            <tr>
                                <td><strong>@profile.ProviderName</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(profile.ProviderAccount) ? "—" : profile.ProviderAccount)</td>
                                <td>@BuildRules(profile)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Corridas recientes</h3>
                    <p class="panel-card__subtitle">Cabeceras desde `IA_Costos_Importacion_CAB`.</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Proveedor</th>
                            <th>Archivo</th>
                            <th>Estado</th>
                            <th>Filas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in _batches)
                        {
                            <tr>
                                <td><a class="action-link" href="/costos/lotes/@batch.Id">#@batch.Id</a></td>
                                <td>@batch.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@batch.ProviderName</td>
                                <td>@batch.SourceFileName</td>
                                <td>@batch.Status</td>
                                <td>@batch.TotalRowsRead</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Historial</h3>
                    <p class="panel-card__subtitle">Últimas actualizaciones registradas en `IA_Costos_Actualizacion_Hist`.</p>
                </div>
                <a class="action-link" href="/costos/historial">Ver todo</a>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Proveedor</th>
                            <th>Artículo</th>
                            <th>Descripción</th>
                            <th>Nuevo costo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _history.Take(10))
                        {
                            <tr>
                                <td>@item.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.ProviderName</td>
                                <td>@item.ArticleId</td>
                                <td>@item.ImportedDescription</td>
                                <td>@(item.NewCost?.ToString("N2") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
}

@code {
    private bool _loading = true;
    private string _error = string.Empty;
    private IReadOnlyList<DashboardCompras.Models.CostosProfileDto> _profiles = [];
    private IReadOnlyList<DashboardCompras.Models.CostosBatchSummaryDto> _batches = [];
    private IReadOnlyList<DashboardCompras.Models.CostosHistoryDto> _history = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profiles = await CostosSvc.GetProfilesAsync();
            _batches = await CostosSvc.GetRecentBatchesAsync();
            _history = await CostosSvc.GetRecentHistoryAsync(25);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string BuildRules(DashboardCompras.Models.CostosProfileDto profile)
    {
        var parts = new List<string>();
        if (profile.OnlyAdd) parts.Add("SoloAlta");
        if (profile.OnlyModify) parts.Add("SoloModificación");
        if (parts.Count == 0) parts.Add("Sin reglas");
        return string.Join(" · ", parts);
    }
}
