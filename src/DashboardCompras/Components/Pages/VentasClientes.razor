@page "/ventas/clientes"
@inject DashboardCompras.Services.IGestionDashboardService GestionSvc
@inject DashboardCompras.Services.GestionFilterStateService FilterState

<PageTitle>Clientes | Ventas</PageTitle>

<section class="page-grid">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">Clientes</h2>
            <p class="page-intro__text">Ranking comercial, concentración y últimos movimientos por cliente.</p>
        </div>
    </div>

    <VentasFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" Titulo="Filtros de clientes" Subtitulo="Clientes, fechas y circuito comercial para profundizar ventas." />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="panel-card empty-state"><p>@_error</p></div>
    }
    else if (_page is null)
    {
        <div class="loading">Cargando clientes...</div>
    }
    else
    {
        <div class="kpi-grid">
            <KpiCard Titulo="Total facturado" Valor="@Moneda(_page.TotalFacturado)" Icono="$" />
            <KpiCard Titulo="Clientes activos" Valor="@_page.ClientesActivos.ToString("N0")" Icono="C" />
            <KpiCard Titulo="Ticket promedio" Valor="@Moneda(_page.TicketPromedio)" Icono="T" />
        </div>

        <div class="split-grid">
            <section class="panel-card">
                <HorizontalBarChart Data="_page.TopClientes" Titulo="Top clientes" Subtitulo="Clientes con mayor facturación" />
            </section>

            <DataTable Titulo="Listado de clientes" Subtitulo="Participación y actividad comercial">
                <Header>
                    <tr>
                        <th>Cliente</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">% total</th>
                        <th style="text-align:right;">Comprobantes</th>
                        <th style="text-align:right;">Ticket prom.</th>
                        <th>Última venta</th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in _page.Clientes)
                    {
                        <tr>
                            <td><strong>@item.Cliente</strong><div class="text-muted">@item.Cuenta</div></td>
                            <td style="text-align:right;">@Moneda(item.TotalFacturado)</td>
                            <td style="text-align:right;">@Porcentaje(item.Participacion)</td>
                            <td style="text-align:right;">@item.CantidadComprobantes.ToString("N0")</td>
                            <td style="text-align:right;">@Moneda(item.TicketPromedio)</td>
                            <td>@Fecha(item.UltimaVenta)</td>
                        </tr>
                    }
                </Rows>
            </DataTable>
        </div>
    }
</section>

@code {
    private VentasDashboardFilters _filters = null!;
    private VentasFilterOptionsDto _options = new();
    private VentasClientesPageDto? _page;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Ventas;
        _options = await GestionSvc.GetVentasFilterOptionsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        try { _page = await GestionSvc.GetVentasClientesAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Porcentaje(decimal valor) => valor.ToString("P1", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string Fecha(DateTime? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "Sin dato";
}
