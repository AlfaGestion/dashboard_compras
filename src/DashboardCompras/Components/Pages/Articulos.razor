@page "/compras/articulos"
@inject DashboardCompras.Services.IComprasDashboardService DashboardService
@inject DashboardCompras.Services.FilterStateService FilterState

<PageTitle>Artículos | Dashboard de Compras</PageTitle>

<section class="page-grid">
    <div class="page-intro"><div><h2 class="page-intro__title">Artículos</h2><p class="page-intro__text">Impacto económico, variación de precio, proveedor principal y últimas compras por artículo. <a class="help-link" href="/ayuda#9-artículos">Ver ayuda</a></p></div></div>
    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="LoadAsync" />

    @if (_page?.Kpis is not null)
    {
        <div class="kpi-grid kpi-grid--6">
            <KpiCard Titulo="Total comprado" Valor="@Moneda(_page.Kpis.TotalComprado)" Icono="$" />
            <KpiCard Titulo="Artículos distintos" Valor="@_page.Kpis.CantidadArticulosDistintos.ToString("N0")" Icono="A" />
            <KpiCard Titulo="Ítems totales" Valor="@_page.Kpis.CantidadItems.ToString("N0")" Icono="I" />
            <KpiCard Titulo="Costo promedio general" Valor="@Moneda(_page.Kpis.CostoPromedioGeneral)" Icono="C" />
            <KpiCard Titulo="Artículos con aumento" Valor="@_page.Kpis.ArticulosConAumento.ToString("N0")" Icono="▲" />
            <KpiCard Titulo="Artículos con baja" Valor="@_page.Kpis.ArticulosConBaja.ToString("N0")" Icono="▼" />
            <KpiCard Titulo="Artículos nuevos" Valor="@_page.Kpis.ArticulosNuevos.ToString("N0")" Icono="✦" />
            <KpiCard Titulo="Mayor aumento" Valor="@RenderMayorVariacion(_page.Kpis.MayorAumentoArticulo, _page.Kpis.MayorAumentoVariacion)" Icono="+" />
            <KpiCard Titulo="Mayor baja" Valor="@RenderMayorVariacion(_page.Kpis.MayorBajaArticulo, _page.Kpis.MayorBajaVariacion)" Icono="-" />
        </div>
    }

    @if (_page?.Insights?.Any() == true)
    {
        <div class="alert-band">
            @foreach (var insight in _page.Insights)
            {
                <span class="alert-chip">@insight.Mensaje</span>
            }
        </div>
    }

    @if (_page is null)
    {
        <div class="loading">Cargando artículos...</div>
    }
    else
    {
        <div class="three-grid">
            <section class="panel-card"><HorizontalBarChart Data="_page.TopPorTotal" Titulo="Top por impacto económico" Subtitulo="Artículos con mayor total comprado" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.TopPorCantidad" Titulo="Top por cantidad comprada" Subtitulo="Artículos con mayor volumen" Formato="numero" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.TopAumentos" Titulo="Top aumentos de precio" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
            <section class="panel-card"><HorizontalBarChart Data="_page.TopBajas" Titulo="Top bajas de precio" Subtitulo="Variación vs período anterior" Formato="porcentaje" /></section>
        </div>

        @if (_page.Articulos.Any())
        {
            var nSubieron  = _page.Articulos.Count(x => x.VariacionPrecio > 0.005m);
            var nBajaron   = _page.Articulos.Count(x => x.VariacionPrecio < -0.005m);
            var nSinVar    = _page.Articulos.Count(x => x.VariacionPrecio.HasValue && x.VariacionPrecio >= -0.005m && x.VariacionPrecio <= 0.005m);
            var nNuevos    = _page.Articulos.Count(x => x.EsNuevo);
            <div class="quick-filter-bar">
                <button class="@QfClass("")  quick-filter-btn" @onclick='() => _filtroVar = ""'>Todos (@_page.Articulos.Count)</button>
                <button class="@QfClass("subio") quick-filter-btn quick-filter-btn--up"   @onclick='() => _filtroVar = "subio"'>▲ Subieron (@nSubieron)</button>
                <button class="@QfClass("bajo")  quick-filter-btn quick-filter-btn--down" @onclick='() => _filtroVar = "bajo"'>▼ Bajaron (@nBajaron)</button>
                <button class="@QfClass("plano") quick-filter-btn" @onclick='() => _filtroVar = "plano"'>= Sin variación (@nSinVar)</button>
                <button class="@QfClass("nuevo") quick-filter-btn quick-filter-btn--new"  @onclick='() => _filtroVar = "nuevo"'>✦ Nuevos (@nNuevos)</button>
            </div>
        }

        <div class="split-grid">
            <DataTable Titulo="Artículos" Subtitulo="Análisis ejecutivo por impacto, precio y proveedor principal">
                <Header>
                    <tr>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th style="text-align:right;">Cantidad</th>
                        <th style="text-align:right;">Total</th>
                        <th style="text-align:right;">Costo prom.</th>
                        <th style="text-align:right;">Precio ant.</th>
                        <th style="text-align:right;">Precio act.</th>
                        <th style="text-align:center;">Variación</th>
                        <th>Última compra</th>
                        <th>Proveedor principal</th>
                        <th style="text-align:right;">Compras</th>
                        <th></th>
                    </tr>
                </Header>
                <Rows>
                    @foreach (var item in ArticulosFiltrados)
                    {
                        <tr class="@GetArticuloRowClass(item)">
                            <td style="text-align:@GetCodigoAlign(item.IdArticulo);"><strong>@item.IdArticulo</strong></td>
                            <td>
                                <strong>@item.DescripcionArticulo</strong>
                                @if (!string.IsNullOrWhiteSpace(item.ProveedorPrincipal))
                                {
                                    <div class="text-muted">@item.ProveedorPrincipal</div>
                                }
                            </td>
                            <td style="text-align:right;">@item.CantidadComprada.ToString("N2")</td>
                            <td style="text-align:right;">@Moneda(item.TotalComprado)</td>
                            <td style="text-align:right;">@Moneda(item.CostoPromedio)</td>
                            <td style="text-align:right;">@MonedaNullable(item.PrecioAnterior)</td>
                            <td style="text-align:right;">@Moneda(item.PrecioActual)</td>
                            <td style="text-align:center;">@((MarkupString)RenderVariacionBadge(item.VariacionPrecio, item.EsNuevo))</td>
                            <td>@Fecha(item.UltimaCompra)</td>
                            <td>
                                <strong>@(string.IsNullOrWhiteSpace(item.ProveedorPrincipal) ? "Sin dato" : item.ProveedorPrincipal)</strong>
                                @if (item.ParticipacionProveedorPrincipal > 0)
                                {
                                    <div class="text-muted">@((item.ParticipacionProveedorPrincipal * 100m).ToString("N1"))% del total</div>
                                }
                            </td>
                            <td style="text-align:right;">@item.CantidadCompras.ToString("N0")</td>
                            <td><button class="btn btn--ghost" @onclick="() => SelectAsync(item.IdArticulo)">Detalle</button></td>
                        </tr>
                    }
                </Rows>
            </DataTable>

            @if (_detalle is not null)
            {
                <DetailCard Titulo="@_detalle.Resumen.DescripcionArticulo" Subtitulo="Resumen del artículo">
                    <div class="detail-row"><span class="detail-row__label">Código</span><strong style="text-align:@GetCodigoAlign(_detalle.Resumen.IdArticulo); display:inline-block; min-width:100%;">@_detalle.Resumen.IdArticulo</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Cantidad</span><strong>@_detalle.Resumen.CantidadComprada.ToString("N2")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Total</span><strong>@Moneda(_detalle.Resumen.TotalComprado)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Costo promedio</span><strong>@Moneda(_detalle.Resumen.CostoPromedio)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Precio anterior</span><strong>@MonedaNullable(_detalle.Resumen.PrecioAnterior)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Precio actual</span><strong>@Moneda(_detalle.Resumen.PrecioActual)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Variación</span><strong>@((MarkupString)RenderVariacionBadge(_detalle.Resumen.VariacionPrecio, _detalle.Resumen.EsNuevo))</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Última compra</span><strong>@Fecha(_detalle.Resumen.UltimaCompra)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Proveedor principal</span><strong>@(string.IsNullOrWhiteSpace(_detalle.Resumen.ProveedorPrincipal) ? "Sin dato" : _detalle.Resumen.ProveedorPrincipal)</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Participación proveedor</span><strong>@(_detalle.Resumen.ParticipacionProveedorPrincipal > 0 ? $"{(_detalle.Resumen.ParticipacionProveedorPrincipal * 100m):N1}%" : "Sin dato")</strong></div>
                    <div class="detail-row"><span class="detail-row__label">Cantidad de compras</span><strong>@_detalle.Resumen.CantidadCompras.ToString("N0")</strong></div>
                </DetailCard>
            }
        </div>

        @if (_detalle is not null)
        {
            <div class="three-grid">
                <section class="panel-card"><LineChart Data="_detalle.EvolucionCosto" Titulo="Evolución del precio" Subtitulo="Costo promedio mensual del artículo" /></section>
                <section class="panel-card"><HorizontalBarChart Data="_detalle.Proveedores" Titulo="Proveedores asociados" Subtitulo="Participación por total comprado" /></section>
                <section class="panel-card">
                    <div class="panel-card__header"><div><h3 class="panel-card__title">Historial</h3><p class="panel-card__subtitle">Últimos comprobantes del artículo</p></div></div>
                    <div class="detail-list">
                        @foreach (var item in _detalle.Historial)
                        {
                            <div class="detail-row">
                                <span class="detail-row__label">@item.Fecha.ToString("dd/MM/yy") · @item.Tc @item.IdComprobante</span>
                                <a class="action-link" href="/compras/comprobantes?tc=@item.Tc&id=@item.IdComprobante&cuenta=@Uri.EscapeDataString(item.Cuenta)">Abrir</a>
                            </div>
                        }
                    </div>
                </section>
            </div>
        }
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "articulo")] public string? ArticuloQuery { get; set; }
    [SupplyParameterFromQuery(Name = "familia")] public string? FamiliaQuery { get; set; }
    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private ArticulosPageDto? _page;
    private ArticuloDetalleDto? _detalle;
    private string _filtroVar = "";

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        if (!string.IsNullOrWhiteSpace(ArticuloQuery))
            _filters.Articulo = ArticuloQuery;
        if (!string.IsNullOrWhiteSpace(FamiliaQuery))
            _filters.Familia = FamiliaQuery;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _filtroVar = "";
        _page = await DashboardService.GetArticulosPageDataAsync(_filters);
        _detalle = !string.IsNullOrWhiteSpace(_filters.Articulo) ? await DashboardService.GetArticuloDetalleAsync(_filters.Articulo, _filters) : null;
    }

    private IEnumerable<ArticuloResumenDto> ArticulosFiltrados => _filtroVar switch
    {
        "subio"  => _page!.Articulos.Where(x => x.VariacionPrecio > 0.005m),
        "bajo"   => _page!.Articulos.Where(x => x.VariacionPrecio < -0.005m),
        "plano"  => _page!.Articulos.Where(x => x.VariacionPrecio.HasValue && x.VariacionPrecio >= -0.005m && x.VariacionPrecio <= 0.005m),
        "nuevo"  => _page!.Articulos.Where(x => x.EsNuevo),
        _        => _page!.Articulos
    };

    private async Task SelectAsync(string articulo)
    {
        _filters.Articulo = articulo;
        _detalle = await DashboardService.GetArticuloDetalleAsync(articulo, _filters);
    }

    private string QfClass(string key) => key == _filtroVar ? "btn btn--primary" : "btn btn--ghost";

    private static string Moneda(decimal valor) => valor.ToString("$ #,##0.00", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
    private static string MonedaNullable(decimal? valor) => valor.HasValue ? Moneda(valor.Value) : "Sin dato";
    private static string Fecha(DateTime? fecha) => fecha?.ToString("dd/MM/yyyy") ?? "Sin dato";

    private static string RenderMayorVariacion(string? articulo, decimal? variacion)
    {
        if (string.IsNullOrWhiteSpace(articulo) || !variacion.HasValue)
            return "Sin cambios";

        return $"{articulo} · {(variacion.Value * 100m):N1}%";
    }

    private static string GetArticuloRowClass(ArticuloResumenDto item)
    {
        if (item.VariacionPrecio is >= 0.20m or <= -0.20m)
            return "row--warning";

        return string.Empty;
    }

    private static string RenderVariacionBadge(decimal? variacion, bool esNuevo = false)
    {
        if (!variacion.HasValue)
            return esNuevo
                ? "<span class=\"var-badge var-badge--new\">Nuevo</span>"
                : "<span class=\"var-badge var-badge--flat\">Sin per. ant.</span>";

        var clase = variacion.Value switch
        {
            > 0.005m => "var-badge var-badge--up",
            < -0.005m => "var-badge var-badge--down",
            _ => "var-badge var-badge--flat"
        };

        var signo = variacion.Value > 0 ? "+" : string.Empty;
        return $"<span class=\"{clase}\">{signo}{(variacion.Value * 100m):N1}%</span>";
    }

    private static string GetCodigoAlign(string? codigo)
    {
        if (string.IsNullOrWhiteSpace(codigo))
            return "left";

        return codigo.All(char.IsDigit) ? "right" : "left";
    }
}
