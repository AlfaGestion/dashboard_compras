@page "/informesia"
@inject DashboardCompras.Services.IComprasDashboardService DashboardService
@inject DashboardCompras.Services.IInformesIaService InformesIaService
@inject DashboardCompras.Services.FilterStateService FilterState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>InformesIA | Dashboard de Compras</PageTitle>

<section class="page-grid ia-page">
    <div class="page-intro">
        <div>
            <h2 class="page-intro__title">InformesIA</h2>
            <p class="page-intro__text">Prepará consultas en lenguaje natural, elegí si querés gráfico y abrí cada resultado en una pestaña nueva para comparar varios informes a la vez.</p>
        </div>
    </div>

    <section class="panel-card ia-query-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Consulta libre</h3>
                <p class="panel-card__subtitle">Interpretación segura sobre las vistas autorizadas del dashboard. También podés pedir columnas y orden de salida.</p>
            </div>
            <span class="panel-card__tag">Solo lectura</span>
        </div>

        <div class="ia-query-box">
            <textarea id="ia-query-box"
                      class="ia-query-box__input"
                      placeholder="Ej: listado de compras del mes actual, mostrame fecha factura, cuenta, nombre, neto, iva, total y ordenalo por fecha"
                      @bind="_consulta"
                      @bind:event="oninput"></textarea>

            <div class="ia-launcher-options">
                <label class="ia-check">
                    <input type="checkbox" @bind="_incluirGrafico" />
                    <span>Incluir gráfico cuando el resultado lo amerite</span>
                </label>
                <span class="ia-launcher-hint">Si lo destildás, el informe se abre solo con tabla y resumen.</span>
            </div>

            <div class="ia-query-box__actions">
                <button class="btn btn--ghost" @onclick="StartDictationAsync">
                    <i class="bi bi-mic-fill"></i>
                    <span>Dictar</span>
                </button>
                <button class="btn btn--ghost" @onclick="ClearQuery">Limpiar</button>
                <button class="btn btn--primary" @onclick="ExecuteAsync" disabled="@_loading">
                    <i class="bi bi-box-arrow-up-right"></i>
                    <span>@(_loading ? "Generando..." : "Abrir informe en nueva pestaña")</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_voiceMessage))
        {
            <div class="ia-inline-message ia-inline-message--info">@_voiceMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_launcherMessage))
        {
            <div class="ia-inline-message ia-inline-message--safe">@_launcherMessage</div>
        }

    </section>

    <GlobalFiltersBar Model="_filters" Options="_options" OnApply="SaveFilterContextAsync" Titulo="Filtros globales del informe" Subtitulo="Se aplican a la generación segura del reporte." />

    <section class="ia-grid">
        <section class="panel-card ia-suggestions">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Sugerencias rápidas</h3>
                    <p class="panel-card__subtitle">Consultas iniciales listas para tocar y después abrir en su propia pestaña.</p>
                </div>
            </div>

            <div class="ia-chip-list">
                @foreach (var item in _suggestions)
                {
                    <button class="ia-chip" @onclick="() => ApplySuggestion(item.Texto)">
                        <span class="ia-chip__title">@item.Texto</span>
                        <span class="ia-chip__meta">@item.Categoria</span>
                    </button>
                }
            </div>
        </section>

        <section class="panel-card ia-history">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Historial reciente</h3>
                    <p class="panel-card__subtitle">Últimas 20 consultas. Podés cargar el texto, repetirla o abrir el resultado guardado.</p>
                </div>
            </div>

            @if (_history.Count == 0)
            {
                <p class="panel-card__subtitle">Todavía no hay consultas registradas.</p>
            }
            else
            {
                <div class="ia-history-list">
                    @foreach (var item in _history)
                    {
                        <div class="ia-history-item">
                            <div class="ia-history-item__content">
                                <strong>@item.Consulta</strong>
                                <span>@item.FechaHora.ToString("dd/MM/yyyy HH:mm") · @(item.Exitosa ? "OK" : "Falló") · @item.TipoResultado</span>
                            </div>
                            <div class="ia-history-item__actions">
                                <button class="btn btn--ghost btn--sm" @onclick="() => LoadHistoryItem(item)">Cargar</button>
                                @if (item.ExecutionId.HasValue)
                                {
                                    <button class="btn btn--ghost btn--sm" @onclick="() => OpenResultAsync(item.ExecutionId.Value)">Abrir</button>
                                }
                                <button class="btn btn--ghost btn--sm" @onclick="() => ReRunHistoryAsync(item)">Repetir</button>
                                <button class="btn btn--ghost btn--sm" @onclick="() => DeleteHistoryAsync(item.Id)">Borrar</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </section>
</section>

@code {
    private string _consulta = string.Empty;
    private string? _voiceMessage;
    private string? _launcherMessage;
    private bool _loading;
    private bool _incluirGrafico = true;
    private DashboardFilters _filters = null!;
    private FilterOptionsDto _options = new();
    private IReadOnlyList<InformeIaSuggestionDto> _suggestions = [];
    private IReadOnlyList<InformeIaHistoryItemDto> _history = [];

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Current;
        _options = await DashboardService.GetFilterOptionsAsync();
        _suggestions = await InformesIaService.GetSuggestionsAsync();
        _history = await InformesIaService.GetHistoryAsync();
    }

    private async Task ExecuteAsync()
    {
        _loading = true;
        _voiceMessage = null;
        _launcherMessage = null;
        try
        {
            var execution = await InformesIaService.ExecuteAndStoreAsync(new InformeIaRequestDto
            {
                Consulta = _consulta,
                Filtros = _filters,
                Preferencias = new InformeIaPreferencesDto
                {
                    IncluirGrafico = _incluirGrafico
                }
            });

            var absoluteUrl = Nav.ToAbsoluteUri(execution.UrlResultado).ToString();
            await JS.InvokeVoidAsync("openInNewTab", absoluteUrl);
            _launcherMessage = execution.Resultado.Exitoso
                ? "Informe generado. Se abrió una nueva pestaña con el resultado."
                : "La consulta se abrió en una nueva pestaña con el detalle del rechazo o validación.";
            _history = await InformesIaService.GetHistoryAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task SaveFilterContextAsync()
    {
        _launcherMessage = "Filtros actualizados para el próximo informe.";
        return Task.CompletedTask;
    }

    private void ApplySuggestion(string text)
    {
        _consulta = text;
        _voiceMessage = null;
        _launcherMessage = null;
    }

    private void LoadHistoryItem(InformeIaHistoryItemDto item)
    {
        _consulta = item.Consulta;
        _voiceMessage = null;
        _launcherMessage = "Consulta cargada desde el historial.";
    }

    private async Task ReRunHistoryAsync(InformeIaHistoryItemDto item)
    {
        _consulta = item.Consulta;
        await ExecuteAsync();
    }

    private async Task OpenResultAsync(Guid executionId)
    {
        var absoluteUrl = Nav.ToAbsoluteUri($"/informesia/resultado/{executionId}").ToString();
        await JS.InvokeVoidAsync("openInNewTab", absoluteUrl);
    }

    private async Task DeleteHistoryAsync(Guid id)
    {
        await InformesIaService.DeleteHistoryItemAsync(id);
        _history = await InformesIaService.GetHistoryAsync();
    }

    private void ClearQuery()
    {
        _consulta = string.Empty;
        _voiceMessage = null;
        _launcherMessage = null;
    }

    private async Task StartDictationAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("dashboardExport.startDictation", "ia-query-box");
            _voiceMessage = "Escuchando... cuando termine el dictado, el texto se cargará en la consulta.";
        }
        catch (Exception ex)
        {
            _voiceMessage = ex.Message;
        }
    }
}
