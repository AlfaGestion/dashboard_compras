@page "/consultas/{Id:int}"
@inject DashboardCompras.Services.IConsultasService ConsultasSvc
@inject IJSRuntime JS
@using DashboardCompras.Models

<PageTitle>@(_consulta?.Grupo ?? "Consulta") | Alfa Gestión</PageTitle>

@if (_cargando)
{
    <div class="consultas-loading">
        <i class="bi bi-hourglass-split"></i> Cargando consulta…
    </div>
}
else if (_consulta is null)
{
    <div class="consultas-error">
        <i class="bi bi-exclamation-triangle"></i> Consulta no encontrada.
        <a href="/consultas">Volver a la lista</a>
    </div>
}
else
{
    <div class="consulta-detalle">

        <div class="consulta-detalle__topbar">
            <a class="consulta-detalle__back" href="/consultas">
                <i class="bi bi-arrow-left"></i> Volver a consultas
            </a>
            <div style="display:flex; gap:.5rem;">
                <a class="btn btn--ghost btn--sm" href="/consultas/nueva?from=@_consulta!.Id">
                    <i class="bi bi-copy"></i> Duplicar
                </a>
                <a class="btn btn--ghost btn--sm" href="/consultas/@_consulta!.Id/editar">
                    <i class="bi bi-pencil"></i> Editar
                </a>
            </div>
        </div>

        @if (_ruta.Count > 1)
        {
            <nav class="breadcrumb">
                @foreach (var (nodo, i) in _ruta.SkipLast(1).Select((n, i) => (n, i)))
                {
                    @if (i > 0) { <span class="breadcrumb__sep">›</span> }
                    <span class="breadcrumb__item">@nodo.Nombre</span>
                }
            </nav>
        }

        <div class="consulta-detalle__meta">
            <p class="consulta-detalle__clave">@_consulta.Clave</p>
            <h2 class="consulta-detalle__titulo">@_consulta.Grupo</h2>
            @if (!string.IsNullOrWhiteSpace(_consulta.Descripcion))
            {
                <p class="consulta-detalle__desc">@_consulta.Descripcion</p>
            }
        </div>

        @if (_consulta.TieneParametros)
        {
            <div class="consulta-params">
                <p class="consulta-params__title">Parámetros</p>
                <div class="consulta-params__grid">
                    @foreach (var param in _consulta.Parametros)
                    {
                        <div class="consulta-params__field">
                            <label class="consulta-params__label">@param.Campo</label>
                            @if (param.Tipo == TipoParametro.Fecha)
                            {
                                <input class="consulta-params__input"
                                       type="date"
                                       value="@_valores[param.Orden]"
                                       @onchange="e => _valores[param.Orden] = e.Value?.ToString() ?? string.Empty" />
                            }
                            else if (param.Tipo == TipoParametro.Numero)
                            {
                                <input class="consulta-params__input"
                                       type="number"
                                       value="@_valores[param.Orden]"
                                       @onchange="e => _valores[param.Orden] = e.Value?.ToString() ?? string.Empty" />
                            }
                            else
                            {
                                <input class="consulta-params__input"
                                       type="text"
                                       placeholder="@param.Campo"
                                       value="@_valores[param.Orden]"
                                       @onchange="e => _valores[param.Orden] = e.Value?.ToString() ?? string.Empty" />
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="consulta-actions">
            <button class="btn btn--primary" @onclick="EjecutarAsync" disabled="@_ejecutando">
                @if (_ejecutando)
                {
                    <i class="bi bi-hourglass-split"></i>
                    <span>Ejecutando…</span>
                }
                else
                {
                    <i class="bi bi-play-fill"></i>
                    <span>Ejecutar</span>
                }
            </button>

            @if (_resultado is { Exitoso: true, Filas.Count: > 0 })
            {
                <a class="btn btn--ghost" href="@GetExcelUrl()">
                    <i class="bi bi-file-earmark-excel"></i> Excel
                </a>
                <button class="btn btn--ghost no-print" @onclick="ImprimirAsync">
                    <i class="bi bi-printer"></i> PDF
                </button>
                <button class="btn btn--ghost @(_mostrarGrafico ? "btn--active" : "")" @onclick="ToggleGrafico">
                    <i class="bi bi-bar-chart-line"></i>
                    @(_mostrarGrafico ? "Ocultar gráfico" : "Ver gráfico")
                </button>
                <button class="btn btn--ghost @(_mostrarAgrupador ? "btn--active" : "")" @onclick="ToggleAgrupador">
                    <i class="bi bi-table"></i>
                    @(_mostrarAgrupador ? "Ocultar agrupador" : "Agrupar")
                </button>
            }
        </div>

        @if (_mostrarGrafico && _resultado is { Exitoso: true, Filas.Count: > 0 })
        {
            <div class="result-chart-panel">
                <div class="result-chart-controls">

                    <div class="result-chart-control">
                        <label class="result-chart-control__label">Tipo</label>
                        <div class="result-chart-type">
                            <button class="result-chart-type__btn @(_tipoGrafico == "Barras" ? "active" : "")"
                                    @onclick='() => _tipoGrafico = "Barras"'>
                                <i class="bi bi-bar-chart-fill"></i> Barras
                            </button>
                            <button class="result-chart-type__btn @(_tipoGrafico == "Lineas" ? "active" : "")"
                                    @onclick='() => _tipoGrafico = "Lineas"'>
                                <i class="bi bi-graph-up"></i> Líneas
                            </button>
                        </div>
                    </div>

                    <div class="result-chart-control">
                        <label class="result-chart-control__label">Eje X (etiqueta)</label>
                        <select class="editor-field__input editor-field__input--sm" @bind="_colEtiqueta">
                            @foreach (var (col, i) in _resultado.Columnas.Select((c, i) => (c, i)))
                            {
                                <option value="@i">@col</option>
                            }
                        </select>
                    </div>

                    <div class="result-chart-control">
                        <label class="result-chart-control__label">Eje Y (valores)</label>
                        <div class="result-chart-ycols">
                            @if (_columnasNumericas.Count == 0)
                            {
                                <span style="font-size:.82rem; color:var(--color-text-muted)">No se detectaron columnas numéricas.</span>
                            }
                            @foreach (var (nombre, idx) in _columnasNumericas)
                            {
                                <label class="result-chart-ycol">
                                    <input type="checkbox"
                                           checked="@_colsValores.Contains(idx)"
                                           @onchange="e => ToggleColValor(idx, (bool)e.Value!)" />
                                    @nombre
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <ResultChart Filas="@(_filasFiltradas.Count > 0 ? _filasFiltradas : _resultado.Filas)"
                             Columnas="@_resultado.Columnas"
                             ColEtiqueta="@_colEtiqueta"
                             ColsValores="@_colsValores"
                             TipoGrafico="@_tipoGrafico" />
            </div>
        }

        @if (_mostrarAgrupador && _resultado is { Exitoso: true, Filas.Count: > 0 })
        {
            <div class="result-group-panel">
                <div class="result-group-config">
                    <div class="result-group-by">
                        <label class="result-group-by__label">Agrupar por</label>
                        <select class="editor-field__input editor-field__input--sm"
                                @bind="_colAgrupador" @bind:after="OnAgrupadorChanged">
                            <option value="-1">— elegir columna —</option>
                            @foreach (var (col, i) in _resultado.Columnas.Select((c, i) => (c, i)))
                            {
                                <option value="@i">@col</option>
                            }
                        </select>
                    </div>

                    @if (_colAgrupador >= 0)
                    {
                        <div class="result-group-cols">
                            @foreach (var (col, i) in _resultado.Columnas.Select((c, i) => (c, i)).Where(t => t.i != _colAgrupador))
                            {
                                var iCopy = i;
                                <div class="result-group-col">
                                    <span class="result-group-col__name" title="@col">@col</span>
                                    <select class="result-group-col__op"
                                            @onchange="e => OnAgregacionChanged(iCopy, e.Value?.ToString() ?? string.Empty)">
                                        <option value="" selected="@(_agregaciones.GetValueOrDefault(i) == string.Empty)">excluir</option>
                                        <option value="SUM" selected="@(_agregaciones.GetValueOrDefault(i) == "SUM")">Suma</option>
                                        <option value="COUNT" selected="@(_agregaciones.GetValueOrDefault(i) == "COUNT")">Conteo</option>
                                        <option value="AVG" selected="@(_agregaciones.GetValueOrDefault(i) == "AVG")">Promedio</option>
                                        <option value="MIN" selected="@(_agregaciones.GetValueOrDefault(i) == "MIN")">Mínimo</option>
                                        <option value="MAX" selected="@(_agregaciones.GetValueOrDefault(i) == "MAX")">Máximo</option>
                                    </select>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (_colAgrupador >= 0 && _tablaAgrupada.Count > 0)
                {
                    <div class="result-group-table-wrap">
                        <table class="result-group-table">
                            <thead>
                                <tr>
                                    @foreach (var (col, i) in _columnasAgrupadas.Select((c, i) => (c, i)))
                                    {
                                        <th class="sortable @(_sortColAgrupada == i ? (_sortDescAgrupada ? "sort-desc" : "sort-asc") : "")"
                                            @onclick="() => SortByAgrupada(i)">
                                            @col
                                            <i class="bi @(_sortColAgrupada == i ? (_sortDescAgrupada ? "bi-sort-down" : "bi-sort-up") : "bi-arrow-down-up") sort-icon"></i>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fila in TablaAgrupadaOrdenada())
                                {
                                    <tr>
                                        @foreach (var (val, j) in fila.Select((v, j) => (v, j)))
                                        {
                                            <td class="@(j > 0 ? "result-group-table__num" : "")">@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            @if (_totalesAgrupados.Length > 0)
                            {
                                <tfoot>
                                    <tr class="result-group-total">
                                        @foreach (var (val, j) in _totalesAgrupados.Select((v, j) => (v, j)))
                                        {
                                            <td class="@(j > 0 ? "result-group-table__num" : "")">@val</td>
                                        }
                                    </tr>
                                </tfoot>
                            }
                        </table>
                    </div>
                    <p class="result-group-info">
                        @_tablaAgrupada.Count grupo(s) ·
                        @(string.IsNullOrWhiteSpace(_filtroAplicado)
                            ? _resultado.TotalFilas.ToString("N0")
                            : _filasFiltradas.Count.ToString("N0")) filas procesadas
                    </p>
                }
                else if (_colAgrupador >= 0)
                {
                    <p class="result-group-info">Sin datos para agrupar.</p>
                }
            </div>
        }

        @if (_resultado is not null)
        {
            <div class="consulta-result">
                @if (!_resultado.Exitoso)
                {
                    <div class="consulta-result__error">
                        <i class="bi bi-exclamation-circle"></i>
                        @_resultado.MensajeError
                    </div>
                }
                else if (_resultado.Filas.Count == 0)
                {
                    <div class="consulta-result__empty">
                        <i class="bi bi-inbox"></i>
                        La consulta se ejecutó correctamente pero no devolvió datos con los parámetros actuales.
                    </div>
                }
                else
                {
                    <div class="consulta-result__header">
                        <div class="consulta-result__stats">
                            <span><strong>@_resultado.TotalFilas.ToString("N0")</strong> filas</span>
                            <span>@_resultado.TiempoEjecucion.TotalSeconds.ToString("F2") seg</span>
                            <span class="consulta-result__ts">@_resultado.EjecutadoEn.ToString("HH:mm:ss")</span>
                        </div>
                        @if (_resultado.TieneMasFilas)
                        {
                            <div class="consulta-result__warn">
                                <i class="bi bi-exclamation-triangle"></i>
                                Se muestran las primeras 500 filas. Usá Excel para ver el resultado completo.
                            </div>
                        }
                    </div>

                    <div class="result-search">
                        <i class="bi bi-search result-search__icon"></i>
                        <input class="result-search__input"
                               @bind="_filtroResultado"
                               @bind:event="oninput"
                               @onkeydown="OnFiltroBuscarKeyDown"
                               placeholder="Buscar en el resultado… (Enter para filtrar, Esc para limpiar)" />
                        @if (!string.IsNullOrWhiteSpace(_filtroAplicado))
                        {
                            <span class="result-search__count">@_filasFiltradas.Count filas</span>
                            <button class="result-search__clear" @onclick="LimpiarFiltro" title="Limpiar filtro">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>

                    <div class="consulta-result__table-wrap">
                        <table class="consulta-table">
                            <thead>
                                <tr>
                                    @foreach (var (col, i) in _resultado.Columnas.Select((c, i) => (c, i)))
                                    {
                                        <th class="sortable @(_sortCol == i ? (_sortDesc ? "sort-desc" : "sort-asc") : "")"
                                            @onclick="() => SortBy(i)" title="Ordenar por @col">
                                            @col
                                            <i class="bi @(_sortCol == i ? (_sortDesc ? "bi-sort-down" : "bi-sort-up") : "bi-arrow-down-up") sort-icon"></i>
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fila in FilasPagina())
                                {
                                    <tr>
                                        @foreach (var val in fila)
                                        {
                                            <td title="@val">@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (TotalPaginas > 1)
                    {
                        <div class="result-pagination">
                            <div class="result-pagination__info">
                                Mostrando @(_pagina * _filasPorPagina + 1)–@(Math.Min((_pagina + 1) * _filasPorPagina, _filasFiltradas.Count))
                                de @_filasFiltradas.Count filas
                                @if (!string.IsNullOrWhiteSpace(_filtroAplicado))
                                {
                                    <span style="color:var(--color-primary)"> (filtrado)</span>
                                }
                            </div>
                            <div class="result-pagination__controls">
                                <button class="result-pagination__btn" @onclick="() => _pagina = 0" disabled="@(_pagina == 0)" title="Primera">«</button>
                                <button class="result-pagination__btn" @onclick="() => _pagina--" disabled="@(_pagina == 0)" title="Anterior">‹</button>
                                @{
                                    int desde = Math.Max(0, _pagina - 2);
                                    int hasta = Math.Min(TotalPaginas - 1, _pagina + 2);
                                }
                                @for (int p = desde; p <= hasta; p++)
                                {
                                    var pCopy = p;
                                    <button class="result-pagination__btn @(pCopy == _pagina ? "result-pagination__btn--active" : "")"
                                            @onclick="() => _pagina = pCopy">@(pCopy + 1)</button>
                                }
                                <button class="result-pagination__btn" @onclick="() => _pagina++" disabled="@(_pagina >= TotalPaginas - 1)" title="Siguiente">›</button>
                                <button class="result-pagination__btn" @onclick="() => _pagina = TotalPaginas - 1" disabled="@(_pagina >= TotalPaginas - 1)" title="Última">»</button>
                            </div>
                            <select class="result-pagination__size" @onchange="e => { _filasPorPagina = int.Parse(e.Value!.ToString()!); _pagina = 0; }">
                                <option value="25" selected="@(_filasPorPagina == 25)">25 / pág.</option>
                                <option value="50" selected="@(_filasPorPagina == 50)">50 / pág.</option>
                                <option value="100" selected="@(_filasPorPagina == 100)">100 / pág.</option>
                                <option value="200" selected="@(_filasPorPagina == 200)">200 / pág.</option>
                            </select>
                        </div>
                    }
                }
            </div>
        }

    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ConsultaGuardadaDto? _consulta;
    private ConsultaResultadoDto? _resultado;
    private string[] _valores = [];
    private List<NodoArbolDto> _ruta = [];
    private bool _cargando = true;
    private bool _ejecutando;

    private int _pagina = 0;
    private int _filasPorPagina = 50;
    private int _sortCol = -1;
    private bool _sortDesc = false;
    private string _filtroResultado = string.Empty;
    private string _filtroAplicado = string.Empty;
    private List<string[]> _filasFiltradas = [];

    private int TotalPaginas => (int)Math.Ceiling(_filasFiltradas.Count / (double)_filasPorPagina);

    private void AplicarFiltro(string filtro)
    {
        _filtroAplicado = filtro.Trim();
        _pagina = 0;
        _filasFiltradas = string.IsNullOrWhiteSpace(_filtroAplicado)
            ? (_resultado?.Filas.ToList() ?? [])
            : (_resultado?.Filas
                .Where(r => r.Any(v => v.Contains(_filtroAplicado, StringComparison.CurrentCultureIgnoreCase)))
                .ToList() ?? []);

        if (_mostrarAgrupador && _colAgrupador >= 0)
            RecalcularAgrupacion();
    }

    private void OnFiltroBuscarKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AplicarFiltro(_filtroResultado);
        else if (e.Key == "Escape") LimpiarFiltro();
    }

    private void LimpiarFiltro()
    {
        _filtroResultado = string.Empty;
        AplicarFiltro(string.Empty);
    }

    private IEnumerable<string[]> FilasOrdenadas() => _sortCol < 0
        ? _filasFiltradas
        : _sortDesc
            ? _filasFiltradas.OrderByDescending(r => r[_sortCol])
            : _filasFiltradas.OrderBy(r => r[_sortCol]);

    private IEnumerable<string[]> FilasPagina() =>
        FilasOrdenadas().Skip(_pagina * _filasPorPagina).Take(_filasPorPagina);

    private void SortBy(int col)
    {
        if (_sortCol == col) _sortDesc = !_sortDesc;
        else { _sortCol = col; _sortDesc = false; }
        _pagina = 0;
    }

    // ── Agrupador ──
    private bool _mostrarAgrupador;
    private bool _agrupadorInicializado;
    private int _colAgrupador = -1;
    private Dictionary<int, string> _agregaciones = [];
    private List<string> _columnasAgrupadas = [];
    private List<string[]> _tablaAgrupada = [];
    private List<decimal[]> _tablaAgrupadaRaw = [];
    private string[] _totalesAgrupados = [];
    private int _sortColAgrupada = -1;
    private bool _sortDescAgrupada;

    private void ToggleAgrupador()
    {
        _mostrarAgrupador = !_mostrarAgrupador;
        if (_mostrarAgrupador && !_agrupadorInicializado)
            _agrupadorInicializado = true;
    }

    private void OnAgrupadorChanged()
    {
        if (_colAgrupador < 0) { _tablaAgrupada = []; _totalesAgrupados = []; return; }

        _agregaciones = [];
        for (int i = 0; i < _resultado!.Columnas.Count; i++)
        {
            if (i == _colAgrupador) continue;
            _agregaciones[i] = EsColumnaNumerica(i) ? "SUM" : string.Empty;
        }
        _sortColAgrupada = -1;
        _sortDescAgrupada = false;
        RecalcularAgrupacion();
    }

    private void OnAgregacionChanged(int colIdx, string op)
    {
        _agregaciones[colIdx] = op;
        RecalcularAgrupacion();
    }

    private void SortByAgrupada(int col)
    {
        if (_sortColAgrupada == col) _sortDescAgrupada = !_sortDescAgrupada;
        else { _sortColAgrupada = col; _sortDescAgrupada = false; }
    }

    private IEnumerable<string[]> TablaAgrupadaOrdenada()
    {
        if (_sortColAgrupada < 0) return _tablaAgrupada;
        var withRaw = _tablaAgrupada.Zip(_tablaAgrupadaRaw, (r, raw) => (r, raw)).ToList();
        IEnumerable<(string[] r, decimal[] raw)> ordered = _sortColAgrupada == 0
            ? (_sortDescAgrupada ? withRaw.OrderByDescending(t => t.r[0]) : withRaw.OrderBy(t => t.r[0]))
            : (_sortDescAgrupada
                ? withRaw.OrderByDescending(t => _sortColAgrupada - 1 < t.raw.Length ? t.raw[_sortColAgrupada - 1] : 0m)
                : withRaw.OrderBy(t => _sortColAgrupada - 1 < t.raw.Length ? t.raw[_sortColAgrupada - 1] : 0m));
        return ordered.Select(t => t.r);
    }

    private void RecalcularAgrupacion()
    {
        if (_colAgrupador < 0 || _resultado is null) { _tablaAgrupada = []; _totalesAgrupados = []; return; }

        var colsConOp = _agregaciones
            .Where(kv => !string.IsNullOrEmpty(kv.Value))
            .OrderBy(kv => kv.Key)
            .ToList();

        _columnasAgrupadas = [
            _resultado.Columnas[_colAgrupador],
            .. colsConOp.Select(kv => $"{OpLabel(kv.Value)}({_resultado.Columnas[kv.Key]})")
        ];

        var fuente = string.IsNullOrWhiteSpace(_filtroAplicado) ? _resultado.Filas : _filasFiltradas;
        var grupos = fuente.GroupBy(r => _colAgrupador < r.Length ? r[_colAgrupador] : string.Empty)
                           .OrderBy(g => g.Key);

        _tablaAgrupada = [];
        _tablaAgrupadaRaw = [];
        var sumasTotal = new decimal[colsConOp.Count];

        foreach (var grupo in grupos)
        {
            var fila = new string[1 + colsConOp.Count];
            var raw = new decimal[colsConOp.Count];
            fila[0] = grupo.Key;

            for (int j = 0; j < colsConOp.Count; j++)
            {
                var colIdx = colsConOp[j].Key;
                var op = colsConOp[j].Value;
                var nums = grupo.Select(r => ParseAgrupDecimal(colIdx < r.Length ? r[colIdx] : string.Empty)).ToList();

                decimal val = op switch
                {
                    "SUM" => nums.Sum(),
                    "COUNT" => grupo.Count(),
                    "AVG" => nums.Count > 0 ? Math.Round(nums.Sum() / nums.Count, 2) : 0m,
                    "MIN" => nums.Count > 0 ? nums.Min() : 0m,
                    "MAX" => nums.Count > 0 ? nums.Max() : 0m,
                    _ => 0m
                };

                raw[j] = val;
                fila[j + 1] = FormatAgregado(val, op);

                if (op is "SUM" or "COUNT") sumasTotal[j] += val;
            }

            _tablaAgrupada.Add(fila);
            _tablaAgrupadaRaw.Add(raw);
        }

        // Fila de totales
        _totalesAgrupados = new string[1 + colsConOp.Count];
        _totalesAgrupados[0] = "Total";
        for (int j = 0; j < colsConOp.Count; j++)
        {
            var colIdx = colsConOp[j].Key;
            var op = colsConOp[j].Value;
            if (op is "SUM" or "COUNT")
            {
                _totalesAgrupados[j + 1] = FormatAgregado(sumasTotal[j], op);
            }
            else
            {
                var allNums = fuente.Select(r => ParseAgrupDecimal(colIdx < r.Length ? r[colIdx] : string.Empty)).ToList();
                decimal gt = op switch
                {
                    "AVG" => allNums.Count > 0 ? Math.Round(allNums.Sum() / allNums.Count, 2) : 0m,
                    "MIN" => allNums.Count > 0 ? allNums.Min() : 0m,
                    "MAX" => allNums.Count > 0 ? allNums.Max() : 0m,
                    _ => 0m
                };
                _totalesAgrupados[j + 1] = FormatAgregado(gt, op);
            }
        }
    }

    private static decimal ParseAgrupDecimal(string s) =>
        decimal.TryParse(s.Replace(',', '.'),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : 0m;

    private static string FormatAgregado(decimal v, string op)
    {
        if (op == "COUNT") return ((long)v).ToString("N0", System.Globalization.CultureInfo.CurrentCulture);
        if (v == 0m) return "0";
        return v.ToString("N2", System.Globalization.CultureInfo.CurrentCulture);
    }

    private static string OpLabel(string op) => op switch
    {
        "SUM" => "Suma", "COUNT" => "Conteo", "AVG" => "Promedio",
        "MIN" => "Mín", "MAX" => "Máx", _ => op
    };

    // ── Gráfico ──
    private bool _mostrarGrafico;
    private bool _graficoInicializado;
    private string _tipoGrafico = "Barras";
    private int _colEtiqueta;
    private List<int> _colsValores = [];
    private List<(string Nombre, int Indice)> _columnasNumericas = [];

    private void ToggleGrafico()
    {
        _mostrarGrafico = !_mostrarGrafico;
        if (_mostrarGrafico && !_graficoInicializado)
        {
            InicializarGrafico();
            _graficoInicializado = true;
        }
    }

    private void InicializarGrafico()
    {
        if (_resultado is null) return;

        _columnasNumericas = _resultado.Columnas
            .Select((c, i) => (c, i))
            .Where(t => EsColumnaNumerica(t.i))
            .Select(t => (t.c, t.i))
            .ToList();

        // Eje X: primera columna NO numérica, o la 0
        var noNumerica = _resultado.Columnas
            .Select((c, i) => (c, i))
            .FirstOrDefault(t => !EsColumnaNumerica(t.i));
        _colEtiqueta = noNumerica.i;

        // Eje Y: desde CamposTotaliza si está definido, si no las primeras 2 numéricas
        _colsValores = [];
        if (!string.IsNullOrWhiteSpace(_consulta?.CamposTotaliza))
        {
            var campos = _consulta.CamposTotaliza
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _colsValores = campos
                .Select(c => _resultado.Columnas.ToList().IndexOf(c))
                .Where(i => i >= 0)
                .ToList();
        }
        if (_colsValores.Count == 0)
            _colsValores = _columnasNumericas.Take(2).Select(t => t.Indice).ToList();
    }

    private bool EsColumnaNumerica(int colIdx) =>
        _resultado!.Filas.Take(20)
            .Where(r => colIdx < r.Length && !string.IsNullOrWhiteSpace(r[colIdx]))
            .Any(r => decimal.TryParse(r[colIdx].Replace(',', '.'),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out _));

    private void ToggleColValor(int idx, bool checked_)
    {
        if (checked_) { if (!_colsValores.Contains(idx)) _colsValores = [.. _colsValores, idx]; }
        else _colsValores = _colsValores.Where(i => i != idx).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        var tareaConsulta = ConsultasSvc.GetConsultaAsync(Id);
        var tareaArbol = ConsultasSvc.GetArbolAsync();
        await Task.WhenAll(tareaConsulta, tareaArbol);

        _consulta = await tareaConsulta;
        if (_consulta is not null)
        {
            _ruta = EncontrarRuta(await tareaArbol, _consulta.Clave);
            _valores = new string[_consulta.Parametros.Count];
            if (!_consulta.TieneParametros)
                await EjecutarAsync();
        }

        _cargando = false;
    }

    private static List<NodoArbolDto> EncontrarRuta(IEnumerable<NodoArbolDto> nodos, string clave)
    {
        foreach (var nodo in nodos)
        {
            if (nodo.Clave == clave) return [nodo];
            var sub = EncontrarRuta(nodo.Hijos, clave);
            if (sub.Count > 0) { sub.Insert(0, nodo); return sub; }
        }
        return [];
    }

    private async Task EjecutarAsync()
    {
        if (_ejecutando) return;
        _ejecutando = true;
        _pagina = 0;
        _sortCol = -1;
        _sortDesc = false;
        _filtroResultado = string.Empty;
        _filtroAplicado = string.Empty;
        _filasFiltradas = [];
        _mostrarGrafico = false;
        _graficoInicializado = false;
        _mostrarAgrupador = false;
        _agrupadorInicializado = false;
        _colAgrupador = -1;
        _agregaciones = [];
        _tablaAgrupada = [];
        _totalesAgrupados = [];
        StateHasChanged();
        try
        {
            _resultado = await ConsultasSvc.EjecutarAsync(new EjecutarConsultaRequest
            {
                ConsultaId = Id,
                ValoresParametros = [.. _valores]
            });
            AplicarFiltro(string.Empty);
        }
        finally
        {
            _ejecutando = false;
        }
    }

    private string GetExcelUrl()
    {
        var qs = string.Join("&", _valores.Select((v, i) => $"p{i}={Uri.EscapeDataString(v)}"));
        return qs.Length > 0 ? $"/consultas/{Id}/descargar-excel?{qs}" : $"/consultas/{Id}/descargar-excel";
    }

    private async Task ImprimirAsync() =>
        await JS.InvokeVoidAsync("dashboardExport.printCurrentPage", _consulta?.Descripcion ?? "Consulta");
}
