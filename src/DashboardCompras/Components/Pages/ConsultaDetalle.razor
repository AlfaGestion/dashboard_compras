    {
        public string Grupo { get; init; } = string.Empty;
        public List<string[]> Filas { get; init; } = [];
        public List<TotalGrupoResultado> Totales { get; init; } = [];
    }

    private sealed record TotalGrupoResultado(string Label, string Valor);
