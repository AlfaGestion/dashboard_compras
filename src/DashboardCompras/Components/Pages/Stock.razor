@page "/stock"
@inject DashboardCompras.Services.IGestionDashboardService GestionSvc
@inject DashboardCompras.Services.GestionFilterStateService FilterState

<PageTitle>Stock | Alfa Gestión</PageTitle>

<div class="page-grid">
    <section class="page-intro">
        <div>
            <h2 class="page-intro__title">Stock</h2>
            <p class="page-intro__text">Seguimiento de valorización, movimiento y artículos críticos para reposición.</p>
        </div>
    </section>

    <section class="panel-card filters-card">
        <div class="panel-card__header">
            <div>
                <h3 class="panel-card__title">Filtros de stock</h3>
                <p class="panel-card__subtitle">Artículos, depósitos y estado operativo para analizar rotación y faltantes.</p>
            </div>
            <div class="quick-range">
                <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
                <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
                <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
                <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
                <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
                <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
            </div>
        </div>

        <div class="filters-grid filters-grid--dates">
            <div class="field">
                <label>Fecha desde</label>
                <InputDate @bind-Value="_filters.FechaDesde" />
            </div>
            <div class="field">
                <label>Fecha hasta</label>
                <InputDate @bind-Value="_filters.FechaHasta" />
            </div>
            <div class="filters-toggle-wrap">
                <button type="button" class="btn btn--ghost filters-toggle" @onclick="ToggleAdvanced">
                    @(_showAdvanced ? "Ocultar filtros" : "Mostrar filtros")
                </button>
            </div>
        </div>

        <div class="filters-summary" aria-live="polite">
            <span class="filters-summary__label">Filtros activos</span>
            <span class="filters-summary__text">@BuildSummary()</span>
        </div>

        @if (_showAdvanced)
        {
            <div class="filters-grid filters-grid--wide">
                <div class="field">
                    <label>Código artículo</label>
                    <InputText @bind-Value="_filters.ArticuloCodigo" />
                </div>
                <div class="field">
                    <label>Descripción artículo</label>
                    <InputText @bind-Value="_filters.ArticuloDescripcion" />
                </div>
                <div class="field">
                    <label>Rubro</label>
                    <InputSelect @bind-Value="_filters.Rubro">
                        <option value="">Todos</option>
                        @foreach (var item in _options.Rubros)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Familia</label>
                    <InputSelect @bind-Value="_filters.Familia">
                        <option value="">Todas</option>
                        @foreach (var item in _options.Familias)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Depósito</label>
                    <InputSelect @bind-Value="_filters.Deposito">
                        <option value="">Todos</option>
                        @foreach (var item in _options.Depositos)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Sucursal</label>
                    <InputSelect @bind-Value="_filters.Sucursal">
                        <option value="">Todas</option>
                        @foreach (var item in _options.Sucursales)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Estado</label>
                    <InputSelect @bind-Value="_filters.Estado">
                        <option value="">Todos</option>
                        @foreach (var item in _options.Estados)
                        {
                            <option value="@item">@item</option>
                        }
                    </InputSelect>
                </div>
            </div>
        }

        <div class="actions">
            <button class="btn btn--primary" @onclick="LoadAsync">Aplicar filtros</button>
            <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
        </div>
    </section>

    @if (_loading)
    {
        <div class="consultas-loading"><i class="bi bi-hourglass-split"></i> Cargando stock…</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="consultas-error"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }
    else
    {
        <section class="kpi-grid">
            <article class="kpi-card"><div class="kpi-card__label">Stock valorizado</div><div class="kpi-card__value">@FmtMoney(_data.StockValorizado)</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Artículos con stock</div><div class="kpi-card__value">@_data.ArticulosConStock</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Bajo punto pedido</div><div class="kpi-card__value">@_data.BajoPuntoPedido</div></article>
            <article class="kpi-card"><div class="kpi-card__label">Sin stock</div><div class="kpi-card__value">@_data.SinStock</div></article>
        </section>

        <section class="two-grid">
            <article class="panel-card">
                <LineChart Data="_data.EvolucionMensual" Titulo="Stock valorizado" Subtitulo="Últimos 12 cierres mensuales" />
            </article>
            <article class="panel-card">
                <HorizontalBarChart Data="_data.TopMovimientos" Titulo="Artículos más movidos" Subtitulo="Rotación del período" />
            </article>
        </section>

        <section class="panel-card">
            <div class="panel-card__header">
                <div>
                    <h3 class="panel-card__title">Artículos críticos</h3>
                    <p class="panel-card__subtitle">Debajo del punto de pedido o cerca del faltante.</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead><tr><th>Artículo</th><th>Descripción</th><th>Stock actual</th><th>Punto pedido</th><th>Valorizado</th></tr></thead>
                    <tbody>
                    @foreach (var item in _data.Criticos)
                    {
                        <tr>
                            <td>@item.IdArticulo</td>
                            <td>@item.Descripcion</td>
                            <td>@item.StockActual.ToString("#,##0.##", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</td>
                            <td>@item.PuntoPedido.ToString("#,##0.##", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</td>
                            <td>@FmtMoney(item.Valorizado)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private string _error = string.Empty;
    private bool _showAdvanced;
    private StockDashboardDto _data = new();
    private StockDashboardFilters _filters = null!;
    private StockFilterOptionsDto _options = new();

    protected override async Task OnInitializedAsync()
    {
        _filters = FilterState.Stock;
        try
        {
            _options = await GestionSvc.GetStockFilterOptionsAsync();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _loading = false;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = string.Empty;
        try { _data = await GestionSvc.GetStockAsync(_filters); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private Task HoyAsync() => ApplyQuickRangeAsync("hoy");
    private Task SemanaAsync() => ApplyQuickRangeAsync("semana");
    private Task MesAsync() => ApplyQuickRangeAsync("mes");
    private Task MesAnteriorAsync() => ApplyQuickRangeAsync("mes-anterior");
    private Task UltimosTresAsync() => ApplyQuickRangeAsync("ultimos-3");
    private Task AnioAsync() => ApplyQuickRangeAsync("anio");
    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
        _filters.FechaHasta = today;
        _filters.ArticuloCodigo = null;
        _filters.ArticuloDescripcion = null;
        _filters.Rubro = null;
        _filters.Familia = null;
        _filters.Deposito = null;
        _filters.Sucursal = null;
        _filters.Estado = null;
        await LoadAsync();
    }

    private async Task ApplyQuickRangeAsync(string key)
    {
        var today = DateTime.Today;
        switch (key)
        {
            case "hoy":
                _filters.FechaDesde = today;
                _filters.FechaHasta = today;
                break;
            case "semana":
                var diff = ((int)today.DayOfWeek + 6) % 7;
                _filters.FechaDesde = today.AddDays(-diff);
                _filters.FechaHasta = today;
                break;
            case "mes":
                _filters.FechaDesde = new DateTime(today.Year, today.Month, 1);
                _filters.FechaHasta = today;
                break;
            case "mes-anterior":
                var firstThisMonth = new DateTime(today.Year, today.Month, 1);
                _filters.FechaDesde = firstThisMonth.AddMonths(-1);
                _filters.FechaHasta = firstThisMonth.AddDays(-1);
                break;
            case "ultimos-3":
                _filters.FechaDesde = today.AddMonths(-3);
                _filters.FechaHasta = today;
                break;
            case "anio":
                _filters.FechaDesde = new DateTime(today.Year, 1, 1);
                _filters.FechaHasta = today;
                break;
        }

        await LoadAsync();
    }

    private string BuildSummary()
    {
        var parts = new List<string>();
        if (_filters.FechaDesde.HasValue || _filters.FechaHasta.HasValue)
        {
            parts.Add($"Fecha: {_filters.FechaDesde:dd/MM/yyyy} a {_filters.FechaHasta:dd/MM/yyyy}");
        }

        AddIfPresent(parts, "Código", _filters.ArticuloCodigo);
        AddIfPresent(parts, "Descripción", _filters.ArticuloDescripcion);
        AddIfPresent(parts, "Rubro", _filters.Rubro);
        AddIfPresent(parts, "Familia", _filters.Familia);
        AddIfPresent(parts, "Depósito", _filters.Deposito);
        AddIfPresent(parts, "Sucursal", _filters.Sucursal);
        AddIfPresent(parts, "Estado", _filters.Estado);

        return parts.Count == 0 ? "Sin filtros seleccionados." : string.Join(" | ", parts);
    }

    private static void AddIfPresent(List<string> parts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add($"{label}: {value}");
        }
    }

    private static string FmtMoney(decimal value) => value.ToString("$ #,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
