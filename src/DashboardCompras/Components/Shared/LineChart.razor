@if (!string.IsNullOrWhiteSpace(Titulo) || !string.IsNullOrWhiteSpace(Subtitulo))
{
    <div class="panel-card__header">
        <div>
            @if (!string.IsNullOrWhiteSpace(Titulo))
            {
                <h3 class="panel-card__title">@Titulo</h3>
            }
            @if (!string.IsNullOrWhiteSpace(Subtitulo))
            {
                <p class="panel-card__subtitle">@Subtitulo</p>
            }
        </div>
    </div>
}

@if (Data.Count == 0)
{
    <p class="chart-empty">Sin datos para graficar.</p>
}
else
{
    <div class="line-chart">
        <svg viewBox="0 0 640 290" class="line-chart__svg" role="img" aria-label="@Titulo">
            <defs>
                <linearGradient id="@_gradientId" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(14,165,233,0.35)" />
                    <stop offset="100%" stop-color="rgba(14,165,233,0.02)" />
                </linearGradient>
            </defs>

            @foreach (var gridLine in _gridLines)
            {
                <line x1="56" y1="@gridLine.Y.ToString("F2")" x2="620" y2="@gridLine.Y.ToString("F2")" class="line-chart__grid" />
            }

            <path d="@_areaPath" fill="url(#@_gradientId)" />
            <path d="@_linePath" class="line-chart__path" />

            @if (Data.Count <= 20)
            {
                @foreach (var point in _points)
                {
                    <circle cx="@point.X.ToString("F2")" cy="@point.Y.ToString("F2")" r="4.5" class="line-chart__point" />
                }
            }

            @((MarkupString)_xLabels)
            @((MarkupString)_yLabels)
        </svg>
    </div>
}

@code {
    private const int MaxLabels = 8;
    private readonly string _gradientId = $"g{Guid.NewGuid():N}";

    private string _linePath = string.Empty;
    private string _areaPath = string.Empty;
    private string _xLabels = string.Empty;
    private string _yLabels = string.Empty;
    private List<ChartPoint> _points = [];
    private List<ChartPoint> _labelPoints = [];
    private List<GridLine> _gridLines = [];

    [Parameter, EditorRequired] public IReadOnlyList<MonthlyPointDto> Data { get; set; } = [];
    [Parameter] public string Titulo { get; set; } = "Evolución";
    [Parameter] public string Subtitulo { get; set; } = string.Empty;
    [Parameter] public bool MostrarMoneda { get; set; } = true;

    protected override void OnParametersSet()
    {
        if (Data.Count == 0)
        {
            _points = [];
            _labelPoints = [];
            _gridLines = [];
            _linePath = string.Empty;
            _areaPath = string.Empty;
            return;
        }

        const double chartW = 564;
        const double chartH = 176;
        const double startX = 56;
        const double startY = 26;

        var max = Math.Max(Data.Max(x => x.Total), 1);
        var min = Math.Min(Data.Min(x => x.Total), 0);
        var range = Math.Max(max - min, 1);

        _points = Data.Select((item, index) =>
        {
            var x = startX + chartW / Math.Max(Data.Count - 1, 1) * index;
            var y = startY + chartH - (double)((item.Total - min) / range) * chartH;
            return new ChartPoint(x, y, item.Periodo);
        }).ToList();

        var step = Math.Max(1, (int)Math.Ceiling((double)Data.Count / MaxLabels));
        _labelPoints = _points
            .Where((_, i) => i % step == 0 || i == Data.Count - 1)
            .ToList();

        _linePath = BuildSmoothPath(_points);
        _areaPath = $"{_linePath} L {_points[^1].X:F2},{202} L {_points[0].X:F2},{202} Z";

        _xLabels = string.Join("", _labelPoints.Select(p =>
            $"<text x=\"{p.X:F2}\" y=\"278\" class=\"line-chart__label-svg\" text-anchor=\"middle\">{System.Net.WebUtility.HtmlEncode(p.Label)}</text>"));

        _gridLines = Enumerable.Range(0, 4)
            .Select(i =>
            {
                var value = min + (max - min) / 3m * i;
                var y = startY + chartH - (double)((value - min) / range) * chartH;
                return new GridLine(y, value);
            })
            .Reverse()
            .ToList();

        _yLabels = string.Join("", _gridLines.Select(g =>
            $"<text x=\"52\" y=\"{g.Y + 4:F2}\" class=\"line-chart__axis-svg\" text-anchor=\"end\">{System.Net.WebUtility.HtmlEncode(FormatearValor(g.Value))}</text>"));
    }

    private static string BuildSmoothPath(List<ChartPoint> points)
    {
        if (points.Count == 0) return string.Empty;
        if (points.Count == 1) return $"M {points[0].X:F2},{points[0].Y:F2}";

        var sb = new System.Text.StringBuilder();
        sb.Append($"M {points[0].X:F2},{points[0].Y:F2}");

        for (int i = 1; i < points.Count; i++)
        {
            var p0 = points[Math.Max(i - 2, 0)];
            var p1 = points[i - 1];
            var p2 = points[i];
            var p3 = points[Math.Min(i + 1, points.Count - 1)];

            double cp1x = p1.X + (p2.X - p0.X) / 6.0;
            double cp1y = p1.Y + (p2.Y - p0.Y) / 6.0;
            double cp2x = p2.X - (p3.X - p1.X) / 6.0;
            double cp2y = p2.Y - (p3.Y - p1.Y) / 6.0;

            sb.Append($" C {cp1x:F2},{cp1y:F2} {cp2x:F2},{cp2y:F2} {p2.X:F2},{p2.Y:F2}");
        }

        return sb.ToString();
    }

    private string FormatearValor(decimal valor)
        => MostrarMoneda
            ? valor.ToString("$ #,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))
            : valor.ToString("#,##0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private sealed record ChartPoint(double X, double Y, string Label);
    private sealed record GridLine(double Y, decimal Value);
}
