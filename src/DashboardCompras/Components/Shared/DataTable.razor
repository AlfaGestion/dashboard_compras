<section class="panel-card">
    <div class="table-toolbar">
        <div>
            <h3 class="panel-card__title">@Titulo</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitulo))
            {
                <p class="panel-card__subtitle">@Subtitulo</p>
            }
        </div>
        @if (Toolbar is not null)
        {
            <div>@Toolbar</div>
        }
    </div>

    <div class="table-wrap">
        <table class="data-table">
            <thead>@Header</thead>
            <tbody>@Rows</tbody>
        </table>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string? Subtitulo { get; set; }
    [Parameter, EditorRequired] public RenderFragment Header { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment Rows { get; set; } = default!;
    [Parameter] public RenderFragment? Toolbar { get; set; }
}
