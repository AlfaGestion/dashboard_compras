@using DashboardCompras.Models

<section class="panel-card filters-card">
    <div class="panel-card__header">
        <div>
            <h3 class="panel-card__title">@Titulo</h3>
            <p class="panel-card__subtitle">@Subtitulo</p>
        </div>
        <div class="quick-range">
            <button class="btn btn--ghost" @onclick="HoyAsync">Hoy</button>
            <button class="btn btn--ghost" @onclick="SemanaAsync">Esta semana</button>
            <button class="btn btn--ghost" @onclick="MesAsync">Este mes</button>
            <button class="btn btn--ghost" @onclick="MesAnteriorAsync">Mes anterior</button>
            <button class="btn btn--ghost" @onclick="UltimosTresAsync">Últimos 3 meses</button>
            <button class="btn btn--ghost" @onclick="AnioAsync">Año actual</button>
        </div>
    </div>

    <div class="filters-grid filters-grid--dates">
        <div class="field">
            <label>Fecha desde</label>
            <InputDate @bind-Value="Model.FechaDesde" />
        </div>
        <div class="field">
            <label>Fecha hasta</label>
            <InputDate @bind-Value="Model.FechaHasta" />
        </div>
        <div class="filters-toggle-wrap">
            <button type="button" class="btn btn--ghost filters-toggle" @onclick="ToggleAdvanced">
                @(_showAdvanced ? "Ocultar filtros" : "Mostrar filtros")
            </button>
        </div>
    </div>

    <div class="filters-summary" aria-live="polite">
        <span class="filters-summary__label">Filtros activos</span>
        <span class="filters-summary__text">@BuildSummary()</span>
    </div>

    @if (_showAdvanced)
    {
        <div class="filters-grid filters-grid--wide">
        <div class="field">
            <label>Proveedor</label>
            <InputText @bind-Value="Model.Proveedor" />
        </div>
        <div class="field">
            <label>Código artículo</label>
            <InputText @bind-Value="Model.ArticuloCodigo" />
        </div>
        <div class="field">
            <label>Descripción artículo</label>
            <InputText @bind-Value="Model.ArticuloDescripcion" />
        </div>
        <div class="field">
            <label>Rubro</label>
            <InputSelect @bind-Value="Model.Rubro">
                <option value="">Todos</option>
                @foreach (var item in Options.Rubros)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>Familia</label>
            <InputSelect @bind-Value="Model.Familia">
                <option value="">Todas</option>
                @foreach (var item in Options.Familias)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>Usuario</label>
            <InputSelect @bind-Value="Model.Usuario">
                <option value="">Todos</option>
                @foreach (var item in Options.Usuarios)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>Sucursal</label>
            <InputSelect @bind-Value="Model.Sucursal">
                <option value="">Todas</option>
                @foreach (var item in Options.Sucursales)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>Depósito</label>
            <InputSelect @bind-Value="Model.Deposito">
                <option value="">Todos</option>
                @foreach (var item in Options.Depositos)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>Estado</label>
            <InputSelect @bind-Value="Model.Estado">
                <option value="">Todos</option>
                @foreach (var item in Options.Estados)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        <div class="field">
            <label>TC</label>
            <InputSelect @bind-Value="Model.TipoComprobante">
                <option value="">Todos</option>
                @foreach (var item in Options.TiposComprobante)
                {
                    <option value="@item">@item</option>
                }
            </InputSelect>
        </div>
        </div>
    }

    <div class="actions">
        <button class="btn btn--primary" @onclick="ApplyAsync">Aplicar filtros</button>
        <button class="btn btn--ghost" @onclick="ClearAsync">Limpiar</button>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public DashboardFilters Model { get; set; } = new();
    [Parameter] public FilterOptionsDto Options { get; set; } = new();
    [Parameter] public string Titulo { get; set; } = "Filtros globales";
    [Parameter] public string Subtitulo { get; set; } = "Usá estos filtros para acotar el análisis de todas las pantallas.";
    [Parameter] public EventCallback OnApply { get; set; }

    private bool _showAdvanced;

    private async Task ApplyAsync() => await OnApply.InvokeAsync();
    private Task HoyAsync() => ApplyQuickRangeAsync("hoy");
    private Task SemanaAsync() => ApplyQuickRangeAsync("semana");
    private Task MesAsync() => ApplyQuickRangeAsync("mes");
    private Task MesAnteriorAsync() => ApplyQuickRangeAsync("mes-anterior");
    private Task UltimosTresAsync() => ApplyQuickRangeAsync("ultimos-3");
    private Task AnioAsync() => ApplyQuickRangeAsync("anio");
    private void ToggleAdvanced() => _showAdvanced = !_showAdvanced;

    private async Task ClearAsync()
    {
        var today = DateTime.Today;
        Model.FechaDesde = new DateTime(today.Year, today.Month, 1);
        Model.FechaHasta = today;
        Model.Proveedor = null;
        Model.Articulo = null;
        Model.ArticuloCodigo = null;
        Model.ArticuloDescripcion = null;
        Model.Rubro = null;
        Model.Familia = null;
        Model.Usuario = null;
        Model.Sucursal = null;
        Model.Deposito = null;
        Model.Estado = null;
        Model.TipoComprobante = null;
        await OnApply.InvokeAsync();
    }

    private async Task ApplyQuickRangeAsync(string key)
    {
        var today = DateTime.Today;
        switch (key)
        {
            case "hoy":
                Model.FechaDesde = today;
                Model.FechaHasta = today;
                break;
            case "semana":
                var diff = ((int)today.DayOfWeek + 6) % 7;
                Model.FechaDesde = today.AddDays(-diff);
                Model.FechaHasta = today;
                break;
            case "mes":
                Model.FechaDesde = new DateTime(today.Year, today.Month, 1);
                Model.FechaHasta = today;
                break;
            case "mes-anterior":
                var firstThisMonth = new DateTime(today.Year, today.Month, 1);
                var firstPreviousMonth = firstThisMonth.AddMonths(-1);
                Model.FechaDesde = firstPreviousMonth;
                Model.FechaHasta = firstThisMonth.AddDays(-1);
                break;
            case "ultimos-3":
                Model.FechaDesde = today.AddMonths(-3);
                Model.FechaHasta = today;
                break;
            case "anio":
                Model.FechaDesde = new DateTime(today.Year, 1, 1);
                Model.FechaHasta = today;
                break;
        }

        await OnApply.InvokeAsync();
    }

    private string BuildSummary()
    {
        var parts = new List<string>();

        if (Model.FechaDesde.HasValue || Model.FechaHasta.HasValue)
        {
            var desde = Model.FechaDesde?.ToString("dd/MM/yyyy") ?? "...";
            var hasta = Model.FechaHasta?.ToString("dd/MM/yyyy") ?? "...";
            parts.Add($"Fecha: {desde} a {hasta}");
        }

        AddIfPresent(parts, "Proveedor", Model.Proveedor);
        AddIfPresent(parts, "Código artículo", Model.ArticuloCodigo);
        AddIfPresent(parts, "Desc. artículo", Model.ArticuloDescripcion);
        AddIfPresent(parts, "Artículo", Model.Articulo);
        AddIfPresent(parts, "Rubro", Model.Rubro);
        AddIfPresent(parts, "Familia", Model.Familia);
        AddIfPresent(parts, "Usuario", Model.Usuario);
        AddIfPresent(parts, "Sucursal", Model.Sucursal);
        AddIfPresent(parts, "Depósito", Model.Deposito);
        AddIfPresent(parts, "Estado", Model.Estado);
        AddIfPresent(parts, "TC", Model.TipoComprobante);

        return parts.Count == 0
            ? "Sin filtros seleccionados."
            : string.Join(" | ", parts);
    }

    private static void AddIfPresent(List<string> parts, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add($"{label}: {value}");
        }
    }
}
