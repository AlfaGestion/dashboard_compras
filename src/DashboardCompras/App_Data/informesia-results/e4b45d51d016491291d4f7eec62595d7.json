  "sqlGenerado": "SELECT TOP (10) d.IDARTICULO, d.DESCRIPCION_ARTICULO, d.COSTO, SUM(d.TotalDashboard) AS TotalVendido FROM vw_compras_detalle_dashboard d WHERE (@CurFechaDesde IS NULL OR d.FECHA \u003E= @CurFechaDesde) AND (@CurFechaHasta IS NULL OR d.FECHA \u003C DATEADD(day, 1, @CurFechaHasta)) GROUP BY d.IDARTICULO, d.DESCRIPCION_ARTICULO, d.COSTO ORDER BY d.COSTO DESC"
